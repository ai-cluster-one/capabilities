                     "contract/preamble.py")

# ---------------------------------------------------------------- I/O contract

def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value if value.endswith("\n") else value + "\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


def _die(exit_code: int, code: str, message: str, hint: str | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _warn(message: str) -> None:
    sys.stderr.write(json.dumps({"warning": message}, ensure_ascii=False) + "\n")

# ---------------------------------------------------------------- shared shape

def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding capabilities/, legacy .capabilities/,
    .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / PROJECT_CAPABILITIES_REL / "settings.json").is_file()
                or (d / LEGACY_PROJECT_CAPABILITIES_REL).is_dir()
                or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _require_project() -> Path:
    root = _project_root()
    if root is None:
        _die(6, "no_project", "not inside a project",
             "run from a directory with capabilities/, .env, or a .git root")
    return root


def _project_capabilities_dir(root: Path) -> Path:
    """Canonical visible envelope, with read compatibility for legacy projects."""
    current = root / PROJECT_CAPABILITIES_REL
    legacy = root / LEGACY_PROJECT_CAPABILITIES_REL
    if (current / "settings.json").is_file() or not legacy.is_dir():
        return current
    return legacy


def _gate_file(root: Path) -> Path:
    return _project_capabilities_dir(root) / "settings.json"


def _read_json(path: Path):
    try:
        return json.loads(path.read_text())
    except (OSError, ValueError):
        return None


def _write_json(path: Path, value) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
    tmp.replace(path)


def _parse_env_file(path: Path) -> dict[str, str]:
    """Parse the small dotenv subset needed for manager-level project knobs."""
    try:
        lines = path.read_text().splitlines()
    except OSError:
        return {}
    out: dict[str, str] = {}
    for raw in lines:
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[7:].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        if not re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", key):
            continue
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
            value = value[1:-1]
        out[key] = value
    return out


def _project_env(root: Path) -> dict[str, str]:
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))
    return merged


def _context_prompt(root: Path) -> str:
    prompt = (_project_env(root).get(CONTEXT_PROMPT_ENV)
              or os.environ.get(CONTEXT_PROMPT_ENV))
    if prompt and prompt.strip():
        return prompt.replace("\\n", "\n").strip()
    return DEFAULT_CONTEXT_PROMPT


def _contextkit_managed(root: Path) -> bool:
    """True when ContextKit has bound this project and owns host injection."""
    return (root / CONTEXTKIT_CONFIG_REL).is_file()


def _contextkit_handoff(root: Path, targets: list[str]) -> dict:
    target = "all" if len(targets) > 1 else targets[0]
    return {
        "owner": "contextkit",
        "config": str(root / CONTEXTKIT_CONFIG_REL),
        "capabilities_host_wiring": "skipped",
        "targets": targets,
        "refresh": f"contextkit build --target {target}",
    }


def _prune_session_hooks(path: Path, predicate) -> bool:
    """Remove only matching hook commands; preserve every unrelated setting."""
    value = _read_json(path)
    if not isinstance(value, dict):
        return False
    hooks = value.get("hooks")
    session = hooks.get("SessionStart") if isinstance(hooks, dict) else None
    if not isinstance(session, list):
        return False
    changed = False
    next_session = []
    for entry in session:
        if not isinstance(entry, dict):
            next_session.append(entry)
            continue
        commands = entry.get("hooks")
        if not isinstance(commands, list):
            next_session.append(entry)
            continue
        kept = [hook for hook in commands
                if not (isinstance(hook, dict) and predicate(hook))]
        if len(kept) != len(commands):
            changed = True
        if kept:
            updated = dict(entry)
            updated["hooks"] = kept
            next_session.append(updated)
    if changed:
        hooks["SessionStart"] = next_session
        _write_json(path, value)
    return changed


def _remove_generated_file(path: Path, marker: str) -> bool:
    try:
        owned = marker in path.read_text()
    except OSError:
        return False
    if not owned:
        return False
    path.unlink()
    return True


def _retire_capabilities_host_wiring(root: Path) -> list[str]:
    """Remove legacy capabilities-owned injection after ContextKit takes over.

    Ownership markers are mandatory: ContextKit and human-authored host files
    are never deleted. The Codex hook shares a command path with ContextKit, so
    it is retired only when the compiler at that path is capabilities-owned.
    """
    removed: list[str] = []
    claude_settings = root / ".claude" / "settings.json"
    if _prune_session_hooks(
            claude_settings,
            lambda hook: "capabilities context --claude" in str(hook.get("command", ""))):
        removed.append("claude_hook")
    claude_context = root / ".claude" / "rules" / "CAPABILITIES.md"
    if _remove_generated_file(claude_context, CONTEXT_BEGIN):
        removed.append(str(claude_context))

    compiler = root / CODEX_BUILD_REL
    try:
        compiler_owned = "Generated by `capabilities init --codex`" in compiler.read_text()
    except OSError:
        compiler_owned = False
    if compiler_owned:
        compiler.unlink()
        removed.append(str(compiler))
        if _prune_session_hooks(
                root / CODEX_HOOKS_REL,
                lambda hook: ".codex/hooks/build-context.sh" in
                str(hook.get("command", ""))):
            removed.append("codex_hook")
    codex_fragment = root / CODEX_CAPABILITIES_REL
    if _remove_generated_file(codex_fragment, CONTEXT_BEGIN):
        removed.append(str(codex_fragment))
    codex_context = root / CODEX_CONTEXT_REL
    if _remove_generated_file(
            codex_context,
            "Generated by .codex/hooks/build-context.sh. Do not edit by hand."):
        removed.append(str(codex_context))
    return removed


def _project_visibility_hint(name: str | None = None) -> list[str]:
    enable = f"capabilities enable {name}" if name else "capabilities enable <name>"
    return [
        "Codex: run `capabilities init --codex` once in the consuming project, "
        f"then `{enable}`. After manual capabilities/ envelope edits, refresh "
        "with `capabilities context --codex` or `.codex/hooks/build-context.sh`.",
        "Claude Code: run `capabilities init --claude` once in the consuming "
        f"project, then `{enable}`.",
        "No project-root instruction markdown file is required or assumed. Do not "
        "create or edit generated capabilities context by hand; the manager owns "
        "the Codex .codex wiring and .claude/rules/CAPABILITIES.md.",
        "ContextKit exception: when .contextkit/config.toml is present, ContextKit "
        "owns both host bindings and the combined context; use `contextkit build`.",
    ]


def _sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()

# ---------------------------------------------------------------- registry

def _registry_dir(name: str) -> Path:
    return CAP_HOME / name


def _script_path(name: str) -> Path:
    return _registry_dir(name) / name


def _installed() -> dict[str, dict]:
    """name -> meta.json for every registry entry that holds a script."""
    out: dict[str, dict] = {}
    if not CAP_HOME.is_dir():
        return out
    for d in sorted(CAP_HOME.iterdir()):
        if d.name.startswith(".") or not d.is_dir():
            continue
        if (d / d.name).is_file():
            out[d.name] = _read_json(d / "meta.json") or {}
    return out


def _snapshot_env() -> dict:
    """Subprocess env for snapshotting: outside any project, so never gated."""
    env = dict(os.environ)
    env.pop("CLAUDE_PROJECT_DIR", None)
    return env


def _run_script(script: Path, args: list[str], cwd: Path | None = None,
                env: dict | None = None, timeout: int = 60) -> tuple[int, str, str]:
    try:
        proc = subprocess.run(
            [str(script), *args], capture_output=True, text=True,
            cwd=str(cwd or script.parent), env=env or _snapshot_env(), timeout=timeout)
    except subprocess.TimeoutExpired:
        return (124, "", f"timed out after {timeout}s")
    except OSError as e:
        return (126, "", str(e))
    return (proc.returncode, proc.stdout, proc.stderr)

# ---------------------------------------------------------------- bin dir

def _bin_dir() -> Path:
    override = os.environ.get("CAPABILITIES_BIN")
    if override:
        return Path(override).expanduser()
    on_path = {Path(p).expanduser().resolve() for p in
               os.environ.get("PATH", "").split(os.pathsep) if p}
    for cand in (Path.home() / ".local" / "bin", Path.home() / "bin"):
        if cand.is_dir() and cand.resolve() in on_path:
            return cand
    fallback = Path.home() / ".local" / "bin"
    return fallback

# ---------------------------------------------------------------- manifest

REQUIRED_MANIFEST_FIELDS = ("name", "summary", "credentials",
                            "docs", "state", "post_install")


def _validate_manifest(name: str, manifest) -> list[str]:
    """Mechanical shape check; returns a list of problems (empty = conformant)."""
    problems: list[str] = []
    if not isinstance(manifest, dict):
        return ["manifest is not a JSON object"]
    for field in REQUIRED_MANIFEST_FIELDS:
        if field not in manifest:
            problems.append(f"manifest missing field: {field}")
    if "protocol" in manifest:
        problems.append("manifest field 'protocol' was removed; the capability contract is unversioned")
    if manifest.get("name") != name:
        problems.append(f"manifest name {manifest.get('name')!r} != {name!r}")
    if not isinstance(manifest.get("summary"), str) or not manifest.get("summary", "").strip():
        problems.append("manifest summary missing or empty")
    creds = manifest.get("credentials")
    if isinstance(creds, dict):
        if creds.get("scope") not in ("project", "user"):
            problems.append(f"credentials.scope {creds.get('scope')!r} not project|user")
        keys = creds.get("keys")
        if not isinstance(keys, list):
            problems.append("credentials.keys is not a list")
        else:
            for k in keys:
                if not isinstance(k, dict) or "key" not in k:
                    problems.append(f"credentials.keys entry malformed: {k!r}")
    else:
        problems.append("credentials is not an object")
    docs = manifest.get("docs")
    if isinstance(docs, dict):
        if not isinstance(docs.get("base", ""), str):
            problems.append("docs.base is not a string")
        if not isinstance(docs.get("topics", []), list):
            problems.append("docs.topics is not a list")
    else:
        problems.append("docs is not an object")
    if not isinstance(manifest.get("state"), bool):
        problems.append("state is not a boolean")
    post = manifest.get("post_install")
    if not isinstance(post, list):
        problems.append("post_install is not a list")
    else:
        for step in post:
            if not isinstance(step, dict) or "cmd" not in step:
                problems.append(f"post_install entry malformed: {step!r}")
    service = manifest.get("service")
    if service is not None:
        if not isinstance(service, dict):
            problems.append("service is not an object")
        else:
            if not isinstance(service.get("name"), str) or not service.get("name", "").strip():
                problems.append("service.name missing or empty")
            if not isinstance(service.get("summary"), str) or not service.get("summary", "").strip():
                problems.append("service.summary missing or empty")
            verbs = service.get("verbs")
            if not isinstance(verbs, list) or not all(isinstance(v, str) for v in verbs):
                problems.append("service.verbs is not a list of strings")
    return problems

# ---------------------------------------------------------------- snapshots

def _snapshot(name: str, script: Path, registry: Path | None = None) -> dict:
    """Run stub + manifest outside any project; persist snapshots keyed by hash."""
    reg = registry or _registry_dir(name)
    rc, stub_out, err = _run_script(script, ["stub"])
    if rc != 0:
        _die(6, "snapshot_failed", f"`{name} stub` exited {rc}", err.strip() or None)
    rc, man_out, err = _run_script(script, ["manifest", "--json"])
    if rc != 0:
        _die(6, "snapshot_failed", f"`{name} manifest --json` exited {rc}",
             err.strip() or None)
    try:
        manifest = json.loads(man_out)
    except ValueError:
        _die(6, "snapshot_failed", f"`{name} manifest --json` did not emit JSON")
    problems = _validate_manifest(name, manifest)
    if problems:
        _die(6, "manifest_invalid", f"{name}: manifest fails validation",
             "; ".join(problems))
    (reg / "stub").write_text(stub_out.strip() + "\n")
    _write_json(reg / "manifest.json", manifest)
    return manifest


def _load_snapshots(name: str) -> tuple[str | None, dict | None]:
    reg = _registry_dir(name)
    stub = None
    try:
        stub = (reg / "stub").read_text().strip()
    except OSError:
        pass
    return stub, _read_json(reg / "manifest.json")

# ---------------------------------------------------------------- install

def _bundle_ignore(_dir: str, names: list[str]) -> set[str]:
    ignored = set()
    for n in names:
        if n in {"__pycache__", ".git", ".hg", ".svn"}:
            ignored.add(n)
        elif n.endswith((".pyc", ".pyo", ".session", ".session-journal",
                         ".session-wal", ".session-shm")):
            ignored.add(n)
    return ignored


def _bundle_script(bundle: Path, name: str) -> Path | None:
    for cand in (bundle / name, bundle / "bin" / name):
        if cand.is_file():
            return cand
    return None


def _enclosing_bundle_for_script(script: Path, name: str) -> Path | None:
    """The bundle directory that owns a script path, when it matches the layout."""
    if script.name != name:
        return None
    candidates: list[Path] = []
    if script.parent.name == "bin":
        candidates.append(script.parent.parent)
    candidates.append(script.parent)
    for bundle in candidates:
        cand = _bundle_script(bundle, name)
        if cand is not None and cand.resolve() == script.resolve():
            return bundle
    return None


def _catalogue_archive_url(name: str, script_url: str) -> str | None:
    pattern = (
        rf"^https://raw\.githubusercontent\.com/([^/]+)/([^/]+)/([^/]+)/"
        rf"capabilities/{re.escape(name)}/bin/{re.escape(name)}$"
    )
    m = re.match(pattern, script_url.rstrip("/"))
    if not m:
        return None
    owner, repo, ref = m.groups()
    return f"https://codeload.github.com/{owner}/{repo}/tar.gz/{ref}"


def _extract_tar_safely(archive: Path, dest: Path) -> None:
    root = dest.resolve()
    with tarfile.open(archive, "r:gz") as tf:
        for member in tf.getmembers():
            target = (dest / member.name).resolve()
            if target != root and root not in target.parents:
                _die(5, "server_error", f"archive member escapes target: {member.name}")
            if member.isdir():
                target.mkdir(parents=True, exist_ok=True)
            elif member.isfile():
                src = tf.extractfile(member)
                if src is None:
                    continue
                target.parent.mkdir(parents=True, exist_ok=True)
                with target.open("wb") as out:
                    shutil.copyfileobj(src, out)
                os.chmod(target, member.mode & 0o777)


def _fetch_catalogue_bundle(name: str, script_url: str) -> tuple[bytes, Path, Path] | None:
    archive_url = _catalogue_archive_url(name, script_url)
    if archive_url is None:
        return None
    tmp_root = Path(tempfile.mkdtemp(prefix="capabilities-bundle-"))
    try:
        try:
            resp = httpx.get(archive_url, follow_redirects=True, timeout=60.0)
        except httpx.HTTPError as e:
            _die(5, "network_error", f"fetch failed: {e}", archive_url)
        if resp.status_code != 200:
            _die(5, "server_error", f"fetch returned {resp.status_code}", archive_url)
        archive = tmp_root / "repo.tar.gz"
        archive.write_bytes(resp.content)
        _extract_tar_safely(archive, tmp_root)
        for root in sorted(p for p in tmp_root.iterdir() if p.is_dir()):
            bundle = root / "capabilities" / name
            cand = _bundle_script(bundle, name)
            if cand is not None:
                return cand.read_bytes(), tmp_root, bundle
        _die(3, "not_found", f"no bundled capability {name!r} in catalogue archive",
             archive_url)
    except BaseException:
        shutil.rmtree(tmp_root, ignore_errors=True)
        raise


def _resolve_source(name: str, from_ref: str | None) -> tuple[bytes, str, Path | None, Path | None]:
    """Return (script bytes, recorded source string, bundle dir, temp root)."""
    if from_ref and not re.match(r"^https?://", from_ref):
        p = Path(from_ref).expanduser().resolve()
        if p.is_dir():
            bundles = [p]
            repo_bundle = p / "capabilities" / name
            if repo_bundle.is_dir():
                bundles.append(repo_bundle)
            for bundle in bundles:
                cand = _bundle_script(bundle, name)
                if cand is not None:
                    return cand.read_bytes(), str(bundle), bundle, None
            _die(3, "not_found", f"no script for {name!r} under {p}",
                 f"expected {name}, bin/{name}, or capabilities/{name}/bin/{name}")
        if p.is_file():
            bundle = _enclosing_bundle_for_script(p, name)
            if bundle is not None:
                return p.read_bytes(), str(bundle), bundle, None
            return p.read_bytes(), str(p), None, None
        _die(3, "not_found", f"--from path does not exist: {p}")
    url = from_ref or f"{SOURCE}/capabilities/{name}/bin/{name}"
    bundle = _fetch_catalogue_bundle(name, url)
    if bundle is not None:
        content, tmp_root, bundle_dir = bundle
        return content, url, bundle_dir, tmp_root
    try:
        resp = httpx.get(url, follow_redirects=True, timeout=30.0)
    except httpx.HTTPError as e:
        _die(5, "network_error", f"fetch failed: {e}", url)
    if resp.status_code == 404:
        _die(3, "not_found", f"no such capability in the catalogue: {name}", url)
    if resp.status_code != 200:
        _die(5, "server_error", f"fetch returned {resp.status_code}", url)
    return resp.content, url, None, None


def _install_payload(name: str, content: bytes, bundle_dir: Path | None,
                     registry: Path) -> Path:
    reg = registry
    reg.mkdir(parents=True, exist_ok=True)
    if bundle_dir is not None:
        shutil.copytree(bundle_dir, reg, dirs_exist_ok=True, ignore=_bundle_ignore)
    script = reg / name
    script.write_bytes(content)
    script.chmod(script.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    return script


def _validate_installed_payload(name: str, manifest: dict,
                                registry: Path | None = None) -> None:
    reg = registry or _registry_dir(name)
    if manifest.get("service") is not None and not (reg / "service").is_dir():
        _die(6, "service_bundle_missing",
             f"{name}: manifest declares a service but service/ was not installed",
             "reinstall/update from a bundled source; public catalogue sources should "
             "install the full capability bundle")


def _prepare_payload(name: str, content: bytes, bundle_dir: Path | None,
                     temp_root: Path | None, source: str) -> tuple[Path, dict]:
    """Build and fully audit a candidate away from the live registry."""
    _require_authoring_assets()
    CAP_HOME.mkdir(parents=True, exist_ok=True)
    stage = Path(tempfile.mkdtemp(prefix=f".{name}-stage-", dir=CAP_HOME))
    try:
        script = _install_payload(name, content, bundle_dir, stage)
        failures = _audit_script(name, script)
        if failures:
            _die(7, "audit_failed", f"{name} from {source} fails capability audit",
                 "; ".join(failures))
        manifest = _snapshot(name, script, stage)
        _validate_installed_payload(name, manifest, stage)
        return stage, manifest
    except BaseException:
        shutil.rmtree(stage, ignore_errors=True)
        raise
    finally:
        if temp_root is not None:
            shutil.rmtree(temp_root, ignore_errors=True)


def _activate_payload(name: str, stage: Path) -> Path:
    """Atomically replace one registry entry, restoring the old copy on error."""
    reg = _registry_dir(name)
    backup = CAP_HOME / f".{name}-previous"
    if backup.exists():
        shutil.rmtree(backup)
    if reg.exists():
        reg.rename(backup)
    try:
        stage.rename(reg)
    except BaseException:
        if backup.exists() and not reg.exists():
            backup.rename(reg)
        raise
    shutil.rmtree(backup, ignore_errors=True)
    return reg / name


def _payload_sha256(reg: Path) -> str:
    h = hashlib.sha256()
    skip = {"meta.json", "stub", "manifest.json"}
    for path in sorted(p for p in reg.rglob("*") if p.is_file()):
        if (path.name in skip or "__pycache__" in path.parts
                or path.suffix in {".pyc", ".pyo", ".session"}
                or path.name.endswith((".session-journal", ".session-wal", ".session-shm"))):
            continue
        rel = path.relative_to(reg).as_posix()
        h.update(rel.encode("utf-8") + b"\0")
        h.update(path.read_bytes())
        h.update(b"\0")
    return h.hexdigest()


def _symlink(name: str, script: Path) -> Path:
    bin_dir = _bin_dir()
    bin_dir.mkdir(parents=True, exist_ok=True)
    link = bin_dir / name
    if link.is_symlink() or link.exists():
        link.unlink()
    link.symlink_to(script)
    on_path = {Path(p).expanduser().resolve() for p in
               os.environ.get("PATH", "").split(os.pathsep) if p}
    if bin_dir.resolve() not in on_path:
        _warn(f"{bin_dir} is not on PATH — add it so `{name}` resolves by name")
    return link


def _scaffold_credentials(name: str, manifest: dict) -> list[str]:
    """Per declared scope. Returns human-facing notes. Never writes a secret."""
    notes: list[str] = []
    creds = manifest.get("credentials", {})
    keys = [k for k in creds.get("keys", []) if isinstance(k, dict)]
    if not keys:
        return notes
    required = [k["key"] for k in keys if k.get("required")]
    if creds.get("scope") == "user":
        cred_file = _CONFIG_HOME / name / "credentials.env"
        existing = ""
        if cred_file.exists():
            existing = cred_file.read_text()
        else:
            cred_file.parent.mkdir(parents=True, exist_ok=True)
            cred_file.touch(mode=0o600)
        added = []
        with cred_file.open("a") as f:
            for k in keys:
                if k["key"] not in existing:
                    note = k.get("note", "")
                    # The note is a full-line comment, never inline after `=`:
                    # the cascade parser does not strip inline comments (a `#`
                    # can be a legitimate secret character), so an inline note
                    # would be read as the value.
                    f.write(f"# {note}\n{k['key']}=\n" if note else f"{k['key']}=\n")
                    added.append(k["key"])
        if added:
            notes.append(f"fill {', '.join(added)} in {cred_file}")
    else:
        if required:
            notes.append(
                f"project scope: set {', '.join(required)} in the consuming "
                f"project's .env or .env.local")
    return notes


def cmd_install(name: str, from_ref: str | None, source_id: str | None,
                yes: bool) -> None:
    provenance = {}
    if source_id:
        if from_ref:
            _die(6, "input", "install accepts either --from or --source, not both")
        from_ref, provenance = _source_install_ref(name, source_id)
    content, source, bundle_dir, temp_root = _resolve_source(name, from_ref)
    stage, manifest = _prepare_payload(name, content, bundle_dir, temp_root, source)
    _write_json(stage / "meta.json", {
        "name": name, "source": source, "source_type": "directory" if bundle_dir else "script",
        "sha256": _sha256(stage / name), "payload_sha256": _payload_sha256(stage),
        **provenance,
    })
    script = _activate_payload(name, stage)
    reg = _registry_dir(name)
    link = _symlink(name, script)
    notes = _scaffold_credentials(name, manifest)
    post = manifest.get("post_install") or []
    ran = []
    if post and yes:
        for step in post:
            proc = subprocess.run(["sh", "-c", step["cmd"]], capture_output=True,
                                  text=True, env=_snapshot_env())
            ran.append({"cmd": step["cmd"], "exit": proc.returncode})
    _regen_skills()
    result = {
        "installed": name, "registry": str(reg), "symlink": str(link),
        "summary": manifest.get("summary"), "scope": manifest["credentials"]["scope"],
        "bundle": bool(bundle_dir),
        "project_visibility": _project_visibility_hint(name),
    }
    if notes:
        result["credentials"] = notes
    if post and not yes:
        result["post_install"] = [
            {"cmd": s["cmd"], "note": s.get("note", "")} for s in post]
        result["post_install_hint"] = \
            "declared idempotent — review and re-run install with --yes to execute"
    if ran:
        result["post_install_ran"] = ran
    _emit(result)


def cmd_uninstall(name: str, purge_credentials: bool) -> None:
    reg = _registry_dir(name)
    if not reg.is_dir():
        _die(3, "not_found", f"{name} is not installed")
    link = _bin_dir() / name
    removed_link = False
    if link.is_symlink():
        link.unlink()
        removed_link = True
    shutil.rmtree(reg)
    _regen_skills()
    result = {"uninstalled": name, "symlink_removed": removed_link}
    cred_file = _CONFIG_HOME / name / "credentials.env"
    if cred_file.exists():
        if purge_credentials:
            shutil.rmtree(cred_file.parent)
            result["credentials_purged"] = str(cred_file)
        else:
            result["credentials_kept"] = str(cred_file)
    _emit(result)


def cmd_update(name: str | None) -> None:
    targets = [name] if name else sorted(_installed())
    if name and not _registry_dir(name).is_dir():
        _die(3, "not_found", f"{name} is not installed")
    results = []
    for n in targets:
        meta = _read_json(_registry_dir(n) / "meta.json") or {}
        source_id = meta.get("source_id")
        provenance = {}
        if source_id:
            source, provenance = _source_install_ref(n, source_id)
        else:
            source = meta.get("source")
        before = meta.get("payload_sha256")
        if before is None and _script_path(n).exists():
            before = _sha256(_script_path(n))
        content, source, bundle_dir, temp_root = _resolve_source(n, source)
        stage, manifest = _prepare_payload(n, content, bundle_dir, temp_root, source)
        after = _payload_sha256(stage)
        _write_json(stage / "meta.json", {
            "name": n, "source": source, "source_type": "directory" if bundle_dir else "script",
            "sha256": _sha256(stage / n), "payload_sha256": after,
            **provenance,
        })
        _activate_payload(n, stage)
        results.append({"name": n, "changed": before != after})
    _regen_skills()
    _emit({"updated": results})


def cmd_self_update() -> None:
    """Refresh the installed manager itself from the canonical source.

    The manager is not a capability — it has no registry entry, no snapshots,
    no gate. It lives at CAP_HOME/.manager/capabilities, symlinked onto PATH.
    install.sh is the first-install bootstrap; this is the ongoing update, a
    discoverable verb rather than a remembered curl one-liner. Idempotent:
    a no-op (with "already current") when the installed bytes match canonical.
    """
    url = f"{SOURCE}/bin/capabilities"
    try:
        resp = httpx.get(url, follow_redirects=True, timeout=30.0)
    except httpx.HTTPError as e:
        _die(5, "network_error", f"fetch failed: {e}", url)
    if resp.status_code != 200:
        _die(5, "server_error", f"fetch returned {resp.status_code}", url)
    content = resp.content
    assets: dict[str, bytes] = {}
    for rel in _AUTHORING_ASSETS:
        asset_url = f"{SOURCE}/{rel}"
        try:
            asset_resp = httpx.get(asset_url, follow_redirects=True, timeout=30.0)
        except httpx.HTTPError as e:
            _die(5, "network_error", f"authoring asset fetch failed: {e}", asset_url)
        if asset_resp.status_code != 200:
            _die(5, "server_error",
                 f"authoring asset fetch returned {asset_resp.status_code}", asset_url)
        assets[rel] = asset_resp.content
    # The fetched bytes must actually be the manager script, not an error page
    # or a redirect body — mirror install.sh's shebang guard.
    if b"uv run" not in content.split(b"\n", 1)[0]:
        _die(5, "server_error",
             "fetched file does not look like the manager script", url)
    manager = CAP_HOME / ".manager" / "capabilities"
    before = _sha256(manager) if manager.exists() and not manager.is_symlink() else None
    after = hashlib.sha256(content).hexdigest()
    if before == after:
        for rel, body in assets.items():
            target = manager.parent / rel
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_bytes(body)
        _emit({"self_update": "already current",
               "manager": str(manager), "sha256": after, "source": url,
               "authoring_assets": sorted(assets)})
        return
    manager.parent.mkdir(parents=True, exist_ok=True)
    # Never write through a stray symlink into a working tree — the same
    # canonical-source discipline doctor enforces for capability registry
    # entries. Replace with a fresh real file.
    if manager.is_symlink() or manager.exists():
        manager.unlink()
    manager.write_bytes(content)
    manager.chmod(manager.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    for rel, body in assets.items():
        target = manager.parent / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_bytes(body)
    link = _symlink("capabilities", manager)
    _emit({"self_update": "updated", "manager": str(manager),
           "sha256_before": before, "sha256_after": after,
           "symlink": str(link), "source": url,
           "authoring_assets": sorted(assets)})


def cmd_list() -> None:
    entries = []
    root = _project_root()
    gate = _read_json(_gate_file(root)) if root else None
    gate_caps = (gate or {}).get("capabilities", {})
    for name, meta in _installed().items():
        stub, manifest = _load_snapshots(name)
        entry: dict = {"name": name,
                       "summary": (manifest or {}).get("summary", "")}
        if root:
            g = gate_caps.get(name)
            entry["gate"] = ("enabled" if (g or {}).get("enabled") is True
                             else "disabled" if (g or {}).get("enabled") is False
                             else "ungated")
        entries.append(entry)
    enabled_not_installed = [n for n, g in gate_caps.items()
                             if (g or {}).get("enabled") is True
                             and n not in _installed()]
    out: dict = {"installed": entries}
    if enabled_not_installed:
        out["enabled_not_installed"] = enabled_not_installed
    _emit(out)

# ---------------------------------------------------------------- gate

def _load_gate(root: Path) -> dict:
    gate = _read_json(_gate_file(root))
    if gate is None or not isinstance(gate.get("capabilities"), dict):
        gate = {"capabilities": {}}
    return gate


def _merge_gate_values(legacy: Path, current: Path) -> dict | None:
    """Merge standard gate objects, or return None on a semantic conflict."""
    old = _read_json(legacy)
    new = _read_json(current)
    if not isinstance(old, dict) or not isinstance(new, dict):
        return None
    old_caps = old.get("capabilities")
    new_caps = new.get("capabilities")
    if not isinstance(old_caps, dict) or not isinstance(new_caps, dict):
        return None
    merged = dict(new)
    merged_caps = dict(new_caps)
    for name, entry in old_caps.items():
        if name in merged_caps and merged_caps[name] != entry:
            return None
        merged_caps[name] = entry
    for key, value in old.items():
        if key == "capabilities":
            continue
        if key in merged and merged[key] != value:
            return None
        merged.setdefault(key, value)
    merged["capabilities"] = merged_caps
    return merged


def _migrate_legacy_envelope(root: Path) -> list[str]:
    """Move legacy .capabilities/ into visible capabilities/ without data loss.

    The whole merge is preflighted before writes. Identical files coalesce;
    settings.json merges disjoint capability entries; .gitignore merges lines.
    Any other collision refuses the migration and leaves both trees untouched.
    """
    legacy = root / LEGACY_PROJECT_CAPABILITIES_REL
    current = root / PROJECT_CAPABILITIES_REL
    if not legacy.is_dir():
        return []
    conflicts: list[str] = []
    merged_gate: dict | None = None
    merged_gitignore: str | None = None
    for source in sorted(legacy.rglob("*")):
        rel = source.relative_to(legacy)
        target = current / rel
        if source.is_symlink():
            conflicts.append(f"legacy symlink: {rel}")
            continue
        if source.is_dir():
            if target.exists() and not target.is_dir():
                conflicts.append(str(rel))
            continue
        if not target.exists():
            continue
        if not target.is_file():
            conflicts.append(str(rel))
        elif rel == Path("settings.json"):
            merged_gate = _merge_gate_values(source, target)
            if merged_gate is None:
                conflicts.append(str(rel))
        elif rel == Path(".gitignore"):
            lines = list(dict.fromkeys([
                *target.read_text().splitlines(),
                *source.read_text().splitlines(),
            ]))
            merged_gitignore = "\n".join(lines).rstrip() + "\n"
        elif source.read_bytes() != target.read_bytes():
            conflicts.append(str(rel))
    if conflicts:
        _die(6, "envelope_conflict",
             "cannot migrate legacy .capabilities/ into capabilities/; "
             f"conflicting paths: {', '.join(conflicts)}",
             "merge those paths manually, then rerun `capabilities init`; "
             "neither tree was changed")

    current.mkdir(exist_ok=True)
    moved: list[str] = []
    for source in sorted(legacy.rglob("*"), key=lambda p: (len(p.parts), str(p))):
        if not source.is_dir():
            continue
        (current / source.relative_to(legacy)).mkdir(parents=True, exist_ok=True)
    for source in sorted(p for p in legacy.rglob("*") if p.is_file()):
        rel = source.relative_to(legacy)
        target = current / rel
        if target.exists():
            if rel == Path("settings.json") and merged_gate is not None:
                _write_json(target, merged_gate)
            elif rel == Path(".gitignore") and merged_gitignore is not None:
                target.write_text(merged_gitignore)
            source.unlink()
        else:
            target.parent.mkdir(parents=True, exist_ok=True)
            source.replace(target)
        moved.append(str(rel))
    for directory in sorted(
            (p for p in legacy.rglob("*") if p.is_dir()),
            key=lambda p: len(p.parts), reverse=True):
        directory.rmdir()
    legacy.rmdir()
    return moved


def _ensure_envelope(root: Path) -> list[str]:
    """Manager-owned project files: migrate, then scaffold gate + state guard."""
    migrated = _migrate_legacy_envelope(root)
    capdir = root / PROJECT_CAPABILITIES_REL
    capdir.mkdir(exist_ok=True)
    gi = capdir / ".gitignore"
    if not gi.exists() or GITIGNORE_BODY.strip() not in gi.read_text():
        existing = gi.read_text() if gi.exists() else ""
        gi.write_text(existing + ("" if existing.endswith("\n") or not existing else "\n")
                      + GITIGNORE_BODY)
    gate_file = root / GATE_REL
    if not gate_file.exists():
        _write_json(gate_file, {"capabilities": {}})
    return migrated


def _deny_rule(name: str) -> str:
    return f"Bash({name}:*)"


def _edit_deny(root: Path, name: str, add: bool) -> bool:
    """Add/remove the harness deny rule in .claude/settings.json. True if changed."""
    settings_file = root / ".claude" / "settings.json"
    settings = _read_json(settings_file)
    if settings is None:
        if not add:
            return False
        settings = {}
    perms = settings.setdefault("permissions", {})
    deny = perms.setdefault("deny", [])
    rule = _deny_rule(name)
    changed = False
    if add and rule not in deny:
        deny.append(rule)
        changed = True
    if not add and rule in deny:
        deny.remove(rule)
        changed = True
    if changed:
        _write_json(settings_file, settings)
    return changed


def _set_gate(name: str, enabled: bool, deny: bool = False) -> None:
    root = _require_project()
    migrated = _ensure_envelope(root)
    gate = _load_gate(root)
    gate["capabilities"].setdefault(name, {})["enabled"] = enabled
    _write_json(root / GATE_REL, gate)
    result: dict = {("enabled" if enabled else "disabled"): name,
                    "gate": str(root / GATE_REL)}
    if migrated:
        result["migrated_from"] = str(root / LEGACY_PROJECT_CAPABILITIES_REL)
    if enabled:
        if _edit_deny(root, name, add=False):
            result["deny_rule_removed"] = _deny_rule(name)
    elif deny:
        _edit_deny(root, name, add=True)
        result["deny_rule"] = _deny_rule(name)
    if name not in _installed():
        result["note"] = f"{name} is not installed — run `capabilities install {name}`"
    if _contextkit_managed(root):
        result["context"] = _contextkit_handoff(root, ["codex", "claude"])
    else:
        refreshed = _refresh_context(root)
        if refreshed:
            result["context"] = refreshed
        elif enabled:
            result["context_hint"] = _project_visibility_hint(name)
    _emit(result)

# ---------------------------------------------------------------- context

def _md_escape(s: str) -> str:
    return s.replace("\n", " ").strip()


def _front_matter(path: Path) -> dict:
    """Parse the YAML front-matter envelope: name + description lines only."""
    try:
        text = path.read_text()
    except OSError:
        return {}
    if not text.startswith("---"):
        return {}
    out: dict = {}
    for line in text.split("\n", 50)[1:]:
        if line.strip() == "---":
            break
        m = re.match(r"^(name|description):\s*(.+)$", line.strip())
        if m:
            out[m.group(1)] = m.group(2).strip()
    return out


def _compose_context(root: Path) -> str:
    """Deterministic injection body: gate + snapshots + envelopes, files only."""
    gate = _load_gate(root)
    enabled = sorted(n for n, g in gate["capabilities"].items()
                     if (g or {}).get("enabled") is True)
    lines: list[str] = [
        "# Capabilities", "", CONTEXT_BEGIN, "",
        CAPABILITIES_CONTEXT_INTRO, "",
    ]
    if not enabled:
        lines += ["No capabilities are enabled in this project. "
                  "`capabilities list` shows what is installed; "
                  "`capabilities enable <name>` makes one visible here.", ""]
    else:
        lines += [_context_prompt(root), ""]
    for name in enabled:
        stub, manifest = _load_snapshots(name)
        lines.append(f"## {name}")
        lines.append("")
        if stub is None:
            lines += [f"Enabled but not installed — run `capabilities install {name}`.", ""]
            continue
        lines += [_md_escape(stub), ""]
        bullet: list[str] = []
        envdir = _project_capabilities_dir(root) / name
        conns = _read_json(envdir / "connections.json")
        valid = (isinstance(conns, dict)
                 and isinstance(conns.get("connections"), dict)
                 and conns["connections"])
        single_ro = (valid and len(conns["connections"]) == 1
                     and (next(iter(conns["connections"].values())) or {})
                     .get("allow_write") is False)
        if valid and (len(conns["connections"]) > 1 or single_ro):
            default = conns.get("default")
            items = "; ".join(
                cid + ("*" if cid == default else "")
                + (" (read-only)" if isinstance(entry, dict)
                   and entry.get("allow_write") is False else "")
                for cid, entry in sorted(conns["connections"].items()))
            bullet.append(f"- Connections (`--connection <id>`; * = default): {items}")
        elif conns is not None and not valid:
            bullet.append(f"- Connections file present but not a valid envelope — "
                          f"fix capabilities/{name}/connections.json")
        ids = _read_json(envdir / "identifiers.json")
        if isinstance(ids, dict) and ids:
            bullet.append(f"- Identifiers ({len(ids)}): run `capabilities ids {name}` "
                          f"for the full labelled list; `{name} ids get <label>` "
                          f"for a single value")
        elif ids is not None:
            bullet.append(f"- Identifiers file present but not a JSON object — "
                          f"fix capabilities/{name}/identifiers.json")
        topics = ((manifest or {}).get("docs") or {}).get("topics") or []
        if topics:
            bullet.append(f"- Guides (`{name} guide <topic>`): " + ", ".join(sorted(topics)))
        service = (manifest or {}).get("service")
        if isinstance(service, dict):
            verbs = service.get("verbs") or []
            verb_hint = ", ".join(str(v) for v in verbs[:8])
            summary = service.get("summary") or service.get("name") or "bundled service"
            line = f"- Service (`{name} service ...`): {summary}"
            if verb_hint:
                line += f" (verbs: {verb_hint})"
            bullet.append(line)
        refs = []
        refdir = envdir / "reference"
        if refdir.is_dir():
            for md in sorted(refdir.glob("*.md")):
                fm = _front_matter(md)
                if fm.get("name"):
                    rel = md.relative_to(root)
                    desc = fm.get("description", "")
                    refs.append(f"- `{rel}` — {desc}".rstrip(" —"))
        if refs:
            if bullet:
                bullet.append("")
            bullet.append("**References** (load on demand):")
            bullet.append("")
            bullet.extend(refs)
        if bullet:
            lines += bullet + [""]
    lines.append(CONTEXT_END)
    return "\n".join(lines) + "\n"


def _refresh_context(root: Path) -> dict | None:
    """Regenerate placed context files that already exist. Quiet otherwise."""
    if _contextkit_managed(root):
        return None
    out = {}
    claude_file = root / ".claude" / "rules" / "CAPABILITIES.md"
    if claude_file.exists():
        claude_file.write_text(_compose_context(root))
        out["claude"] = str(claude_file)
    codex_fragment = root / CODEX_CAPABILITIES_REL
    codex_build = root / CODEX_BUILD_REL
    if codex_fragment.exists() or codex_build.exists():
        out["codex"] = str(_write_codex_capabilities(root))
        built = _run_codex_build(root)
        if built:
            out["codex_compiled"] = built
    return out or None


def _write_codex_capabilities(root: Path) -> Path:
    """Write the capabilities fragment consumed by the Codex context compiler."""
    target = root / CODEX_CAPABILITIES_REL
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(_compose_context(root))
    return target


def _run_codex_build(root: Path) -> str | None:
    """Refresh Codex's compiled context when the generated compiler exists."""
    script = root / CODEX_BUILD_REL
    if not script.exists() or os.environ.get(CODEX_BUILD_ENV):
        return None
    env = dict(os.environ)
    env[CODEX_BUILD_ENV] = "1"
    try:
        proc = subprocess.run(["/bin/bash", str(script)], capture_output=True,
                              text=True, cwd=str(root), env=env, timeout=30)
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode == 0:
        return str(root / CODEX_CONTEXT_REL)
    _warn(f"Codex context compiler exited {proc.returncode}: "
          f"{(proc.stderr or proc.stdout).strip()}")
    return None


def _id_value(v) -> str:
    """A string inlines bare; anything else as compact JSON — both in a code span."""
    return f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"


def cmd_ids(name: str) -> None:
    """Render <name>'s project identifiers envelope as markdown.

    The full labelled list the session context points to: the manager renders
    the standard `{label: {value, note}}` envelope without the capability's
    help (DOCTRINE rule 4). `<name> ids get/set/rm` stays the per-value data
    interface on the capability itself.
    """
    root = _require_project()
    ids = _read_json(_project_capabilities_dir(root) / name / "identifiers.json")
    if not isinstance(ids, dict) or not ids:
        _emit(f"# {name} identifiers\n\n"
              f"None recorded for `{name}` in this project ({root}). The CLI "
              f"discovers and writes them with `{name} ids set <label> <value>`.")
        return
    lines = [f"# {name} identifiers", "",
             f"Structural lookups for `{name}` in this project ({root}). "
             f"Fetch a single raw value with `{name} ids get <label>`.", ""]
    for label, entry in sorted(ids.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        line = f"- **{label}**: {_id_value(entry.get('value'))}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    _emit("\n".join(lines) + "\n")


def _codex_build_script() -> str:
    manager = shlex.quote(str(Path(sys.argv[0]).resolve()))
    return f"""#!/usr/bin/env bash
set -euo pipefail

# Generated by `capabilities init --codex`; do not edit by hand.
# Manager-owned host wiring; overwritten on every `capabilities init --codex`.

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
ROOT="$(cd "$ROOT" && pwd -P)"
cd "$ROOT"

CODEX_CONTEXT="{CODEX_CONTEXT_REL.as_posix()}"
CAPABILITIES_CONTEXT="{CODEX_CAPABILITIES_REL.as_posix()}"
CAPABILITIES_MANAGER={manager}
TMP_PARENT="${{TMPDIR:-/tmp}}"
TMP_PARENT="${{TMP_PARENT%/}}"

export CLAUDE_PROJECT_DIR="$ROOT"
if [ -x "$CAPABILITIES_MANAGER" ]; then
  {CODEX_BUILD_ENV}=1 "$CAPABILITIES_MANAGER" context --codex >/dev/null 2>&1 || true
elif command -v capabilities >/dev/null 2>&1; then
  {CODEX_BUILD_ENV}=1 capabilities context --codex >/dev/null 2>&1 || true
fi

source_dirs=()
if [ -d ".context" ]; then
  source_dirs+=(".context")
elif [ -d ".claude/rules" ]; then
  source_dirs+=(".claude/rules")
fi

tmp_sources="$(mktemp "$TMP_PARENT/codex-context-sources.XXXXXX")"
tmp_sorted="$(mktemp "$TMP_PARENT/codex-context-sources.sorted.XXXXXX")"
tmp_context="$(mktemp "$TMP_PARENT/codex-context.XXXXXX")"
tmp_root="$(mktemp "$TMP_PARENT/codex-context-target.XXXXXX")"

cleanup() {{
  rm -f "$tmp_sources" "$tmp_sorted" "$tmp_context" "$tmp_root"
}}
trap cleanup EXIT

: > "$tmp_sources"
if [ "${{#source_dirs[@]}}" -gt 0 ]; then
  for dir in "${{source_dirs[@]}}"; do
    find "$dir" -type f -name '*.md' ! -name 'CAPABILITIES.md' -print >> "$tmp_sources"
  done
fi
LC_ALL=C sort -u "$tmp_sources" > "$tmp_sorted"

relative_path() {{
  local path="$1"
  local dir
  local base
  local abs

  dir="$(dirname "$path")"
  base="$(basename "$path")"
  abs="$(cd "$dir" && pwd -P)/$base"

  case "$abs" in
    "$ROOT"/*) printf '%s\\n' "${{abs#"$ROOT"/}}" ;;
    *) printf '%s\\n' "$abs" ;;
  esac
}}

absolute_path() {{
  local path="$1"
  local dir
  local base

  dir="$(dirname "$path")"
  base="$(basename "$path")"
  printf '%s/%s\\n' "$(cd "$dir" && pwd -P)" "$base"
}}

emit_file_with_imports() {{
  local source="$1"
  local source_dir
  local line
  local import
  local target
  local target_abs
  local target_rel

  source_dir="$(dirname "$source")"

  while IFS= read -r line || [ -n "$line" ]; do
    if [[ "$line" == @*.md && "$line" != *" "* && "$line" != *$'\\t'* ]]; then
      import="${{line#@}}"
      target="$source_dir/$import"
      if [ -f "$target" ]; then
        target_abs="$(absolute_path "$target")"
        target_rel="$(relative_path "$target")"
        printf '\\n<!-- Begin import: %s -->\\n\\n' "$target_rel"
        cat "$target_abs"
        printf '\\n\\n<!-- End import: %s -->\\n\\n' "$target_rel"
      else
        printf '%s\\n' "$line"
        printf '\\n<!-- Missing import from %s: %s -->\\n\\n' "$source" "$import"
      fi
    else
      printf '%s\\n' "$line"
    fi
  done < "$source"
}}

{{
  printf '# Codex Context\\n\\n'
  printf '<!-- Generated by .codex/hooks/build-context.sh. Do not edit by hand. -->\\n'
  printf '<!-- SessionStart regeneration may be visible to the next Codex session, not the launching one. -->\\n\\n'

  if [ "${{#source_dirs[@]}}" -eq 0 ]; then
    printf 'No context source directory found. Expected `.context/` or `.claude/rules/`.\\n'
  else
    printf 'Compiled source directories:\\n\\n'
    for dir in "${{source_dirs[@]}}"; do
      printf -- '- `%s`\\n' "$dir"
    done
    printf '\\n'
  fi

  if [ ! -s "$tmp_sorted" ]; then
    printf 'No markdown context files found.\\n'
  else
    while IFS= read -r source; do
      [ -n "$source" ] || continue
      printf '\\n---\\n\\n'
      printf '## Source: `%s`\\n\\n' "$source"
      emit_file_with_imports "$source"
      printf '\\n'
    done < "$tmp_sorted"
  fi

  if [ -f "$CAPABILITIES_CONTEXT" ]; then
    printf '\\n---\\n\\n'
    printf '<!-- Capability index — generated by `capabilities context` from the live registry. -->\\n\\n'
    cat "$CAPABILITIES_CONTEXT"
    printf '\\n'
  fi
}} > "$tmp_context"

cp "$tmp_context" "$tmp_root"
mkdir -p "$(dirname "$CODEX_CONTEXT")"
mv -f "$tmp_root" "$CODEX_CONTEXT"
chmod 0644 "$CODEX_CONTEXT"

trap - EXIT
cleanup
"""


def _wire_codex_config(root: Path) -> bool:
    path = root / CODEX_CONFIG_REL
    path.parent.mkdir(parents=True, exist_ok=True)
    if not path.exists():
        path.write_text(
            f'project_doc_fallback_filenames = ["{CODEX_CONTEXT_REL.as_posix()}"]\n'
            "project_doc_max_bytes = 131072\n")
        return True
    text = path.read_text()
    changed = False
    context = CODEX_CONTEXT_REL.as_posix()
    m = re.search(r"^project_doc_fallback_filenames\s*=\s*\[(.*?)\]\s*$",
                  text, flags=re.M | re.S)
    if m:
        items = re.findall(r'"([^"]+)"|\'([^\']+)\'', m.group(1))
        values = [a or b for a, b in items]
        if context not in values:
            values.append(context)
            replacement = "project_doc_fallback_filenames = [" + \
                ", ".join(json.dumps(v) for v in values) + "]"
            text = text[:m.start()] + replacement + text[m.end():]
            changed = True
    else:
        text = text.rstrip("\n") + \
            f'\nproject_doc_fallback_filenames = ["{context}"]\n'
        changed = True
    if "project_doc_max_bytes" not in text:
        text = text.rstrip("\n") + "\nproject_doc_max_bytes = 131072\n"
        changed = True
    if changed:
        path.write_text(text if text.endswith("\n") else text + "\n")
    return changed


def _wire_codex_hooks(root: Path) -> bool:
    path = root / CODEX_HOOKS_REL
    hooks = _read_json(path) if path.exists() else None
    if not isinstance(hooks, dict):
        hooks = {}
    root_hooks = hooks.setdefault("hooks", {})
    session = root_hooks.setdefault("SessionStart", [])
    for entry in session:
        for h in (entry or {}).get("hooks", []):
            if ".codex/hooks/build-context.sh" in h.get("command", ""):
                return False
    session.append({
        "matcher": "startup|resume|clear|compact",
        "hooks": [{
            "type": "command",
            "command": CODEX_HOOK_COMMAND,
            "timeout": 30,
            "statusMessage": "Regenerating Codex context",
        }],
    })
    _write_json(path, hooks)
    return True


def _wire_codex_build_script(root: Path) -> bool:
    path = root / CODEX_BUILD_REL
    body = _codex_build_script()
    path.parent.mkdir(parents=True, exist_ok=True)
    existing = path.read_text() if path.exists() else None
    path.write_text(body)
    path.chmod(path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    return existing != body


def _wire_codex(root: Path) -> dict:
    changed_script = _wire_codex_build_script(root)
    return {
        "config": str(root / CODEX_CONFIG_REL),
        "config_changed": _wire_codex_config(root),
        "hooks": str(root / CODEX_HOOKS_REL),
        "hook_added": _wire_codex_hooks(root),
        "compiler": str(root / CODEX_BUILD_REL),
        "compiler_written": True,
        "compiler_changed": changed_script,
        "capabilities_context": str(_write_codex_capabilities(root)),
        "compiled_context": _run_codex_build(root),
    }


def cmd_context(host: str) -> None:
    root = _require_project()
    if host == "fragment":
        _emit(_compose_context(root))
        return
    if _contextkit_managed(root):
        result = _contextkit_handoff(root, [host])
        result["skipped"] = True
        _emit(result)
        return
    if host == "claude":
        target = root / ".claude" / "rules" / "CAPABILITIES.md"
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(_compose_context(root))
    else:
        target = _write_codex_capabilities(root)
    gate = _load_gate(root)
    enabled = [n for n, g in gate["capabilities"].items()
               if (g or {}).get("enabled") is True]
    result = {"written": str(target), "enabled": sorted(enabled)}
    if host == "codex":
        built = _run_codex_build(root)
        if built:
            result["compiled_context"] = built
        elif not (root / CODEX_BUILD_REL).exists():
            result["hint"] = "run `capabilities init --codex` to wire Codex's context compiler"
    _emit(result)

# ---------------------------------------------------------------- init

HOOK_COMMAND = "capabilities context --claude"


def _wire_claude_hook(root: Path) -> bool:
    settings_file = root / ".claude" / "settings.json"
    settings = _read_json(settings_file) or {}
    hooks = settings.setdefault("hooks", {})
    session = hooks.setdefault("SessionStart", [])
    for entry in session:
        for h in (entry or {}).get("hooks", []):
            if "capabilities context" in h.get("command", ""):
                return False
    session.append({"hooks": [{"type": "command", "command": HOOK_COMMAND}]})
    _write_json(settings_file, settings)
    return True


def cmd_init(claude: bool, codex: bool) -> None:
    # init ESTABLISHES the project root: an existing root wins, else cwd.
    root = _project_root() or Path.cwd().resolve()
    migrated = _ensure_envelope(root)
    result: dict = {"project": str(root),
                    "gate": str(root / GATE_REL)}
    if migrated:
        result["migrated_from"] = str(root / LEGACY_PROJECT_CAPABILITIES_REL)
        result["migrated_entries"] = migrated
    if not claude and not codex:
        claude = True
    if _contextkit_managed(root):
        targets = (["claude"] if claude else []) + (["codex"] if codex else [])
        result["context"] = _contextkit_handoff(root, targets)
        retired = _retire_capabilities_host_wiring(root)
        if retired:
            result["retired_capabilities_wiring"] = retired
        _regen_skills(force_claude=claude, force_codex=codex)
        _emit(result)
        return
    if claude:
        result["hook_added"] = _wire_claude_hook(root)
        target = root / ".claude" / "rules" / "CAPABILITIES.md"
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(_compose_context(root))
        result["context"] = str(target)
    if codex:
        result["codex"] = _wire_codex(root)
    _regen_skills(force_claude=claude, force_codex=codex)
    _emit(result)

# ---------------------------------------------------------------- skill

SKILL_BODY = """\
Capabilities are self-contained CLIs installed on PATH, managed by the
`capabilities` manager. Each one is self-describing through the same contract
verbs:

- `<name> help` — the full usage contract (always start here)
- `<name> doctor` — proves credentials, reachability, identity, per connection
- `<name> connections` — where every value resolves from (tier, source,
  secrets masked) — local only, no network
- `<name> guide [<topic>]` — its how-to guides, fetched live
- `<name> ids list|get|set|rm` — the project's identifiers envelope
- `<name> refs` — the project's reference files for it

Manager surface: `capabilities list` (what is installed and gated where),
`capabilities install <name>`, `capabilities enable|disable <name>` (the
per-project gate), `capabilities init` (wire a project), `capabilities ids
<name>` (render a capability's project identifiers), `capabilities doctor` /
`capabilities audit <name>` (verify), `capabilities context --fragment`
(render the manager-owned project block), `capabilities help` (full contract).
Custom managed source code lives only under
`~/capabilities-sources/<source-id>/`: create it with `capabilities source init
<id>`, create packages with `capabilities new <name> --source <id>`, and run
`capabilities source index <id>` plus `source check <id>` before committing.
Remote catalogues attach through `capabilities source add`; `capabilities
search` lists their generated indexes without executing package code. Never
edit the read-only source cache, installed registry, or a project's capability
envelope as source code.

Project visibility is host-owner-generated. Without ContextKit, in a Codex project run
`capabilities init --codex` once, then `capabilities enable <name>`; after
manual capabilities/ envelope edits refresh with `capabilities context
--codex` or `.codex/hooks/build-context.sh`. No project-root instruction
markdown file is required or assumed. Do not create or edit generated
capabilities context by hand: the manager owns the Codex `.codex` wiring and
generated `.codex/generated/` context; `.codex/hooks/build-context.sh` is
overwritten on each `capabilities init --codex`. In Claude Code use
`capabilities init --claude` (or bare `capabilities init`, which defaults to
Claude wiring) and the manager-owned `.claude/rules/CAPABILITIES.md`.

When `.contextkit/config.toml` is present, ContextKit owns Claude/Codex hooks
and the combined generated context. It obtains the manager-owned capability
block through `capabilities context --fragment` and inserts it verbatim.
`capabilities init` and the host-writing context modes do not write host wiring
there; refresh with `contextkit build`.

THE GATES (both exit 4 — ask the user, never lift one yourself): a capability
disabled by project policy (capabilities/settings.json) refuses every verb;
a connection that does not allow writes (its entry's allow_write, else the
capability's declared default — false where writes leave the system) refuses
write verbs. Do not work around either — ask, then stop; granting a write is
`allow_write: true` on that connection in connections.json.

Configuration resolves as connections. With no registry there is one implicit
connection, `default`, from the cascade: flags → project .env(.local) → user
~/.config/<name>/credentials.env → process env. A registry names more —
project capabilities/<name>/connections.json, else machine-level
~/.config/<name>/connections.json, first found wins (`--connection <id>`
selects; a `default` pointer covers unflagged calls). Secrets never go on
argv; an inline secret is an env-prefix invocation (`KEY=value <name> …`).
"""


def _skill_text() -> str:
    names = sorted(_installed())
    listed = ", ".join(names) if names else "none installed yet"
    description = (
        f"Operate installed capability CLIs ({listed}) and the capabilities "
        f"manager — contract verbs, per-project enable/disable gate, exit-4 "
        f"rule, credential cascade, connections.")
    return (f"---\nname: capabilities\ndescription: {description}\n---\n\n"
            f"# Capabilities\n\n{SKILL_BODY}")


def _regen_skills(force_claude: bool = False, force_codex: bool = False) -> list[str]:
    """Generate the skill for each host present on this machine."""
    written = []
    text = _skill_text()
    for base, forced in ((Path.home() / ".claude", force_claude),
                         (Path.home() / ".agents", force_codex)):
        if base.is_dir() or forced:
            skill = base / "skills" / "capabilities" / "SKILL.md"
            skill.parent.mkdir(parents=True, exist_ok=True)
            skill.write_text(text)
            written.append(str(skill))
    return written

# ---------------------------------------------------------------- doctor

def _check_registry(findings: list[str], owner: str, conn_file: Path) -> None:
    """Validate one connections envelope; append findings."""
    reg = _read_json(conn_file)
    if not isinstance(reg, dict) or not isinstance(reg.get("connections"), dict) \
            or not reg["connections"]:
        findings.append(f"{owner}: {conn_file} is not a connections envelope "
                        f"(needs a non-empty 'connections' object)")
        return
    entries = reg["connections"]
    default = reg.get("default")
    if default is not None and default not in entries:
        findings.append(f"{owner}: connections default {default!r} names no entry "
                        f"(known: {', '.join(sorted(entries))}) — {conn_file}")
    for cid, entry in entries.items():
        if not isinstance(entry, dict):
            findings.append(f"{owner}: connection {cid!r} is not an object — {conn_file}")
            continue
        aw = entry.get("allow_write")
        if aw is not None and not isinstance(aw, bool):
            findings.append(f"{owner}: connection {cid!r} allow_write is not a "
                            f"boolean — {conn_file}")


def cmd_doctor() -> None:
    findings: list[str] = []
    bin_dir = _bin_dir()
    for name, meta in _installed().items():
        script = _script_path(name)
        # The registry copy is the canonical binary — a real file the manager
        # wrote, never a symlink into a working tree. A dev-time `ln -s` back to
        # a project checkout makes the machine run an uncommitted binary and
        # reintroduces a direct project reference; the closed-loop lifecycle
        # (.claude/rules/CONFORMANCE.md) exists to prevent exactly that.
        if script.is_symlink():
            findings.append(
                f"{name}: registry script is a symlink to {script.resolve()}, "
                f"not a canonical file under {CAP_HOME} — reinstall from the "
                f"canonical source with `capabilities install {name}`")
        if not os.access(script, os.X_OK):
            findings.append(f"{name}: script is not executable ({script})")
        link = bin_dir / name
        if not link.is_symlink():
            findings.append(f"{name}: no symlink at {link}")
        elif link.resolve() != script.resolve():
            findings.append(f"{name}: symlink points to {link.resolve()}, not {script}")
        stub, manifest = _load_snapshots(name)
        if stub is None:
            findings.append(f"{name}: stub snapshot missing — run `capabilities update {name}`")
        if manifest is None:
            findings.append(f"{name}: manifest snapshot missing — run `capabilities update {name}`")
        recorded = meta.get("sha256")
        if recorded and script.exists() and _sha256(script) != recorded:
            findings.append(f"{name}: script hash differs from snapshot key — "
                            f"run `capabilities update {name}` to refresh snapshots")
        user_reg = _CONFIG_HOME / name / "connections.json"
        if user_reg.exists():
            _check_registry(findings, name, user_reg)
    root = _project_root()
    if root and (root / LEGACY_PROJECT_CAPABILITIES_REL).is_dir():
        findings.append(
            "project: legacy .capabilities/ envelope is still present — run "
            "`capabilities init` to migrate it into visible capabilities/")
    envelope = _project_capabilities_dir(root) if root else None
    if root and envelope and (envelope / "settings.json").is_file():
        gate_file = envelope / "settings.json"
        gate = _read_json(gate_file)
        if gate_file.exists() and gate is None:
            findings.append(f"project: gate file unreadable ({gate_file})")
        gate = gate if isinstance(gate, dict) else {"capabilities": {}}
        caps = gate.get("capabilities") or {}
        for n, g in caps.items():
            extra = set((g or {})) - {"enabled"}
            if extra:
                findings.append(f"project: gate entry {n} carries non-standard keys: "
                                f"{sorted(extra)}")
            if (g or {}).get("enabled") is True and n not in _installed():
                findings.append(f"project: {n} enabled but not installed")
        gi = envelope / ".gitignore"
        if not gi.exists() or "*/state/" not in gi.read_text():
            findings.append("project: capabilities/.gitignore missing the */state/ "
                            "guard — session state could be committed")
        for conn_file in sorted(envelope.glob("*/connections.json")):
            _check_registry(findings, "project", conn_file)
        settings = _read_json(root / ".claude" / "settings.json") or {}
        deny = (settings.get("permissions") or {}).get("deny") or []
        for n, g in caps.items():
            if (g or {}).get("enabled") is True and _deny_rule(n) in deny:
                findings.append(f"project: {n} is enabled but a deny rule blocks it "
                                f"— remove {_deny_rule(n)} or disable the capability")
    report = {"ok": not findings, "findings": findings}
    if findings:
        _emit(report)
        sys.exit(7)
    _emit(report)

# ---------------------------------------------------------------- contract preamble

def _fence_markers(region: str) -> tuple[str, str]:
    """The exact open/close marker lines bounding a vendored contract region."""
    return (
        f"# >>> contract: {region} (generated — edit contract/preamble.py, "
        f"run `capabilities sync-contract`) >>>",
        f"# <<< contract: {region} <<<",
    )


def _split_region(text: str, region: str) -> tuple[str, str, str] | None:
    """Split `text` around one fenced region into (head, interior, tail): head
    ends with the open-marker line, tail starts with the close marker, interior
    is everything between. None when the region is absent; ValueError when a
    marker is unbalanced or misordered."""
    open_m, close_m = _fence_markers(region)
    oi, ci = text.find(open_m), text.find(close_m)
    if oi == -1 and ci == -1:
        return None
    if oi == -1 or ci == -1 or ci < oi:
        raise ValueError(f"region {region!r} fence is unbalanced or misordered")
    interior_start = text.find("\n", oi) + 1
    return text[:interior_start], text[interior_start:ci], text[ci:]


def _canonical_regions() -> dict[str, str]:
    """The canonical interior text of each region, read from contract/preamble.py."""
    text = _PREAMBLE.read_text()
    out: dict[str, str] = {}
    for region in _CONTRACT_REGIONS:
        split = _split_region(text, region)
        if split is None:
            _die(7, "bad_fence", f"contract/preamble.py is missing region {region!r}")
        out[region] = split[1]
    return out


def _contract_drift(text: str, canonical: dict[str, str]) -> list[str]:
    """Regions whose interior differs from canonical. Absent regions are not
    drift; a malformed fence is reported as its own labelled drift."""
    out: list[str] = []
    for region, canon in canonical.items():
        try:
            split = _split_region(text, region)
        except ValueError as e:
            out.append(f"{region} ({e})")
            continue
        if split is not None and split[1] != canon:
            out.append(region)
    return out


def cmd_sync_contract(check_only: bool) -> None:
    """Stamp (or, with --check, audit) the canonical preamble into every
    capabilities/*/bin/* fenced region. The manager itself never participates."""
    if not _PREAMBLE.is_file():
        _die(5, "no_preamble", f"canonical preamble not found at {_PREAMBLE}",
             "run sync-contract from a checkout of the capabilities repo")
    src = _REPO_ROOT / "capabilities"
    if not src.is_dir():
        _die(5, "no_source", f"capability source tree not found at {src}")
    canonical = _canonical_regions()
    changed: list[dict] = []
    for capdir in sorted(p for p in src.iterdir() if p.is_dir()):
        script = capdir / "bin" / capdir.name
        if not script.is_file():
            continue
        text = script.read_text()
        new_text, stamped = text, []
        for region in _CONTRACT_REGIONS:
            try:
                split = _split_region(new_text, region)
            except ValueError as e:
                _die(7, "bad_fence", f"{capdir.name}: {e}")
            if split is None:
                continue
            head, interior, tail = split
            if interior != canonical[region]:
                new_text = head + canonical[region] + tail
                stamped.append(region)
        if stamped:
            changed.append({"capability": capdir.name, "regions": stamped})
            if not check_only:
                script.write_text(new_text)
    if check_only:
        _emit({"preamble": str(_PREAMBLE), "drift": changed, "ok": not changed})
        if changed:
            sys.exit(7)
    else:
        _emit({"preamble": str(_PREAMBLE), "stamped": changed, "ok": True})

# ---------------------------------------------------------------- audit

def _audit_script(name: str, script: Path) -> list[str]:
    failures: list[str] = []
    env = _snapshot_env()
    script_text = script.read_text()
    # A capability with no `connections` fence is core-only: it carries the
    # capability-core declaration surface and stops (DOCTRINE — core-only is an
    # absence, not a deviation). Its `connections` verb reports no connections.
    core_only = _split_region(script_text, "connections") is None

    if _PREAMBLE.is_file():
        for region in _contract_drift(script_text, _canonical_regions()):
            failures.append(
                f"contract-drift: {region} differs from contract/preamble.py "
                f"— run `capabilities sync-contract`")

    # doctor gates on the shared resolution before any round-trip: a
    # connection-bearing capability's doctor consumes _doctor_gate — the cascade
    # verdict the `connections` report reads — so readiness is judged through one
    # resolver, never a parallel credential check. The call lives in the
    # capability's own code, outside the vendored fence that defines the helper.
    if not core_only:
        _conn = _split_region(script_text, "connections")
        _outside = script_text.replace(_conn[1], "") if _conn else script_text
        if "_doctor_gate(" not in _outside:
            failures.append(
                "doctor: no _doctor_gate(...) call in the capability's own code "
                "— readiness must be judged through the cascade resolution, not "
                "a parallel check")

    rc, out, err = _run_script(script, ["stub"])
    if rc != 0:
        failures.append(f"stub: exit {rc}")
    else:
        stub = out.strip()
        if not stub:
            failures.append("stub: empty")
        elif "\n" in stub:
            failures.append("stub: more than one line")
        elif f"`{name} help`" not in stub:
            failures.append(f"stub: does not end in the discovery pointer `{name} help`")

    manifest = None
    rc, out, err = _run_script(script, ["manifest", "--json"])
    if rc != 0:
        failures.append(f"manifest: exit {rc}")
    else:
        try:
            manifest = json.loads(out)
        except ValueError:
            failures.append("manifest: not JSON")
    if manifest is not None:
        failures += [f"manifest: {p}" for p in _validate_manifest(name, manifest)]
        if str(manifest.get("summary", "")).startswith("TODO:"):
            failures.append("manifest: scaffold summary placeholder remains")
    if "Replace this scaffold check with" in script_text:
        failures.append("doctor: scaffold readiness placeholder remains")

    rc, out, err = _run_script(script, ["help"])
    if rc != 0:
        failures.append(f"help: exit {rc}")
    else:
        for verb in ("doctor", "connections", "stub", "manifest", "guide", "ids", "refs"):
            if verb not in out:
                failures.append(f"help: contract verb {verb!r} undocumented")

    # the gate, exercised in a sandbox — disabled / enabled / absent.
    # A second throwaway dir isolates the XDG/HOME surface: the verdict must not
    # depend on the developer's real ~/.config or ~/.local/state. A live
    # connections.json there would otherwise leak into the registry-free
    # 'implicit' check, so every sandboxed run resolves config and state from
    # nothing. The home lives outside the sandbox to leave project-root walking
    # (which stops at $HOME) untouched.
    with tempfile.TemporaryDirectory() as td, tempfile.TemporaryDirectory() as home_td:
        sandbox = Path(td)
        home = Path(home_td)
        env = {**env, "HOME": str(home),
               "XDG_CONFIG_HOME": str(home / "config"),
               "XDG_STATE_HOME": str(home / "state"),
               "XDG_DATA_HOME": str(home / "data"),
               "XDG_CACHE_HOME": str(home / "cache")}
        for state, expect in (("disabled", 4), ("enabled", 0), ("absent", 0)):
            capdir = sandbox / "capabilities"
            if state == "absent":
                shutil.rmtree(capdir, ignore_errors=True)
                (sandbox / ".git").mkdir(exist_ok=True)  # roots the walk
            else:
                capdir.mkdir(exist_ok=True)
                _write_json(capdir / "settings.json", {
                    "capabilities": {name: {"enabled": state == "enabled"}}})
            genv = dict(env)
            genv["CLAUDE_PROJECT_DIR"] = str(sandbox)
            rc, out, errs = _run_script(script, ["stub"], cwd=sandbox, env=genv)
            if rc != expect:
                failures.append(f"gate/{state}: `stub` exited {rc}, expected {expect}")
            if state == "disabled":
                try:
                    envl = json.loads(errs.strip().splitlines()[-1])
                    if envl.get("error", {}).get("code") != "disabled":
                        failures.append("gate/disabled: envelope code is not 'disabled'")
                except (ValueError, IndexError):
                    failures.append("gate/disabled: no JSON error envelope on stderr")

        # refs + ids in an enabled sandbox project
        capdir = sandbox / "capabilities"
        capdir.mkdir(exist_ok=True)
        _write_json(capdir / "settings.json",
                    {"capabilities": {name: {"enabled": True}}})
        genv = dict(env)
        genv["CLAUDE_PROJECT_DIR"] = str(sandbox)
        refdir = capdir / name / "reference"
        refdir.mkdir(parents=True, exist_ok=True)
        (refdir / "audit-probe.md").write_text(
            "---\nname: audit-probe\ndescription: audit probe reference\n---\n\nbody\n")
        rc, out, errs = _run_script(script, ["refs"], cwd=sandbox, env=genv)
        if rc != 0:
            failures.append(f"refs: exit {rc}")
        else:
            try:
                arr = json.loads(out)
                if not isinstance(arr, list):
                    failures.append("refs: output is not a JSON array")
                elif not any((r or {}).get("name") == "audit-probe" for r in arr):
                    failures.append(
                        "refs: a reference in capabilities/<name>/reference/ is not surfaced")
            except ValueError:
                failures.append("refs: not JSON")
        rc, out, errs = _run_script(script, ["ids", "list"], cwd=sandbox, env=genv)
        if rc != 0:
            failures.append(f"ids list: exit {rc}")
        else:
            try:
                if not isinstance(json.loads(out), dict):
                    failures.append("ids list: output is not a JSON object")
            except ValueError:
                failures.append("ids list: not JSON")
        rc, out, errs = _run_script(
            script, ["ids", "set", "audit-probe", '{"v": 1}', "--note", "audit probe"],
            cwd=sandbox, env=genv)
        if rc != 0:
            failures.append(f"ids set: exit {rc}")
        else:
            stored = _read_json(capdir / name / "identifiers.json") or {}
            probe = stored.get("audit-probe") or {}
            if probe.get("value") != {"v": 1} or probe.get("note") != "audit probe":
                failures.append("ids set: envelope shape wrong in identifiers.json")
            rc, out, errs = _run_script(script, ["ids", "get", "audit-probe"],
                                        cwd=sandbox, env=genv)
            if rc != 0:
                failures.append(f"ids get: exit {rc}")
            rc, out, errs = _run_script(script, ["ids", "rm", "audit-probe"],
                                        cwd=sandbox, env=genv)
            if rc != 0:
                failures.append(f"ids rm: exit {rc}")

        # connections — the resolution report, implicit default then registry-driven
        def _check_connections(expect_ids: set[str], label: str,
                               expect_default: str | None = None) -> None:
            rc, out, errs = _run_script(script, ["connections"], cwd=sandbox, env=genv)
            if rc != 0:
                failures.append(f"connections/{label}: exit {rc} "
                                f"(the report renders even unconfigured)")
                return
            try:
                report = json.loads(out)
            except ValueError:
                failures.append(f"connections/{label}: not JSON")
                return
            conns = report.get("connections")
            if not isinstance(conns, dict) or set(conns) != expect_ids:
                failures.append(f"connections/{label}: ids {sorted(conns or [])} != "
                                f"{sorted(expect_ids)}")
                return
            if expect_default is not None and report.get("default") != expect_default:
                failures.append(f"connections/{label}: default is "
                                f"{report.get('default')!r}, expected {expect_default!r}")
            for cid, entry in conns.items():
                keys = (entry or {}).get("keys")
                if not isinstance(keys, list):
                    failures.append(f"connections/{label}: {cid} carries no keys list")
                    continue
                for k in keys:
                    if k.get("secret") and k.get("set") and not str(
                            k.get("value", "")).startswith(("…", "****")):
                        failures.append(f"connections/{label}: secret "
                                        f"{k.get('key')!r} not masked")

        if core_only:
            # No connections fence: `connections` reports none, and no registry
            # is consulted. An empty/absent 'connections' map is the contract.
            rc, out, errs = _run_script(script, ["connections"], cwd=sandbox, env=genv)
            if rc != 0:
                failures.append(f"connections/core-only: exit {rc} "
                                f"(the report renders even unconfigured)")
            else:
                try:
                    report = json.loads(out)
                except ValueError:
                    failures.append("connections/core-only: not JSON")
                else:
                    if report.get("connections"):
                        failures.append(
                            "connections/core-only: a capability with no "
                            "connections fence must report no connections "
                            "(an empty 'connections' map)")
        else:
            _check_connections({"default"}, "implicit", expect_default="default")
            conn_file = capdir / name / "connections.json"
            conn_file.parent.mkdir(exist_ok=True)
            _write_json(conn_file, {"default": "a",
                                    "connections": {"a": {}, "b": {"allow_write": False}}})
            _check_connections({"a", "b"}, "registry", expect_default="a")
            conn_file.unlink()

        # guide menu agrees with the manifest
        if manifest is not None:
            topics = (manifest.get("docs") or {}).get("topics") or []
            rc, out, errs = _run_script(script, ["guide"], cwd=sandbox, env=genv)
            if topics:
                if rc != 0:
                    failures.append(f"guide: exit {rc}")
                else:
                    for t in topics:
                        if t not in out:
                            failures.append(f"guide: declared topic {t!r} missing from menu")
            elif rc == 0 and out.strip() not in ("[]", ""):
                try:
                    if json.loads(out):
                        failures.append("guide: menu non-empty but manifest declares no topics")
                except ValueError:
                    failures.append("guide: menu non-empty but manifest declares no topics")
    return failures


def cmd_audit(name: str, from_ref: str | None) -> None:
    if from_ref:
        p = Path(from_ref).expanduser().resolve()
        if p.is_dir():
            for cand in (p / name, p / "bin" / name,
                         p / "capabilities" / name / "bin" / name):
                if cand.is_file():
                    p = cand
                    break
        if not p.is_file():
            _die(3, "not_found", f"--from script not found: {from_ref}")
        script = p
    else:
        script = _script_path(name)
        if not script.is_file():
            _die(3, "not_found", f"{name} is not installed",
                 f"`capabilities install {name}` or audit --from <path>")
    failures = _audit_script(name, script)
    report = {"name": name, "ok": not failures, "failures": failures}
    _emit(report)
    if failures:
        sys.exit(7)


# ---------------------------------------------------------------- sources / authoring

def _validate_source_id(source_id: str) -> None:
    if not re.fullmatch(r"[a-z0-9][a-z0-9._-]*", source_id):
        _die(6, "bad_source_id", f"invalid source id {source_id!r}",
             "use lowercase letters, digits, dots, underscores, or hyphens")


def _sources_config() -> dict:
    raw = _read_json(SOURCES_FILE)
    if raw is None:
        return {"sources": {}}
    if not isinstance(raw, dict) or not isinstance(raw.get("sources"), dict):
        _die(6, "bad_sources", f"{SOURCES_FILE} is not a sources registry",
             'expected {"sources": {"<id>": {"kind", ...}}}')
    return raw


def _source_entry(source_id: str) -> dict:
    if source_id == OFFICIAL_SOURCE_ID:
        return {"kind": "git", "url": OFFICIAL_GIT_URL, "ref": "main",
                "builtin": True}
    entry = (_sources_config().get("sources") or {}).get(source_id)
    if not isinstance(entry, dict):
        _die(3, "source_not_found", f"unknown capability source {source_id!r}",
             "`capabilities source list` shows registered sources")
    if entry.get("kind") == "workspace":
        configured = Path(entry.get("path") or "").expanduser()
        canonical = _source_workspace(source_id)
        if configured.resolve() != canonical.resolve():
            _die(6, "noncanonical_workspace",
                 f"source {source_id!r} workspace is not canonical: {configured}",
                 f"managed source workspaces must live at {canonical}")
    elif entry.get("kind") != "git":
        _die(6, "bad_source", f"source {source_id!r} has unknown kind {entry.get('kind')!r}")
    return entry


def _source_workspace(source_id: str) -> Path:
    return SOURCE_WORKSPACE_ROOT / source_id


def _source_cache(source_id: str) -> Path:
    return SOURCE_CACHE_ROOT / source_id


def _source_root(source_id: str) -> Path:
    entry = _source_entry(source_id)
    if entry.get("kind") == "workspace":
        return Path(entry.get("path") or _source_workspace(source_id)).expanduser()
    return _source_cache(source_id)


def _source_author_root(source_id: str) -> Path:
    """Editable root for a registered workspace or the official repo checkout."""
    if source_id == OFFICIAL_SOURCE_ID and \
            (_REPO_ROOT / "capabilities.repo.json").is_file():
        return _REPO_ROOT
    return _source_root(source_id)


def _git(args: list[str], cwd: Path | None = None) -> str:
    try:
        proc = subprocess.run(["git", *args], cwd=str(cwd) if cwd else None,
                              capture_output=True, text=True, timeout=120)
    except FileNotFoundError:
        _die(6, "missing_git", "git is required for capability sources")
    except subprocess.TimeoutExpired:
        _die(5, "git_timeout", "git command timed out", " ".join(args))
    if proc.returncode != 0:
        _die(5, "git_failed", proc.stderr.strip() or "git command failed",
             "git " + " ".join(args))
    return proc.stdout.strip()


def _require_authoring_assets() -> None:
    missing = [rel for rel in _AUTHORING_ASSETS if not (_ASSET_ROOT / rel).is_file()]
    if missing:
        _die(5, "authoring_assets_missing",
             f"manager authoring kit is incomplete: {', '.join(missing)}",
             "run `capabilities self-update`; bootstrap installs the manager and its authoring kit")


def _authoring_markdown(source_id: str) -> str:
    root = _source_workspace(source_id)
    return f"""\
# Authoring managed capabilities

This repository is the sole editable source for `{source_id}`. Its canonical
workspace is `{root}`. Never edit installed payloads under `~/.capabilities/`,
manager caches under `~/.cache/capabilities/`, or a consuming project's
`capabilities/` envelope as capability source code.

Create a capability only with:

```sh
capabilities new <name> --source {source_id}
```

The manager stamps generated contract regions from `contract/preamble.py`.
Never edit text between `# >>> contract:` and `# <<< contract:` markers.
Before every commit run:

```sh
capabilities source index {source_id}
capabilities source check {source_id}
```

Install for a local smoke test with `capabilities install <name> --source
{source_id}`. Commit and push only from this workspace with ordinary git.
There is no conformance override: a managed capability must pass the contract
and audit. A free-form CLI remains usable directly, outside this manager.
"""


def _repo_agent_markdown(source_id: str) -> str:
    return f"""\
# Managed capability source

Read `AUTHORING.md` before editing. Create packages with `capabilities new
<name> --source {source_id}`. Never hand-edit generated contract regions.
Run `capabilities source index {source_id}` and `capabilities source check
{source_id}` before committing. Source code lives only under
`capabilities/<name>/`; installed and project-envelope copies are not source.
"""


def _scaffold_source_repo(source_id: str, root: Path) -> None:
    _require_authoring_assets()
    (root / "capabilities").mkdir(parents=True, exist_ok=True)
    (root / ".capability-source").mkdir(parents=True, exist_ok=True)
    for rel in _AUTHORING_ASSETS:
        target = root / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        source_asset = _ASSET_ROOT / rel
        if source_asset.resolve() != target.resolve():
            shutil.copy2(source_asset, target)
    _write_json(root / "capabilities.repo.json", {"kind": "capability-source"})
    _write_json(root / "contract" / "contract.json", {
        "preamble_sha256": _sha256(root / "contract" / "preamble.py")})
    _write_json(root / ".capability-source" / "catalog.json", {"capabilities": {}})
    (root / "AUTHORING.md").write_text(_authoring_markdown(source_id))
    agent_text = _repo_agent_markdown(source_id)
    (root / "AGENTS.md").write_text(agent_text)
    (root / "CLAUDE.md").write_text(agent_text)
    (root / "README.md").write_text(
        f"# {source_id} capabilities\n\nSee [AUTHORING.md](AUTHORING.md).\n")
    (root / ".gitignore").write_text("**/__pycache__/\n*.pyc\n")


def cmd_source_init(source_id: str, remote: str | None) -> None:
    _validate_source_id(source_id)
    if source_id == OFFICIAL_SOURCE_ID:
        _die(6, "reserved_source", f"{OFFICIAL_SOURCE_ID!r} is reserved")
    cfg = _sources_config()
    if source_id in cfg["sources"]:
        _die(6, "source_exists", f"source {source_id!r} is already registered")
    root = _source_workspace(source_id)
    if root.exists():
        _die(6, "workspace_exists", f"canonical workspace already exists: {root}",
             "move or remove it deliberately before initializing this source")
    root.parent.mkdir(parents=True, exist_ok=True)
    try:
        root.mkdir()
        _scaffold_source_repo(source_id, root)
        _git(["init", "--initial-branch", "main"], cwd=root)
        if remote:
            _git(["remote", "add", "origin", remote], cwd=root)
    except BaseException:
        shutil.rmtree(root, ignore_errors=True)
        raise
    cfg["sources"][source_id] = {
        "kind": "workspace", "path": str(root), "ref": "main",
        **({"url": remote} if remote else {})}
    _write_json(SOURCES_FILE, cfg)
    _emit({"source": source_id, "kind": "workspace", "path": str(root),
           "remote": remote, "next": [
               f"cd {shlex.quote(str(root))}",
               f"capabilities new <name> --source {source_id}",
               f"capabilities source index {source_id}",
               f"capabilities source check {source_id}"]})


def _refresh_source(source_id: str) -> dict:
    entry = _source_entry(source_id)
    root = _source_root(source_id)
    if entry.get("kind") == "workspace":
        if not (root / ".git").is_dir():
            _die(6, "bad_workspace", f"source workspace is not a git repository: {root}")
        commit = _git(["rev-parse", "HEAD"], cwd=root) if \
            _git(["rev-list", "--all", "--count"], cwd=root) != "0" else None
        dirty = bool(_git(["status", "--porcelain"], cwd=root))
        return {"source": source_id, "kind": "workspace", "path": str(root),
                "commit": commit, "dirty": dirty}
    url = entry.get("url")
    ref = entry.get("ref") or "main"
    if not isinstance(url, str) or not url:
        _die(6, "bad_source", f"source {source_id!r} has no git URL")
    SOURCE_CACHE_ROOT.mkdir(parents=True, exist_ok=True)
    if root.exists():
        if not (root / ".git").is_dir():
            shutil.rmtree(root)
        else:
            _git(["fetch", "--depth", "1", "origin", ref], cwd=root)
            _git(["reset", "--hard", "FETCH_HEAD"], cwd=root)
    if not root.exists():
        _git(["clone", "--depth", "1", "--branch", ref, url, str(root)])
    marker = _read_json(root / "capabilities.repo.json")
    catalog = _read_json(root / ".capability-source" / "catalog.json")
    if not isinstance(marker, dict) or marker.get("kind") != "capability-source":
        _die(7, "source_invalid", f"{source_id!r} is not a managed capability source",
             "missing capabilities.repo.json capability-source marker")
    if not isinstance(catalog, dict) or not isinstance(catalog.get("capabilities"), dict):
        _die(7, "source_invalid", f"{source_id!r} has no generated capability catalog",
             "the source owner must run `capabilities source index <id>` and publish it")
    return {"source": source_id, "kind": "git", "path": str(root),
            "ref": ref, "commit": _git(["rev-parse", "HEAD"], cwd=root)}


def _source_install_ref(name: str, source_id: str) -> tuple[str, dict]:
    entry = _source_entry(source_id)
    state = _refresh_source(source_id)
    root = _source_root(source_id)
    capdir = root / "capabilities" / name
    script = capdir / "bin" / name
    if not script.is_file():
        _die(3, "not_found", f"source {source_id!r} has no capability {name!r}",
             f"expected {script}")
    catalog = _read_json(root / ".capability-source" / "catalog.json") or {}
    listed = (catalog.get("capabilities") or {}).get(name)
    if not isinstance(listed, dict):
        _die(7, "catalog_missing", f"{name!r} is not present in source {source_id!r} catalog",
             f"the source owner must run `capabilities source index {source_id}` and publish it")
    expected_hash = listed.get("payload_sha256")
    actual_hash = _payload_sha256(capdir)
    if expected_hash != actual_hash:
        _die(7, "catalog_drift", f"{source_id}/{name} payload differs from its catalog",
             f"run `capabilities source index {source_id}` before installing")
    return str(capdir), {
        "source_id": source_id,
        "source_url": entry.get("url"),
        "source_ref": entry.get("ref") or "main",
        "source_commit": state.get("commit"),
        "source_dirty": state.get("dirty", False),
    }


def cmd_source_add(source_id: str, url: str, ref: str) -> None:
    _validate_source_id(source_id)
    if source_id == OFFICIAL_SOURCE_ID:
        _die(6, "reserved_source", f"{OFFICIAL_SOURCE_ID!r} is reserved")
    cfg = _sources_config()
    if source_id in cfg["sources"]:
        _die(6, "source_exists", f"source {source_id!r} is already registered")
    cfg["sources"][source_id] = {"kind": "git", "url": url, "ref": ref}
    _write_json(SOURCES_FILE, cfg)
    try:
        result = _refresh_source(source_id)
    except BaseException:
        cfg["sources"].pop(source_id, None)
        _write_json(SOURCES_FILE, cfg)
        shutil.rmtree(_source_cache(source_id), ignore_errors=True)
        raise
    _emit({"registered": source_id, **result})


def cmd_source_clone(source_id: str, url: str, ref: str) -> None:
    _validate_source_id(source_id)
    if source_id == OFFICIAL_SOURCE_ID:
        _die(6, "reserved_source", f"{OFFICIAL_SOURCE_ID!r} is reserved")
    cfg = _sources_config()
    if source_id in cfg["sources"]:
        _die(6, "source_exists", f"source {source_id!r} is already registered")
    root = _source_workspace(source_id)
    if root.exists():
        _die(6, "workspace_exists", f"canonical workspace already exists: {root}")
    root.parent.mkdir(parents=True, exist_ok=True)
    try:
        _git(["clone", "--branch", ref, url, str(root)])
        failures = _source_contract_failures(root)
        if failures:
            _die(7, "source_invalid", "; ".join(failures),
                 "the repository owner must publish a manager-created capability source")
    except BaseException:
        shutil.rmtree(root, ignore_errors=True)
        raise
    cfg["sources"][source_id] = {
        "kind": "workspace", "path": str(root), "url": url, "ref": ref}
    _write_json(SOURCES_FILE, cfg)
    _emit({"source": source_id, "kind": "workspace", "path": str(root),
           "url": url, "ref": ref,
           "next": [f"cd {shlex.quote(str(root))}",
                    f"capabilities source check {source_id}"]})


def cmd_source_list() -> None:
    entries = [{"id": OFFICIAL_SOURCE_ID, "kind": "git",
                "url": OFFICIAL_GIT_URL, "ref": "main", "builtin": True,
                "cached": _source_cache(OFFICIAL_SOURCE_ID).is_dir()}]
    for source_id, entry in sorted((_sources_config().get("sources") or {}).items()):
        root = _source_root(source_id)
        entries.append({"id": source_id, **entry, "available": root.is_dir()})
    _emit({"sources": entries, "workspace_root": str(SOURCE_WORKSPACE_ROOT),
           "cache_root": str(SOURCE_CACHE_ROOT)})


def cmd_source_path(source_id: str) -> None:
    entry = _source_entry(source_id)
    if entry.get("kind") != "workspace":
        _die(6, "not_editable", f"source {source_id!r} is a remote cache, not an editable workspace",
             f"authoring workspaces are created by `capabilities source init <id>` under {SOURCE_WORKSPACE_ROOT}")
    _emit({"source": source_id, "path": str(_source_root(source_id))})


def cmd_source_refresh(source_id: str | None) -> None:
    ids = [source_id] if source_id else [OFFICIAL_SOURCE_ID, *sorted(
        (_sources_config().get("sources") or {}).keys())]
    _emit({"refreshed": [_refresh_source(sid) for sid in ids]})


def cmd_source_remove(source_id: str) -> None:
    if source_id == OFFICIAL_SOURCE_ID:
        _die(6, "reserved_source", "the built-in official source cannot be removed")
    cfg = _sources_config()
    entry = cfg["sources"].get(source_id)
    if not isinstance(entry, dict):
        _die(3, "source_not_found", f"unknown capability source {source_id!r}")
    root = Path(entry.get("path") or _source_workspace(source_id)) if \
        entry.get("kind") == "workspace" else _source_cache(source_id)
    cfg["sources"].pop(source_id)
    _write_json(SOURCES_FILE, cfg)
    cache = _source_cache(source_id)
    if cache.is_dir() and entry.get("kind") != "workspace":
        shutil.rmtree(cache)
    result = {"removed": source_id}
    if entry.get("kind") == "workspace":
        result["workspace_kept"] = str(root)
    _emit(result)


def _catalog_payload(root: Path, audit: bool) -> tuple[dict, dict[str, list[str]]]:
    cap_root = root / "capabilities"
    entries: dict = {}
    failures: dict[str, list[str]] = {}
    if not cap_root.is_dir():
        return {"capabilities": {}}, {"repository": ["missing capabilities/ directory"]}
    for capdir in sorted(p for p in cap_root.iterdir() if p.is_dir()):
        name = capdir.name
        script = capdir / "bin" / name
        if not script.is_file():
            failures[name] = [f"missing canonical executable capabilities/{name}/bin/{name}"]
            continue
        problems = _audit_script(name, script) if audit else []
        rc, out, err = _run_script(script, ["manifest", "--json"])
        manifest = None
        if rc == 0:
            try:
                manifest = json.loads(out)
            except ValueError:
                problems.append("manifest: not JSON")
        else:
            problems.append(f"manifest: exit {rc}: {err.strip()}")
        if manifest is not None:
            problems += [f"manifest: {p}" for p in _validate_manifest(name, manifest)]
        if problems:
            failures[name] = sorted(set(problems))
            continue
        entries[name] = {
            "path": f"capabilities/{name}",
            "summary": manifest.get("summary", ""),
            "payload_sha256": _payload_sha256(capdir),
        }
    return {"capabilities": entries}, failures


def _source_contract_failures(root: Path) -> list[str]:
    _require_authoring_assets()
    failures = []
    marker = _read_json(root / "capabilities.repo.json")
    if not isinstance(marker, dict) or marker.get("kind") != "capability-source":
        failures.append("capabilities.repo.json: missing capability-source marker")
    source_preamble = root / "contract" / "preamble.py"
    if not source_preamble.is_file():
        failures.append("contract: missing contract/preamble.py")
    elif source_preamble.read_bytes() != _PREAMBLE.read_bytes():
        failures.append("contract: preamble differs from the manager's canonical contract")
    lock = _read_json(root / "contract" / "contract.json")
    if not isinstance(lock, dict) or lock.get("preamble_sha256") != _sha256(_PREAMBLE):
        failures.append("contract: contract.json checksum is stale")
    return failures


def cmd_source_index(source_id: str) -> None:
    root = _source_author_root(source_id)
    if not root.is_dir():
        _die(3, "source_unavailable", f"source {source_id!r} is not available locally",
             f"run `capabilities source refresh {source_id}`")
    contract_failures = _source_contract_failures(root)
    catalog, failures = _catalog_payload(root, audit=True)
    if contract_failures or failures:
        _emit({"source": source_id, "ok": False,
               "contract": contract_failures, "failures": failures})
        sys.exit(7)
    path = root / ".capability-source" / "catalog.json"
    _write_json(path, catalog)
    _emit({"source": source_id, "indexed": sorted(catalog["capabilities"]),
           "catalog": str(path), "ok": True})


def cmd_source_check(source_id: str) -> None:
    root = _source_author_root(source_id)
    if not root.is_dir():
        _die(3, "source_unavailable", f"source {source_id!r} is not available locally",
             f"run `capabilities source refresh {source_id}`")
    contract_failures = _source_contract_failures(root)
    expected, failures = _catalog_payload(root, audit=True)
    current = _read_json(root / ".capability-source" / "catalog.json")
    if current != expected:
        failures.setdefault("catalog", []).append(
            f"generated catalog is stale — run `capabilities source index {source_id}`")
    ok = not contract_failures and not failures
    _emit({"source": source_id, "root": str(root), "ok": ok,
           "contract": contract_failures, "failures": failures,
           "capabilities": sorted(expected["capabilities"])})
    if not ok:
        sys.exit(7)


def cmd_search(query: str | None, source_id: str | None) -> None:
    ids = [source_id] if source_id else [OFFICIAL_SOURCE_ID, *sorted(
        (_sources_config().get("sources") or {}).keys())]
    needle = (query or "").lower()
    matches = []
    unavailable = []
    for sid in ids:
        root = _source_author_root(sid)
        catalog = _read_json(root / ".capability-source" / "catalog.json") if root.is_dir() else None
        if not isinstance(catalog, dict) or not isinstance(catalog.get("capabilities"), dict):
            unavailable.append({"source": sid,
                                "hint": f"capabilities source refresh {sid}"})
            continue
        for name, entry in sorted(catalog["capabilities"].items()):
            summary = (entry or {}).get("summary", "")
            if needle and needle not in name.lower() and needle not in summary.lower():
                continue
            matches.append({"name": name, "source": sid, "summary": summary,
                            "installed": _registry_dir(name).is_dir()})
    _emit({"matches": matches, "unavailable_sources": unavailable})


def _capability_skeleton(name: str, core_only: bool) -> str:
    canonical = _canonical_regions()
    core_open, core_close = _fence_markers("capability core")
    conn_open, conn_close = _fence_markers("connections")
    connections = ""
    report = """\
def _connections_report() -> dict:
    reg, _reg_file = _connections_registry()
    out: dict = {"default": None, "connections": {}}
    if reg is None:
        rows = []
        for spec in CRED_KEYS:
            value, tier, source = _resolve_env_key(spec["key"])
            rows.append(_key_report(spec["key"], bool(spec.get("secret")),
                                    bool(spec.get("required")), value, tier, source))
        out["default"] = "default"
        out["connections"]["default"] = {
            "allow_write": WRITE_DEFAULT, "keys": rows}
        return out
    conns = reg["connections"]
    out["default"] = reg.get("default") or (next(iter(conns)) if len(conns) == 1 else None)
    for cid, raw in conns.items():
        entry = raw if isinstance(raw, dict) else {}
        rows = []
        for spec in CRED_KEYS:
            value, tier, source = _resolve_env_key(spec["key"])
            rows.append(_key_report(spec["key"], bool(spec.get("secret")),
                                    bool(spec.get("required")), value, tier, source))
        out["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": rows}
    return out


def _cmd_connections() -> None:
    _emit(_connections_report())
"""
    doctor = """\
def cmd_doctor(wanted: str | None) -> None:
    report = _connections_report()
    _doctor_gate(report, wanted)
    _emit({"ok": True, "connections": report["connections"],
           "note": "Replace this scaffold check with the cheapest real readiness round-trip."})
"""
    if not core_only:
        connections = (f"\n{conn_open}\n{canonical['connections']}{conn_close}\n\n" +
                       report + "\n" + doctor)
    else:
        report = """\
def _cmd_connections() -> None:
    _emit({"default": None, "connections": {}})
"""
        doctor = """\
def cmd_doctor(_wanted: str | None) -> None:
    _emit({"ok": True, "note": "Replace this scaffold check with a real readiness proof."})
"""
        connections = "\n" + report + "\n" + doctor
    return f'''#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""{name} — managed capability scaffold.

Contract:
  {name} help
  {name} doctor [--connection ID]
  {name} connections
  {name} stub
  {name} manifest --json
  {name} guide [topic]
  {name} ids list|get|set|rm
  {name} refs

Add the smallest useful domain verb surface below the generated contract
regions. Never edit text inside those regions. Success is JSON on stdout;
errors are JSON on stderr. Exit 4 is policy refusal.
"""

import json
import os
import sys
from pathlib import Path
from typing import NoReturn

NAME = {name!r}
SUMMARY = "TODO: describe the capability's smallest useful surface."
SCOPE = "project"
CRED_KEYS = []  # Add credential declarations; never put secret values here.
WRITE_VERBS = set()
WRITE_DEFAULT = True
DOCS_BASE = ""
TOPICS: list[str] = []
STATE = False
POST_INSTALL: list[dict] = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / NAME / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

{core_open}
{canonical['capability core']}{core_close}
{connections}

def main() -> None:
    _gate()
    argv = sys.argv[1:]
    _contract(argv)
    wanted = None
    cleaned = []
    i = 0
    while i < len(argv):
        if argv[i] == "--connection" and i + 1 < len(argv):
            wanted = argv[i + 1]
            i += 2
            continue
        if argv[i].startswith("--connection="):
            wanted = argv[i].split("=", 1)[1]
            i += 1
            continue
        cleaned.append(argv[i])
        i += 1
    if cleaned == ["doctor"]:
        cmd_doctor(wanted)
        return
    _die(6, "input", "unknown or incomplete command",
         f"run `{{NAME}} help`; add domain verbs to this scaffold")


if __name__ == "__main__":
    main()
'''


def cmd_new_capability(name: str, source_id: str, core_only: bool) -> None:
    if not re.fullmatch(r"[a-z][a-z0-9-]*", name):
        _die(6, "bad_name", f"invalid capability name {name!r}",
             "use lowercase letters, digits, and hyphens; start with a letter")
    entry = _source_entry(source_id)
    official_checkout = source_id == OFFICIAL_SOURCE_ID and \
        (_REPO_ROOT / "capabilities.repo.json").is_file()
    if entry.get("kind") != "workspace" and not official_checkout:
        _die(6, "not_editable", f"source {source_id!r} is not an editable workspace",
             "create one with `capabilities source init <id>`")
    root = _source_author_root(source_id)
    contract_failures = _source_contract_failures(root)
    if contract_failures:
        _die(7, "contract_drift", "; ".join(contract_failures),
             f"run `capabilities source sync {source_id}`")
    capdir = root / "capabilities" / name
    if capdir.exists():
        _die(6, "capability_exists", f"capability source already exists: {capdir}")
    script = capdir / "bin" / name
    script.parent.mkdir(parents=True)
    (capdir / "guides").mkdir()
    script.write_text(_capability_skeleton(name, core_only))
    script.chmod(0o755)
    _emit({"created": name, "source": source_id, "path": str(capdir),
           "executable": str(script), "core_only": core_only,
           "next": [f"edit only outside generated contract regions in {script}",
                    f"capabilities source index {source_id}",
                    f"capabilities source check {source_id}",
                    f"capabilities install {name} --source {source_id}"]})


def cmd_source_sync(source_id: str) -> None:
    entry = _source_entry(source_id)
    official_checkout = source_id == OFFICIAL_SOURCE_ID and \
        (_REPO_ROOT / "capabilities.repo.json").is_file()
    if entry.get("kind") != "workspace" and not official_checkout:
        _die(6, "not_editable", "contract sync is only available for an editable workspace")
    root = _source_author_root(source_id)
    _require_authoring_assets()
    for rel in _AUTHORING_ASSETS:
        target = root / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        source_asset = _ASSET_ROOT / rel
        if source_asset.resolve() != target.resolve():
            shutil.copy2(source_asset, target)
    canonical = _canonical_regions()
    stamped = []
    for capdir in sorted(p for p in (root / "capabilities").iterdir() if p.is_dir()):
        script = capdir / "bin" / capdir.name
        if not script.is_file():
            continue
        source_text = script.read_text()
        updated = source_text
        regions = []
        for region, body in canonical.items():
            split = _split_region(updated, region)
            if split is None:
                if region == "capability core":
                    _die(7, "contract_missing", f"{capdir.name}: missing generated core region")
                continue
            head, interior, tail = split
            if interior != body:
                updated = head + body + tail
                regions.append(region)
        if updated != source_text:
            script.write_text(updated)
            stamped.append({"capability": capdir.name, "regions": regions})
    _write_json(root / "contract" / "contract.json", {
        "preamble_sha256": _sha256(_PREAMBLE)})
    _emit({"source": source_id, "contract": str(root / "contract"),
           "stamped": stamped, "ok": True})

# ---------------------------------------------------------------- selfcheck

# The stable ids of the checks `audit` performs — the executable vocabulary a
# DOCTRINE.md rule names in its `Validate (audit: <id>)` tag. Each id is the
# leading token of the failures it raises, so a deliberate break can assert its
# check is live, not vacuous — the failure mode that let the core-only gap hide.
_AUDIT_CHECKS = {
    "contract-drift", "stub", "manifest", "help", "gate",
    "refs", "ids", "connections", "connections/core-only", "guide", "doctor",
}


def _stamp_regions(text: str, canonical: dict[str, str]) -> str:
    """Set every present fenced region's interior to canonical — a fresh stamp."""
    for region, canon in canonical.items():
        split = _split_region(text, region)
        if split is not None:
            head, _old, tail = split
            text = head + canon + tail
    return text


def _check_id(failure: str) -> str:
    """The audit check-id a failure string belongs to (its leading token)."""
    head = failure.split(":", 1)[0].strip()
    if head.startswith("connections/core-only"):
        return "connections/core-only"
    return head.split("/", 1)[0].split()[0]


def _inject_before_main(text: str, snippet: str) -> str | None:
    """Insert `snippet` just above the `__main__` guard so it binds before main."""
    marker = '\nif __name__ == "__main__":'
    i = text.rfind(marker)
    return None if i == -1 else text[:i] + "\n\n" + snippet + "\n" + text[i:]


def _selfcheck_negatives(canonical: dict[str, str]) -> list[str]:
    """Prove the high-value audit checks BITE. Stamp a real capability fresh,
    apply one targeted break, and require the expected check to fire; a check that
    stays silent on its own break is vacuous (how the core-only gap survived)."""
    findings: list[str] = []
    src = _REPO_ROOT / "capabilities"
    core = conn = None
    for capdir in sorted(p for p in src.iterdir() if p.is_dir()):
        script = capdir / "bin" / capdir.name
        if not script.is_file():
            continue
        if _split_region(script.read_text(), "connections") is None:
            core = core or (capdir.name, script)
        else:
            conn = conn or (capdir.name, script)
    if core is None:
        findings.append("coverage: no core-only capability — the core-only audit "
                        "branch has no living green example")
    if conn is None:
        findings.append("coverage: no connection-bearing capability — the "
                        "connections audit branch has no living green example")

    report_conn = ('def _cmd_connections() -> None:\n'
                   '    _emit({"connections": {"x": {"keys": []}}, "default": "x"})')
    report_unmasked = (
        'def _cmd_connections() -> None:\n'
        '    _emit({"default": "default", "connections": {"default": {'
        '"allow_write": True, "keys": [{"key": "SECRET", "secret": True, '
        '"required": True, "set": True, "value": "plaintext-unmasked"}]}}})')

    def break_fence(text: str):
        s = _split_region(text, "capability core")
        if s is None:
            return None
        head, interior, tail = s
        return head + interior + "# injected drift\n" + tail

    def break_doctor_gate(text: str):
        """Strip the doctor's _doctor_gate call from the capability's own code,
        leaving the vendored definition intact, so only the `doctor` check fires."""
        s = _split_region(text, "connections")
        if s is None:
            return None
        head, interior, tail = s
        broken = head.replace("_doctor_gate(", "_ungated(") + interior + \
            tail.replace("_doctor_gate(", "_ungated(")
        return None if broken == text else broken

    cases = []
    if core:
        cases.append(("connections/core-only", core,
                      lambda t: _inject_before_main(t, report_conn)))
        cases.append(("contract-drift", core, break_fence))
    if conn:
        cases.append(("connections", conn,
                      lambda t: _inject_before_main(t, report_unmasked)))
        cases.append(("doctor", conn, break_doctor_gate))

    with tempfile.TemporaryDirectory() as td:
        for expect, (name, script), mutate in cases:
            base = _stamp_regions(script.read_text(), canonical)
            broken = mutate(base)
            if not broken or broken == base:
                findings.append(f"negative/{expect}: could not build the break on {name}")
                continue
            p = Path(td) / name
            p.write_text(broken)
            p.chmod(0o755)
            if not any(_check_id(f) == expect for f in _audit_script(name, p)):
                findings.append(f"negative/{expect}: audit missed a deliberate break "
                                f"on {name} — the check is absent or vacuous")
    return findings


def _selfcheck_doctrine() -> list[str]:
    """Every standing rule names how it is enforced; every Validate(audit: id)
    names a check the audit performs; every audit check backs some rule."""
    import re
    doc = _REPO_ROOT / "DOCTRINE.md"
    if not doc.is_file():
        return ["doctrine: DOCTRINE.md not found"]
    findings: list[str] = []
    claimed: set[str] = set()
    clause_re = re.compile(r"\*Validate \(([^)]*)\):\*")
    seg_re = re.compile(r"(audit|doctor|review)(?::\s*(.*))?$")
    for ln in doc.read_text().splitlines():
        if not ln.lstrip().startswith("*Validate"):
            continue
        m = clause_re.search(ln)
        if not m:
            findings.append("doctrine: a Validate clause carries no "
                            f"(audit:…|doctor|review:…) tag: {ln.strip()[:55]}…")
            continue
        for seg in m.group(1).split(";"):
            sm = seg_re.match(seg.strip())
            if not sm:
                findings.append(f"doctrine: malformed Validate tag {seg.strip()!r}")
                continue
            if sm.group(1) == "audit":
                ids = [v.strip() for v in (sm.group(2) or "").split(",") if v.strip()]
                if not ids:
                    findings.append("doctrine: an audit tag names no check id")
                for cid in ids:
                    claimed.add(cid)
                    if cid not in _AUDIT_CHECKS:
                        findings.append(f"doctrine: Validate(audit: {cid}) names a "
                                        "check the audit does not perform")
    for cid in sorted(_AUDIT_CHECKS - claimed):
        findings.append(f"doctrine: audit check {cid!r} backs no standing rule "
                        f"(tag one Validate(audit: {cid}))")
    return findings


def _selfcheck_doclinks() -> list[str]:
    """Every relative markdown link in the doctrine surface resolves to a file."""
    import re
    findings: list[str] = []
    link_re = re.compile(r"\[[^\]]+\]\(([^)]+)\)")
    docs = [_REPO_ROOT / n for n in
            ("DOCTRINE.md", "SHEBANG.md", "TEMPLATE.md", "ROUTINES.md", "README.md")]
    docs += sorted((_REPO_ROOT / ".claude" / "rules").glob("*.md"))
    for doc in docs:
        if not doc.is_file():
            continue
        for m in link_re.finditer(doc.read_text()):
            target = m.group(1).strip()
            if target.startswith(("http://", "https://", "mailto:", "#")):
                continue
            target = target.split("#", 1)[0]
            if target and not (doc.parent / target).resolve().exists():
                findings.append(f"doclink: {doc.name} → {target} does not resolve")
    return findings


def cmd_selfcheck() -> None:
    """Prove the repo's own wholeness: the enforcer parses, every capability
    audits clean (zero drift), both audit branches have a living green example and
    fire on a deliberate break, every standing rule names an enforcement the
    manager actually has, and every doc link resolves. Exit 0 whole, 7 otherwise."""
    import ast as _ast
    findings: list[str] = []

    for f in (_REPO_ROOT / "bin" / "capabilities", _PREAMBLE):
        try:
            _ast.parse(f.read_text())
        except (OSError, SyntaxError) as e:
            findings.append(f"parse: {f.name}: {e}")

    canonical = _canonical_regions()
    for capdir in sorted(p for p in (_REPO_ROOT / "capabilities").iterdir() if p.is_dir()):
        script = capdir / "bin" / capdir.name
        if not script.is_file():
            continue
        for fail in _audit_script(capdir.name, script):
            findings.append(f"audit: {capdir.name}: {fail}")

    findings += _selfcheck_negatives(canonical)
    findings += _selfcheck_doctrine()
    findings += _selfcheck_doclinks()

    _emit({"ok": not findings, "checks": sorted(_AUDIT_CHECKS), "findings": findings})
    if findings:
        sys.exit(7)

# ---------------------------------------------------------------- authoring

def _manager_guide(topic: str) -> str:
    guides = {
        "authoring": f"""\
# Authoring a managed capability

Create a source with `capabilities source init <id> [--remote <git-url>]`.
Its one editable checkout always lives at `{SOURCE_WORKSPACE_ROOT}/<id>`; ask
the manager for the concrete path with `capabilities source path <id>`.

Create a package only with `capabilities new <name> --source <id>` (add
`--core-only` only when it genuinely has no connections). The manager writes
`capabilities/<name>/bin/<name>` and stamps the generated contract fences.
Replace every scaffold placeholder and implement domain declarations, doctor,
and the smallest useful verb surface outside those fences.

Acceptance is fixed: `capabilities source index <id>`, `capabilities source
check <id>`, then `capabilities install <name> --source <id>` for a local smoke
test. Indexing and installation both run the full audit. There is no
conformance override; free-form CLIs remain outside the manager.
""",
        "repositories": f"""\
# Capability source repositories

Editable source: `{SOURCE_WORKSPACE_ROOT}/<id>`. Remote read-only cache:
`{SOURCE_CACHE_ROOT}/<id>`. Installed payload: `{CAP_HOME}/<name>`. Project
configuration: `<project>/capabilities/<name>/`. Only the editable source is a
git authoring workspace. Never commit from the cache, registry, or project
envelope. `capabilities source path <id>` returns the exact editable path.

The manager owns `{SOURCES_FILE}`. Its shape is
`{{"sources": {{"<id>": {{"kind": "git", "url": "<git-url>", "ref":
"main"}}}}}}`; use `source init`, `source clone`, `source add`, and `source
remove` instead of editing it. `source list` is the supported inspection
surface. A source repository is recognized by `capabilities.repo.json`, its
vendored `contract/`, and generated `.capability-source/catalog.json`.
""",
        "publishing": """\
# Publishing a capability source

Before committing, run `capabilities source index <id>` and `capabilities source
check <id>`, then smoke-install changed packages with `capabilities install
<name> --source <id>`. Use ordinary git only from the path returned by
`capabilities source path <id>`: `git add .`, commit intentionally, and `git
push -u origin main`. The manager validates and records provenance; it does not
commit or push.

Consumers attach the published repository with `capabilities source add <id>
<git-url> [--ref <ref>]`, inspect it with `capabilities search --source <id>`,
and install explicitly with `capabilities install <name> --source <id>`.
Unqualified installs always mean the official catalogue, so custom sources
cannot shadow it.
""",
        "contract": """\
# Generated capability contract

`contract/preamble.py` is vendored by `source init`. `capabilities new` stamps
its fenced regions; agents never write them by hand. `capabilities source sync
<id>` deterministically updates the authoring kit and every existing generated region.
`source check` and installation reject missing or changed regions. No force or
skip flag exists.
""",
    }
    if topic not in guides:
        _die(3, "not_found", f"unknown manager guide {topic!r}",
             "topics: " + ", ".join(sorted(guides)))
    return guides[topic]


def _instructions_new() -> str:
    return f"""\
# Create a capability — agent procedure

The unit you are building is a managed source bundle under the canonical
workspace `{SOURCE_WORKSPACE_ROOT}/<source-id>/capabilities/<name>/`. Start with
`capabilities source init <source-id>`; its vendored SHEBANG.md and AUTHORING.md
are the source-local specification.

## 1. Discover, then gate honestly

Establish: the system to reach; the two or three operations that matter
(smallest useful surface); the auth shape (token, login session, OAuth,
none); where it will be used. Then gate:

- Ordered steps consuming existing tools → a routine, not a capability.
- Light instructions → a skill or prompt.
- One-off → no packaging at all.
- A system to reach + a small verb surface + credentials → a capability.

Say no plainly when it is not a capability.

## 2. Shape before code

- Surface: the smallest set of domain verbs; which of them mutate the remote
  system (WRITE_VERBS — the per-connection write gate refuses these), and
  what silence means (WRITE_DEFAULT — False when a write leaves the system:
  messages a human, sends mail, moves money).
- Credentials: keys, which are secret, and the scope — `project` (service /
  tenant tools, the default) or `user` (personal-account tools only).
- State: does it mint sessions or caches? Then `STATE = True` and state
  lands per the state-resolution rules, keyed per connection.
- I/O: JSON on stdout, the error envelope on stderr, the exit-code taxonomy.

## 3. Create, then edit only the owned surface

Run `capabilities new <name> --source <source-id>`. The manager creates the
bundle and stamps the credential cascade, gates, I/O helpers, and contract verbs
inside generated fences. Never copy or edit those regions manually. Edit the
declaration constants and domain implementation outside the fences: the smallest
useful verbs, a real doctor round-trip, resilient transport, and agent-first help.
No consumer identity is baked in — placeholders in examples, values from the
cascade.

## 4. Verify mechanically, then by judgment

- `capabilities source index <source-id>` to regenerate discovery metadata.
- `capabilities source check <source-id>` until the full repository passes.
- Smoke-test: `doctor` against the real service; one read verb; one write
  verb if any.
- Judgment pass: is each verb worth its place? Is the help written for an
  agent? Anything the tool answers that a doc restates?

## 5. Install

`capabilities install <name> --source <source-id>`, then `capabilities enable
<name>` in the consuming project. Installation reruns full audit in staging and
atomically activates the payload. Record deliberate domain-level departures in
the capability's own deviations file; the generated contract has no override.
"""


def _instructions_conform(ref: str) -> str:
    return f"""\
# Conform `{ref}` to the capability contract — agent procedure

Bring an existing script to the contract without changing what its domain
verbs do. The spec is SHEBANG.md in the capability repo — read it first.

## 1. Read the script; map the gap

Check for each, in this order:

- Declaration constants: NAME, SUMMARY, SCOPE, CRED_KEYS,
  WRITE_VERBS, WRITE_DEFAULT, DOCS_BASE, TOPICS, STATE, POST_INSTALL — one
  home each, top of script.
- `_project_root()` + `_gate()` called before any verb dispatch; exit 4 with
  the `disabled` envelope; fail-open on unreadable gate.
- Contract verbs: help, doctor, connections, stub, manifest --json, guide,
  ids (list/get/set/rm), refs. Render stub/manifest from the constants.
- Credential cascade in SHEBANG order; secrets have no flags; scripts never
  write credentials.env.
- Connections: `--connection <id>` on every domain verb, the registry
  (project capabilities/<name>/connections.json, else the user config
  home's) selected per SHEBANG order, the write gate (entry allow_write,
  else WRITE_DEFAULT; read-only → write verbs exit 4, nothing lifts it),
  `connections` reporting resolution with secrets masked, no network.
- State: minted sessions/caches move to the state dir (project scope:
  capabilities/<name>/state/ where the envelope exists, else
  $XDG_STATE_HOME/<name>/; user scope: $XDG_STATE_HOME/<name>/).
- I/O: `_emit`/`_die` envelope; exit-code taxonomy incl. 4; codes 7+ stated
  in help.
- Identity-free: no consumer names, tenants, or real values in code or help.

## 2. Edit

Make the changes; keep domain verbs byte-compatible (same args, same
output). A deliberate departure is recorded in the capability's own
deviations file, never silently.

## 3. Verify

- `capabilities audit {ref} --from <path>` until it passes.
- `<name> doctor` against the real service.
- Run one representative domain verb and compare output to the pre-edit
  behaviour.
"""


def _instructions_groom(name: str) -> str:
    installed = name in _installed()
    state = "installed" if installed else "NOT installed on this machine"
    return f"""\
# Groom `{name}` ({state}) — agent procedure

A periodic review of one capability: drift, dead weight, sharpening.

## 1. Mechanical pass

- `capabilities audit {name}` — fix what fails.
- `capabilities doctor` — registry/symlink/snapshot drift for this entry.
- `{name} doctor` — does it still prove identity against the live service?

## 2. Judgment pass

- Read the deviations file first; recorded deviations are deliberate.
- Help text: still the single source of truth? Anything stale, anything a
  doc restates that the tool answers?
- Verb surface: any verb unused in practice? Any common operation that
  needs two calls and deserves one?
- Guides: do declared topics still match upstream files? Anything learned
  repeatedly in sessions that belongs in a guide?
- Identifiers/references in consuming projects: still non-secret, still
  provenance-split (chosen → connections.json, discovered → identifiers.json)?
  Connections registries: no secret in an entry, default pointer names a real
  entry, read-only entries still correct?

## 3. Close

Apply fixes, update the capability's guides upstream if topics changed,
re-run `capabilities audit {name}`, and `capabilities update {name}` so
snapshots refresh.
"""


def _instructions_sanitize(name: str) -> str:
    installed = name in _installed()
    state = "installed" if installed else "NOT installed on this machine"
    return f"""\
# Sanitize `{name}`'s project envelope ({state}) — agent procedure

A content review of the `{name}` project envelope in the *current* consuming
project — semantics, placement, ambiguity. The scope split, in one line each:

- `capabilities audit {name}` — mechanical contract conformance of the script.
- `capabilities groom {name}` — periodic review of the installed capability
  (the machine side).
- `capabilities sanitize {name}` — the envelope-side content review (this
  procedure): every file the project holds under the `{name}` capability's
  envelope, judged as prose.

The manager judges nothing here; you do, inside the consuming project.

## 1. Inventory through the capability's own surface

Discover what to review by asking the tool — never by asserting paths:

- `{name} refs` — the reference envelope (name, description, path per file).
- `{name} ids list` — the identifiers the CLI has discovered here.
- `{name} connections` — the connections declared, with secrets masked.

An empty envelope is **conformant-empty**, not a finding. Do not invent
content to fill a slot; a project that has not accrued a reference yet has
no reference to review.

## 2. Walk the checks

For each file the inventory named, walk the list below. Each check names the
doctrine rule it enforces — read the rule at the source (`DOCTRINE.md`)
before deciding a finding stands.

1. **Name/description ↔ body** *(TEMPLATE.md's reference envelope).*  For
   every reference, the front-matter `description` is load-bearing — it is
   how an agent decides to load the body. A body that outgrew or shrank from
   its description is a finding; fix by tightening the description or
   splitting the body into siblings.

2. **The identifiers/reference split** *(rule 4, rule 11).*  Both directions:
   a structural lookup value (an id, code, label, classification) buried in
   reference prose belongs in `identifiers.json`; a treatment or usage
   narrative sitting in an identifiers note belongs in a reference. A
   reference holds the model, not the values; an identifier holds the
   value, not the narrative.

3. **Domain ownership and consumer identity** *(rule 9, rule 10).*  Facts in
   this envelope that belong to a **sibling capability's** envelope (source-
   vs consumer-side domain), to the **consuming project's own files** (its
   identity, restated), or to **no one** (dead or already-resolved notes).
   Each finding names the correct home.

4. **One fact, one home + affirmative framing** *(rule 1, rule 12).*
   Duplication or contradiction across the envelope's files; prose that
   defines by negation, by history ("formerly", "moved from"), or by a
   neighbour's behaviour ("unlike X"). Restate affirmatively; consolidate
   the duplicate to one home the others reference by role.

5. **Pointer direction** *(rule 7, rule 8).*  An asset that names its
   consumer (a routine, a workflow, a caller upstream) is a violation — the
   asset describes itself; consumers point down to it. Hard literal links
   between reference files across capability boundaries are a violation
   too — resolve through the capability's own `refs`/`ids` surface.

6. **Model vs procedure** *(rule 11).*  A step-by-step task recipe inside a
   reference belongs in the consuming project's routines; the reference
   keeps the model (mapping, treatment, taxonomy) the routine names by role.

7. **WIP hygiene.**  Resolved items, fix-it lists, and to-dos living in a
   reference belong on the consuming project's task system, not in the
   envelope. The reference is for the durable model, not the open queue.

## 3. Report, then fix on the project's terms

Emit findings as a list. For each: **the file**, **the quoted fragment**,
**the rule** it violates, and **the proposed move or fix**. Group by file
so the reader sees each home once.

Apply only what the consuming project's own norms allow — some fixes cross
into project files this envelope does not own (a routine, a task list, a
sibling capability's envelope); those are proposals for the project's
maintainer, not this procedure's edits.

## 4. Close

- Re-run `{name} refs` to confirm the envelope still parses.
- Refresh the generated context so the session sees the sharpened envelope:
  `capabilities context --claude` (or `--codex`, per host).
"""

# ---------------------------------------------------------------- main

def main() -> None:
    argv = sys.argv[1:]
    if not argv or argv[0] in ("help", "--help", "-h"):
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return
    cmd, rest = argv[0], argv[1:]

    def flag(name: str) -> bool:
        return name in rest

    def opt(name: str) -> str | None:
        if name in rest:
            i = rest.index(name)
            if i + 1 >= len(rest):
                _die(6, "input", f"{name} needs a value")
            return rest[i + 1]
        prefix = name + "="
        for value in rest:
            if value.startswith(prefix):
                return value.split("=", 1)[1]
        return None

    def positional() -> list[str]:
        out, skip = [], False
        for i, a in enumerate(rest):
            if skip:
                skip = False
                continue
            if a in ("--from", "--source", "--remote", "--ref"):
                skip = True
                continue
            if a.startswith("--"):
                continue
            out.append(a)
        return out

    pos = positional()

    if cmd == "install":
        if not pos:
            _die(6, "input", "install needs a capability name")
        cmd_install(pos[0], opt("--from"), opt("--source"), flag("--yes"))
    elif cmd == "uninstall":
        if not pos:
            _die(6, "input", "uninstall needs a capability name")
        cmd_uninstall(pos[0], flag("--purge-credentials"))
    elif cmd == "update":
        cmd_update(pos[0] if pos else None)
    elif cmd == "self-update":
        cmd_self_update()
    elif cmd == "list":
        cmd_list()
    elif cmd == "search":
        cmd_search(pos[0] if pos else None, opt("--source"))
    elif cmd == "source":
        if not pos:
            _die(6, "input", "source needs a subcommand")
        sub = pos[0]
        if sub == "init":
            if len(pos) < 2:
                _die(6, "input", "source init needs an id")
            cmd_source_init(pos[1], opt("--remote"))
        elif sub == "add":
            if len(pos) < 3:
                _die(6, "input", "source add needs an id and git URL")
            cmd_source_add(pos[1], pos[2], opt("--ref") or "main")
        elif sub == "clone":
            if len(pos) < 3:
                _die(6, "input", "source clone needs an id and git URL")
            cmd_source_clone(pos[1], pos[2], opt("--ref") or "main")
        elif sub == "list":
            cmd_source_list()
        elif sub == "path":
            if len(pos) < 2:
                _die(6, "input", "source path needs an id")
            cmd_source_path(pos[1])
        elif sub == "refresh":
            cmd_source_refresh(pos[1] if len(pos) > 1 else None)
        elif sub == "sync":
            if len(pos) < 2:
                _die(6, "input", "source sync needs an id")
            cmd_source_sync(pos[1])
        elif sub == "check":
            if len(pos) < 2:
                _die(6, "input", "source check needs an id")
            cmd_source_check(pos[1])
        elif sub == "index":
            if len(pos) < 2:
                _die(6, "input", "source index needs an id")
            cmd_source_index(pos[1])
        elif sub == "remove":
            if len(pos) < 2:
                _die(6, "input", "source remove needs an id")
            cmd_source_remove(pos[1])
        else:
            _die(6, "input", f"unknown source subcommand: {sub}")
    elif cmd == "enable":
        if not pos:
            _die(6, "input", "enable needs a capability name")
        _set_gate(pos[0], True)
    elif cmd == "disable":
        if not pos:
            _die(6, "input", "disable needs a capability name")
        _set_gate(pos[0], False, deny=flag("--deny"))
    elif cmd == "init":
        cmd_init(flag("--claude"), flag("--codex"))
    elif cmd == "context":
        modes = [name for name in ("--claude", "--codex", "--fragment") if flag(name)]
        if len(modes) > 1:
            _die(6, "input", "context accepts exactly one of --claude, --codex, or --fragment")
        if flag("--fragment"):
            cmd_context("fragment")
        elif flag("--claude"):
            cmd_context("claude")
        elif flag("--codex"):
            cmd_context("codex")
        else:
            _die(6, "input", "context needs --claude, --codex, or --fragment")
    elif cmd == "ids":
        if not pos:
            _die(6, "input", "ids needs a capability name")
        cmd_ids(pos[0])
    elif cmd == "doctor":
        cmd_doctor()
    elif cmd == "audit":
        if not pos:
            _die(6, "input", "audit needs a capability name")
        cmd_audit(pos[0], opt("--from"))
    elif cmd == "sync-contract":
        cmd_sync_contract(check_only=flag("--check"))
    elif cmd == "selfcheck":
        cmd_selfcheck()
    elif cmd == "new":
        if not pos:
            _emit(_instructions_new())
        else:
            source_id = opt("--source")
            if not source_id:
                _die(6, "input", "new <name> needs --source ID",
                     "create a canonical workspace with `capabilities source init <id>`")
            cmd_new_capability(pos[0], source_id, flag("--core-only"))
    elif cmd == "guide":
        if not pos:
            _die(6, "input", "guide needs a topic: authoring, repositories, publishing, or contract")
        _emit(_manager_guide(pos[0]))
    elif cmd == "conform":
        if not pos:
            _die(6, "input", "conform needs a capability name or path")
        _emit(_instructions_conform(pos[0]))
    elif cmd == "groom":
        if not pos:
            _die(6, "input", "groom needs a capability name")
        _emit(_instructions_groom(pos[0]))
    elif cmd == "sanitize":
        if not pos:
            _die(6, "input", "sanitize needs a capability name")
        _emit(_instructions_sanitize(pos[0]))
    else:
        _die(6, "input", f"unknown command: {cmd}", "run `capabilities help`")


if __name__ == "__main__":
    main()
