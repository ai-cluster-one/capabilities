_CACHE_HOME = Path(os.environ.get("XDG_CACHE_HOME") or (Path.home() / ".cache"))
SOURCE_WORKSPACE_ROOT = Path.home() / "capabilities-sources"
SOURCES_FILE = _CONFIG_HOME / "capabilities" / "sources.json"
SOURCE_CACHE_ROOT = _CACHE_HOME / "capabilities" / "sources"
OFFICIAL_SOURCE_ID = "official"
