# directo — credentials (copy to $XDG_CONFIG_HOME/directo/credentials.env,
# default ~/.config/directo/credentials.env, and fill). This is the tier-3
# (user config) source in the 4-tier cascade:
#   flags > project .env(.local) > THIS user config > process env.
# A consuming project can override per-project by setting these in its own .env.
# PUBLIC REPO: never commit real values. Leave blank here; fill only the copy.

DIRECTO_USERNAME=
DIRECTO_PASSWORD=
DIRECTO_DB=
# DIRECTO_KOHT is the active location — a per-session choice; `directo login` writes it back.
DIRECTO_KOHT=
# DIRECTO_COOKIE is the live session — `directo login` writes it back. Never commit a value.
DIRECTO_COOKIE=
