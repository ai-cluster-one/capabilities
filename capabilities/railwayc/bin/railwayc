#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""railwayc — a credential harness around the official `railway` CLI. It resolves a
PROJECT-SCOPED Railway token, injects it, and forwards your command verbatim to
`railway`. railwayc owns auth and readiness; the command surface stays railway's own.

USAGE
  railwayc <command> [args...]   Forward to `railway <command> [args...]`, authenticated
                                 with the resolved project token.
  railwayc doctor                Prove the token resolves and report the project.
  railwayc help                  Print this contract.

Contract commands (the same on every capability; railwayc's own, never forwarded):
  railwayc stub                                 One-line awareness text.
  railwayc manifest --json                      Machine-readable declaration.
  railwayc guide [<topic>]                      Guide topics / one guide body.
  railwayc ids list|get <l>|set <l> <v>|rm <l>  The project identifiers envelope
           [--note <text>]                      (.capabilities/railwayc/identifiers.json).
  railwayc refs                                 Menu of the project's reference files.

Agent-invoked. Run `railwayc help` to reload this contract; run `railway help` (the
real CLI) for the full command surface — railwayc does NOT re-document or re-map it.

MODEL
  railwayc is not a wrapper around railway's command surface — it never maps, renames,
  or enumerates railway commands. It is a thin auth shim: it puts a project token in
  front of `railway` and execs it. `railwayc logs -s web` runs `railway logs -s web`
  with RAILWAY_TOKEN set; stdout, stderr, and the exit code are railway's, passed
  through untouched, so streaming, --json, and colors behave exactly as in railway
  itself. Only `help`, `doctor`, and the contract commands are railwayc's own; every
  other word forwards (`railwayc help <cmd>` forwards too, so railway's own help
  stays reachable).

  It REQUIRES a project token and never falls back to interactive login or this
  machine's account session — that refusal is the point: access stays scoped to the
  one Railway project + environment the token was minted for, never the whole account.

CREDENTIALS
  RAILWAY_TOKEN — a Railway PROJECT token (project → Settings → Tokens), scoped to ONE
  project and ONE environment. Because it is project-scoped, its home is the CONSUMING
  PROJECT's .env, not a global file. Resolved (first non-empty wins):
    1. project env   .env.local then .env, walking up from $CLAUDE_PROJECT_DIR (else cwd)
    2. process env   RAILWAY_TOKEN (deployed box, or one-shot `RAILWAY_TOKEN=… railwayc …`)
  There is deliberately no token flag (a secret must not touch argv) and no user-config
  tier (a global token would mis-scope every project). One token = one project + one
  environment; a project with prod + staging uses one token per environment.

  Optional, non-secret — RAILWAYC_EXPECT_PROJECT (project .env): if set, `doctor`
  asserts the token resolves to that project (by name or id) and exits 7 on mismatch.
  The safety net against pasting the wrong project's token into a project's .env.

COMMANDS railwayc owns
  doctor
      Resolve RAILWAY_TOKEN and run `railway status --json` with it injected. On
      success emits {ok, project:{id,name}, workspace, environments:[…], services:[…]}.
      Exit 0 healthy / 2 token missing or rejected / 5 railway not installed or
      unreachable / 7 token resolved to a project other than RAILWAYC_EXPECT_PROJECT.
      Use this for health — `railway whoami` does NOT work under a project token.

  help
      Print this document. (`railway help` is the real CLI's surface, a separate
      thing; railwayc reserves a bare `help` for itself but forwards `help <cmd>`.)

EVERYTHING ELSE — forwarded verbatim to `railway`, token injected, I/O transparent.
  Run `railway <cmd> --help` for each; railwayc adds nothing to them. Common reaches:
    status [--json]                  project + services + deployment state
    logs [-s SVC] [-e ENV] [--json]  deploy / build logs
    variables [-s SVC] [--json]      read service variables
    variables --set "K=V" [-s SVC]   set a variable (triggers a deploy)
    redeploy [-s SVC]  /  restart    redeploy / restart the latest deployment
    up [-c]  /  down                 deploy from cwd / remove the latest deploy
    domain                           add / generate / list domains
    run -- <cmd>                     run a local command with the environment's vars

EXIT CODES (railwayc's own layer)
  0 success · 2 auth (RAILWAY_TOKEN missing or rejected) · 4 disabled by project
  policy (.capabilities/settings.json — ask the user) · 5 environment (railway not
  on PATH, or unreachable) · 6 input (bad use of a railwayc-owned command) · 7 wrong
  project (doctor: token ≠ RAILWAYC_EXPECT_PROJECT).
  Forwarded commands return RAILWAY's own exit code, not these — railwayc is
  transparent for everything it forwards.

EXAMPLES
  railwayc doctor
  railwayc status --json
  railwayc logs -s web --json
  railwayc variables -s web --json
  railwayc variables --set "FEATURE_X=1" -s web
  railwayc redeploy -s web
  RAILWAY_TOKEN=… railwayc status        # one-shot, run from outside a project .env
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import NoReturn

# --- Capability declaration (protocol 1) — one home for every contract fact --

NAME = "railwayc"
PROTOCOL = 1
SUMMARY = ("Credential harness around the official `railway` CLI — resolves "
           "a project-scoped Railway token, injects it, and forwards your "
           "command straight to `railway` (everything but railwayc's own "
           "verbs passes through untouched); the command surface is "
           "`railway help`.")
SCOPE = "project"   # credential scope: "project" | "user"
CRED_KEYS = [
    {"key": "RAILWAY_TOKEN", "secret": True, "required": True,
     "note": "project-scoped token; lives in the consuming project's .env"},
    {"key": "RAILWAYC_EXPECT_PROJECT", "secret": False, "required": False,
     "note": "doctor asserts the token resolves to this project (name or id)"},
]
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "railwayc" / "credentials.env"  # contract verbs only;
# the token itself has no user-config tier (see deviations.md)
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

TOKEN_NAME = "RAILWAY_TOKEN"
EXPECT_PROJECT = "RAILWAYC_EXPECT_PROJECT"
DOCTOR_TIMEOUT = 60.0


# ── output helpers ──────────────────────────────────────────────────────────

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value if value.endswith("\n") else value + "\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# ── credentials (project .env(.local) → process env) ────────────────────────
# A project-scoped token has no global home: the flag tier (a secret on argv) and
# the user-config tier (one token leaking onto every project) are both dropped.
# The cascade order is preserved — project files win over process env.

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _resolve(key: str) -> str | None:
    return _project_env().get(key) or os.environ.get(key) or None


# --- Capability contract (protocol 1) — shared verbatim across capabilities --

def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks."""
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _project_settings() -> dict:
    """Capability-owned, non-secret project config: .capabilities/<NAME>/settings.json."""
    envdir = _env_dir()
    if envdir is None:
        return {}
    try:
        return json.loads((envdir / "settings.json").read_text())
    except (OSError, ValueError):
        return {}


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import httpx as _hx
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        resp = _hx.get(url, headers=headers, timeout=10.0, follow_redirects=True)
        if resp.status_code == 200:
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(resp.text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(resp.text); return
        if resp.status_code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if resp.status_code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        raise _hx.HTTPError(f"upstream returned {resp.status_code}")
    except _hx.HTTPError as e:
        if cache.exists():
            sys.stderr.write(json.dumps(
                {"warning": f"upstream unreachable; serving cached copy ({e})"},
                ensure_ascii=False) + "\n")
            _emit(cache.read_text()); return
        _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    out = []
    if envdir and envdir.is_dir():
        for md in sorted(envdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    else:
        return
    sys.exit(0)


# ── railway invocation ──────────────────────────────────────────────────────

def _child_env(token: str) -> dict:
    env = dict(os.environ)
    env[TOKEN_NAME] = token
    # railway errors if both token vars are set; the project token is authoritative here.
    env.pop("RAILWAY_API_TOKEN", None)
    return env


def _capture(argv: list[str], token: str) -> subprocess.CompletedProcess:
    try:
        return subprocess.run(["railway", *argv], env=_child_env(token),
                              capture_output=True, text=True, timeout=DOCTOR_TIMEOUT)
    except subprocess.TimeoutExpired:
        _die(5, "timeout", "railway was unresponsive", "check connectivity to railway.com")
    except OSError as e:
        _die(5, "railway_exec_failed", f"could not run railway: {e}")


def _edges(obj) -> list:
    return obj.get("edges") or [] if isinstance(obj, dict) else []


def cmd_doctor(token: str) -> dict:
    proc = _capture(["status", "--json"], token)
    if proc.returncode != 0:
        err = (proc.stderr or proc.stdout or "").strip()
        low = err.lower()
        if any(s in low for s in ("token", "unauthor", "not found", "log in", "login")):
            _die(2, "token_rejected", err or "railway rejected the token",
                 "RAILWAY_TOKEN is invalid, revoked, or for a deleted project/environment")
        _die(5, "railway_error", err or "`railway status` failed")
    try:
        st = json.loads(proc.stdout)
    except ValueError:
        return {"ok": True, "note": "status returned non-JSON", "raw": proc.stdout[:500]}

    project = {"id": st.get("id"), "name": st.get("name")}
    result = {
        "ok": True,
        "project": project,
        "workspace": (st.get("workspace") or {}).get("name"),
        "environments": [e["node"]["name"] for e in _edges(st.get("environments"))
                         if e.get("node") and e["node"].get("name")],
        "services": [e["node"]["name"] for e in _edges(st.get("services"))
                     if e.get("node") and e["node"].get("name")],
    }
    expect = _resolve(EXPECT_PROJECT)
    if expect:
        if expect not in (project.get("name"), project.get("id")):
            _die(7, "wrong_project",
                 f"token resolves to {project.get('name')!r} ({project.get('id')}), "
                 f"expected {expect!r}",
                 f"the {TOKEN_NAME} in this project points at the wrong Railway project; "
                 f"check the token and {EXPECT_PROJECT}")
        result["expected"] = expect
    return result


def _forward(argv: list[str], token: str) -> NoReturn:
    # Inherit stdio so streaming, prompts, --json, and colors pass straight through;
    # railway's own exit code is the result.
    try:
        proc = subprocess.run(["railway", *argv], env=_child_env(token))
    except OSError as e:
        _die(5, "railway_exec_failed", f"could not run railway: {e}")
    sys.exit(proc.returncode)


# ── dispatch ────────────────────────────────────────────────────────────────

def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; everything else forwards
    argv = sys.argv[1:]
    if not argv or (len(argv) == 1 and argv[0] in ("help", "-h", "--help")):
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return

    if not shutil.which("railway"):
        _die(5, "railway_not_found", "the `railway` CLI is not on PATH",
             "install it: `brew install railway` or `npm i -g @railway/cli` "
             "(https://docs.railway.com/cli)")

    token = _resolve(TOKEN_NAME)
    if not token:
        _die(2, "missing_credentials",
             f"{TOKEN_NAME} is required (a project-scoped Railway token)",
             f"set {TOKEN_NAME} in this project's .env(.local) or export it; "
             f"create one in Railway → your project → Settings → Tokens")

    if argv[0] == "doctor":
        _emit(cmd_doctor(token))
        return

    _forward(argv, token)


if __name__ == "__main__":
    main()
