#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""
askproject — ask a coding agent running in ANOTHER project to answer in its own
context, then return its answer plus traceability to the caller.

This tool is designed to be invoked BY an agent (you), from inside your own
project. It spawns a headless peer agent in a target project's directory, so
that peer loads the target's project context (Claude reads CLAUDE.md, Codex
reads AGENTS.md) / settings / rights and answers as that project — then hands
back the answer with cost, token, and files-changed data.

Two engines drive the peer, selected with `--engine`:
  claude (default)  headless `claude -p`; mode picks the model (haiku/sonnet).
  codex             headless `codex exec`; uses your ~/.codex/config.toml model
                    (the newest) unless you pass --model. No USD cost is
                    reported under ChatGPT auth, so cost_usd stays null.

Run `askproject help` to (re)load this contract on demand — do not rely on
memorised knowledge of its surface.

────────────────────────────────────────────────────────────────────────────
COMMANDS
  askproject <target> "<question>"        Ask the peer (read-only research).
  askproject <target> --act "<task>"      Let the peer modify its own project.
  askproject <target> -c "<follow-up>"    Continue the last conversation with
                                          that target (resumes its session).
  askproject targets                       List targets you've talked to (this
                                          project) + their last session.
  askproject help                          Print this document.

<target> is a path to the other project: absolute, ~-expanded, or relative to
your cwd. YOU decide which project to talk to and pass its path. It must be a
directory (a git repo is strongly recommended — see snapshots below).

────────────────────────────────────────────────────────────────────────────
MODES  (the fence; how each engine implements it differs)
  read  (default)   Pure research. claude: ONLY Read/Glob/Grep + plan mode.
                    codex: an OS read-only sandbox (sandbox_mode=read-only) —
                    it may run read-only shell but cannot write. Model on
                    claude: haiku (cheap). Use for "what does X do", reviews.
  act   (--act)     Peer can edit, run tests, commit, and push from inside the
                    target project without prompts. claude: bypassPermissions +
                    target as --add-dir. codex: bypass approvals + sandbox.
                    Model on claude: sonnet. Use for "fix X", "refactor".

MODELS: on claude the mode auto-picks the model (override with --model); on
codex no model is forced — it uses your ~/.codex/config.toml default (the
newest) unless --model is given.

FENCING REALITY: read mode is a hard fence (claude has no harmful tools; codex
runs in an OS read-only sandbox). act mode intentionally drops the peer's
prompts so it can complete build work end-to-end. The prompt and the git
snapshot (below) are your safety net.

────────────────────────────────────────────────────────────────────────────
SESSION CONTINUITY  (state is LOCAL to the project you call from)
  The map of "which target → which session" is written to:
      <your-project-root>/.claude/askproject/sessions.json
  (your-project-root = nearest ancestor with .git or .claude; else cwd.)
  This is a config of YOUR project, not of the tool — it travels with the repo
  that initiates the calls. It is git-ignored automatically (session ids are
  machine-local). `-c/--continue` resumes the last session for that target;
  add --fork to branch instead of continue.

  Scope a session to ONE unit of work — resume with -c only while on that
  same item; start a fresh call for a new one; use --fork to branch off an
  existing thread without polluting it. Sessions that span unrelated tasks
  just carry dead context and grow costly — short, task-scoped is optimal.

────────────────────────────────────────────────────────────────────────────
OUTPUT  (stdout = one JSON object; use --text to get just the answer)
  {
    "ok": bool, "error": str|null,
    "target": "<abs path>", "engine": "claude|codex", "mode": "read|act",
    "model": "<model id>|null", "session_id": "<uuid>", "resumed": bool,
    "answer": <string OR parsed object when --schema is used>,
    "cost_usd": float, "duration_ms": int, "num_turns": int,
    "tokens": {input, output, cache_read, cache_creation},
    "git": {"repo": bool, "head_before","head_after","dirty_before",
            "files_changed":[{"path","status"}]},
    "permission_denials": [ ... attempts the peer made and was blocked on ... ]
  }
  In read mode files_changed must be empty; if it isn't, ok=false and it is
  flagged loudly (a read query should never mutate).

  While the peer runs, concise stage updates are streamed to stderr. They are
  derived from the engines' native event streams and intentionally omit full
  commands, command output, reasoning, and the final answer. This keeps stdout
  machine-parseable while letting an invoking agent see that work is moving.
  Pass --quiet to suppress these updates for callers that require silent stderr.

FLAGS
  --engine <claude|codex>  Which peer engine to spawn (default: claude, or
                        $ASKPROJECT_ENGINE). A -c resume adopts the session's
                        own engine — a codex thread can't be resumed by claude.
  --act                 Modification mode (bypass prompts; sonnet on claude).
  -c, --continue        Resume the last session for this target.
  --fork                Reserved; neither headless CLI has a non-interactive
                        fork, so this exits with a controlled error.
  --model <m>           Override the model. On claude the `haiku`/`sonnet`/
                        `opus` aliases resolve to known-good full ids; on codex
                        the value is passed straight to `codex -m`.
  --schema <file|json>  Pass a JSON Schema to constrain the peer's answer;
                        `answer` is then the parsed object.
  --timeout <seconds>   Kill the peer after N seconds (default 600).
  --text                Print only the answer to stdout (still exits non-zero
                        on error).
  --quiet               Suppress the concise progress stream on stderr.
  --append <text>       Extra instruction appended to the peer's system prompt.

EXAMPLES
  askproject ../shop "Which file defines the pricing taxonomy?"
  askproject ~/dev/api --act "Add a --json flag to the export command"
  askproject ../shop -c "And where is it consumed?"
  askproject ../shop --engine codex "Trace the checkout flow end to end"

────────────────────────────────────────────────────────────────────────────
CONTRACT  (self-description an agent loads on demand; this capability has NO
           connections — it drives the local `claude`/`codex` CLI, no creds)
  askproject doctor        Readiness — reports which engine CLIs are on PATH.
  askproject stub          One-line awareness text.
  askproject manifest      Machine-readable declaration (JSON).
  askproject guide [topic] How-to guides — `capability-changes`.
  askproject ids …         Project identifier store (list/get/set/rm).
  askproject refs          Project references menu.
  askproject connections   Connections report — empty; this capability has none.
"""

import argparse
import json
import os
import queue
import shutil
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import NoReturn

# --- Capability declaration (protocol 2) — one home for every contract fact --

NAME = "askproject"
PROTOCOL = 2
SUMMARY = ("Bridge to a coding agent in ANOTHER project — spawn a headless peer "
           "(claude or codex) in a target project, fenced by mode (read/act), and "
           "return its answer with cost, token, and files-changed traceability.")
SCOPE = "user"      # credential scope: "project" | "user"
CRED_KEYS: list = []   # no credentials — it drives the local `claude` CLI on PATH
DOCS_BASE = ("https://raw.githubusercontent.com/ai-cluster-one/capabilities/"
             "main/capabilities/askproject/guides/")
TOPICS = ["capability-changes"]   # shipped guide topics
STATE = False       # the session map lives in the CALLING project's .claude/askproject/
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "askproject" / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

ENGINES = ("claude", "codex")
DEFAULT_ENGINE = "claude"

# claude: the mode auto-picks the model; these aliases resolve to full ids.
# codex: no model is forced — it falls back to ~/.codex/config.toml (the newest).
READ_MODEL = "claude-haiku-4-5-20251001"
ACT_MODEL = "claude-sonnet-4-5-20250929"
MODEL_ALIASES = {
    "haiku": READ_MODEL,
    "sonnet": ACT_MODEL,
    "opus": "claude-opus-4-5-20251101",
}

# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding capabilities/, legacy .capabilities/,
    .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / "capabilities" / "settings.json").is_file()
                or (d / ".capabilities").is_dir()
                or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_capabilities_dir(root: Path) -> Path:
    """The active project envelope root.

    `capabilities/` is canonical. A legacy `.capabilities/` remains readable
    until `capabilities init` migrates it. If both exist, the canonical tree
    wins once it carries settings.json; otherwise the legacy configured tree
    remains active so merely creating an empty visible directory loses no gate.
    """
    current = root / "capabilities"
    legacy = root / ".capabilities"
    if (current / "settings.json").is_file() or not legacy.is_dir():
        return current
    return legacy


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _auth_context() -> dict | None:
    """Optional runtime authority envelope passed by an ingress/service.

    Absence means the ordinary project gate is the whole policy. Presence means
    a request-scoped authority layer exists and must fail closed before any
    credential or network work happens.
    """
    raw = os.environ.get("CAPABILITIES_AUTH_CONTEXT")
    if not raw:
        return None
    try:
        if raw.lstrip().startswith("{"):
            data = json.loads(raw)
        else:
            data = json.loads(Path(raw).read_text())
    except (OSError, ValueError) as e:
        _die(4, "auth_context_unreadable",
             "runtime authority context could not be read",
             f"{raw}: {e}")
    if not isinstance(data, dict):
        _die(4, "auth_context_invalid",
             "runtime authority context is not an object")
    return data


def _auth_capability_allowed(rule) -> bool:
    if rule is True or rule == "*":
        return True
    if rule in (False, None):
        return False
    if isinstance(rule, dict):
        if rule.get("deny") is True:
            return False
        if rule.get("enabled") is False or rule.get("allow") is False:
            return False
        return True
    return False


def _auth_gate() -> None:
    ctx = _auth_context()
    if ctx is None:
        return
    allowed = ctx.get("allowed_capabilities")
    if allowed is None:
        return
    if allowed is True or allowed == "*":
        return
    if isinstance(allowed, list):
        if NAME in allowed or "*" in allowed:
            return
    elif isinstance(allowed, dict):
        if _auth_capability_allowed(allowed.get(NAME, allowed.get("*"))):
            return
    else:
        _die(4, "auth_context_invalid",
             "runtime authority context has invalid allowed_capabilities")
    source = ctx.get("source") or "runtime"
    role = ctx.get("sender_role") or ctx.get("role") or "unknown"
    chat = ctx.get("chat_id") or "unknown"
    _die(4, "capability_not_authorized",
         f"{NAME} is not authorized for this {source} request",
         f"role={role}; chat_id={chat}; adjust runtime authority policy instead of bypassing the gate")


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks.

    If an ingress supplied CAPABILITIES_AUTH_CONTEXT, that request-scoped gate
    is stricter and also runs here, before credentials or network calls.
    """
    _auth_gate()
    root = _project_root()
    if root is None:
        return
    gate_file = _project_capabilities_dir(root) / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project's active capabilities/."""
    root = _project_root()
    return (_project_capabilities_dir(root) / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None:
            envelope = _project_capabilities_dir(root)
            if (envelope / "settings.json").is_file():
                return envelope / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import urllib.error as _ue
    import urllib.request as _ur
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        req = _ur.Request(url, headers=headers)
        with _ur.urlopen(req, timeout=10.0) as resp:
            text = resp.read().decode(resp.headers.get_content_charset() or "utf-8")
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(text); return
    except _ue.HTTPError as e:
        if e.code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if e.code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        err = f"upstream returned {e.code}"
    except _ue.URLError as e:
        err = str(e.reason)
    except OSError as e:
        err = str(e)
    if cache.exists():
        sys.stderr.write(json.dumps(
            {"warning": f"upstream unreachable; serving cached copy ({err})"},
            ensure_ascii=False) + "\n")
        _emit(cache.read_text()); return
    _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _render_ids_markdown(data: dict) -> str:
    """Render the {label: {value, note}} envelope as the labelled markdown
    list the manager's `capabilities ids <NAME>` also produces — one shared
    format across the ids surface and the identifiers section of `help`."""
    lines: list[str] = []
    for label, entry in sorted(data.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        v = entry.get("value")
        vs = f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"
        line = f"- **{label}**: {vs}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    return "\n".join(lines)


def _identifiers_section() -> str:
    """The Identifiers block appended to the bare top-level help — deterministic
    first-touch surfacing of `capabilities/<NAME>/identifiers.json` so an
    agent following the `<NAME> help` startup protocol loads the discovered
    labels/values/notes into context at once. Empty when no project envelope
    or nothing recorded (do not bloat help with an empty section)."""
    envdir = _env_dir()
    if envdir is None:
        return ""
    ids_file = envdir / "identifiers.json"
    if not ids_file.exists():
        return ""
    try:
        data = json.loads(ids_file.read_text())
    except (OSError, ValueError):
        return ""
    if not isinstance(data, dict) or not data:
        return ""
    header = (
        "\n═══ Identifiers ═════════════════════════════════════════════════════════════\n\n"
        f"Structural lookups discovered for `{NAME}` in this project. Fetch a single\n"
        f"raw value with `{NAME} ids get <label>`; the full envelope is also at\n"
        f"`capabilities ids {NAME}`.\n\n"
    )
    return header + _render_ids_markdown(data) + "\n"


def _cmd_help() -> None:
    """Bare top-level help: the CLI's HELP body (module-level `HELP` if
    defined, else the module docstring), then the project's Identifiers
    section. Only fires when no extra args follow — per-verb help stays
    untouched so `<NAME> help <subcommand>` is not intercepted."""
    g = globals()
    text = g.get("HELP") or g.get("__doc__") or ""
    if text.startswith("\n"):
        text = text.lstrip("\n")
    sys.stdout.write(text)
    if text and not text.endswith("\n"):
        sys.stdout.write("\n")
    section = _identifiers_section()
    if section:
        sys.stdout.write(section)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not (envdir.parent / "settings.json").is_file():
            _die(6, "no_envelope", "no capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved.

    `help` is a contract verb only when bare (no extra args) — the top-level
    dump plus the Identifiers section. `<NAME> help <subcommand>` falls
    through to the CLI so per-verb help stays clean."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    elif cmd == "help" and len(argv) == 1:
        _cmd_help()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


def _cmd_connections() -> None:
    """Core-only capability: askproject drives the local `claude` CLI and has no
    configured connection, so the connections report is empty by contract."""
    _emit({"connections": {}, "default": None})


def die(msg: str, *, as_json: bool, code: int = 1):
    if as_json:
        print(json.dumps({"ok": False, "error": msg}, indent=2))
    else:
        print(f"askproject: {msg}", file=sys.stderr)
    sys.exit(code)


def find_project_root(start: Path) -> Path:
    """Nearest ancestor (incl. start) containing .git or .claude; else start."""
    start = start.resolve()
    for d in [start, *start.parents]:
        if (d / ".git").exists() or (d / ".claude").exists():
            return d
    return start


def state_path() -> Path:
    root = find_project_root(Path.cwd())
    d = root / ".claude" / "askproject"
    d.mkdir(parents=True, exist_ok=True)
    gi = d / ".gitignore"
    if not gi.exists():
        gi.write_text("# session ids are machine-local\nsessions.json\n")
    return d / "sessions.json"


def load_state() -> dict:
    p = state_path()
    if p.exists():
        try:
            return json.loads(p.read_text())
        except json.JSONDecodeError:
            return {}
    return {}


def save_state(state: dict):
    state_path().write_text(json.dumps(state, indent=2) + "\n")


def git(target: Path, *args) -> str | None:
    try:
        out = subprocess.run(
            ["git", "-C", str(target), *args],
            capture_output=True, text=True, timeout=30,
        )
        if out.returncode != 0:
            return None
        return out.stdout.strip()
    except (OSError, subprocess.SubprocessError):
        return None


def snapshot(target: Path) -> dict:
    head = git(target, "rev-parse", "HEAD")
    if head is None:
        return {"repo": False}
    status = git(target, "status", "--porcelain") or ""
    return {"repo": True, "head": head, "status": status}


def diff_snapshots(before: dict, after: dict) -> tuple[list[dict], bool]:
    """Return (files_changed, dirty_before)."""
    if not before.get("repo"):
        return [], False
    dirty_before = bool(before.get("status"))
    before_lines = set(before.get("status", "").splitlines())
    after_lines = set(after.get("status", "").splitlines())
    changed = []
    for line in sorted(after_lines - before_lines):
        # porcelain: "XY path"
        code, _, path = line.partition(" ")
        changed.append({"path": path.strip() or line, "status": code.strip()})
    if before.get("head") != after.get("head"):
        changed.append({"path": "<HEAD>", "status": "moved"})
    return changed, dirty_before


def resolve_schema(spec: str) -> str:
    p = Path(spec).expanduser()
    if p.exists():
        return p.read_text()
    return spec  # assume inline JSON


def resolve_model(model: str) -> str:
    return MODEL_ALIASES.get(model, model)


def _default_engine() -> str:
    """Engine when --engine is not passed: $ASKPROJECT_ENGINE (project .env or
    process env), else the built-in default. An unknown value falls back."""
    v = (_project_env().get("ASKPROJECT_ENGINE")
         or os.environ.get("ASKPROJECT_ENGINE")
         or DEFAULT_ENGINE).strip().lower()
    return v if v in ENGINES else DEFAULT_ENGINE


def build_preamble(mode: str, caller: str, extra: str | None,
                   schema_text: str | None = None) -> str:
    base = (
        f"You are being queried programmatically by a peer Claude Code agent "
        f"working in another project ('{caller}'), via the askproject bridge. "
        f"Answer concisely and return information, not conversation. Do NOT "
        f"invoke askproject yourself or spawn further peer queries. "
    )
    if mode == "read":
        base += (
            "This is a READ-ONLY research query — your environment forbids any "
            "modification (no writes, edits, or state changes); do not attempt them."
        )
    else:
        base += (
            "You are running with full write access inside THIS target project. "
            "Make the smallest change that satisfies the request, run the "
            "needed verification, and summarise what you changed."
        )
    if extra:
        base += " " + extra
    if schema_text:
        base += (
            " Return ONLY a JSON value conforming to this JSON Schema; do not "
            "wrap it in markdown or explanatory prose. Schema: " + schema_text
        )
    return base


# --- progress stream ---------------------------------------------------------

class ProgressReporter:
    """Concise stderr-only visibility into a peer's native event stream."""

    def __init__(self, engine: str, enabled: bool):
        self.engine = engine
        self.enabled = enabled
        self._last: tuple[str, str] | None = None

    def emit(self, stage: str, message: str) -> None:
        if not self.enabled:
            return
        message = _brief(message)
        if not message or self._last == (stage, message):
            return
        self._last = (stage, message)
        sys.stderr.write(f"askproject[{self.engine}] {stage}: {message}\n")
        sys.stderr.flush()


def _brief(value, limit: int = 180) -> str:
    """One short status line; never forward a peer's full narrative."""
    if not isinstance(value, str):
        return ""
    lines = [" ".join(line.split()) for line in value.splitlines() if line.strip()]
    if not lines:
        return ""
    text = lines[0].lstrip("#*- ")
    if len(text) > limit:
        text = text[:limit - 1].rstrip() + "…"
    return text


def _command_stage(command) -> tuple[str, str]:
    """Classify a command without exposing its argv or output."""
    text = command if isinstance(command, str) else ""
    lower = f" {text.lower()} "
    if any(marker in lower for marker in (
            "pytest", "unittest", "npm test", "pnpm test", "yarn test",
            "cargo test", "go test", "rspec", "vitest", "jest")):
        return "verify", "Running tests"
    if any(marker in lower for marker in (
            " lint", " typecheck", " type-check", " mypy", " pyright",
            " ruff", " eslint", " tsc", " build", " audit")):
        return "verify", "Running verification"
    if any(marker in lower for marker in (
            " apply_patch", " sed -i", " perl -pi", " tee ")):
        return "edit", "Updating project files"
    if any(marker in lower for marker in (
            " rg ", " grep ", " find ", " ls ", " sed -n", " git status",
            " git diff", " git log", " cat ", " head ", " tail ")):
        return "inspect", "Inspecting the project"
    return "work", "Running a project command"


def _tool_stage(name, tool_input=None) -> tuple[str, str]:
    """Map a Claude tool event to a small, host-neutral status vocabulary."""
    name = name if isinstance(name, str) else ""
    if name in ("Read", "Glob", "Grep", "LS", "NotebookRead"):
        return "inspect", "Inspecting the project"
    if name == "Bash":
        command = tool_input.get("command", "") if isinstance(tool_input, dict) else ""
        return _command_stage(command)
    if name in ("Edit", "MultiEdit", "Write", "NotebookEdit"):
        return "edit", "Updating project files"
    if name in ("WebFetch", "WebSearch"):
        return "research", "Checking external documentation"
    if name in ("TodoWrite", "ExitPlanMode"):
        return "plan", "Updating the work plan"
    return "work", "Using a project tool"


def _stream_process(cmd: list[str], *, cwd: str, timeout: int,
                    on_stdout) -> subprocess.CompletedProcess:
    """Capture both pipes without deadlock while delivering stdout lines live."""
    proc = subprocess.Popen(
        cmd, cwd=cwd, stdin=subprocess.DEVNULL, stdout=subprocess.PIPE,
        stderr=subprocess.PIPE, text=True, bufsize=1,
    )
    events: queue.Queue = queue.Queue()

    def pump(kind: str, stream) -> None:
        try:
            for line in iter(stream.readline, ""):
                events.put((kind, line))
        finally:
            events.put((kind, None))

    threads = [
        threading.Thread(target=pump, args=("stdout", proc.stdout), daemon=True),
        threading.Thread(target=pump, args=("stderr", proc.stderr), daemon=True),
    ]
    for thread in threads:
        thread.start()

    captured = {"stdout": [], "stderr": []}
    open_streams = 2
    deadline = time.monotonic() + timeout
    while open_streams:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            proc.kill()
            proc.wait()
            raise subprocess.TimeoutExpired(
                cmd, timeout,
                output="".join(captured["stdout"]),
                stderr="".join(captured["stderr"]),
            )
        try:
            kind, line = events.get(timeout=min(0.25, remaining))
        except queue.Empty:
            continue
        if line is None:
            open_streams -= 1
            continue
        captured[kind].append(line)
        if kind == "stdout":
            on_stdout(line)

    returncode = proc.wait()
    for thread in threads:
        thread.join(timeout=1)
    return subprocess.CompletedProcess(
        cmd, returncode,
        stdout="".join(captured["stdout"]),
        stderr="".join(captured["stderr"]),
    )


def _event(line: str) -> dict | None:
    try:
        value = json.loads(line)
    except (TypeError, ValueError):
        return None
    return value if isinstance(value, dict) else None


class CodexProgress:
    """Render Codex JSONL while withholding the last agent message (the answer)."""

    def __init__(self, reporter: ProgressReporter):
        self.reporter = reporter
        self.pending_message = ""

    def feed(self, line: str) -> None:
        evt = _event(line)
        if evt is None:
            return
        kind = evt.get("type")
        item = evt.get("item") if isinstance(evt.get("item"), dict) else {}
        item_type = item.get("type")

        if kind == "item.completed" and item_type == "agent_message":
            # Codex uses the same event for commentary and the final answer.
            # Hold it until the next event: a following tool makes it commentary;
            # turn.completed makes it the answer, which progress must not echo.
            self.pending_message = _brief(item.get("text"))
            return

        if self.pending_message:
            if kind != "turn.completed":
                self.reporter.emit("update", self.pending_message)
            self.pending_message = ""

        if kind == "thread.started":
            self.reporter.emit("started", "Codex peer started")
        elif kind == "turn.started":
            self.reporter.emit("work", "Peer is working")
        elif kind == "item.started":
            if item_type == "command_execution":
                self.reporter.emit(*_command_stage(item.get("command")))
            elif item_type in ("file_change", "file_changes"):
                self.reporter.emit("edit", "Updating project files")
            elif item_type in ("mcp_tool_call", "dynamic_tool_call"):
                self.reporter.emit("work", "Using a project tool")
            elif item_type == "web_search":
                self.reporter.emit("research", "Checking external documentation")
        elif kind == "item.completed" and item_type == "command_execution":
            if item.get("exit_code") not in (None, 0):
                self.reporter.emit("update", "A command failed; the peer is handling it")
        elif kind == "item.completed" and item_type in ("file_change", "file_changes"):
            self.reporter.emit("edit", "Updated project files")
        elif kind == "turn.completed":
            self.reporter.emit("completed", "Codex peer finished")
        elif kind in ("turn.failed", "error"):
            self.reporter.emit("failed", "Codex peer reported a failure")


def _claude_progress(evt: dict, reporter: ProgressReporter) -> None:
    kind = evt.get("type")
    if kind == "system" and evt.get("subtype") == "init":
        reporter.emit("started", "Claude peer started")
        return
    if kind == "assistant":
        message = evt.get("message") if isinstance(evt.get("message"), dict) else {}
        content = message.get("content") if isinstance(message.get("content"), list) else []
        tools = [block for block in content
                 if isinstance(block, dict) and block.get("type") == "tool_use"]
        if tools:
            # Text accompanying a tool call is commentary, not the final answer.
            for block in content:
                if isinstance(block, dict) and block.get("type") == "text":
                    reporter.emit("update", block.get("text", ""))
                    break
            for block in tools:
                reporter.emit(*_tool_stage(block.get("name"), block.get("input")))
        return
    if kind == "result":
        if evt.get("is_error"):
            reporter.emit("failed", "Claude peer reported a failure")
        else:
            reporter.emit("completed", "Claude peer finished")


# --- engines -----------------------------------------------------------------
# Each engine turns (target, prompt, mode, model, resume) into ONE normalized
# dict so run() stays engine-blind:
#   {answer, session_id, model, cost_usd, duration_ms, num_turns,
#    tokens:{input,output,cache_read,cache_creation}, is_error, permission_denials}

def run_claude(target, prompt, mode, model, caller, append,
               schema_text, resume_id, timeout, as_json,
               reporter: ProgressReporter) -> dict:
    """Headless Claude. Progress uses stream-json; --quiet retains json mode."""
    output_format = "stream-json" if reporter.enabled else "json"
    cmd = ["claude", "-p", prompt, "--output-format", output_format,
           "--model", model]
    if reporter.enabled:
        cmd += ["--verbose"]
    if resume_id:
        cmd += ["--resume", resume_id]
    if mode == "read":
        cmd += ["--allowedTools", "Read,Glob,Grep", "--permission-mode", "plan"]
    else:
        cmd += ["--permission-mode", "bypassPermissions", "--add-dir", str(target)]
    cmd += ["--append-system-prompt", build_preamble(mode, caller, append, schema_text)]

    result_event: dict = {}
    try:
        if reporter.enabled:
            def on_stdout(line: str) -> None:
                evt = _event(line)
                if evt is None:
                    return
                _claude_progress(evt, reporter)
                if evt.get("type") == "result":
                    result_event.update(evt)

            proc = _stream_process(cmd, cwd=str(target), timeout=timeout,
                                   on_stdout=on_stdout)
        else:
            proc = subprocess.run(cmd, cwd=str(target), capture_output=True,
                                  text=True, timeout=timeout,
                                  stdin=subprocess.DEVNULL)
    except subprocess.TimeoutExpired:
        reporter.emit("failed", f"Peer timed out after {timeout}s")
        die(f"peer timed out after {timeout}s", as_json=as_json)
    if proc.returncode != 0:
        reporter.emit("failed", f"Claude peer exited with status {proc.returncode}")
        snippet = (proc.stderr or proc.stdout or "").strip()[-800:]
        die(f"peer exited {proc.returncode}: {snippet}", as_json=as_json)
    if reporter.enabled:
        env = result_event
        if not env:
            die(f"could not parse peer output: {proc.stdout[:800]}", as_json=as_json)
    else:
        try:
            env = json.loads(proc.stdout)
        except json.JSONDecodeError:
            die(f"could not parse peer output: {proc.stdout[:800]}", as_json=as_json)

    answer = env.get("result", "")
    if schema_text:
        # structured output may arrive parsed in `structured_output`, or as a
        # JSON string in `result` depending on harness version — handle both.
        if env.get("structured_output") is not None:
            answer = env["structured_output"]
        elif isinstance(answer, str):
            try:
                answer = json.loads(answer)
            except json.JSONDecodeError:
                pass
    usage = env.get("usage", {}) or {}
    return {
        "answer": answer,
        "session_id": env.get("session_id"),
        "model": model,
        "cost_usd": env.get("total_cost_usd"),
        "duration_ms": env.get("duration_ms"),
        "num_turns": env.get("num_turns"),
        "tokens": {
            "input": usage.get("input_tokens"),
            "output": usage.get("output_tokens"),
            "cache_read": usage.get("cache_read_input_tokens"),
            "cache_creation": usage.get("cache_creation_input_tokens"),
        },
        "is_error": bool(env.get("is_error", False)),
        "permission_denials": env.get("permission_denials", []),
    }


def _parse_codex_events(stdout: str) -> tuple[dict, str | None, bool]:
    """Pull usage + thread id (+ any failure) out of codex's --json JSONL."""
    usage: dict = {}
    thread_id = None
    is_error = False
    for line in (stdout or "").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            o = json.loads(line)
        except ValueError:
            continue
        t = o.get("type")
        if t == "turn.completed":
            usage = o.get("usage") or usage
        elif t == "thread.started":
            thread_id = o.get("thread_id") or thread_id
        elif t in ("turn.failed", "error"):
            is_error = True
    return usage, thread_id, is_error


def run_codex(target, prompt, mode, model, caller, append,
              schema_text, resume_id, timeout, as_json,
              reporter: ProgressReporter) -> dict:
    """Headless `codex exec`. codex has no system-prompt flag, so the peer
    preamble is folded into the prompt; the final message is read from -o and
    usage/thread id from the --json JSONL. Schema uses codex's native
    --output-schema. No USD cost under ChatGPT auth → cost_usd stays null."""
    import tempfile
    prompt = build_preamble(mode, caller, append, None) + "\n\n" + prompt
    out_fd, outfile = tempfile.mkstemp(prefix="askproject-codex-", suffix=".txt")
    os.close(out_fd)
    schema_file = None
    try:
        cmd = ["codex", "exec"]
        if resume_id:
            cmd += ["resume", resume_id]
        cmd += [prompt, "--skip-git-repo-check", "--json", "-o", outfile]
        if mode == "read":
            # -s/--sandbox is absent on `resume`; the config override works on
            # both the fresh and resume paths and genuinely blocks writes.
            cmd += ["-c", 'sandbox_mode="read-only"', "-c", 'approval_policy="never"']
        else:
            cmd += ["--dangerously-bypass-approvals-and-sandbox"]
        if model:
            cmd += ["-m", model]
        if schema_text:
            s_fd, schema_file = tempfile.mkstemp(prefix="askproject-schema-", suffix=".json")
            os.close(s_fd)
            Path(schema_file).write_text(schema_text)
            cmd += ["--output-schema", schema_file]

        try:
            if reporter.enabled:
                progress = CodexProgress(reporter)
                proc = _stream_process(cmd, cwd=str(target), timeout=timeout,
                                       on_stdout=progress.feed)
            else:
                proc = subprocess.run(cmd, cwd=str(target), capture_output=True,
                                      text=True, timeout=timeout,
                                      stdin=subprocess.DEVNULL)
        except subprocess.TimeoutExpired:
            reporter.emit("failed", f"Peer timed out after {timeout}s")
            die(f"peer timed out after {timeout}s", as_json=as_json)
        if proc.returncode != 0:
            reporter.emit("failed", f"Codex peer exited with status {proc.returncode}")
            snippet = (proc.stderr or proc.stdout or "").strip()[-800:]
            die(f"peer exited {proc.returncode}: {snippet}", as_json=as_json)

        answer = Path(outfile).read_text().strip()
        usage, thread_id, evt_error = _parse_codex_events(proc.stdout)
        if schema_text and answer:
            try:
                answer = json.loads(answer)
            except json.JSONDecodeError:
                pass
    finally:
        for f in (outfile, schema_file):
            if f:
                try:
                    os.unlink(f)
                except OSError:
                    pass

    return {
        "answer": answer,
        "session_id": thread_id,
        "model": model,
        "cost_usd": None,
        "duration_ms": None,
        "num_turns": None,
        "tokens": {
            "input": usage.get("input_tokens"),
            "output": usage.get("output_tokens"),
            "cache_read": usage.get("cached_input_tokens"),
            "cache_creation": None,
        },
        "is_error": bool(evt_error or not answer),
        "permission_denials": [],
    }


ENGINE_RUNNERS = {"claude": run_claude, "codex": run_codex}


def run(args):
    text_only = args.text
    as_json = not text_only

    target = Path(args.target).expanduser()
    if not target.is_absolute():
        target = (Path.cwd() / target).resolve()
    if not target.is_dir():
        die(f"target is not a directory: {target}", as_json=as_json)

    mode = "act" if args.act else "read"
    caller = find_project_root(Path.cwd()).name

    state = load_state()
    key = str(target)
    entry = state.get(key, {})

    # engine selection: explicit --engine > env/default. A -c resume adopts the
    # session's own engine (a codex thread can't be resumed by claude).
    resumed = False
    resume_id = None
    if args.cont:
        stored_engine = entry.get("engine") or "claude"
        if args.engine and args.engine != stored_engine:
            die(f"cannot resume {target} with {args.engine}: the last session "
                f"used {stored_engine}", as_json=as_json)
        engine = args.engine or stored_engine
        resume_id = entry.get("last_session_id")
        if not resume_id:
            die(f"no prior session for {target}; run without -c first", as_json=as_json)
        if args.fork:
            die("--fork is not supported in headless mode", as_json=as_json)
        resumed = True
    else:
        engine = args.engine or _default_engine()

    if not shutil.which(engine):
        die(f"`{engine}` CLI not found on PATH", as_json=as_json)

    if engine == "claude":
        model = resolve_model(args.model or (ACT_MODEL if mode == "act" else READ_MODEL))
    else:
        model = args.model or None   # codex: fall back to its config default (newest)

    schema_text = resolve_schema(args.schema) if args.schema else None

    reporter = ProgressReporter(engine, enabled=not args.quiet)
    reporter.emit("starting", f"Launching {engine} peer")
    before = snapshot(target)
    res = ENGINE_RUNNERS[engine](target, args.prompt, mode, model, caller,
                                 args.append, schema_text, resume_id,
                                 args.timeout, as_json, reporter)
    after = snapshot(target)
    files_changed, dirty_before = diff_snapshots(before, after)

    answer = res["answer"]
    session_id = res["session_id"]
    ok = not res["is_error"]
    err = None
    if mode == "read" and files_changed:
        ok = False
        err = "READ MODE MUTATED THE TARGET — investigate"

    # persist session mapping (local to the initiating project)
    if session_id:
        entry["last_session_id"] = session_id
        entry["last_model"] = res.get("model")
        entry["engine"] = engine
        entry["interactions"] = entry.get("interactions", 0) + 1
        state[key] = entry
        save_state(state)

    if text_only:
        out = answer if isinstance(answer, str) else json.dumps(answer, indent=2)
        print(out)
        sys.exit(0 if ok else 1)

    result = {
        "ok": ok,
        "error": err,
        "target": str(target),
        "engine": engine,
        "mode": mode,
        "model": res.get("model"),
        "session_id": session_id,
        "resumed": resumed,
        "answer": answer,
        "cost_usd": res.get("cost_usd"),
        "duration_ms": res.get("duration_ms"),
        "num_turns": res.get("num_turns"),
        "tokens": res.get("tokens", {}),
        "git": {
            "repo": before.get("repo", False),
            "head_before": before.get("head"),
            "head_after": after.get("head"),
            "dirty_before": dirty_before,
            "files_changed": files_changed,
        },
        "permission_denials": res.get("permission_denials", []),
    }
    print(json.dumps(result, indent=2))
    sys.exit(0 if ok else 1)


def cmd_targets():
    state = load_state()
    if not state:
        print("no targets recorded for this project")
        return
    for k, v in state.items():
        print(f"{k}")
        print(f"  last_session: {v.get('last_session_id')}  engine: {v.get('engine', 'claude')}")
        print(f"  model: {v.get('last_model')}  interactions: {v.get('interactions')}")


def cmd_doctor():
    """Readiness: report which engine CLIs are on PATH. ok requires the default
    engine to be present (either engine covers its own --engine calls)."""
    engines = {name: shutil.which(name) for name in ENGINES}
    default = _default_engine()
    ok = bool(engines.get(default))
    _emit({"ok": ok, "engines": engines, "default_engine": default,
           "error": None if ok else f"default engine {default!r} not found on PATH"})
    sys.exit(0 if ok else 2)


def main():
    argv = sys.argv[1:]
    _gate()              # disabled in this project → exit 4
    _contract(argv)      # stub/manifest/guide/ids/refs/connections → emit + exit; else return
    if not argv or argv[0] in ("help", "-h", "--help"):
        print(__doc__)
        return
    if argv[0] == "doctor":
        cmd_doctor()
        return
    if argv[0] == "targets":
        cmd_targets()
        return

    p = argparse.ArgumentParser(prog="askproject", add_help=False)
    p.add_argument("target")
    p.add_argument("prompt")
    p.add_argument("--engine", choices=ENGINES)
    p.add_argument("--act", action="store_true")
    p.add_argument("-c", "--continue", dest="cont", action="store_true")
    p.add_argument("--fork", action="store_true")
    p.add_argument("--model")
    p.add_argument("--schema")
    p.add_argument("--timeout", type=int, default=600)
    p.add_argument("--text", action="store_true")
    p.add_argument("--quiet", action="store_true")
    p.add_argument("--append")
    args = p.parse_args(argv)
    run(args)


if __name__ == "__main__":
    main()
