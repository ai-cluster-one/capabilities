#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""
askproject — ask a Claude Code agent running in ANOTHER project to answer in
its own context, then return its answer plus traceability to the caller.

This tool is designed to be invoked BY an agent (you), from inside your own
project. It spawns a headless `claude -p` in a target project's directory, so
that peer loads the target's CLAUDE.md / settings / rights and answers as that
project — then hands back the answer with cost, token, and files-changed data.

Run `askproject help` to (re)load this contract on demand — do not rely on
memorised knowledge of its surface.

────────────────────────────────────────────────────────────────────────────
COMMANDS
  askproject <target> "<question>"        Ask the peer (read-only research).
  askproject <target> --act "<task>"      Let the peer modify its own project.
  askproject <target> -c "<follow-up>"    Continue the last conversation with
                                          that target (resumes its session).
  askproject targets                       List targets you've talked to (this
                                          project) + their last session.
  askproject help                          Print this document.

<target> is a path to the other project: absolute, ~-expanded, or relative to
your cwd. YOU decide which project to talk to and pass its path. It must be a
directory (a git repo is strongly recommended — see snapshots below).

────────────────────────────────────────────────────────────────────────────
MODES & MODELS  (model is auto-picked from mode; override with --model)
  read  (default)   Peer gets ONLY Read/Glob/Grep + plan mode. It physically
                    cannot edit, write, or run shell — pure research. Model:
                    haiku (cheap). Use for "what does X do", "find Y", reviews.
  act   (--act)     Peer gets acceptEdits + the target as an --add-dir. It can
                    edit files INSIDE its project without prompts; writes
                    outside the project and un-allowlisted shell are auto-denied
                    in headless mode. Model: opus. Use for "fix X", "refactor".
  bypass (--bypass) Adds --dangerously-skip-permissions. ⚠ This REMOVES all
                    fences: the peer can touch ANYTHING your user can, anywhere
                    on disk — not just its own project. Explicit opt-in only.

FENCING REALITY: flags are behavioural, not an OS sandbox. read mode is a hard
"no tools to do harm" fence. act mode confines a cooperative agent but is not
escape-proof against allowlisted shell. The git snapshot (below) is your safety
net. A true OS sandbox is future work.

────────────────────────────────────────────────────────────────────────────
SESSION CONTINUITY  (state is LOCAL to the project you call from)
  The map of "which target → which session" is written to:
      <your-project-root>/.claude/askproject/sessions.json
  (your-project-root = nearest ancestor with .git or .claude; else cwd.)
  This is a config of YOUR project, not of the tool — it travels with the repo
  that initiates the calls. It is git-ignored automatically (session ids are
  machine-local). `-c/--continue` resumes the last session for that target;
  add --fork to branch instead of continue.

  Scope a session to ONE unit of work — resume with -c only while on that
  same item; start a fresh call for a new one; use --fork to branch off an
  existing thread without polluting it. Sessions that span unrelated tasks
  just carry dead context and grow costly — short, task-scoped is optimal.

────────────────────────────────────────────────────────────────────────────
OUTPUT  (stdout = one JSON object; use --text to get just the answer)
  {
    "ok": bool, "error": str|null,
    "target": "<abs path>", "mode": "read|act|bypass",
    "model": "<model id>", "session_id": "<uuid>", "resumed": bool,
    "answer": <string OR parsed object when --schema is used>,
    "cost_usd": float, "duration_ms": int, "num_turns": int,
    "tokens": {input, output, cache_read, cache_creation},
    "git": {"repo": bool, "head_before","head_after","dirty_before",
            "files_changed":[{"path","status"}]},
    "permission_denials": [ ... attempts the peer made and was blocked on ... ]
  }
  In read mode files_changed must be empty; if it isn't, ok=false and it is
  flagged loudly (a read query should never mutate).

FLAGS
  --act                 Modification mode (acceptEdits + opus).
  --bypass              Add --dangerously-skip-permissions (DANGEROUS).
  -c, --continue        Resume the last session for this target.
  --fork                With -c: branch a new session instead of continuing.
  --model <m>           Override the model (alias like 'opus'/'haiku' or id).
  --schema <file|json>  Pass a JSON Schema to constrain the peer's answer;
                        `answer` is then the parsed object.
  --timeout <seconds>   Kill the peer after N seconds (default 600).
  --text                Print only the answer to stdout (still exits non-zero
                        on error).
  --append <text>       Extra instruction appended to the peer's system prompt.

EXAMPLES
  askproject ../simplbooks "Which file defines the VAT regime taxonomy?"
  askproject ~/dev/api --act "Add a --json flag to the export command"
  askproject ../simplbooks -c "And where is it consumed?"

────────────────────────────────────────────────────────────────────────────
CONTRACT  (self-description an agent loads on demand; this capability has NO
           connections — it drives the local `claude` CLI, with no credentials)
  askproject doctor        Readiness — confirms the `claude` CLI is on PATH.
  askproject stub          One-line awareness text.
  askproject manifest      Machine-readable declaration (JSON).
  askproject guide [topic] How-to guides — `capability-changes`.
  askproject ids …         Project identifier store (list/get/set/rm).
  askproject refs          Project references menu.
  askproject connections   Connections report — empty; this capability has none.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import NoReturn

# --- Capability declaration (protocol 2) — one home for every contract fact --

NAME = "askproject"
PROTOCOL = 2
SUMMARY = ("Bridge to a Claude Code agent in ANOTHER project — spawn a headless "
           "`claude -p` in a target project, fenced by mode (read/act/bypass), "
           "and return its answer with cost, token, and files-changed traceability.")
SCOPE = "user"      # credential scope: "project" | "user"
CRED_KEYS: list = []   # no credentials — it drives the local `claude` CLI on PATH
DOCS_BASE = ("https://raw.githubusercontent.com/ai-cluster-one/capabilities/"
             "main/capabilities/askproject/guides/")
TOPICS = ["capability-changes"]   # shipped guide topics
STATE = False       # the session map lives in the CALLING project's .claude/askproject/
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "askproject" / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

READ_MODEL = "claude-haiku-4-5-20251001"
ACT_MODEL = "opus"

# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks."""
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import httpx as _hx
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        resp = _hx.get(url, headers=headers, timeout=10.0, follow_redirects=True)
        if resp.status_code == 200:
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(resp.text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(resp.text); return
        if resp.status_code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if resp.status_code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        raise _hx.HTTPError(f"upstream returned {resp.status_code}")
    except _hx.HTTPError as e:
        if cache.exists():
            sys.stderr.write(json.dumps(
                {"warning": f"upstream unreachable; serving cached copy ({e})"},
                ensure_ascii=False) + "\n")
            _emit(cache.read_text()); return
        _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


def _cmd_connections() -> None:
    """Core-only capability: askproject drives the local `claude` CLI and has no
    configured connection, so the connections report is empty by contract."""
    _emit({"connections": {}, "default": None})


def die(msg: str, *, as_json: bool, code: int = 1):
    if as_json:
        print(json.dumps({"ok": False, "error": msg}, indent=2))
    else:
        print(f"askproject: {msg}", file=sys.stderr)
    sys.exit(code)


def find_project_root(start: Path) -> Path:
    """Nearest ancestor (incl. start) containing .git or .claude; else start."""
    start = start.resolve()
    for d in [start, *start.parents]:
        if (d / ".git").exists() or (d / ".claude").exists():
            return d
    return start


def state_path() -> Path:
    root = find_project_root(Path.cwd())
    d = root / ".claude" / "askproject"
    d.mkdir(parents=True, exist_ok=True)
    gi = d / ".gitignore"
    if not gi.exists():
        gi.write_text("# session ids are machine-local\nsessions.json\n")
    return d / "sessions.json"


def load_state() -> dict:
    p = state_path()
    if p.exists():
        try:
            return json.loads(p.read_text())
        except json.JSONDecodeError:
            return {}
    return {}


def save_state(state: dict):
    state_path().write_text(json.dumps(state, indent=2) + "\n")


def git(target: Path, *args) -> str | None:
    try:
        out = subprocess.run(
            ["git", "-C", str(target), *args],
            capture_output=True, text=True, timeout=30,
        )
        if out.returncode != 0:
            return None
        return out.stdout.strip()
    except (OSError, subprocess.SubprocessError):
        return None


def snapshot(target: Path) -> dict:
    head = git(target, "rev-parse", "HEAD")
    if head is None:
        return {"repo": False}
    status = git(target, "status", "--porcelain") or ""
    return {"repo": True, "head": head, "status": status}


def diff_snapshots(before: dict, after: dict) -> tuple[list[dict], bool]:
    """Return (files_changed, dirty_before)."""
    if not before.get("repo"):
        return [], False
    dirty_before = bool(before.get("status"))
    before_lines = set(before.get("status", "").splitlines())
    after_lines = set(after.get("status", "").splitlines())
    changed = []
    for line in sorted(after_lines - before_lines):
        # porcelain: "XY path"
        code, _, path = line.partition(" ")
        changed.append({"path": path.strip() or line, "status": code.strip()})
    if before.get("head") != after.get("head"):
        changed.append({"path": "<HEAD>", "status": "moved"})
    return changed, dirty_before


def resolve_schema(spec: str) -> str:
    p = Path(spec).expanduser()
    if p.exists():
        return p.read_text()
    return spec  # assume inline JSON


def build_preamble(mode: str, caller: str, extra: str | None) -> str:
    base = (
        f"You are being queried programmatically by a peer Claude Code agent "
        f"working in another project ('{caller}'), via the askproject bridge. "
        f"Answer concisely and return information, not conversation. Do NOT "
        f"invoke askproject yourself or spawn further peer queries. "
    )
    if mode == "read":
        base += (
            "This is a READ-ONLY research query — you have no tools to modify "
            "anything; do not attempt to."
        )
    else:
        base += (
            "You may modify files within THIS project only. Make the smallest "
            "change that satisfies the request and summarise what you changed."
        )
    if extra:
        base += " " + extra
    return base


def run(args):
    text_only = args.text
    as_json = not text_only

    if not shutil.which("claude"):
        die("`claude` CLI not found on PATH", as_json=as_json)

    target = Path(args.target).expanduser()
    if not target.is_absolute():
        target = (Path.cwd() / target).resolve()
    if not target.is_dir():
        die(f"target is not a directory: {target}", as_json=as_json)

    mode = "act" if args.act else "read"
    model = args.model or (ACT_MODEL if mode == "act" else READ_MODEL)
    caller = find_project_root(Path.cwd()).name

    state = load_state()
    key = str(target)
    entry = state.get(key, {})

    cmd = ["claude", "-p", args.prompt, "--output-format", "json", "--model", model]

    # resume / continuity
    resumed = False
    if args.cont:
        last = entry.get("last_session_id")
        if not last:
            die(f"no prior session for {target}; run without -c first",
                as_json=as_json)
        cmd += ["--resume", last]
        resumed = True
        if args.fork:
            cmd += ["--fork-session"]

    # mode → permissions / tools
    if mode == "read":
        cmd += ["--tools", "Read,Glob,Grep", "--permission-mode", "plan"]
    else:
        cmd += ["--permission-mode", "acceptEdits", "--add-dir", str(target)]
    if args.bypass:
        cmd += ["--dangerously-skip-permissions"]

    cmd += ["--append-system-prompt", build_preamble(mode, caller, args.append)]

    if args.schema:
        cmd += ["--json-schema", resolve_schema(args.schema)]

    before = snapshot(target)

    try:
        proc = subprocess.run(
            cmd, cwd=str(target), capture_output=True, text=True,
            timeout=args.timeout,
        )
    except subprocess.TimeoutExpired:
        die(f"peer timed out after {args.timeout}s", as_json=as_json)

    if proc.returncode != 0:
        snippet = (proc.stderr or proc.stdout or "").strip()[-800:]
        die(f"peer exited {proc.returncode}: {snippet}", as_json=as_json)

    try:
        env = json.loads(proc.stdout)
    except json.JSONDecodeError:
        die(f"could not parse peer output: {proc.stdout[:800]}", as_json=as_json)

    after = snapshot(target)
    files_changed, dirty_before = diff_snapshots(before, after)

    answer = env.get("result", "")
    if args.schema:
        # structured output may arrive parsed in `structured_output`, or as a
        # JSON string in `result` depending on harness version — handle both.
        if env.get("structured_output") is not None:
            answer = env["structured_output"]
        elif isinstance(answer, str):
            try:
                answer = json.loads(answer)
            except json.JSONDecodeError:
                pass

    session_id = env.get("session_id")
    usage = env.get("usage", {}) or {}

    ok = not env.get("is_error", False)
    err = None
    if mode == "read" and files_changed:
        ok = False
        err = "READ MODE MUTATED THE TARGET — investigate"

    # persist session mapping (local to the initiating project)
    if session_id:
        entry["last_session_id"] = session_id
        entry["last_model"] = model
        entry["interactions"] = entry.get("interactions", 0) + 1
        state[key] = entry
        save_state(state)

    if text_only:
        out = answer if isinstance(answer, str) else json.dumps(answer, indent=2)
        print(out)
        sys.exit(0 if ok else 1)

    result = {
        "ok": ok,
        "error": err,
        "target": str(target),
        "mode": "bypass" if args.bypass else mode,
        "model": model,
        "session_id": session_id,
        "resumed": resumed,
        "answer": answer,
        "cost_usd": env.get("total_cost_usd"),
        "duration_ms": env.get("duration_ms"),
        "num_turns": env.get("num_turns"),
        "tokens": {
            "input": usage.get("input_tokens"),
            "output": usage.get("output_tokens"),
            "cache_read": usage.get("cache_read_input_tokens"),
            "cache_creation": usage.get("cache_creation_input_tokens"),
        },
        "git": {
            "repo": before.get("repo", False),
            "head_before": before.get("head"),
            "head_after": after.get("head"),
            "dirty_before": dirty_before,
            "files_changed": files_changed,
        },
        "permission_denials": env.get("permission_denials", []),
    }
    print(json.dumps(result, indent=2))
    sys.exit(0 if ok else 1)


def cmd_targets():
    state = load_state()
    if not state:
        print("no targets recorded for this project")
        return
    for k, v in state.items():
        print(f"{k}")
        print(f"  last_session: {v.get('last_session_id')}")
        print(f"  model: {v.get('last_model')}  interactions: {v.get('interactions')}")


def cmd_doctor():
    """Readiness: the `claude` CLI must be on PATH for any query to run."""
    claude = shutil.which("claude")
    if not claude:
        _emit({"ok": False, "claude": None,
               "error": "`claude` CLI not found on PATH"})
        sys.exit(2)
    _emit({"ok": True, "claude": claude})


def main():
    argv = sys.argv[1:]
    _gate()              # disabled in this project → exit 4
    _contract(argv)      # stub/manifest/guide/ids/refs/connections → emit + exit; else return
    if not argv or argv[0] in ("help", "-h", "--help"):
        print(__doc__)
        return
    if argv[0] == "doctor":
        cmd_doctor()
        return
    if argv[0] == "targets":
        cmd_targets()
        return

    p = argparse.ArgumentParser(prog="askproject", add_help=False)
    p.add_argument("target")
    p.add_argument("prompt")
    p.add_argument("--act", action="store_true")
    p.add_argument("--bypass", action="store_true")
    p.add_argument("-c", "--continue", dest="cont", action="store_true")
    p.add_argument("--fork", action="store_true")
    p.add_argument("--model")
    p.add_argument("--schema")
    p.add_argument("--timeout", type=int, default=600)
    p.add_argument("--text", action="store_true")
    p.add_argument("--append")
    args = p.parse_args(argv)
    run(args)


if __name__ == "__main__":
    main()
