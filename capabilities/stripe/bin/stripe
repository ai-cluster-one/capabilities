#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""stripe — read-only Stripe fetch CLI. Emits a neutral JSON contract of what
happened on Stripe; it carries Stripe-domain facts only. A consumer maps the
contract onto its own domain primitives downstream. The contract is the only
coupling.

USAGE
  stripe <command> [options]

Identity-free: it reports on whatever account STRIPE_SECRET_KEY authorizes.
Read-only: every command is a GET against the Stripe REST API. All structured
reads emit JSON to stdout. Date ranges are --from inclusive, --to exclusive
(YYYY-MM-DD, interpreted at local-midnight).

CONNECTIONS
  Configuration resolves as named connections. With no registry the sole
  connection is `default`: STRIPE_SECRET_KEY resolved in a cascade (first
  non-empty wins):
    1. flag           --api-key
    2. project env    .env.local then .env, walking up from $CLAUDE_PROJECT_DIR (else cwd)
    3. user config    $XDG_CONFIG_HOME/stripe/credentials.env (default ~/.config/stripe/)
    4. process env    STRIPE_SECRET_KEY

  A project that reads several Stripe accounts declares them in
  <project>/.capabilities/stripe/connections.json:
    {
      "default": "<id>",
      "connections": {
        "<id>": { "secret_env": "STRIPE_<ID>_SECRET_KEY" }
      }
    }
  The registry resolves project envelope first, else the machine-level
  ~/.config/stripe/connections.json; first found wins, never merged.

  The entry names the env var holding its key ("secret_env"); the value
  resolves through cascade tiers 2-4 above. Every command is a read, so
  "allow_write": false changes nothing here — the write gate guards a
  surface this CLI does not have.

  Selection: --connection <id> (accepted anywhere on the command line).
  Unflagged, the registry's "default" pointer applies, else the sole entry;
  several entries without a pointer is refused as ambiguous.

COMMANDS
  connections
      Where every connection's values resolve from (tier, source, secrets
      masked). Local only — no network.

  doctor [--connection <id>]
      Validate key + API reachability (GET /v1/balance) — every connection,
      or one. Exit 0 all healthy / 2 missing-or-rejected key / 5 unreachable.

  sync-plan --from YYYY-MM-DD --to YYYY-MM-DD [--only-type T]
      THE contract producer. Walks balance_transactions over [from, to),
      classifies each into the neutral event taxonomy, and emits the JSON
      contract on stdout. One call = everything a consumer needs to reconcile.
        · charge  → gross/fee/net split + customer block + invoice block
                    (stripe number, line items [description/qty/amount],
                    hosted PDF url) + resolve:{client_id, invoice_id}=null
                    (the seam a consumer fills with its own ids)
        · fee     → amount + category (billing_usage / invoicing / tax / processing)
        · payout  → amount (for tying to the bank side)
        · refund  → kind:"refund", flagged residual — surfaced, never dropped
      Stateless: emits everything in range. Idempotency is the consumer's (it
      skips events already recorded in its own store, keyed by the txn_ id).
      --only-type restricts to one of charge|fee|payout|refund.

  contract
      Print a valid example of the contract sync-plan emits — the event and
      envelope shape, not live data, no API key required. The machine-readable
      companion to the event taxonomy above; built from the same builders the
      producer uses, so it never drifts. Pipe to jq to inspect the fields.

  invoices list --from YYYY-MM-DD --to YYYY-MM-DD [--status paid]
      Standalone read of Stripe invoices (number, customer, amount, currency,
      hosted PDF url). Inspection read; sync-plan's charge events embed this.

  invoices pdf <invoice_id> --out PATH
      Download an invoice's hosted PDF, for attaching to the books on create.

  balance-transactions list --from YYYY-MM-DD --to YYYY-MM-DD [--type T]
      Lower-level normalized BT read — for resolving an edge case sync-plan
      flagged, or a staged by-type migration. --type one of
      charge|stripe_fee|payout|refund.

  payouts list --from YYYY-MM-DD --to YYYY-MM-DD
      Standalone payout read.

Contract commands (the same on every capability):
  stripe stub                                 One-line awareness text.
  stripe manifest --json                      Machine-readable declaration.
  stripe guide [<topic>]                      Guide topics / one guide body,
                                               fetched live from the docs base.
  stripe ids list|get <l>|set <l> <v>|rm <l>  The project identifiers envelope
              [--note <text>]                  (.capabilities/stripe/identifiers.json).
  stripe refs                                 Menu of the project's reference
                                               files for this capability.

EXIT CODES
  0 success · 2 auth/credentials · 3 not found · 4 policy refusal — the
  project gate (.capabilities/settings.json) on any verb, or a write verb
  on a read-only connection; ask the user, never lift a gate yourself ·
  5 server/network · 6 input
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
from datetime import datetime
from pathlib import Path
from typing import NoReturn

import httpx

STRIPE_API = "https://api.stripe.com/v1"
TIMEOUT = httpx.Timeout(60.0)
MAX_RETRIES = 3

# --- Capability declaration (protocol 2) — one home for every contract fact --

NAME = "stripe"
PROTOCOL = 2
SUMMARY = ("Read-only Stripe CLI over the REST API — emit a neutral JSON "
           "contract of account activity (sync-plan), check "
           "identity/reachability (doctor), list invoices and download their "
           "PDFs, and read balance-transactions and payouts.")
SCOPE = "project"   # credential scope: "project" | "user"
CRED_KEYS = [
    {"key": "STRIPE_SECRET_KEY", "secret": True, "required": True,
     "note": "API key; a restricted read-only key is preferred"},
]
WRITE_VERBS: set = set()   # every command is a GET — nothing mutates Stripe
WRITE_DEFAULT = True    # protocol default; this CLI has no write verbs to gate
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "stripe" / "credentials.env"
KEY_NAME = "STRIPE_SECRET_KEY"


# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks."""
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import httpx as _hx
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        resp = _hx.get(url, headers=headers, timeout=10.0, follow_redirects=True)
        if resp.status_code == 200:
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(resp.text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(resp.text); return
        if resp.status_code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if resp.status_code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        raise _hx.HTTPError(f"upstream returned {resp.status_code}")
    except _hx.HTTPError as e:
        if cache.exists():
            sys.stderr.write(json.dumps(
                {"warning": f"upstream unreachable; serving cached copy ({e})"},
                ensure_ascii=False) + "\n")
            _emit(cache.read_text()); return
        _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


# >>> contract: connections (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

def _resolve_env_key(key: str) -> tuple[str | None, str | None, Path | None]:
    """Resolve one env key through cascade tiers 2-4: project .env(.local) →
    user credentials.env → process env. Returns (value, tier, source)."""
    root = _project_root()
    if root is not None:
        for fname in (".env.local", ".env"):
            val = _parse_env_file(root / fname).get(key)
            if val:
                return val, "project", root / fname
    val = _parse_env_file(CREDENTIALS_ENV).get(key)
    if val:
        return val, "user", CREDENTIALS_ENV
    val = os.environ.get(key)
    if val:
        return val, "env", None
    return None, None, None


def _mask(value: str) -> str:
    return ("…" + value[-4:]) if len(value) >= 8 else "****"


def _connections_registry() -> tuple[dict | None, Path | None]:
    """The connections envelope and its path: project envelope first, else the
    user config home. First found wins, never merged; (None, None) when neither
    declares one (the implicit default connection applies)."""
    envdir = _env_dir()
    candidates = ([envdir / "connections.json"] if envdir else []) + \
                 [_CONFIG_HOME / NAME / "connections.json"]
    for reg_file in candidates:
        if not reg_file.is_file():
            continue
        try:
            raw = json.loads(reg_file.read_text())
        except (ValueError, OSError) as e:
            _die(6, "bad_config", f"cannot read {reg_file}: {e}")
        if not isinstance(raw, dict) or not isinstance(raw.get("connections"), dict) \
                or not raw["connections"]:
            _die(6, "bad_config", f"{reg_file} is not a connections envelope",
                 'expected {"default": "<id>", "connections": { ... }}')
        return raw, reg_file
    return None, None


def _select_connection(reg: dict | None, wanted: str | None) -> tuple[str, dict | None]:
    """flag → default pointer → sole entry → die 6. No registry → the implicit
    default. A connection's own `address` field selects it too (used where a
    connection carries a human-recognizable address; absent fields never match)."""
    if reg is None:
        if wanted and wanted != "default":
            _die(6, "unknown_connection",
                 "no connections registry; the sole connection is 'default'",
                 "the implicit default resolves from the credential cascade")
        return "default", None
    conns = reg["connections"]
    if wanted:
        if wanted in conns:
            return wanted, conns[wanted]
        for cid, entry in conns.items():
            if (entry or {}).get("address", "").lower() == wanted.lower():
                return cid, entry
        _die(6, "unknown_connection", f"no connection matches {wanted!r}",
             f"known: {', '.join(conns)}")
    default = reg.get("default")
    if default:
        if default not in conns:
            _die(6, "bad_default", f"default points to unknown connection {default!r}",
                 f"known: {', '.join(conns)}")
        return default, conns[default]
    if len(conns) == 1:
        cid = next(iter(conns))
        return cid, conns[cid]
    _die(6, "ambiguous_connection",
         f"registry defines {len(conns)} connections and no default; "
         f"pass --connection <id>",
         f"known: {', '.join(conns)}")


def _write_gate(conn_id: str, allow_write: bool, verb: str) -> None:
    """Policy from the committed registry; nothing in the cascade lifts it."""
    if verb in WRITE_VERBS and not allow_write:
        _die(4, "read_only",
             f"connection {conn_id!r} does not allow writes",
             "Do not lift the gate yourself — ask the user; granting is "
             "`allow_write: true` on this connection in connections.json.")


def _key_report(key: str, secret: bool, required: bool,
                value: str | None, tier: str | None, source) -> dict:
    return {"key": key, "secret": secret, "required": required,
            "set": bool(value), "tier": tier if value else None,
            "source": str(source) if (value and source) else None,
            "value": (_mask(value) if secret else value) if value else None}

# <<< contract: connections <<<


# ── credentials ─────────────────────────────────────────────────────────────

def _project_settings() -> dict:
    """Capability-owned, non-secret project config: .capabilities/<NAME>/settings.json."""
    envdir = _env_dir()
    if envdir is None:
        return {}
    try:
        return json.loads((envdir / "settings.json").read_text())
    except (OSError, ValueError):
        return {}


def _cmd_connections() -> None:
    """The resolution report — every connection, every value, its winning tier
    and source, secrets masked. Local only: no network, no login attempt."""
    reg, _ = _connections_registry()
    report: dict = {"default": None, "connections": {}}
    if reg is None:
        value, tier, source = _resolve_env_key(KEY_NAME)
        report["default"] = "default"
        report["connections"]["default"] = {
            "allow_write": WRITE_DEFAULT,
            "keys": [_key_report(KEY_NAME, True, True, value, tier, source)]}
        _emit(report)
        return
    conns = reg["connections"]
    report["default"] = reg.get("default") or \
        (next(iter(conns)) if len(conns) == 1 else None)
    for cid, entry in conns.items():
        entry = entry if isinstance(entry, dict) else {}
        secret_env = entry.get("secret_env")
        if secret_env:
            value, tier, source = _resolve_env_key(secret_env)
            keys = [_key_report(secret_env, True, True, value, tier, source)]
        else:
            keys = [_key_report("secret_env", False, True, None, None, None)]
        report["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": keys}
    _emit(report)


def _resolve_key(args, entry: dict | None, cid: str) -> str:
    """The selected connection's key: the --api-key flag (tier 1) wins; an
    entry resolves its named secret_env; the implicit default the flat key."""
    flag = getattr(args, "api_key", None)
    if flag:
        return flag
    if entry is None:
        key = _resolve_env_key(KEY_NAME)[0]
        if not key:
            _die(2, "missing_credentials",
                 f"{KEY_NAME} is required",
                 f"set it in a project .env(.local), {CREDENTIALS_ENV}, "
                 f"the environment, or via --api-key")
        return key
    secret_env = entry.get("secret_env")
    if not secret_env:
        _die(6, "no_secret_env", f"connection {cid!r} is missing 'secret_env'")
    key = _resolve_env_key(secret_env)[0]
    if not key:
        _die(2, "missing_credentials",
             f"env var {secret_env} (for connection {cid!r}) is unset",
             f"set {secret_env} in the project's .env / .env.local, "
             f"{CREDENTIALS_ENV}, or the environment")
    return key


# ── HTTP with 429/5xx backoff ───────────────────────────────────────────────

def _client(key: str) -> httpx.Client:
    return httpx.Client(base_url=STRIPE_API, auth=(key, ""), timeout=TIMEOUT)


def _request(client: httpx.Client, method: str, path: str,
             params=None):
    last_status: int | None = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = client.request(method, path, params=params)
        except httpx.TimeoutException:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "timeout", f"request timed out: {method} {path}", "Stripe was unresponsive")
        except httpx.RequestError as e:
            _die(5, "network_error", f"network error: {e}", "check connectivity to api.stripe.com")

        last_status = resp.status_code
        if resp.status_code == 429:
            retry_after = float(resp.headers.get("Retry-After", str(attempt * 1.5)))
            if attempt < MAX_RETRIES:
                time.sleep(retry_after)
                continue
            _die(5, "rate_limited", "rate-limited by Stripe", status=429)
        if resp.status_code >= 500:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "server_error", f"Stripe returned {resp.status_code}",
                 (resp.text or "")[:300], status=resp.status_code)

        if resp.status_code >= 400:
            msg = (resp.text or "").strip()[:400] or "unknown error"
            try:
                j = resp.json()
                if isinstance(j, dict) and isinstance(j.get("error"), dict):
                    msg = j["error"].get("message") or msg
            except ValueError:
                pass
            if resp.status_code in (401, 403):
                _die(2, "unauthorized", msg, "STRIPE_SECRET_KEY invalid or lacks scope", status=resp.status_code)
            if resp.status_code == 404:
                _die(3, "not_found", msg, status=resp.status_code)
            _die(6, "invalid_request", msg, status=resp.status_code)

        try:
            return resp.json()
        except ValueError:
            return {}

    _die(5, "exhausted_retries", f"exhausted {MAX_RETRIES} attempts on {method} {path}", status=last_status)


# ── Stripe domain helpers ───────────────────────────────────────────────────

def _ts(date_str: str) -> int:
    try:
        return int(datetime.strptime(date_str, "%Y-%m-%d").timestamp())
    except ValueError:
        _die(6, "bad_date", f"expected YYYY-MM-DD, got {date_str!r}")


def _amt(cents, currency: str) -> str:
    """Minor units → decimal string. Zero-decimal currencies kept whole.
    Neutral dot-decimal — the consumer reformats to its own locale."""
    zero_decimal = {"jpy", "krw", "vnd", "clp", "isk", "huf", "twd"}
    if (currency or "").lower() in zero_decimal:
        return str(abs(int(cents)))
    return f"{abs(int(cents)) / 100:.2f}"


def _day(epoch) -> str | None:
    """Epoch seconds → YYYY-MM-DD in local time, matching the local-midnight
    basis of the --from/--to range filter."""
    if not epoch:
        return None
    return datetime.fromtimestamp(int(epoch)).strftime("%Y-%m-%d")


def _paginate(client: httpx.Client, path: str, params: list[tuple[str, str]]):
    starting_after = None
    while True:
        page_params = list(params)
        if starting_after:
            page_params.append(("starting_after", starting_after))
        data = _request(client, "GET", path, params=page_params)
        items = data.get("data", []) if isinstance(data, dict) else []
        for item in items:
            yield item
        if not (isinstance(data, dict) and data.get("has_more") and items):
            return
        starting_after = items[-1]["id"]


def _list_bts(client: httpx.Client, ts_from: int, ts_to: int):
    params = [
        ("limit", "100"),
        ("created[gte]", str(ts_from)),
        ("created[lt]", str(ts_to)),
        ("expand[]", "data.source"),
    ]
    return _paginate(client, "/balance_transactions", params)


def _fee_category(description: str | None) -> str:
    """Best-effort Stripe-domain bucket of a standalone fee. Raw description is
    kept alongside; this is a hint, not authority."""
    d = (description or "").lower()
    if "tax" in d:
        return "tax"
    if "invoic" in d:
        return "invoicing"
    if "billing" in d or "usage" in d:
        return "billing_usage"
    return "processing"


def _resolve_customer(client: httpx.Client, charge: dict, cache: dict) -> dict:
    """stripe_id (the stable mapping key) + best-effort name/email."""
    cust_id = charge.get("customer")
    bd = charge.get("billing_details") or {}
    name = bd.get("name")
    email = bd.get("email") or charge.get("receipt_email")
    if cust_id and cust_id not in cache:
        try:
            c = _request(client, "GET", f"/customers/{cust_id}")
            cache[cust_id] = {"name": c.get("name"), "email": c.get("email")}
        except SystemExit:
            cache[cust_id] = {}
    extra = cache.get(cust_id, {})
    return {
        "stripe_id": cust_id,
        "name": name or extra.get("name"),
        "email": email or extra.get("email"),
    }


def _resolve_invoice(client: httpx.Client, charge: dict, cache: dict) -> dict | None:
    inv_id = charge.get("invoice")
    if not inv_id:
        return None
    if inv_id not in cache:
        inv = _request(client, "GET", f"/invoices/{inv_id}")
        currency = inv.get("currency")
        lines = [
            {
                "description": ln.get("description"),
                "quantity": ln.get("quantity"),
                "amount": _amt(ln["amount"], currency) if ln.get("amount") is not None else None,
            }
            for ln in (inv.get("lines", {}).get("data") or [])
        ]
        cache[inv_id] = {
            "stripe_number": inv.get("number"),
            "pdf_url": inv.get("invoice_pdf"),
            "hosted_url": inv.get("hosted_invoice_url"),
            "lines": lines,
        }
    return cache[inv_id]


# ── contract shape — the single source of the event/envelope structure ───────
# Both the producer (sync-plan) and the `contract` example call these, so the
# shape lives once and cannot drift between the two.

def _event_charge(txn, date_iso, customer, invoice, gross, fee, net, currency) -> dict:
    return {
        "kind": "charge",
        "txn": txn,
        "date": date_iso,
        "customer": customer,
        "invoice": invoice,
        "gross": gross,
        "fee": fee,
        "net": net,
        "currency": currency,
        "resolve": {"client_id": None, "invoice_id": None},
    }


def _event_fee(txn, date_iso, amount, currency, category, description) -> dict:
    return {
        "kind": "fee",
        "txn": txn,
        "date": date_iso,
        "amount": amount,
        "currency": currency,
        "category": category,
        "description": description,
    }


def _event_payout(txn, date_iso, amount, currency, description) -> dict:
    return {
        "kind": "payout",
        "txn": txn,
        "date": date_iso,
        "amount": amount,
        "currency": currency,
        "description": description,
    }


def _event_refund(txn, date_iso, amount, currency, description) -> dict:
    return {
        "kind": "refund",
        "txn": txn,
        "date": date_iso,
        "amount": amount,
        "currency": currency,
        "residual": True,
        "description": description,
    }


def _event_other(txn, date_iso, stripe_type, amount, currency) -> dict:
    return {
        "kind": "other",
        "txn": txn,
        "date": date_iso,
        "stripe_type": stripe_type,
        "amount": amount,
        "currency": currency,
        "residual": True,
    }


def _contract_envelope(from_date: str, to_date: str, events: list[dict]) -> dict:
    counts: dict = {}
    for e in events:
        counts[e["kind"]] = counts.get(e["kind"], 0) + 1
    return {
        "source": "stripe",
        "clears_through": "stripe",
        "period": {"from": from_date, "to": to_date},
        "counts": counts,
        "events": events,
    }


# ── commands ────────────────────────────────────────────────────────────────

def _check_connection(key: str) -> dict:
    """One connection's round-trip, reported rather than died — doctor covers
    every connection, so a broken one becomes a finding, not a stop."""
    try:
        with _client(key) as c:
            r = c.get("/balance")
            if r.status_code >= 400:
                cat = 2 if r.status_code in (401, 403) else 5
                return {"ok": False, "category": cat,
                        "error": f"/v1/balance returned {r.status_code}"}
            bal = r.json()
            available = bal.get("available", []) if isinstance(bal, dict) else []
            currencies = sorted({b.get("currency") for b in available
                                 if b.get("currency")})
            return {"ok": True, "livemode": bool(bal.get("livemode")),
                    "currencies": currencies}
    except httpx.RequestError as e:
        return {"ok": False, "category": 5, "error": f"network error: {e}"}
    except ValueError as e:
        return {"ok": False, "category": 5, "error": f"bad response: {e}"}


def cmd_doctor(args, reg: dict | None, wanted: str | None) -> None:
    """Every connection bare; one with --connection. Exit 0 only when every
    examined connection is healthy, else the first failure's category."""
    if wanted is not None or reg is None:
        targets = [_select_connection(reg, wanted)]
    else:
        targets = list(reg["connections"].items())
    connections: dict = {}
    fail_exit = 0
    for cid, entry in targets:
        secret_env = KEY_NAME if entry is None else entry.get("secret_env")
        if not secret_env:
            res = {"ok": False, "category": 6,
                   "error": f"connection {cid!r} is missing 'secret_env'"}
        else:
            key = getattr(args, "api_key", None) or _resolve_env_key(secret_env)[0]
            if not key:
                res = {"ok": False, "category": 2,
                       "error": f"{secret_env} not found in a project .env, "
                                f"{CREDENTIALS_ENV}, or the environment"}
            else:
                res = _check_connection(key)
        if not res.get("ok") and not fail_exit:
            fail_exit = res.get("category") or 5
        res.pop("category", None)
        connections[cid] = res
    _emit({"ok": fail_exit == 0, "connections": connections})
    if fail_exit:
        sys.exit(fail_exit)


def cmd_sync_plan(client: httpx.Client, from_date: str, to_date: str, only_type: str | None) -> dict:
    ts_from, ts_to = _ts(from_date), _ts(to_date)
    cust_cache: dict = {}
    inv_cache: dict = {}
    events: list[dict] = []

    for bt in sorted(_list_bts(client, ts_from, ts_to), key=lambda b: b.get("created", 0)):
        bt_type = bt.get("type")
        date_iso = _day(bt.get("created"))
        currency = bt.get("currency")
        amount = int(bt.get("amount") or 0)
        fee = int(bt.get("fee") or 0)

        if bt_type == "charge":
            kind = "charge"
        elif bt_type == "stripe_fee":
            kind = "fee"
        elif bt_type == "payout":
            kind = "payout"
        elif bt_type == "refund":
            kind = "refund"
        else:
            kind = "other"
        if only_type and kind != only_type:
            continue

        if kind == "charge":
            charge = bt.get("source") if isinstance(bt.get("source"), dict) else {}
            events.append(_event_charge(
                bt["id"], date_iso,
                _resolve_customer(client, charge, cust_cache),
                _resolve_invoice(client, charge, inv_cache),
                _amt(amount, currency), _amt(fee, currency), _amt(amount - fee, currency),
                currency,
            ))
        elif kind == "fee":
            desc = bt.get("description")
            events.append(_event_fee(
                bt["id"], date_iso, _amt(amount, currency), currency,
                _fee_category(desc), desc,
            ))
        elif kind == "payout":
            events.append(_event_payout(
                bt["id"], date_iso, _amt(amount, currency), currency, bt.get("description"),
            ))
        elif kind == "refund":
            events.append(_event_refund(
                bt["id"], date_iso, _amt(amount, currency), currency, bt.get("description"),
            ))
        else:
            events.append(_event_other(
                bt["id"], date_iso, bt_type, _amt(amount, currency), currency,
            ))

    return _contract_envelope(from_date, to_date, events)


def cmd_contract() -> dict:
    """A valid example of the contract sync-plan emits — the shape, not live
    data. Built by the same event builders as the producer, so it cannot drift
    from what sync-plan actually returns. No API key required."""
    return _contract_envelope("2026-01-01", "2026-02-01", [
        _event_charge(
            "txn_1ExampleCharge0000", "2026-01-12",
            {"stripe_id": "cus_Example", "name": "Example Co", "email": "billing@example.com"},
            {"stripe_number": "ABCD-0001",
             "pdf_url": "https://pay.stripe.com/invoice/.../pdf",
             "hosted_url": "https://invoice.stripe.com/i/...",
             "lines": [{"description": "Monthly subscription",
                        "quantity": 1, "amount": "100.00"}]},
            "100.00", "2.50", "97.50", "eur",
        ),
        _event_fee("txn_1ExampleFee000000", "2026-01-31", "1.20", "eur", "tax",
                   "Tax computation fee"),
        _event_payout("txn_1ExamplePayout000", "2026-01-15", "950.00", "eur",
                      "STRIPE PAYOUT"),
        _event_refund("txn_1ExampleRefund000", "2026-01-20", "-30.00", "eur",
                      "Refund for ch_Example"),
        _event_other("txn_1ExampleOther0000", "2026-01-22", "adjustment", "-5.00", "eur"),
    ])


def cmd_invoices_list(client: httpx.Client, from_date: str, to_date: str, status: str | None) -> list:
    params = [
        ("limit", "100"),
        ("created[gte]", str(_ts(from_date))),
        ("created[lt]", str(_ts(to_date))),
    ]
    if status:
        params.append(("status", status))
    out = []
    for inv in _paginate(client, "/invoices", params):
        currency = inv.get("currency")
        out.append({
            "id": inv.get("id"),
            "number": inv.get("number"),
            "status": inv.get("status"),
            "customer": inv.get("customer"),
            "customer_name": inv.get("customer_name"),
            "customer_email": inv.get("customer_email"),
            "total": _amt(inv.get("total") or 0, currency),
            "currency": currency,
            "date": _day(inv.get("created")),
            "pdf_url": inv.get("invoice_pdf"),
            "hosted_url": inv.get("hosted_invoice_url"),
        })
    return out


def cmd_invoices_pdf(client: httpx.Client, invoice_id: str, out: str) -> dict:
    inv = _request(client, "GET", f"/invoices/{invoice_id}")
    pdf_url = inv.get("invoice_pdf")
    if not pdf_url:
        _die(3, "no_pdf", f"invoice {invoice_id} has no invoice_pdf url")
    # invoice_pdf is a fully-qualified URL outside the /v1 base; fetch raw.
    with httpx.Client(timeout=TIMEOUT) as plain:
        try:
            r = plain.get(pdf_url, follow_redirects=True)
            r.raise_for_status()
        except httpx.HTTPError as e:
            _die(5, "pdf_fetch_failed", f"could not download PDF: {e}")
        content = r.content
    dest = Path(out).expanduser()
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_bytes(content)
    return {"ok": True, "invoice": invoice_id, "number": inv.get("number"),
            "out": str(dest), "bytes": len(content)}


def cmd_bt_list(client: httpx.Client, from_date: str, to_date: str, bt_type: str | None) -> list:
    out = []
    for bt in _list_bts(client, _ts(from_date), _ts(to_date)):
        if bt_type and bt.get("type") != bt_type:
            continue
        currency = bt.get("currency")
        out.append({
            "id": bt.get("id"),
            "type": bt.get("type"),
            "date": _day(bt.get("created")),
            "amount": _amt(bt.get("amount") or 0, currency),
            "fee": _amt(bt.get("fee") or 0, currency),
            "net": _amt(int(bt.get("amount") or 0) - int(bt.get("fee") or 0), currency),
            "currency": currency,
            "description": bt.get("description"),
        })
    return out


def cmd_payouts_list(client: httpx.Client, from_date: str, to_date: str) -> list:
    params = [
        ("limit", "100"),
        ("created[gte]", str(_ts(from_date))),
        ("created[lt]", str(_ts(to_date))),
    ]
    out = []
    for po in _paginate(client, "/payouts", params):
        currency = po.get("currency")
        out.append({
            "id": po.get("id"),
            "status": po.get("status"),
            "amount": _amt(po.get("amount") or 0, currency),
            "currency": currency,
            "arrival_date": _day(po.get("arrival_date")),
            "created": _day(po.get("created")),
            "description": po.get("description"),
        })
    return out


# ── dispatch ────────────────────────────────────────────────────────────────

def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    p = argparse.ArgumentParser(prog="stripe", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("--api-key", default=None, help="STRIPE_SECRET_KEY (prefer config/env; avoid on CLI)")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help")
    sub.add_parser("contract")
    sub.add_parser("doctor")

    sp = sub.add_parser("sync-plan")
    sp.add_argument("--from", dest="from_date", required=True)
    sp.add_argument("--to", dest="to_date", required=True)
    sp.add_argument("--only-type", choices=["charge", "fee", "payout", "refund"], default=None)

    inv = sub.add_parser("invoices")
    inv_sub = inv.add_subparsers(dest="subcmd", required=True)
    il = inv_sub.add_parser("list")
    il.add_argument("--from", dest="from_date", required=True)
    il.add_argument("--to", dest="to_date", required=True)
    il.add_argument("--status", default=None)
    ip = inv_sub.add_parser("pdf")
    ip.add_argument("invoice_id")
    ip.add_argument("--out", required=True)

    bt = sub.add_parser("balance-transactions")
    bt_sub = bt.add_subparsers(dest="subcmd", required=True)
    bl = bt_sub.add_parser("list")
    bl.add_argument("--from", dest="from_date", required=True)
    bl.add_argument("--to", dest="to_date", required=True)
    bl.add_argument("--type", dest="bt_type",
                    choices=["charge", "stripe_fee", "payout", "refund"], default=None)

    po = sub.add_parser("payouts")
    po_sub = po.add_subparsers(dest="subcmd", required=True)
    pl = po_sub.add_parser("list")
    pl.add_argument("--from", dest="from_date", required=True)
    pl.add_argument("--to", dest="to_date", required=True)

    # `--connection <id>` is a global selector accepted anywhere on the line
    # (extracted before argparse so it works after the subcommand too).
    argv = sys.argv[1:]
    wanted_conn: str | None = None
    cleaned: list[str] = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--connection" and i + 1 < len(argv):
            wanted_conn = argv[i + 1]; i += 2; continue
        if a.startswith("--connection="):
            wanted_conn = a.split("=", 1)[1]; i += 1; continue
        cleaned.append(a); i += 1

    args = p.parse_args(cleaned)
    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return
    if args.cmd == "contract":
        _emit(cmd_contract())
        return

    reg, _ = _connections_registry()
    if args.cmd == "doctor":
        cmd_doctor(args, reg, wanted_conn)
        return

    cid, entry = _select_connection(reg, wanted_conn)
    allow_write = WRITE_DEFAULT if entry is None else \
        bool(entry.get("allow_write", WRITE_DEFAULT))
    _write_gate(cid, allow_write, args.cmd)
    key = _resolve_key(args, entry, cid)
    try:
        with _client(key) as c:
            if args.cmd == "sync-plan":
                _emit(cmd_sync_plan(c, args.from_date, args.to_date, args.only_type))
            elif args.cmd == "invoices" and args.subcmd == "list":
                _emit(cmd_invoices_list(c, args.from_date, args.to_date, args.status))
            elif args.cmd == "invoices" and args.subcmd == "pdf":
                _emit(cmd_invoices_pdf(c, args.invoice_id, args.out))
            elif args.cmd == "balance-transactions" and args.subcmd == "list":
                _emit(cmd_bt_list(c, args.from_date, args.to_date, args.bt_type))
            elif args.cmd == "payouts" and args.subcmd == "list":
                _emit(cmd_payouts_list(c, args.from_date, args.to_date))
            else:
                _die(6, "unknown_command", f"no handler for {args.cmd!r}")
    finally:
        del key


if __name__ == "__main__":
    main()
