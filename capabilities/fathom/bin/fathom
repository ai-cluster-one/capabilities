#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
#     "psycopg2-binary>=2.9",
# ]
# ///
"""fathom — agent-first CLI for Fathom meeting recordings and transcripts.

This tool is designed to be invoked by agents. Run `fathom help` to load the
full usage contract on demand — do not rely on memorised knowledge of its
surface. It is a sync + I/O adapter over two backends at once: the Fathom
External API (meetings, recordings, transcripts) and a PostgreSQL database
(the consumer's own store) that holds the synced meetings,
transcripts, summaries, and a vocabulary table of speech-to-text corrections.

It syncs meetings with their transcripts in a single pass, lists and filters
them, reads and updates stored meetings, and searches the store at three
levels. It does NOT interpret meeting content: AI summaries are generated by
the host agent (see `fathom guide enrichment`) and written back via `update`.

CONNECTIONS
  Configuration resolves as named connections. Each connection bundles one
  Fathom account and one PostgreSQL database. With no registry the sole
  connection is `default`, resolved by the cascade (first non-empty wins):
    1. flags          --connection only (a secret never has a flag)
    2. project env    .env.local then .env, walking up from $CLAUDE_PROJECT_DIR (else cwd)
    3. user config    $XDG_CONFIG_HOME/fathom/credentials.env (default ~/.config/fathom/)
    4. process env    the keys below
  The project you're in wins; process env is the fallback (so a deployed
  host's injected env governs when no config file is present).

  Credential scope is `user` — install scaffolds the keys into
  ~/.config/fathom/credentials.env. The keys the implicit default resolves:
    FATHOM_API_KEY        secret — Fathom External API key (never on argv)
    FATHOM_DB_HOST        Postgres host, e.g. db.<ref>.example.com
    FATHOM_DB_PASSWORD    secret — Postgres password (never on argv)
    FATHOM_DB_PORT        optional; default 5432
    FATHOM_DB_USER        optional; default postgres
    FATHOM_DB_NAME        optional; default postgres
    FATHOM_DB_SSLMODE     optional; default require (disable for local Postgres)

  A machine that talks to several Fathom accounts / databases declares them in
  ~/.config/fathom/connections.json (or a project's
  capabilities/fathom/connections.json):
    {
      "default": "<id>",
      "connections": {
        "<id>": {
          "db_host": "db.<ref>.example.com",
          "db_port": "5432",
          "db_user": "postgres",
          "db_name": "postgres",
          "db_sslmode": "require",
          "fathom_key_env": "FATHOM_API_KEY_<ID>",
          "db_password_env": "FATHOM_DB_PASSWORD_<ID>",
          "allow_write": true
        }
      }
    }
  Non-secret DB wiring sits literally in the entry; the two secrets are named
  by env-key indirection (fathom_key_env, db_password_env) and resolve through
  the cascade (project .env(.local) → user credentials.env → process env).
  "allow_write": false makes the connection a read-only source: every mutating
  verb (sync, update, transcript, schema, vocab add/remove) exits 4, and no
  flag or env var lifts the gate. Read verbs (list, read, search, scan, grep,
  vocab list) always run.

  Selection: --connection <id>, placed before the command. Unflagged, the
  registry's "default" pointer applies, else the sole entry; several entries
  without a pointer is refused as ambiguous.

DATABASE
  The store is the consumer's own PostgreSQL. Two tables back this CLI:
    fathom      id (bigint PK, the Fathom recording_id), title, recording_start,
                recording_end, language, project, summary, transcript,
                metadata (jsonb), synced_at, enriched_at
    vocabulary  id (serial PK), correct_term (text UNIQUE), variants (text[])
  metadata jsonb holds: participants [{name,email}], invitee_domains,
  share_url, duration_minutes, corrections_applied [{wrong,right,count}].
  `fathom schema` creates both tables if absent (idempotent). `fathom doctor`
  proves the API key, the database credentials, and that the tables exist.
  Standing the store up from scratch — provisioning Postgres, wiring the
  connection, the failure ladder — is the runbook `fathom guide setup`.

COMMANDS
  sync [--created-after ISO] [--force]
        Paginate all Fathom meetings with inline transcripts; per meeting
        upsert metadata, process the transcript (merge speaker turns, apply
        vocabulary corrections), and save. Meetings that already have a stored
        transcript are not re-processed (metadata is still updated) unless
        --force. --created-after limits to meetings created after an ISO ts.
  list [--language LANG] [--has-transcript true|false] [--participant NAME]
        List stored meetings, newest first, with the given filters.
  read <id>
        The full stored meeting: metadata, summary, and transcript text.
  update <id> [--summary TEXT] [--project NAME] [--metadata JSON]
        Set fields on a stored meeting. --summary stamps enriched_at; --project
        sets/clears the project tag (empty clears); --metadata merges a JSON
        object into the metadata column.
  transcript <id> [--title TITLE]
        Fetch one transcript from the Fathom recordings API, apply vocabulary
        corrections, and upsert it (a fallback / force-refresh; sync handles
        this automatically).
  search <query>
        Match across title, summary, and metadata (participants, domains).
  scan <query>
        Match summaries only; returns a snippet around each match.
  grep <query> [--max-matches N]
        Full-text match across transcript bodies; returns matched lines
        (default 5 per meeting).
  vocab list
        List vocabulary entries (canonical term + variants).
  vocab add <term> [--variants "a, b, c"]
        Add/update a canonical term and its incorrect variants.
  vocab remove <term>
        Remove a vocabulary entry.
  schema
        Create the fathom and vocabulary tables if absent (idempotent DDL).

CONTRACT VERBS
  help                  This usage contract, verbatim.
  doctor [--connection ID]
                        Cheapest authenticated round-trip per connection:
                        proves the API key, the DB credentials, and the tables.
  connections           Resolution report — every connection, every value, its
                        winning tier and source, secrets masked. Local only.
  stub                  The one-line awareness text.
  manifest [--json]     The machine-readable declaration.
  guide [<topic>]       Upstream guide menu / one guide's body, fetched live.
  ids list|get|set|rm   The project identifiers envelope, managed.
  refs                  The project's reference files, from front-matter.

I/O CONTRACT
  Success is JSON on stdout. Failure is {"error": {"code","message","hint"?,
  "status"?}} on stderr; the exit code carries the category. Progress during
  sync prints to stderr; stdout stays clean for the final JSON.

EXIT CODES
  0 success   2 auth (missing/rejected API key or DB credentials, 401/403)
  3 not found (recording absent, missing table, 404)
  4 policy refusal (project gate, or a write verb on a read-only connection)
  5 server/network (timeout, connection error, 429 after retries, 5xx, DB down)
  6 input/validation (bad argument, malformed JSON, ambiguous connection)
"""

import argparse
import json
import os
import re
import sys
import time
from datetime import datetime
from pathlib import Path
from typing import NoReturn

import httpx
import psycopg2
from psycopg2.extras import Json

# ── Declaration ────────────────────────────────────────────────────────────────

NAME = "fathom"
PROTOCOL = 2
SUMMARY = ("Fathom CLI over the External API + a PostgreSQL store — sync "
           "meetings and transcripts in one pass, read/update stored meetings, "
           "manage a vocabulary, and search the store at three levels.")
SCOPE = "user"      # personal-account tool: one human, one Fathom account
CRED_KEYS = [       # the implicit default connection; a registry entry supplies these per id
    {"key": "FATHOM_API_KEY", "secret": True, "required": True,
     "note": "Fathom External API key"},
    {"key": "FATHOM_DB_HOST", "secret": False, "required": True,
     "note": "Postgres host, e.g. db.<ref>.example.com"},
    {"key": "FATHOM_DB_PASSWORD", "secret": True, "required": True,
     "note": "Postgres password"},
    {"key": "FATHOM_DB_PORT", "secret": False, "required": False,
     "note": "Postgres port (default 5432)"},
    {"key": "FATHOM_DB_USER", "secret": False, "required": False,
     "note": "Postgres user (default postgres)"},
    {"key": "FATHOM_DB_NAME", "secret": False, "required": False,
     "note": "Postgres database (default postgres)"},
    {"key": "FATHOM_DB_SSLMODE", "secret": False, "required": False,
     "note": "SSL mode (default require; disable for a local non-TLS Postgres)"},
]
WRITE_VERBS = {     # verbs that mutate the consumer's database
    "sync", "update", "transcript", "schema", "vocab-add", "vocab-remove",
}
WRITE_DEFAULT = True    # writes stay inside a database the consumer owns
DOCS_BASE = ("https://raw.githubusercontent.com/ai-cluster-one/capabilities/"
             "main/capabilities/fathom/guides/")
TOPICS = ["enrichment", "setup"]
STATE = False       # data lives in the remote DB; only the guides cache is local
POST_INSTALL = [
    {"cmd": f"{NAME} guide setup",
     "note": "storage-engine setup runbook: provision Postgres, wire creds, "
             "create the tables, verify with doctor"},
]

BASE_URL = "https://api.fathom.ai/external/v1"
TIMEOUT = httpx.Timeout(60.0)
MAX_RETRIES = 3

_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))
_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / NAME / "credentials.env"


# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding capabilities/, legacy .capabilities/,
    .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / "capabilities" / "settings.json").is_file()
                or (d / ".capabilities").is_dir()
                or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_capabilities_dir(root: Path) -> Path:
    """The active project envelope root.

    `capabilities/` is canonical. A legacy `.capabilities/` remains readable
    until `capabilities init` migrates it. If both exist, the canonical tree
    wins once it carries settings.json; otherwise the legacy configured tree
    remains active so merely creating an empty visible directory loses no gate.
    """
    current = root / "capabilities"
    legacy = root / ".capabilities"
    if (current / "settings.json").is_file() or not legacy.is_dir():
        return current
    return legacy


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _auth_context() -> dict | None:
    """Optional runtime authority envelope passed by an ingress/service.

    Absence means the ordinary project gate is the whole policy. Presence means
    a request-scoped authority layer exists and must fail closed before any
    credential or network work happens.
    """
    raw = os.environ.get("CAPABILITIES_AUTH_CONTEXT")
    if not raw:
        return None
    try:
        if raw.lstrip().startswith("{"):
            data = json.loads(raw)
        else:
            data = json.loads(Path(raw).read_text())
    except (OSError, ValueError) as e:
        _die(4, "auth_context_unreadable",
             "runtime authority context could not be read",
             f"{raw}: {e}")
    if not isinstance(data, dict):
        _die(4, "auth_context_invalid",
             "runtime authority context is not an object")
    return data


def _auth_capability_allowed(rule) -> bool:
    if rule is True or rule == "*":
        return True
    if rule in (False, None):
        return False
    if isinstance(rule, dict):
        if rule.get("deny") is True:
            return False
        if rule.get("enabled") is False or rule.get("allow") is False:
            return False
        return True
    return False


def _auth_gate() -> None:
    ctx = _auth_context()
    if ctx is None:
        return
    allowed = ctx.get("allowed_capabilities")
    if allowed is None:
        return
    if allowed is True or allowed == "*":
        return
    if isinstance(allowed, list):
        if NAME in allowed or "*" in allowed:
            return
    elif isinstance(allowed, dict):
        if _auth_capability_allowed(allowed.get(NAME, allowed.get("*"))):
            return
    else:
        _die(4, "auth_context_invalid",
             "runtime authority context has invalid allowed_capabilities")
    source = ctx.get("source") or "runtime"
    role = ctx.get("sender_role") or ctx.get("role") or "unknown"
    chat = ctx.get("chat_id") or "unknown"
    _die(4, "capability_not_authorized",
         f"{NAME} is not authorized for this {source} request",
         f"role={role}; chat_id={chat}; adjust runtime authority policy instead of bypassing the gate")


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks.

    If an ingress supplied CAPABILITIES_AUTH_CONTEXT, that request-scoped gate
    is stricter and also runs here, before credentials or network calls.
    """
    _auth_gate()
    root = _project_root()
    if root is None:
        return
    gate_file = _project_capabilities_dir(root) / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project's active capabilities/."""
    root = _project_root()
    return (_project_capabilities_dir(root) / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None:
            envelope = _project_capabilities_dir(root)
            if (envelope / "settings.json").is_file():
                return envelope / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import urllib.error as _ue
    import urllib.request as _ur
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        req = _ur.Request(url, headers=headers)
        with _ur.urlopen(req, timeout=10.0) as resp:
            text = resp.read().decode(resp.headers.get_content_charset() or "utf-8")
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(text); return
    except _ue.HTTPError as e:
        if e.code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if e.code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        err = f"upstream returned {e.code}"
    except _ue.URLError as e:
        err = str(e.reason)
    except OSError as e:
        err = str(e)
    if cache.exists():
        sys.stderr.write(json.dumps(
            {"warning": f"upstream unreachable; serving cached copy ({err})"},
            ensure_ascii=False) + "\n")
        _emit(cache.read_text()); return
    _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _render_ids_markdown(data: dict) -> str:
    """Render the {label: {value, note}} envelope as the labelled markdown
    list the manager's `capabilities ids <NAME>` also produces — one shared
    format across the ids surface and the identifiers section of `help`."""
    lines: list[str] = []
    for label, entry in sorted(data.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        v = entry.get("value")
        vs = f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"
        line = f"- **{label}**: {vs}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    return "\n".join(lines)


def _identifiers_section() -> str:
    """The Identifiers block appended to the bare top-level help — deterministic
    first-touch surfacing of `capabilities/<NAME>/identifiers.json` so an
    agent following the `<NAME> help` startup protocol loads the discovered
    labels/values/notes into context at once. Empty when no project envelope
    or nothing recorded (do not bloat help with an empty section)."""
    envdir = _env_dir()
    if envdir is None:
        return ""
    ids_file = envdir / "identifiers.json"
    if not ids_file.exists():
        return ""
    try:
        data = json.loads(ids_file.read_text())
    except (OSError, ValueError):
        return ""
    if not isinstance(data, dict) or not data:
        return ""
    header = (
        "\n═══ Identifiers ═════════════════════════════════════════════════════════════\n\n"
        f"Structural lookups discovered for `{NAME}` in this project. Fetch a single\n"
        f"raw value with `{NAME} ids get <label>`; the full envelope is also at\n"
        f"`capabilities ids {NAME}`.\n\n"
    )
    return header + _render_ids_markdown(data) + "\n"


def _cmd_help() -> None:
    """Bare top-level help: the CLI's HELP body (module-level `HELP` if
    defined, else the module docstring), then the project's Identifiers
    section. Only fires when no extra args follow — per-verb help stays
    untouched so `<NAME> help <subcommand>` is not intercepted."""
    g = globals()
    text = g.get("HELP") or g.get("__doc__") or ""
    if text.startswith("\n"):
        text = text.lstrip("\n")
    sys.stdout.write(text)
    if text and not text.endswith("\n"):
        sys.stdout.write("\n")
    section = _identifiers_section()
    if section:
        sys.stdout.write(section)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not (envdir.parent / "settings.json").is_file():
            _die(6, "no_envelope", "no capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved.

    `help` is a contract verb only when bare (no extra args) — the top-level
    dump plus the Identifiers section. `<NAME> help <subcommand>` falls
    through to the CLI so per-verb help stays clean."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    elif cmd == "help" and len(argv) == 1:
        _cmd_help()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


# >>> contract: connections (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

def _resolve_env_key(key: str) -> tuple[str | None, str | None, Path | None]:
    """Resolve one env key through cascade tiers 2-4: project .env(.local) →
    user credentials.env → process env. Returns (value, tier, source)."""
    root = _project_root()
    if root is not None:
        for fname in (".env.local", ".env"):
            val = _parse_env_file(root / fname).get(key)
            if val:
                return val, "project", root / fname
    val = _parse_env_file(CREDENTIALS_ENV).get(key)
    if val:
        return val, "user", CREDENTIALS_ENV
    val = os.environ.get(key)
    if val:
        return val, "env", None
    return None, None, None


def _mask(value: str) -> str:
    return ("…" + value[-4:]) if len(value) >= 8 else "****"


def _connections_registry() -> tuple[dict | None, Path | None]:
    """The connections envelope and its path: project envelope first, else the
    user config home. First found wins, never merged; (None, None) when neither
    declares one (the implicit default connection applies)."""
    envdir = _env_dir()
    candidates = ([envdir / "connections.json"] if envdir else []) + \
                 [_CONFIG_HOME / NAME / "connections.json"]
    for reg_file in candidates:
        if not reg_file.is_file():
            continue
        try:
            raw = json.loads(reg_file.read_text())
        except (ValueError, OSError) as e:
            _die(6, "bad_config", f"cannot read {reg_file}: {e}")
        if not isinstance(raw, dict) or not isinstance(raw.get("connections"), dict) \
                or not raw["connections"]:
            _die(6, "bad_config", f"{reg_file} is not a connections envelope",
                 'expected {"default": "<id>", "connections": { ... }}')
        return raw, reg_file
    return None, None


def _select_connection(reg: dict | None, wanted: str | None) -> tuple[str, dict | None]:
    """flag → default pointer → sole entry → die 6. No registry → the implicit
    default. A connection's own `address` field selects it too (used where a
    connection carries a human-recognizable address; absent fields never match)."""
    if reg is None:
        if wanted and wanted != "default":
            _die(6, "unknown_connection",
                 "no connections registry; the sole connection is 'default'",
                 "the implicit default resolves from the credential cascade")
        return "default", None
    conns = reg["connections"]
    if wanted:
        if wanted in conns:
            return wanted, conns[wanted]
        for cid, entry in conns.items():
            if (entry or {}).get("address", "").lower() == wanted.lower():
                return cid, entry
        _die(6, "unknown_connection", f"no connection matches {wanted!r}",
             f"known: {', '.join(conns)}")
    default = reg.get("default")
    if default:
        if default not in conns:
            _die(6, "bad_default", f"default points to unknown connection {default!r}",
                 f"known: {', '.join(conns)}")
        return default, conns[default]
    if len(conns) == 1:
        cid = next(iter(conns))
        return cid, conns[cid]
    _die(6, "ambiguous_connection",
         f"registry defines {len(conns)} connections and no default; "
         f"pass --connection <id>",
         f"known: {', '.join(conns)}")


def _write_gate(conn_id: str, allow_write: bool, verb: str) -> None:
    """Policy from the committed registry; nothing in the cascade lifts it."""
    if verb in WRITE_VERBS and not allow_write:
        _die(4, "read_only",
             f"connection {conn_id!r} does not allow writes",
             "Do not lift the gate yourself — ask the user; granting is "
             "`allow_write: true` on this connection in connections.json.")


def _key_report(key: str, secret: bool, required: bool,
                value: str | None, tier: str | None, source) -> dict:
    return {"key": key, "secret": secret, "required": required,
            "set": bool(value), "tier": tier if value else None,
            "source": str(source) if (value and source) else None,
            "value": (_mask(value) if secret else value) if value else None}


def _missing_required(keys: list) -> list:
    """Required report rows (from _key_report) that did not resolve through the
    cascade — empty ⇒ credentials present. The primitive behind doctor's
    network-free readiness gate, read from the same per-key resolution
    `connections` reports, so the gate and the report can never disagree."""
    return [k["key"] for k in keys if k["required"] and not k["set"]]


def _doctor_gate(report: dict, wanted: str | None) -> None:
    """doctor's network-free readiness gate. Refuse with exit 2 — naming the
    unresolved required keys, before any round-trip — when a connection under
    test cannot resolve its required config through the cascade, so readiness is
    judged by the same resolution `connections` reports, never a parallel check.
    Checks the selected connection, else every connection in the report."""
    conns = report.get("connections") or {}
    targets = [wanted] if (wanted and wanted in conns) else list(conns)
    problems: dict = {}
    for cid in targets:
        miss = _missing_required((conns.get(cid) or {}).get("keys") or [])
        if miss:
            problems[cid] = miss
    if problems:
        detail = "; ".join(f"{c}: {', '.join(ks)}" for c, ks in sorted(problems.items()))
        _die(2, "credentials_missing",
             f"unresolved required config — {detail}",
             f"set each in the project .env/.env.local, the user credentials.env, "
             f"or process env; `{NAME} connections` shows where every value resolves")

# <<< contract: connections <<<


# ── I/O envelope ────────────────────────────────────────────────────────────────


# ── Cascade & gate ──────────────────────────────────────────────────────────────


# ── Connections ─────────────────────────────────────────────────────────────────

# Each connection bundles two secrets (the Fathom API key and the DB password)
# and four non-secret DB fields. See deviations.md — the standard's single
# `secret_env` becomes a named pair, fathom_key_env + db_password_env.

DB_FIELDS = (   # (entry field, env key for the implicit default, default, required)
    ("db_host", "FATHOM_DB_HOST", None, True),
    ("db_port", "FATHOM_DB_PORT", "5432", False),
    ("db_user", "FATHOM_DB_USER", "postgres", False),
    ("db_name", "FATHOM_DB_NAME", "postgres", False),
    ("db_sslmode", "FATHOM_DB_SSLMODE", "require", False),
)


def _build_conn(cid: str, entry: dict | None) -> tuple[dict | None, dict | None]:
    """Materialize one connection. Returns (conn, problem) — problem is an error
    dict ({"exit","code","message","hint"?}) instead of a die, so doctor can
    report every connection rather than stopping at the first."""
    if entry is None:   # the implicit default — flat keys through the cascade
        fathom_key, _, _ = _resolve_env_key("FATHOM_API_KEY")
        db_password, _, _ = _resolve_env_key("FATHOM_DB_PASSWORD")
        db = {}
        for field, env_key, default, _required in DB_FIELDS:
            val, _, _ = _resolve_env_key(env_key)
            db[field] = val or default
        missing = []
        if not fathom_key:
            missing.append("FATHOM_API_KEY")
        if not db_password:
            missing.append("FATHOM_DB_PASSWORD")
        if not db["db_host"]:
            missing.append("FATHOM_DB_HOST")
        if missing:
            return None, {
                "exit": 2, "code": "missing_credentials",
                "message": f"unset: {', '.join(missing)}",
                "hint": f"set them in the project .env(.local), {CREDENTIALS_ENV}, "
                        f"or the environment — or declare a connections registry "
                        f"(~/.config/{NAME}/connections.json). Full runbook: "
                        f"`{NAME} guide setup`"}
        return {"id": cid, "allow_write": WRITE_DEFAULT, "fathom_key": fathom_key,
                "db_password": db_password, **db}, None
    # registry entry — non-secret DB fields literal, secrets by env-key indirection
    fathom_env = entry.get("fathom_key_env")
    db_pw_env = entry.get("db_password_env")
    if not fathom_env or not db_pw_env:
        miss = [k for k in ("fathom_key_env", "db_password_env") if not entry.get(k)]
        return None, {"exit": 6, "code": "no_secret_env",
                      "message": f"connection {cid!r} is missing: {', '.join(miss)}"}
    fathom_key, _, _ = _resolve_env_key(fathom_env)
    db_password, _, _ = _resolve_env_key(db_pw_env)
    unset = [e for e, v in ((fathom_env, fathom_key), (db_pw_env, db_password)) if not v]
    if unset:
        return None, {
            "exit": 2, "code": "missing_secret",
            "message": f"env var(s) {', '.join(unset)} (for connection {cid!r}) unset",
            "hint": f"set them in the project's .env / .env.local, "
                    f"{CREDENTIALS_ENV}, or the environment"}
    db = {}
    for field, _env_key, default, required in DB_FIELDS:
        val = entry.get(field) or default
        if required and not val:
            return None, {"exit": 6, "code": "incomplete_connection",
                          "message": f"connection {cid!r} missing: {field}"}
        db[field] = str(val) if val is not None else None
    return {"id": cid, "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "fathom_key": fathom_key, "db_password": db_password, **db}, None


def _resolve_conn(args) -> dict:
    reg, _ = _connections_registry()
    cid, entry = _select_connection(reg, getattr(args, "connection", None))
    conn, problem = _build_conn(cid, entry)
    if problem:
        _die(problem["exit"], problem["code"], problem["message"], problem.get("hint"))
    return conn


def _connections_report() -> dict:
    """The resolution report — every connection, every value, its winning tier
    and source, secrets masked. Local only: no network, no login attempt."""
    reg, reg_path = _connections_registry()
    report: dict = {"default": None, "connections": {}}
    if reg is None:
        keys = []
        for k in CRED_KEYS:
            value, tier, source = _resolve_env_key(k["key"])
            keys.append(_key_report(k["key"], k["secret"], k["required"],
                                    value, tier, source))
        report["default"] = "default"
        report["connections"]["default"] = {"allow_write": WRITE_DEFAULT, "keys": keys}
        return report
    conns = reg["connections"]
    report["default"] = reg.get("default") or \
        (next(iter(conns)) if len(conns) == 1 else None)
    for cid, entry in conns.items():
        entry = entry if isinstance(entry, dict) else {}
        keys = []
        for field, _env_key, _default, required in DB_FIELDS:
            value = entry.get(field)
            keys.append(_key_report(field, False, required,
                                    str(value) if value is not None else None,
                                    "connection", reg_path))
        for env_field in ("fathom_key_env", "db_password_env"):
            secret_env = entry.get(env_field)
            if secret_env:
                value, tier, source = _resolve_env_key(secret_env)
                keys.append(_key_report(secret_env, True, True, value, tier, source))
            else:
                keys.append(_key_report(env_field, False, True, None, None, None))
        report["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": keys}
    return report


def _cmd_connections() -> None:
    _emit(_connections_report())


# ── Contract verbs ──────────────────────────────────────────────────────────────


# ── Fathom API ──────────────────────────────────────────────────────────────────


def _fathom_get(client: httpx.Client, path: str, params: dict | None = None) -> dict:
    """GET the Fathom API with bounded, backed-off retries. 4xx maps to the
    exit taxonomy; 429/5xx retry then die 5."""
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = client.get(path, params=params)
        except httpx.TimeoutException:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5); continue
            _die(5, "timeout", f"request timed out: GET {path}", "Fathom was unresponsive")
        except httpx.RequestError as e:
            _die(5, "network_error", f"network error: {e}", "check connectivity")
        if resp.status_code == 429:
            retry_after = float(resp.headers.get("Retry-After")
                                or resp.headers.get("RateLimit-Reset")
                                or attempt * 1.5)
            if attempt < MAX_RETRIES:
                time.sleep(retry_after + 1); continue
            _die(5, "rate_limited", "rate-limited by Fathom", status=429)
        if resp.status_code >= 500:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5); continue
            _die(5, "server_error", f"Fathom returned {resp.status_code}",
                 status=resp.status_code)
        if resp.status_code in (401, 403):
            _die(2, "auth", "Fathom rejected the API key",
                 "check FATHOM_API_KEY", status=resp.status_code)
        if resp.status_code == 404:
            _die(3, "not_found", f"Fathom: {path} not found", status=404)
        if resp.status_code >= 400:
            _die(6, "bad_request", f"Fathom returned {resp.status_code}: {resp.text[:300]}",
                 status=resp.status_code)
        try:
            return resp.json() if resp.text else {}
        except ValueError as e:
            _die(5, "bad_response", f"invalid JSON from Fathom: {e}")
    _die(5, "exhausted", f"GET {path} failed after {MAX_RETRIES} attempts")


def _fathom_client(conn: dict) -> httpx.Client:
    return httpx.Client(base_url=BASE_URL, headers={"X-Api-Key": conn["fathom_key"]},
                        timeout=TIMEOUT, follow_redirects=True)


# ── Database ────────────────────────────────────────────────────────────────────


def _db_connect(conn: dict):
    try:
        return psycopg2.connect(
            host=conn["db_host"], port=conn["db_port"], dbname=conn["db_name"],
            user=conn["db_user"], password=conn["db_password"],
            sslmode=conn["db_sslmode"], connect_timeout=15,
        )
    except psycopg2.OperationalError as e:
        msg = str(e).lower()
        if "password" in msg or "authentication" in msg or "role" in msg:
            _die(2, "db_auth", f"database authentication failed: {e}".strip(),
                 f"check FATHOM_DB_USER / FATHOM_DB_PASSWORD for connection {conn['id']!r} "
                 f"— `{NAME} guide setup`")
        _die(5, "db_unreachable", f"cannot reach database: {e}".strip(),
             f"check FATHOM_DB_HOST / FATHOM_DB_PORT / FATHOM_DB_SSLMODE for "
             f"connection {conn['id']!r} — `{NAME} guide setup`")


# ── Domain logic (ported) ────────────────────────────────────────────────────────


def _iso(dt) -> str | None:
    return dt.isoformat() if dt else None


def compute_duration_minutes(start, end):
    try:
        s = datetime.fromisoformat(start.replace("Z", "+00:00"))
        e = datetime.fromisoformat(end.replace("Z", "+00:00"))
        return int((e - s).total_seconds() / 60)
    except (ValueError, TypeError, AttributeError):
        return None


def load_vocabulary(cur):
    cur.execute("SELECT correct_term, variants FROM vocabulary WHERE variants IS NOT NULL")
    return [(row[0], row[1]) for row in cur.fetchall()]


def apply_vocabulary_corrections(text, vocabulary):
    if not vocabulary or not text:
        return text, []
    corrections_applied = []
    for correct_term, variants in vocabulary:
        for variant in (variants or []):
            pattern = re.compile(re.escape(variant), re.IGNORECASE)
            count = len(pattern.findall(text))
            if count > 0:
                text = pattern.sub(correct_term, text)
                corrections_applied.append({"wrong": variant, "right": correct_term, "count": count})
    return text, corrections_applied


def merge_transcript_turns(entries):
    if not entries:
        return []
    merged = []
    current_speaker = None
    current_texts: list = []
    current_timestamp = None
    for entry in entries:
        speaker = entry["speaker"]["display_name"]
        text = entry["text"]
        timestamp = entry["timestamp"]
        if speaker == current_speaker:
            current_texts.append(text)
        else:
            if current_speaker is not None:
                merged.append({"speaker": current_speaker, "timestamp": current_timestamp,
                               "text": " ".join(current_texts)})
            current_speaker = speaker
            current_texts = [text]
            current_timestamp = timestamp
    if current_speaker is not None:
        merged.append({"speaker": current_speaker, "timestamp": current_timestamp,
                       "text": " ".join(current_texts)})
    return merged


def extract_speakers(transcript_entries):
    seen: dict = {}
    for entry in transcript_entries:
        speaker = entry.get("speaker", {})
        name = speaker.get("display_name", "")
        email = speaker.get("matched_calendar_invitee_email") or ""
        if name and name not in seen:
            seen[name] = email
    return [{"name": n, "email": e} for n, e in seen.items()]


def merge_participants(calendar_invitees, transcript_speakers):
    participants: dict = {}
    for inv in (calendar_invitees or []):
        name = inv.get("name", inv.get("email", ""))
        email = inv.get("email", "")
        if name:
            participants[name.lower()] = {"name": name, "email": email}
    for speaker in (transcript_speakers or []):
        name = speaker.get("name", "")
        email = speaker.get("email", "")
        key = name.lower()
        if key not in participants:
            email_match = False
            if email:
                for p in participants.values():
                    if p["email"] and p["email"].lower() == email.lower():
                        email_match = True
                        break
            if not email_match:
                participants[key] = {"name": name, "email": email}
    return list(participants.values())


def format_transcript_text(merged_turns):
    lines = []
    for turn in merged_turns:
        lines.append(f"[{turn['timestamp']}] **{turn['speaker']}:** {turn['text']}")
        lines.append("")
    return "\n".join(lines)


def process_meeting_metadata(meeting):
    invitees = meeting.get("calendar_invitees", [])
    participants = []
    for inv in invitees:
        p = {"name": inv.get("name", inv.get("email", ""))}
        if inv.get("email"):
            p["email"] = inv["email"]
        participants.append(p)
    invitee_domains = list(set(
        inv.get("email_domain", "") for inv in invitees if inv.get("email_domain")))
    recording_start = meeting.get("recording_start_time", "")
    recording_end = meeting.get("recording_end_time", "")
    duration = compute_duration_minutes(recording_start, recording_end)
    metadata = {
        "participants": participants,
        "invitee_domains": invitee_domains,
        "share_url": meeting.get("share_url", ""),
    }
    if duration:
        metadata["duration_minutes"] = duration
    return recording_start, recording_end, metadata


def process_inline_transcript(meeting, vocabulary, existing_metadata):
    entries = meeting.get("transcript", [])
    if not entries:
        return None, {}
    transcript_speakers = extract_speakers(entries)
    existing_participants = (existing_metadata or {}).get("participants", [])
    merged_participants = merge_participants(existing_participants, transcript_speakers)
    merged_turns = merge_transcript_turns(entries)
    transcript_text = format_transcript_text(merged_turns)
    corrections_applied = []
    if vocabulary:
        transcript_text, corrections_applied = apply_vocabulary_corrections(transcript_text, vocabulary)
    metadata_updates = {"participants": merged_participants}
    if corrections_applied:
        metadata_updates["corrections_applied"] = corrections_applied
    return transcript_text, metadata_updates


# ── Domain commands ──────────────────────────────────────────────────────────────


def cmd_sync(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    vocabulary = load_vocabulary(cur)

    params = {"calendar_invitees_domains_type": "all", "include_transcript": "true"}
    if args.created_after:
        params["created_after"] = args.created_after

    fetched = new = updated = transcripts = 0
    cursor = None
    with _fathom_client(conn) as client:
        while True:
            req_params = dict(params)
            if cursor:
                req_params["cursor"] = cursor
            result = _fathom_get(client, "/meetings", req_params)
            items = result.get("items", [])
            next_cursor = result.get("next_cursor", "")

            for meeting in items:
                recording_id = meeting["recording_id"]
                fetched += 1
                recording_start, recording_end, metadata = process_meeting_metadata(meeting)

                cur.execute("SELECT id, transcript IS NOT NULL FROM fathom WHERE id = %s",
                            (recording_id,))
                existing = cur.fetchone()
                has_transcript = existing[1] if existing else False

                transcript_text = None
                if not has_transcript or args.force:
                    transcript_text, transcript_meta = process_inline_transcript(
                        meeting, vocabulary, metadata)
                    if transcript_meta:
                        metadata.update(transcript_meta)
                    if transcript_text:
                        transcripts += 1

                if existing:
                    if transcript_text:
                        cur.execute(
                            """UPDATE fathom SET title=%s, recording_start=%s,
                                recording_end=%s, language=%s, transcript=%s,
                                metadata = metadata || %s, synced_at = now()
                               WHERE id=%s""",
                            (meeting.get("title", ""), recording_start or None,
                             recording_end or None, meeting.get("transcript_language", ""),
                             transcript_text, Json(metadata), recording_id))
                    else:
                        cur.execute(
                            """UPDATE fathom SET title=%s, recording_start=%s,
                                recording_end=%s, language=%s,
                                metadata = metadata || %s, synced_at = now()
                               WHERE id=%s""",
                            (meeting.get("title", ""), recording_start or None,
                             recording_end or None, meeting.get("transcript_language", ""),
                             Json(metadata), recording_id))
                    updated += 1
                else:
                    cur.execute(
                        """INSERT INTO fathom (id, title, recording_start, recording_end,
                            language, transcript, metadata, synced_at)
                           VALUES (%s,%s,%s,%s,%s,%s,%s, now())""",
                        (recording_id, meeting.get("title", ""), recording_start or None,
                         recording_end or None, meeting.get("transcript_language", ""),
                         transcript_text, Json(metadata)))
                    new += 1

            db.commit()
            if not next_cursor:
                break
            cursor = next_cursor
            sys.stderr.write(f"  ... fetched {fetched} meetings so far\n")

    cur.execute("SELECT count(*), count(transcript) FROM fathom")
    total_meetings, total_transcripts = cur.fetchone()
    cur.close()
    db.close()
    _emit({"fetched": fetched, "new": new, "updated": updated,
           "new_transcripts": transcripts, "total_meetings": total_meetings,
           "total_transcripts": total_transcripts})


def cmd_list(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    conditions, params = [], []
    if args.language:
        conditions.append("language = %s"); params.append(args.language)
    if args.has_transcript is not None:
        conditions.append("transcript IS NOT NULL" if args.has_transcript
                          else "transcript IS NULL")
    if args.participant:
        conditions.append("metadata::text ILIKE %s"); params.append(f"%{args.participant}%")
    where = "WHERE " + " AND ".join(conditions) if conditions else ""
    cur.execute(
        f"""SELECT id, title, recording_start, recording_end, language, summary,
                   transcript IS NOT NULL, metadata
            FROM fathom {where} ORDER BY recording_start DESC""", params)
    rows = cur.fetchall()
    meetings = []
    for rid, title, rec_start, rec_end, lang, summary, has_transcript, metadata in rows:
        md = metadata or {}
        meetings.append({
            "id": rid, "title": title, "recording_start": _iso(rec_start),
            "language": lang, "duration_minutes": md.get("duration_minutes"),
            "participants": [p.get("name", "") for p in md.get("participants", [])],
            "has_summary": bool(summary), "has_transcript": has_transcript})
    cur.execute("SELECT count(*), count(transcript) FROM fathom")
    total, with_transcript = cur.fetchone()
    cur.close(); db.close()
    _emit({"count": len(meetings), "total": total, "with_transcripts": with_transcript,
           "meetings": meetings})


def cmd_read(args, conn):
    rid = _parse_id(args.id)
    db = _db_connect(conn)
    cur = db.cursor()
    cur.execute(
        """SELECT id, title, recording_start, recording_end, language, project,
                  summary, transcript, metadata FROM fathom WHERE id = %s""", (rid,))
    row = cur.fetchone()
    cur.close(); db.close()
    if not row:
        _die(3, "not_found", f"recording {rid} not in the database",
             f"`{NAME} sync` to populate, or `{NAME} transcript {rid}` to fetch one")
    _id, title, rec_start, rec_end, language, project, summary, transcript, metadata = row
    md = metadata or {}
    _emit({
        "id": _id, "title": title, "recording_start": _iso(rec_start),
        "recording_end": _iso(rec_end), "language": language, "project": project,
        "duration_minutes": md.get("duration_minutes"),
        "participants": md.get("participants", []),
        "share_url": md.get("share_url"), "summary": summary,
        "has_transcript": bool(transcript), "transcript": transcript, "metadata": md})


def cmd_update(args, conn):
    rid = _parse_id(args.id)
    updates, params, changed = [], [], []
    if args.summary is not None:
        updates += ["summary = %s", "enriched_at = now()"]; params.append(args.summary)
        changed.append("summary")
    if args.project is not None:
        updates.append("project = %s"); params.append(args.project or None)
        changed.append("project")
    if args.metadata_json:
        try:
            extra = json.loads(args.metadata_json)
        except json.JSONDecodeError as e:
            _die(6, "bad_json", f"invalid JSON for --metadata: {e}")
        updates.append("metadata = metadata || %s"); params.append(Json(extra))
        changed.append("metadata")
    if not updates:
        _die(6, "nothing_to_update", "nothing to update",
             "pass --summary, --project, or --metadata")
    db = _db_connect(conn)
    cur = db.cursor()
    cur.execute("SELECT id FROM fathom WHERE id = %s", (rid,))
    if not cur.fetchone():
        cur.close(); db.close()
        _die(3, "not_found", f"recording {rid} not in the database")
    params.append(rid)
    cur.execute(f"UPDATE fathom SET {', '.join(updates)} WHERE id = %s", params)
    db.commit()
    cur.close(); db.close()
    out = {"id": rid, "updated": changed}
    if args.summary is not None:
        out["summary"] = args.summary
    if args.project is not None:
        out["project"] = args.project or None
    _emit(out)


def cmd_transcript(args, conn):
    rid = _parse_id(args.id)
    db = _db_connect(conn)
    cur = db.cursor()
    cur.execute(
        "SELECT title, recording_start, recording_end, language, metadata FROM fathom WHERE id = %s",
        (rid,))
    row = cur.fetchone()

    with _fathom_client(conn) as client:
        result = _fathom_get(client, f"/recordings/{rid}/transcript")
        entries = result.get("transcript", [])
        if not entries:
            cur.close(); db.close()
            _die(3, "not_found", f"no transcript found for recording {rid}")
        if not row:
            meeting_data = _fathom_get(client, f"/recordings/{rid}")
            title = args.title or meeting_data.get("title", "Untitled Meeting")
            recording_start = meeting_data.get("recording_start_time")
            recording_end = meeting_data.get("recording_end_time")
            language = meeting_data.get("transcript_language", "")
            invitees = meeting_data.get("calendar_invitees", [])
            participants = []
            for inv in invitees:
                p = {"name": inv.get("name", inv.get("email", ""))}
                if inv.get("email"):
                    p["email"] = inv["email"]
                participants.append(p)
            metadata = {
                "participants": participants,
                "invitee_domains": list(set(
                    inv.get("email_domain", "") for inv in invitees if inv.get("email_domain"))),
                "share_url": meeting_data.get("share_url", ""),
            }
            duration = compute_duration_minutes(recording_start or "", recording_end or "")
            if duration:
                metadata["duration_minutes"] = duration
        else:
            title = args.title or row[0] or "Untitled Meeting"
            recording_start, recording_end, language = row[1], row[2], row[3]
            metadata = row[4] or {}

    transcript_speakers = extract_speakers(entries)
    metadata["participants"] = merge_participants(
        metadata.get("participants", []), transcript_speakers)
    merged_turns = merge_transcript_turns(entries)
    transcript_text = format_transcript_text(merged_turns)
    vocabulary = load_vocabulary(cur)
    corrections_applied = []
    if vocabulary:
        transcript_text, corrections_applied = apply_vocabulary_corrections(transcript_text, vocabulary)
        if corrections_applied:
            metadata["corrections_applied"] = corrections_applied

    if row:
        cur.execute(
            "UPDATE fathom SET title=%s, transcript=%s, metadata=%s, synced_at=now() WHERE id=%s",
            (title, transcript_text, Json(metadata), rid))
    else:
        cur.execute(
            """INSERT INTO fathom (id, title, recording_start, recording_end,
                language, transcript, metadata, synced_at)
               VALUES (%s,%s,%s,%s,%s,%s,%s, now())""",
            (rid, title, recording_start, recording_end, language,
             transcript_text, Json(metadata)))
    db.commit()
    cur.close(); db.close()
    _emit({"id": rid, "title": title, "language": language,
           "raw_utterances": len(entries), "merged_turns": len(merged_turns),
           "speakers": [s["name"] for s in transcript_speakers],
           "corrections_applied": corrections_applied})


def cmd_search(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    q = args.query
    cur.execute(
        """SELECT id, title, recording_start, summary FROM fathom
           WHERE title ILIKE %s OR summary ILIKE %s OR metadata::text ILIKE %s
           ORDER BY recording_start DESC""", (f"%{q}%", f"%{q}%", f"%{q}%"))
    rows = cur.fetchall()
    cur.close(); db.close()
    meetings = [{"id": rid, "title": title, "recording_start": _iso(rec_start),
                 "summary": summary} for rid, title, rec_start, summary in rows]
    _emit({"query": q, "count": len(meetings), "meetings": meetings})


def cmd_scan(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    q = args.query
    cur.execute(
        """SELECT id, title, recording_start, summary FROM fathom
           WHERE summary ILIKE %s ORDER BY recording_start DESC""", (f"%{q}%",))
    rows = cur.fetchall()
    cur.close(); db.close()
    matches = []
    for rid, title, rec_start, summary in rows:
        lower = (summary or "").lower()
        pos = lower.find(q.lower())
        if pos >= 0:
            start = max(0, pos - 40)
            end = min(len(summary), pos + len(q) + 40)
            snippet = summary[start:end].replace("\n", " ")
            if start > 0:
                snippet = "..." + snippet
            if end < len(summary):
                snippet = snippet + "..."
        else:
            snippet = (summary or "")[:80].replace("\n", " ")
        matches.append({"id": rid, "title": title,
                        "recording_start": _iso(rec_start), "snippet": snippet})
    _emit({"query": q, "count": len(matches), "matches": matches})


def cmd_grep(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    q = args.query
    cur.execute(
        """SELECT id, title, recording_start, transcript FROM fathom
           WHERE transcript ILIKE %s ORDER BY recording_start DESC""", (f"%{q}%",))
    rows = cur.fetchall()
    cur.close(); db.close()
    results = []
    for rid, title, rec_start, transcript in rows:
        lines = [ln.strip() for ln in transcript.split("\n") if q.lower() in ln.lower()]
        shown = lines[:args.max_matches]
        results.append({"id": rid, "title": title, "recording_start": _iso(rec_start),
                        "matches": shown, "more": max(0, len(lines) - len(shown))})
    _emit({"query": q, "meetings_with_matches": len(results), "results": results})


def cmd_vocab_list(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    cur.execute("SELECT correct_term, variants FROM vocabulary ORDER BY correct_term")
    rows = cur.fetchall()
    cur.close(); db.close()
    _emit({"count": len(rows),
           "terms": [{"correct_term": t, "variants": v or []} for t, v in rows]})


def cmd_vocab_add(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    variants = [v.strip() for v in args.variants.split(",") if v.strip()] if args.variants else None
    cur.execute("SELECT 1 FROM vocabulary WHERE correct_term = %s", (args.term,))
    existed = cur.fetchone() is not None
    cur.execute(
        """INSERT INTO vocabulary (correct_term, variants) VALUES (%s, %s)
           ON CONFLICT (correct_term) DO UPDATE SET variants = %s""",
        (args.term, variants, variants))
    db.commit()
    cur.close(); db.close()
    _emit({"term": args.term, "variants": variants or [],
           "action": "updated" if existed else "added"})


def cmd_vocab_remove(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    cur.execute("DELETE FROM vocabulary WHERE correct_term = %s", (args.term,))
    removed = bool(cur.rowcount)
    db.commit()
    cur.close(); db.close()
    _emit({"term": args.term, "removed": removed})


def cmd_schema(args, conn):
    db = _db_connect(conn)
    cur = db.cursor()
    cur.execute("""
        CREATE TABLE IF NOT EXISTS fathom (
            id              bigint PRIMARY KEY,
            title           text,
            recording_start timestamptz,
            recording_end   timestamptz,
            language        text,
            project         text,
            summary         text,
            transcript      text,
            metadata        jsonb NOT NULL DEFAULT '{}'::jsonb,
            synced_at       timestamptz,
            enriched_at     timestamptz
        );
        CREATE TABLE IF NOT EXISTS vocabulary (
            id           serial PRIMARY KEY,
            correct_term text UNIQUE NOT NULL,
            variants     text[]
        );
    """)
    db.commit()
    cur.close(); db.close()
    _emit({"ok": True, "tables": ["fathom", "vocabulary"]})


# ── doctor ──────────────────────────────────────────────────────────────────────


def _check_connection(conn: dict) -> dict:
    out: dict = {"db_host": conn["db_host"], "db_name": conn["db_name"]}
    # Fathom API — cheapest authenticated round-trip (first page, no transcripts)
    try:
        with _fathom_client(conn) as client:
            resp = client.get("/meetings", params={"include_transcript": "false"})
        if resp.status_code in (401, 403):
            return out | {"ok": False, "category": 2,
                          "error": "Fathom rejected the API key (check FATHOM_API_KEY)"}
        if resp.status_code >= 400:
            return out | {"ok": False, "category": 5,
                          "error": f"Fathom /meetings returned {resp.status_code}"}
        out["fathom_api"] = "reachable"
    except httpx.RequestError as e:
        return out | {"ok": False, "category": 5, "error": f"Fathom unreachable: {e}"}
    # Database — credentials + schema presence
    try:
        db = psycopg2.connect(
            host=conn["db_host"], port=conn["db_port"], dbname=conn["db_name"],
            user=conn["db_user"], password=conn["db_password"],
            sslmode=conn["db_sslmode"], connect_timeout=15)
    except psycopg2.OperationalError as e:
        msg = str(e).lower()
        cat = 2 if ("password" in msg or "authentication" in msg or "role" in msg) else 5
        return out | {"ok": False, "category": cat, "error": f"database: {str(e).strip()}"}
    try:
        cur = db.cursor()
        try:
            cur.execute("SELECT count(*), count(transcript) FROM fathom")
            meetings, transcripts = cur.fetchone()
            out["meetings"], out["transcripts"] = meetings, transcripts
            out["schema"] = "present"
        except psycopg2.errors.UndefinedTable:
            return out | {"ok": False, "category": 3, "schema": "missing",
                          "error": "the fathom table does not exist",
                          "hint": f"run `{NAME} schema` to create it "
                                  f"(`{NAME} guide setup` for the full runbook)"}
        finally:
            cur.close()
            db.close()
    except psycopg2.Error as e:
        return out | {"ok": False, "category": 5, "error": f"database error: {str(e).strip()}"}
    return out | {"ok": True}


def cmd_doctor(args) -> None:
    _doctor_gate(_connections_report(), getattr(args, "connection", None))
    reg, _ = _connections_registry()
    if getattr(args, "connection", None) is not None or reg is None:
        targets = [_select_connection(reg, getattr(args, "connection", None))]
    else:
        targets = list(reg["connections"].items())
    connections: dict = {}
    fail_exit = 0
    for cid, entry in targets:
        conn, problem = _build_conn(cid, entry)
        if problem:
            res = {"ok": False, "category": problem["exit"], "error": problem["message"]}
            if problem.get("hint"):
                res["hint"] = problem["hint"]
        else:
            res = _check_connection(conn)
        if not res.get("ok") and not fail_exit:
            fail_exit = res.get("category") or 5
        res.pop("category", None)
        connections[cid] = res
    _emit({"ok": fail_exit == 0, "connections": connections})
    if fail_exit:
        sys.exit(fail_exit)


# ── main ────────────────────────────────────────────────────────────────────────


def _parse_id(value: str) -> int:
    try:
        return int(value)
    except (ValueError, TypeError):
        _die(6, "bad_id", f"recording id must be an integer, got {value!r}")


def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; help/doctor/domain fall through

    p = argparse.ArgumentParser(
        prog=NAME, description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("--connection", default=None,
                   help="connection id (optional with a default pointer or a sole connection)")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help")
    d = sub.add_parser("doctor")
    d.add_argument("--connection", default=None)

    s = sub.add_parser("sync")
    s.add_argument("--created-after", dest="created_after")
    s.add_argument("--force", action="store_true")

    ls = sub.add_parser("list")
    ls.add_argument("--language")
    ls.add_argument("--has-transcript", dest="has_transcript",
                    type=lambda v: v.lower() in ("true", "1", "yes"), default=None)
    ls.add_argument("--participant")

    rd = sub.add_parser("read"); rd.add_argument("id")

    up = sub.add_parser("update")
    up.add_argument("id")
    up.add_argument("--summary")
    up.add_argument("--project")
    up.add_argument("--metadata", dest="metadata_json")

    tr = sub.add_parser("transcript")
    tr.add_argument("id")
    tr.add_argument("--title")

    sr = sub.add_parser("search"); sr.add_argument("query")
    sc = sub.add_parser("scan"); sc.add_argument("query")
    gr = sub.add_parser("grep")
    gr.add_argument("query")
    gr.add_argument("--max-matches", dest="max_matches", type=int, default=5)

    vp = sub.add_parser("vocab")
    vsub = vp.add_subparsers(dest="vocab_command", required=True)
    vsub.add_parser("list")
    va = vsub.add_parser("add"); va.add_argument("term"); va.add_argument("--variants")
    vr = vsub.add_parser("remove"); vr.add_argument("term")

    sub.add_parser("schema")

    args = p.parse_args()

    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n")); return
    if args.cmd == "doctor":
        cmd_doctor(args); return

    conn = _resolve_conn(args)
    verb = f"vocab-{args.vocab_command}" if args.cmd == "vocab" else args.cmd
    _write_gate(conn["id"], conn["allow_write"], verb)

    dispatch = {
        "sync": cmd_sync, "list": cmd_list, "read": cmd_read, "update": cmd_update,
        "transcript": cmd_transcript, "search": cmd_search, "scan": cmd_scan,
        "grep": cmd_grep, "schema": cmd_schema,
    }
    vocab_dispatch = {"list": cmd_vocab_list, "add": cmd_vocab_add, "remove": cmd_vocab_remove}

    try:
        if args.cmd == "vocab":
            vocab_dispatch[args.vocab_command](args, conn)
        else:
            dispatch[args.cmd](args, conn)
    except psycopg2.errors.UndefinedTable as e:
        _die(3, "schema_missing", f"a required table is missing: {str(e).strip()}",
             f"run `{NAME} schema` to create the fathom and vocabulary tables")
    except psycopg2.OperationalError as e:
        _die(5, "db_error", f"database connection error: {str(e).strip()}")
    except psycopg2.Error as e:
        _die(5, "db_error", f"database error: {str(e).strip()}")


if __name__ == "__main__":
    main()
