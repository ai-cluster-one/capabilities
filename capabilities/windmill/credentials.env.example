# windmill — credentials (copy to $XDG_CONFIG_HOME/windmill/credentials.env,
# default ~/.config/windmill/credentials.env, and fill). This is the tier-3
# (user config) source in the 4-tier cascade:
#   flags > project .env(.local) > THIS user config > process env.
# A consuming project can override per-project by setting these in its own .env.
# PUBLIC REPO: never commit real values. Leave blank here; fill only the copy.

WINDMILL_URL=
WINDMILL_WORKSPACE=
WINDMILL_API_TOKEN=

# Provisioning (read by `windmill provision`/`verify`). The operator is the
# least-privilege workspace user the seat runs as; owners derive from it.
WINDMILL_OPERATOR=
WINDMILL_OPERATOR_NAME=
# WINDMILL_FOLDER (the workspace namespace) is per-project — set it in the
# project .env, not here, since one user config may serve several projects.
