def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    p = argparse.ArgumentParser(
        prog="clickup",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help", help="print the full usage contract")
    sub.add_parser("doctor", help="health check — resolve token, confirm identity")
    sub.add_parser("whoami", help="confirm token and return identity")
    sub.add_parser("workspaces", help="list workspaces (teams)")

    sp = sub.add_parser("members", help="list a workspace's members")
    sp.add_argument("--workspace", default=None, help="workspace (team) id")

    sp = sub.add_parser("spaces", help="list spaces in a workspace")
    sp.add_argument("--workspace", required=True, help="workspace (team) id")

    sp = sub.add_parser("folders", help="list folders in a space")
    sp.add_argument("--space", required=True, help="space id")

    sp = sub.add_parser("lists", help="list lists in a folder or space")
    sp.add_argument("--folder", default=None, help="folder id (its lists)")
    sp.add_argument("--space", default=None, help="space id (its folderless lists)")

    sp = sub.add_parser("statuses", help="list a list's statuses (board columns)")
    sp.add_argument("--list", required=True, dest="list_id", help="list id")

    sp = sub.add_parser("tags", help="list a space's tags")
    sp.add_argument("--space", required=True, help="space id")

    sp = sub.add_parser("fields", help="list a list's custom fields")
    sp.add_argument("--list", required=True, dest="list_id", help="list id")

    sp = sub.add_parser("tasks", help="list tasks in a list")
    sp.add_argument("--list", required=True, dest="list_id", help="list id")
    sp.add_argument("--all", action="store_true", help="include closed tasks")
    sp.add_argument("--archived", action="store_true", help="include archived tasks")
    sp.add_argument("--subtasks", action="store_true", help="include subtasks")
    sp.add_argument("--status", action="append", default=[],
                    help="filter to a status name (repeatable)")
    sp.add_argument("--limit", type=int, default=100, help="max tasks (paginates)")
    sp.add_argument("--page", type=int, default=None,
                    help="read a single 0-indexed page of 100 instead of paginating")

    sp = sub.add_parser("task", help="show one task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--with-subtasks", action="store_true",
                    help="attach the task's subtasks")
    sp.add_argument("--custom-id", action="store_true",
                    help="resolve <task> as a Custom Task ID (needs --workspace)")
    sp.add_argument("--workspace", default=None, help="workspace id (for --custom-id)")

    sp = sub.add_parser("task-context",
                        help="task + comments + attachments + deps, one envelope")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--json", action="store_true",
                    help="emit the assembled tree as JSON instead of markdown")

    sp = sub.add_parser("comments", help="list a task's comments")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--limit", type=int, default=100)

    sp = sub.add_parser("subtasks", help="list a task's subtasks")
    sp.add_argument("task", help="task id or URL")

    sp = sub.add_parser("deps", help="list a task's dependencies (or --dependents)")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--dependents", action="store_true",
                    help="list what depends on this task instead of what it depends on")

    sp = sub.add_parser("attachments", help="list a task's attachments")
    sp.add_argument("task", help="task id or URL")

    sp = sub.add_parser("find", help="resolve a task by Custom Task ID or custom-field key")
    sp.add_argument("custom_id", nargs="?", default=None,
                    help="a ClickApp Custom Task ID (omit when using --field)")
    sp.add_argument("--field", default=None,
                    help="custom field UUID/name to match on")
    sp.add_argument("--value", default=None, help="the value to match (with --field)")
    sp.add_argument("--external-id", default=None,
                    help="external id value; uses configured external_id field")
    sp.add_argument("--workspace", default=None,
                    help="workspace (team) id; default from connection/env")
    sp.add_argument("--list", default=None, dest="list_id",
                    help="list id used only to resolve field names to UUIDs")

    sp = sub.add_parser("field-get", help="read a task's custom field values")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("field", nargs="?", default=None,
                    help="field UUID or name (optional; all fields if omitted)")

    sp = sub.add_parser("assigned", help="tasks assigned to you, stalest first, with last-touch")
    sp.add_argument("--workspace", required=True, help="workspace (team) id")
    sp.add_argument("--assignee", default=None, help="user id (default: you)")
    sp.add_argument("--all", action="store_true", help="include closed tasks")
    sp.add_argument("--status", action="append", default=[],
                    help="filter to a status name (repeatable)")
    sp.add_argument("--limit", type=int, default=100)

    sp = sub.add_parser("create", help="create a task in a list")
    sp.add_argument("--list", required=True, dest="list_id", help="list id")
    sp.add_argument("--name", required=True)
    sp.add_argument("--desc", default=None, help="plain-text body; a file path, or '-'")
    sp.add_argument("--markdown", default=None, help="markdown body; a file path, or '-'")
    sp.add_argument("--assignee", action="append", default=[],
                    help="assignee user id (repeatable)")
    sp.add_argument("--status", default=None, help="initial status name")
    sp.add_argument("--tag", action="append", default=[], help="tag name (repeatable)")
    sp.add_argument("--priority", type=int, default=None,
                    help="1=Urgent 2=High 3=Normal 4=Low")
    sp.add_argument("--due-on", default=None, help="YYYY-MM-DD (all-day)")
    sp.add_argument("--due-at", default=None, help="ISO8601 datetime")
    sp.add_argument("--parent", default=None,
                    help="parent task id — makes this a subtask (same list)")
    sp.add_argument("--external-id", default=None,
                    help="dedup key to check and stamp in configured external_id field")
    sp.add_argument("--external-id-field", default=None,
                    help="override configured external_id field UUID/name")
    sp.add_argument("--workspace", default=None,
                    help="workspace id for external-id dedup; default from connection/env")
    sp.add_argument("--field", action="append", default=[], metavar="UUID=VALUE",
                    help="set a custom field at creation (repeatable; e.g. an external-ID key)")

    sp = sub.add_parser("update", help="update fields on a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--name", default=None)
    sp.add_argument("--desc", default=None, help="plain-text body; a file path, or '-'")
    sp.add_argument("--markdown", default=None, help="markdown body; a file path, or '-'")
    sp.add_argument("--status", default=None, help="status name")
    sp.add_argument("--priority", type=int, default=None,
                    help="1=Urgent 2=High 3=Normal 4=Low")
    sp.add_argument("--due-on", default=None, help="YYYY-MM-DD (all-day)")
    sp.add_argument("--due-at", default=None, help="ISO8601 datetime")
    sp.add_argument("--add-assignee", action="append", default=[],
                    help="user id to add as assignee (repeatable)")
    sp.add_argument("--rem-assignee", action="append", default=[],
                    help="user id to remove from assignees (repeatable)")
    sp.add_argument("--archive", action="store_true", help="archive the task")

    sp = sub.add_parser("comment", help="add a comment to a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--text", default="-",
                    help="comment text, a file path, or '-' for stdin")
    sp.add_argument("--assignee", default=None,
                    help="user id to assign + notify with the comment")
    sp.add_argument("--notify-all", action="store_true",
                    help="notify everyone on the task")

    sp = sub.add_parser("complete", help="mark a task complete (via status)")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--reopen", action="store_true",
                    help="set the first open status instead")
    sp.add_argument("--force", action="store_true",
                    help="complete even with incomplete dependencies")
    sp.add_argument("--no-rollup", action="store_true",
                    help="skip the parent roll-up + unblocked-dependent report")

    sp = sub.add_parser("deliverable",
                        help="create a paired request + dependent agent task")
    sp.add_argument("--list", required=True, dest="list_id", help="list id")
    sp.add_argument("--request-name", required=True,
                    help="title of the human-owned request task")
    sp.add_argument("--request-markdown", default=None,
                    help="request body: markdown, a file path, or '-' for stdin")
    sp.add_argument("--agent-name", required=True,
                    help="title of the dependent agent task")
    sp.add_argument("--agent-markdown", default=None,
                    help="agent-task body: markdown, a file path, or '-' for stdin")
    sp.add_argument("--supervisor", required=True,
                    help="user id assigned the request (the human whose input is needed)")
    sp.add_argument("--agent", required=True,
                    help="user id assigned the dependent task")
    sp.add_argument("--status", default=None, help="status name both tasks start in")
    sp.add_argument("--parent", default=None,
                    help="make the agent task a subtask of this task")
    sp.add_argument("--state-field", default=None,
                    help="custom field UUID to stamp {phase,last_touch} JSON into")

    sp = sub.add_parser("assign", help="add/remove assignees on a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--add", action="append", default=[], help="user id (repeatable)")
    sp.add_argument("--rem", action="append", default=[], help="user id (repeatable)")

    sp = sub.add_parser("watch", help="add/remove watchers on a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--add", action="append", default=[], help="user id (repeatable)")
    sp.add_argument("--rem", action="append", default=[], help="user id (repeatable)")

    sp = sub.add_parser("tag-create", help="create a tag in a space")
    sp.add_argument("--space", required=True, help="space id")
    sp.add_argument("--name", required=True)
    sp.add_argument("--fg", default=None, help="foreground colour hex")
    sp.add_argument("--bg", default=None, help="background colour hex")

    sp = sub.add_parser("tag-add", help="add a tag (by name) to a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("tag", help="tag name")

    sp = sub.add_parser("tag-remove", help="remove a tag from a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("tag", help="tag name")

    sp = sub.add_parser("dep-add", help="add dependency: <task> depends on --on ids")
    sp.add_argument("task", help="the dependent task (waits on --on)")
    sp.add_argument("--on", action="append", required=True,
                    help="task id this task depends on (repeatable)")

    sp = sub.add_parser("dep-remove", help="remove dependency links from <task>")
    sp.add_argument("task", help="the dependent task")
    sp.add_argument("--on", action="append", required=True,
                    help="task id to unlink (repeatable)")

    sp = sub.add_parser("field-set", help="set a custom field on a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("field", help="custom field UUID (see `fields`)")
    sp.add_argument("--value", required=True, help="the value to set")
    sp.add_argument("--json", action="store_true",
                    help="parse --value as JSON (typed/relationship fields)")

    sp = sub.add_parser("field-clear", help="clear a custom field on a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("field", help="custom field UUID")

    sp = sub.add_parser("attach", help="upload a local file to a task")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("file", help="local file path to upload")
    sp.add_argument("--name", default=None, help="override the attachment display name")

    sp = sub.add_parser("list-create", help="create a list in a folder or space")
    sp.add_argument("--folder", default=None, help="folder id")
    sp.add_argument("--space", default=None, help="space id (folderless list)")
    sp.add_argument("--name", required=True)
    sp.add_argument("--content", default=None, help="list description")

    sp = sub.add_parser("webhooks", help="list a workspace's webhooks")
    sp.add_argument("--workspace", required=True, help="workspace (team) id")

    sp = sub.add_parser("webhook-create", help="register a webhook")
    sp.add_argument("--workspace", required=True, help="workspace (team) id")
    sp.add_argument("--endpoint", required=True, help="HTTPS URL to deliver to")
    sp.add_argument("--event", action="append", default=[],
                    help="event name (repeatable); omit for all events")
    sp.add_argument("--space", default=None, help="scope to a space id")
    sp.add_argument("--folder", default=None, help="scope to a folder id")
    sp.add_argument("--list", default=None, dest="list_id", help="scope to a list id")
    sp.add_argument("--task", default=None, help="scope to a task id")

    sp = sub.add_parser("webhook-delete",
                        help="delete a webhook (stops deliveries; needs --yes)")
    sp.add_argument("webhook", help="webhook id")
    sp.add_argument("--yes", action="store_true", help="confirm the irreversible delete")

    sp = sub.add_parser("task-delete", help="delete a task (irreversible; needs --yes)")
    sp.add_argument("task", help="task id or URL")
    sp.add_argument("--yes", action="store_true", help="confirm the irreversible delete")
    sp.add_argument("--custom-id", action="store_true",
                    help="resolve <task> as a Custom Task ID (needs --workspace)")
    sp.add_argument("--workspace", default=None, help="workspace id (for --custom-id)")

    # `--token-env <KEY>` and `--connection <id>` are global overrides accepted
    # anywhere on the line (extracted before argparse so they work after the
    # subcommand). --token-env names the env/cred key holding the token — never
    # the value itself.
    argv = sys.argv[1:]
    token_key: str | None = None
    wanted_conn: str | None = None
    cleaned: list[str] = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--token-env" and i + 1 < len(argv):
            token_key = argv[i + 1]; i += 2; continue
        if a.startswith("--token-env="):
            token_key = a.split("=", 1)[1]; i += 1; continue
        if a == "--connection" and i + 1 < len(argv):
            wanted_conn = argv[i + 1]; i += 2; continue
        if a.startswith("--connection="):
            wanted_conn = a.split("=", 1)[1]; i += 1; continue
        cleaned.append(a); i += 1

    args = p.parse_args(cleaned)

    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return

    reg, reg_file = _connections_registry()
    if args.cmd == "doctor":
        cmd_doctor(reg, wanted_conn, token_key)
        return

    cid, entry = _select_connection(reg, wanted_conn)
    settings = _connection_settings(entry, reg_file)
    default_workspace = settings["workspace_id"]["value"]
    default_external_id_field = settings["external_id_field"]["value"]
    allow_write = WRITE_DEFAULT if entry is None else \
        bool(entry.get("allow_write", WRITE_DEFAULT))
    _write_gate(cid, allow_write, args.cmd)
    if entry is None:
        token = _load_token(token_key or "CLICKUP_API_TOKEN")
    else:
        key = token_key or entry.get("secret_env")
        if not key:
            _die(6, "no_secret_env", f"connection {cid!r} is missing 'secret_env'")
        token = _load_token(key)

    with _client(token) as c:
        if args.cmd == "whoami":
            _emit(cmd_whoami(c))
        elif args.cmd == "workspaces":
            _emit(cmd_workspaces(c))
        elif args.cmd == "members":
            _emit(cmd_members(c, args.workspace))
        elif args.cmd == "spaces":
            _emit(cmd_spaces(c, args.workspace))
        elif args.cmd == "folders":
            _emit(cmd_folders(c, args.space))
        elif args.cmd == "lists":
            _emit(cmd_lists(c, args.folder, args.space))
        elif args.cmd == "statuses":
            _emit(cmd_statuses(c, args.list_id))
        elif args.cmd == "tags":
            _emit(cmd_tags(c, args.space))
        elif args.cmd == "fields":
            _emit(cmd_fields(c, args.list_id))
        elif args.cmd == "tasks":
            _emit(cmd_tasks(c, args.list_id, args.all, args.archived,
                            args.subtasks, args.status, args.limit, args.page))
        elif args.cmd == "task":
            _emit(cmd_task(c, args.task, args.with_subtasks,
                           args.custom_id, args.workspace))
        elif args.cmd == "task-context":
            _emit(cmd_task_context(c, args.task, args.json))
        elif args.cmd == "comments":
            _emit(cmd_comments(c, args.task, args.limit))
        elif args.cmd == "subtasks":
            _emit(cmd_subtasks(c, args.task))
        elif args.cmd == "deps":
            _emit(cmd_deps(c, args.task, args.dependents))
        elif args.cmd == "attachments":
            _emit(cmd_attachments(c, args.task))
        elif args.cmd == "find":
            workspace = args.workspace or default_workspace
            if args.external_id is not None:
                if args.value is not None:
                    _die(6, "input", "--external-id cannot be combined with --value")
                if not workspace:
                    _die(6, "missing_workspace",
                         "find --external-id requires --workspace or configured workspace_id",
                         "set connection workspace_id or CLICKUP_WORKSPACE_ID")
                field = _resolve_custom_field(
                    c, args.field or default_external_id_field, args.list_id,
                    purpose="external-id field")
                _emit(cmd_find(c, workspace, field=field, value=args.external_id))
            elif args.field is not None:
                if args.value is None:
                    _die(6, "input", "--field requires --value")
                if not workspace:
                    _die(6, "missing_workspace",
                         "find --field requires --workspace or configured workspace_id",
                         "set connection workspace_id or CLICKUP_WORKSPACE_ID")
                field = _resolve_custom_field(c, args.field, args.list_id)
                _emit(cmd_find(c, workspace, field=field, value=args.value))
            elif args.custom_id is not None:
                if not workspace:
                    _die(6, "missing_workspace",
                         "find by Custom Task ID requires --workspace or configured workspace_id",
                         "set connection workspace_id or CLICKUP_WORKSPACE_ID")
                _emit(cmd_find(c, workspace, custom_task_id=args.custom_id))
            else:
                _die(6, "input",
                     "find needs a Custom Task ID, --external-id V, or --field UUID --value V")
        elif args.cmd == "field-get":
            _emit(cmd_field_get(c, args.task, args.field))
        elif args.cmd == "assigned":
            _emit(cmd_assigned(c, args.workspace, args.assignee, args.all,
                               args.status, args.limit))
        elif args.cmd == "create":
            if args.desc is not None and args.markdown is not None:
                _die(6, "conflicting_body", "pass only one of --desc / --markdown")
            mode = "plain" if args.desc is not None else "markdown"
            raw = args.desc if args.desc is not None else args.markdown
            body = _read_text(raw) if raw is not None else None
            _emit(cmd_create(c, args.list_id, args.name, body, mode,
                             args.assignee, args.status, args.tag, args.priority,
                             args.due_on, args.due_at, args.parent,
                             _parse_fields(args.field),
                             args.workspace or default_workspace,
                             args.external_id,
                             args.external_id_field or default_external_id_field))
        elif args.cmd == "update":
            if args.desc is not None and args.markdown is not None:
                _die(6, "conflicting_body", "pass only one of --desc / --markdown")
            mode = "plain" if args.desc is not None else "markdown"
            raw = args.desc if args.desc is not None else args.markdown
            body = _read_text(raw) if raw is not None else None
            _emit(cmd_update(c, args.task, args.name, body, mode, args.status,
                             args.priority, args.due_on, args.due_at,
                             args.add_assignee, args.rem_assignee, args.archive))
        elif args.cmd == "comment":
            _emit(cmd_comment(c, args.task, _read_text(args.text),
                              args.assignee, args.notify_all))
        elif args.cmd == "complete":
            _emit(cmd_complete(c, args.task, args.reopen, args.force, args.no_rollup))
        elif args.cmd == "deliverable":
            if args.request_markdown == "-" and args.agent_markdown == "-":
                _die(6, "two_stdin",
                     "--request-markdown and --agent-markdown can't both be '-'",
                     "only one can read stdin; pass the other inline or as a file path")
            req_body = (_read_text(args.request_markdown)
                        if args.request_markdown is not None else None)
            ag_body = (_read_text(args.agent_markdown)
                       if args.agent_markdown is not None else None)
            _emit(cmd_deliverable(c, list_id=args.list_id,
                                  request_name=args.request_name, request_body=req_body,
                                  agent_name=args.agent_name, agent_body=ag_body,
                                  supervisor=args.supervisor, agent=args.agent,
                                  status=args.status, parent=args.parent,
                                  state_field=args.state_field))
        elif args.cmd == "assign":
            _emit(cmd_assign(c, args.task, args.add, args.rem))
        elif args.cmd == "watch":
            _emit(cmd_watch(c, args.task, args.add, args.rem))
        elif args.cmd == "tag-create":
            _emit(cmd_tag_create(c, args.space, args.name, args.fg, args.bg))
        elif args.cmd == "tag-add":
            _emit(cmd_tag_add(c, args.task, args.tag))
        elif args.cmd == "tag-remove":
            _emit(cmd_tag_remove(c, args.task, args.tag))
        elif args.cmd == "dep-add":
            _emit(cmd_dep_add(c, args.task, args.on))
        elif args.cmd == "dep-remove":
            _emit(cmd_dep_remove(c, args.task, args.on))
        elif args.cmd == "field-set":
            _emit(cmd_field_set(c, args.task, args.field, args.value, args.json))
        elif args.cmd == "field-clear":
            _emit(cmd_field_clear(c, args.task, args.field))
        elif args.cmd == "attach":
            _emit(cmd_attach(token, args.task, args.file, args.name))
        elif args.cmd == "list-create":
            _emit(cmd_list_create(c, args.folder, args.space, args.name, args.content))
        elif args.cmd == "webhooks":
            _emit(cmd_webhooks(c, args.workspace))
        elif args.cmd == "webhook-create":
            _emit(cmd_webhook_create(c, args.workspace, args.endpoint, args.event,
                                     args.space, args.folder, args.list_id, args.task))
        elif args.cmd == "webhook-delete":
            if not args.yes:
                _die(6, "delete_requires_confirmation",
                     "webhook-delete is destructive and needs --yes",
                     "deleting a webhook stops all event delivery — confirm with the "
                     "human, then re-run with --yes")
            _emit(cmd_webhook_delete(c, args.webhook))
        elif args.cmd == "task-delete":
            if not args.yes:
                _die(6, "delete_requires_confirmation",
                     "task-delete is destructive and needs --yes",
                     "deleting a task is irreversible — confirm with the human, "
                     "then re-run with --yes")
            _emit(cmd_task_delete(c, args.task, args.custom_id, args.workspace))


if __name__ == "__main__":
    main()
