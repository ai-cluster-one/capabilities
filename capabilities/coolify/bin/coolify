#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""coolify — Coolify CLI over the REST API. Drives a self-hosted Coolify
instance: list projects, resources, servers, applications, services and
databases; read their status and an application's logs; and deploy, restart,
stop or start them. Agent-invoked — run `coolify help` to reload this contract.

USAGE
  coolify <command> [options]

Identity-free: it operates on whatever team the resolved COOLIFY_TOKEN
authorizes, against the instance at COOLIFY_BASE_URL. Every resource is
addressed by its Coolify `uuid` (never a name or slug); a project's
environments come back inside the project object. Structured reads emit JSON
to stdout.

CONNECTIONS
  Configuration resolves as named connections. With no registry the sole
  connection is `default`, resolved from the cascade (first non-empty wins):
    1. flag           --base-url / --token
    2. project env    .env.local then .env, walking up from $CLAUDE_PROJECT_DIR (else cwd)
    3. user config    $XDG_CONFIG_HOME/coolify/credentials.env (default ~/.config/coolify/)
    4. process env    COOLIFY_BASE_URL / COOLIFY_TOKEN
  A secret never has a flag of its own that puts it on argv; --token exists for
  parity but prefer config/env. COOLIFY_BASE_URL is the instance root WITHOUT
  the /api/v1 suffix (e.g. https://coolify.example.com); the CLI appends it.

  More than one instance or team is declared in
  <project>/capabilities/coolify/connections.json:
    {
      "default": "<id>",
      "connections": {
        "<id>": { "base_url": "https://coolify.example.com",
                  "secret_env": "COOLIFY_<ID>_TOKEN",
                  "allow_write": true }
      }
    }
  The registry resolves project envelope first, else the machine-level
  ~/.config/coolify/connections.json; first found wins, never merged. The entry
  names the env var holding its token ("secret_env"); the value resolves through
  cascade tiers 2-4 above. "base_url" sits literally in the entry.

  Selection: --connection <id> (accepted anywhere on the command line).
  Unflagged, the registry's "default" pointer applies, else the sole entry;
  several entries without a pointer is refused as ambiguous.

  A Coolify API token is team-scoped and carries explicit abilities (read,
  read:sensitive, write, deploy, root). A connection without "allow_write": true
  resolves writability from WRITE_DEFAULT (true — deploys stay inside an instance
  the consumer owns); a connection set to false refuses deploy/start/stop/restart
  with exit 4.

COMMANDS
  connections
      Where every connection's values resolve from (tier, source, secrets
      masked). Local only — no network.

  doctor [--connection <id>]
      Validate token + reachability (GET /version, GET /teams/current) and
      report the Coolify version and the token's team — every connection, or
      one. Exit 0 all healthy / 2 missing-or-rejected token / 5 unreachable.

  projects [<uuid>]
      List projects, or get one project (its environments come inside it).
  projects create --name <name> [--description <text>]
      Create a new project. Returns the project_uuid and default environment.
      Write verb - requires allow_write.
  resources
      Flat list of every deployable resource (uuid, name, type, status) —
      the lookup an agent runs to find the uuid to act on.
  applications [<uuid>]            List applications, or get one (full detail).
  services [<uuid>]               List services, or get one.
  databases [<uuid>]              List databases, or get one.
  servers [<uuid>]                List servers, or get one.
  deployments [<uuid>]            List active/queued deployments, or get one
                                  deployment by its uuid.
  logs <uuid> [--lines N]         An application's runtime logs (default 100).

  app create --project <uuid> --server <uuid> --environment <name>
      Create an application. Source-selecting flags (mutually exclusive):
      --git-repository <url> --git-branch <branch>  (public git)
          [--build-pack nixpacks|railpack|static|dockerfile|dockercompose]
          [--docker-compose-location <path>] [--dockerfile-location <path>]
      --private-deploy-key <uuid> (+ git flags above for private git with key)
      --github-app <uuid> (+ git flags above for private git with GitHub app)
      --image <registry/name:tag>  (registry image)
      --dockerfile <file|->  (inline dockerfile, raw content)
      Common optional: --name, --domains, --ports-exposes, --instant-deploy,
      --destination <uuid>. Returns the application uuid.
      Write verb - requires allow_write.

  service create --compose <file|-> --project <uuid> --server <uuid>
                 --environment <name> [--name <name>] [--instant-deploy]
                 [--destination <uuid>]
      Create a service from a docker-compose file. The compose file is
      base64-encoded before sending. Returns the service uuid.
      Write verb - requires allow_write.

  deploy <uuid> [--force] [--tag T]
      Trigger a deployment of an application/service by uuid (GET /deploy).
      --force rebuilds without cache; --tag deploys by image tag instead.
  start <uuid>   --type application|service|database
  stop <uuid>    --type application|service|database
  restart <uuid> --type application|service|database
      In-place lifecycle on a running resource. --type selects the endpoint
      family (defaults to application).

  env list <uuid> [--type application|service]
      List environment variables for an application or service.
  env set <uuid> <KEY> <VALUE> [--type application|service]
      Set or update an environment variable. For secrets, omit VALUE to read
      from stdin (one line, no echo). Write verb - requires allow_write.
  env rm <uuid> <KEY> [--type application|service]
      Remove an environment variable. Write verb - requires allow_write.
  env bulk <uuid> [--type application|service]
      Bulk update environment variables (PATCH). Reads KEY=VALUE pairs from
      stdin, one per line. Write verb - requires allow_write.

Contract commands (the same on every capability):
  coolify stub                                 One-line awareness text.
  coolify manifest --json                      Machine-readable declaration.
  coolify guide [<topic>]                      Guide topics / one guide body.
  coolify ids list|get <l>|set <l> <v>|rm <l>  The project identifiers envelope
              [--note <text>]                   (capabilities/coolify/identifiers.json).
  coolify refs                                 Menu of the project's reference files.

EXIT CODES
  0 success · 2 auth/credentials (401/403, missing token) · 3 not found (404) ·
  4 policy refusal — the project gate (capabilities/settings.json) on any
  verb, or a write verb on a read-only connection; ask the user, never lift a
  gate yourself · 5 server/network (timeout, 429 after retries, 5xx) ·
  6 input (a malformed argument, an unknown/ambiguous connection)
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
from pathlib import Path
from typing import NoReturn

import httpx

API_VERSION = "/api/v1"
TIMEOUT = httpx.Timeout(60.0)
MAX_RETRIES = 3

# --- Capability declaration (protocol 2) — one home for every contract fact --

NAME = "coolify"
PROTOCOL = 2
SUMMARY = ("Coolify CLI over the REST API — list projects/resources/servers, "
           "read application & service status and logs, and deploy/restart/"
           "stop/start them on a self-hosted Coolify instance.")
SCOPE = "project"   # credential scope: "project" | "user"
CRED_KEYS = [
    {"key": "COOLIFY_BASE_URL", "secret": False, "required": True,
     "note": "instance base URL, no /api/v1 suffix (e.g. https://coolify.example.com)"},
    {"key": "COOLIFY_TOKEN", "secret": True, "required": True,
     "note": "API token (Dashboard → Keys & Tokens → API tokens), team-scoped"},
]
WRITE_VERBS = {"deploy", "start", "stop", "restart", "env"}   # verbs that mutate the instance
WRITE_DEFAULT = True    # writes stay inside an instance the consumer owns
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "coolify" / "credentials.env"


# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding capabilities/, legacy .capabilities/,
    .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / "capabilities" / "settings.json").is_file()
                or (d / ".capabilities").is_dir()
                or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_capabilities_dir(root: Path) -> Path:
    """The active project envelope root.

    `capabilities/` is canonical. A legacy `.capabilities/` remains readable
    until `capabilities init` migrates it. If both exist, the canonical tree
    wins once it carries settings.json; otherwise the legacy configured tree
    remains active so merely creating an empty visible directory loses no gate.
    """
    current = root / "capabilities"
    legacy = root / ".capabilities"
    if (current / "settings.json").is_file() or not legacy.is_dir():
        return current
    return legacy


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _auth_context() -> dict | None:
    """Optional runtime authority envelope passed by an ingress/service.

    Absence means the ordinary project gate is the whole policy. Presence means
    a request-scoped authority layer exists and must fail closed before any
    credential or network work happens.
    """
    raw = os.environ.get("CAPABILITIES_AUTH_CONTEXT")
    if not raw:
        return None
    try:
        if raw.lstrip().startswith("{"):
            data = json.loads(raw)
        else:
            data = json.loads(Path(raw).read_text())
    except (OSError, ValueError) as e:
        _die(4, "auth_context_unreadable",
             "runtime authority context could not be read",
             f"{raw}: {e}")
    if not isinstance(data, dict):
        _die(4, "auth_context_invalid",
             "runtime authority context is not an object")
    return data


def _auth_capability_allowed(rule) -> bool:
    if rule is True or rule == "*":
        return True
    if rule in (False, None):
        return False
    if isinstance(rule, dict):
        if rule.get("deny") is True:
            return False
        if rule.get("enabled") is False or rule.get("allow") is False:
            return False
        return True
    return False


def _auth_gate() -> None:
    ctx = _auth_context()
    if ctx is None:
        return
    allowed = ctx.get("allowed_capabilities")
    if allowed is None:
        return
    if allowed is True or allowed == "*":
        return
    if isinstance(allowed, list):
        if NAME in allowed or "*" in allowed:
            return
    elif isinstance(allowed, dict):
        if _auth_capability_allowed(allowed.get(NAME, allowed.get("*"))):
            return
    else:
        _die(4, "auth_context_invalid",
             "runtime authority context has invalid allowed_capabilities")
    source = ctx.get("source") or "runtime"
    role = ctx.get("sender_role") or ctx.get("role") or "unknown"
    chat = ctx.get("chat_id") or "unknown"
    _die(4, "capability_not_authorized",
         f"{NAME} is not authorized for this {source} request",
         f"role={role}; chat_id={chat}; adjust runtime authority policy instead of bypassing the gate")


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks.

    If an ingress supplied CAPABILITIES_AUTH_CONTEXT, that request-scoped gate
    is stricter and also runs here, before credentials or network calls.
    """
    _auth_gate()
    root = _project_root()
    if root is None:
        return
    gate_file = _project_capabilities_dir(root) / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project's active capabilities/."""
    root = _project_root()
    return (_project_capabilities_dir(root) / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None:
            envelope = _project_capabilities_dir(root)
            if (envelope / "settings.json").is_file():
                return envelope / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import urllib.error as _ue
    import urllib.request as _ur
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        req = _ur.Request(url, headers=headers)
        with _ur.urlopen(req, timeout=10.0) as resp:
            text = resp.read().decode(resp.headers.get_content_charset() or "utf-8")
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(text); return
    except _ue.HTTPError as e:
        if e.code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if e.code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        err = f"upstream returned {e.code}"
    except _ue.URLError as e:
        err = str(e.reason)
    except OSError as e:
        err = str(e)
    if cache.exists():
        sys.stderr.write(json.dumps(
            {"warning": f"upstream unreachable; serving cached copy ({err})"},
            ensure_ascii=False) + "\n")
        _emit(cache.read_text()); return
    _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _render_ids_markdown(data: dict) -> str:
    """Render the {label: {value, note}} envelope as the labelled markdown
    list the manager's `capabilities ids <NAME>` also produces — one shared
    format across the ids surface and the identifiers section of `help`."""
    lines: list[str] = []
    for label, entry in sorted(data.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        v = entry.get("value")
        vs = f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"
        line = f"- **{label}**: {vs}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    return "\n".join(lines)


def _identifiers_section() -> str:
    """The Identifiers block appended to the bare top-level help — deterministic
    first-touch surfacing of `capabilities/<NAME>/identifiers.json` so an
    agent following the `<NAME> help` startup protocol loads the discovered
    labels/values/notes into context at once. Empty when no project envelope
    or nothing recorded (do not bloat help with an empty section)."""
    envdir = _env_dir()
    if envdir is None:
        return ""
    ids_file = envdir / "identifiers.json"
    if not ids_file.exists():
        return ""
    try:
        data = json.loads(ids_file.read_text())
    except (OSError, ValueError):
        return ""
    if not isinstance(data, dict) or not data:
        return ""
    header = (
        "\n═══ Identifiers ═════════════════════════════════════════════════════════════\n\n"
        f"Structural lookups discovered for `{NAME}` in this project. Fetch a single\n"
        f"raw value with `{NAME} ids get <label>`; the full envelope is also at\n"
        f"`capabilities ids {NAME}`.\n\n"
    )
    return header + _render_ids_markdown(data) + "\n"


def _cmd_help() -> None:
    """Bare top-level help: the CLI's HELP body (module-level `HELP` if
    defined, else the module docstring), then the project's Identifiers
    section. Only fires when no extra args follow — per-verb help stays
    untouched so `<NAME> help <subcommand>` is not intercepted."""
    g = globals()
    text = g.get("HELP") or g.get("__doc__") or ""
    if text.startswith("\n"):
        text = text.lstrip("\n")
    sys.stdout.write(text)
    if text and not text.endswith("\n"):
        sys.stdout.write("\n")
    section = _identifiers_section()
    if section:
        sys.stdout.write(section)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not (envdir.parent / "settings.json").is_file():
            _die(6, "no_envelope", "no capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved.

    `help` is a contract verb only when bare (no extra args) — the top-level
    dump plus the Identifiers section. `<NAME> help <subcommand>` falls
    through to the CLI so per-verb help stays clean."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    elif cmd == "help" and len(argv) == 1:
        _cmd_help()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


# >>> contract: connections (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

def _resolve_env_key(key: str) -> tuple[str | None, str | None, Path | None]:
    """Resolve one env key through cascade tiers 2-4: project .env(.local) →
    user credentials.env → process env. Returns (value, tier, source)."""
    root = _project_root()
    if root is not None:
        for fname in (".env.local", ".env"):
            val = _parse_env_file(root / fname).get(key)
            if val:
                return val, "project", root / fname
    val = _parse_env_file(CREDENTIALS_ENV).get(key)
    if val:
        return val, "user", CREDENTIALS_ENV
    val = os.environ.get(key)
    if val:
        return val, "env", None
    return None, None, None


def _mask(value: str) -> str:
    return ("…" + value[-4:]) if len(value) >= 8 else "****"


def _connections_registry() -> tuple[dict | None, Path | None]:
    """The connections envelope and its path: project envelope first, else the
    user config home. First found wins, never merged; (None, None) when neither
    declares one (the implicit default connection applies)."""
    envdir = _env_dir()
    candidates = ([envdir / "connections.json"] if envdir else []) + \
                 [_CONFIG_HOME / NAME / "connections.json"]
    for reg_file in candidates:
        if not reg_file.is_file():
            continue
        try:
            raw = json.loads(reg_file.read_text())
        except (ValueError, OSError) as e:
            _die(6, "bad_config", f"cannot read {reg_file}: {e}")
        if not isinstance(raw, dict) or not isinstance(raw.get("connections"), dict) \
                or not raw["connections"]:
            _die(6, "bad_config", f"{reg_file} is not a connections envelope",
                 'expected {"default": "<id>", "connections": { ... }}')
        return raw, reg_file
    return None, None


def _select_connection(reg: dict | None, wanted: str | None) -> tuple[str, dict | None]:
    """flag → default pointer → sole entry → die 6. No registry → the implicit
    default. A connection's own `address` field selects it too (used where a
    connection carries a human-recognizable address; absent fields never match)."""
    if reg is None:
        if wanted and wanted != "default":
            _die(6, "unknown_connection",
                 "no connections registry; the sole connection is 'default'",
                 "the implicit default resolves from the credential cascade")
        return "default", None
    conns = reg["connections"]
    if wanted:
        if wanted in conns:
            return wanted, conns[wanted]
        for cid, entry in conns.items():
            if (entry or {}).get("address", "").lower() == wanted.lower():
                return cid, entry
        _die(6, "unknown_connection", f"no connection matches {wanted!r}",
             f"known: {', '.join(conns)}")
    default = reg.get("default")
    if default:
        if default not in conns:
            _die(6, "bad_default", f"default points to unknown connection {default!r}",
                 f"known: {', '.join(conns)}")
        return default, conns[default]
    if len(conns) == 1:
        cid = next(iter(conns))
        return cid, conns[cid]
    _die(6, "ambiguous_connection",
         f"registry defines {len(conns)} connections and no default; "
         f"pass --connection <id>",
         f"known: {', '.join(conns)}")


def _write_gate(conn_id: str, allow_write: bool, verb: str) -> None:
    """Policy from the committed registry; nothing in the cascade lifts it."""
    if verb in WRITE_VERBS and not allow_write:
        _die(4, "read_only",
             f"connection {conn_id!r} does not allow writes",
             "Do not lift the gate yourself — ask the user; granting is "
             "`allow_write: true` on this connection in connections.json.")


def _key_report(key: str, secret: bool, required: bool,
                value: str | None, tier: str | None, source) -> dict:
    return {"key": key, "secret": secret, "required": required,
            "set": bool(value), "tier": tier if value else None,
            "source": str(source) if (value and source) else None,
            "value": (_mask(value) if secret else value) if value else None}


def _missing_required(keys: list) -> list:
    """Required report rows (from _key_report) that did not resolve through the
    cascade — empty ⇒ credentials present. The primitive behind doctor's
    network-free readiness gate, read from the same per-key resolution
    `connections` reports, so the gate and the report can never disagree."""
    return [k["key"] for k in keys if k["required"] and not k["set"]]


def _doctor_gate(report: dict, wanted: str | None) -> None:
    """doctor's network-free readiness gate. Refuse with exit 2 — naming the
    unresolved required keys, before any round-trip — when a connection under
    test cannot resolve its required config through the cascade, so readiness is
    judged by the same resolution `connections` reports, never a parallel check.
    Checks the selected connection, else every connection in the report."""
    conns = report.get("connections") or {}
    targets = [wanted] if (wanted and wanted in conns) else list(conns)
    problems: dict = {}
    for cid in targets:
        miss = _missing_required((conns.get(cid) or {}).get("keys") or [])
        if miss:
            problems[cid] = miss
    if problems:
        detail = "; ".join(f"{c}: {', '.join(ks)}" for c, ks in sorted(problems.items()))
        _die(2, "credentials_missing",
             f"unresolved required config — {detail}",
             f"set each in the project .env/.env.local, the user credentials.env, "
             f"or process env; `{NAME} connections` shows where every value resolves")

# <<< contract: connections <<<


# ── credentials & connection materialization ────────────────────────────────

SLIM_FIELDS = ("uuid", "name", "description", "status", "type", "fqdn",
               "domains", "git_repository", "git_branch", "server_uuid",
               "environment_name", "image", "created_at", "updated_at")


def _slim(item):
    """Project a resource dict to a scannable subset; pass through anything that
    carries none of the known fields, and any non-dict, untouched."""
    if not isinstance(item, dict):
        return item
    picked = {k: item[k] for k in SLIM_FIELDS if k in item}
    return picked or item


def _slim_list(items):
    if isinstance(items, dict) and isinstance(items.get("data"), list):
        items = items["data"]
    if isinstance(items, list):
        return [_slim(i) for i in items]
    return items


def _build_conn(cid: str, entry: dict | None, args) -> tuple[dict | None, dict | None]:
    """Materialize one connection. Returns (conn, problem) — problem is an error
    dict ({"exit", "code", "message", "hint"?}) instead of a die, so doctor can
    report every connection rather than stopping at the first."""
    if entry is None:   # the implicit default — flat keys through the cascade
        base_url = (getattr(args, "base_url", None)
                    or _resolve_env_key("COOLIFY_BASE_URL")[0])
        token = getattr(args, "token", None) or _resolve_env_key("COOLIFY_TOKEN")[0]
        if not base_url or not token:
            return None, {
                "exit": 2, "code": "missing_credentials",
                "message": "COOLIFY_BASE_URL and COOLIFY_TOKEN are required",
                "hint": f"set them in a project .env(.local), {CREDENTIALS_ENV}, "
                        f"the environment, or via --base-url/--token — or declare a "
                        f"connections registry (capabilities/{NAME}/connections.json)"}
        return {"id": cid, "allow_write": WRITE_DEFAULT,
                "base_url": base_url.rstrip("/"), "token": token}, None
    base_url = getattr(args, "base_url", None) or entry.get("base_url")
    secret_env = entry.get("secret_env")
    if not secret_env:
        return None, {"exit": 6, "code": "no_secret_env",
                      "message": f"connection {cid!r} is missing 'secret_env'"}
    token = getattr(args, "token", None) or _resolve_env_key(secret_env)[0]
    if not token:
        return None, {
            "exit": 2, "code": "missing_secret",
            "message": f"env var {secret_env} (for connection {cid!r}) is unset",
            "hint": f"set {secret_env} in the project's .env / .env.local, "
                    f"{CREDENTIALS_ENV}, or the environment"}
    if not base_url:
        return None, {"exit": 6, "code": "incomplete_connection",
                      "message": f"connection {cid!r} is missing 'base_url'"}
    return {"id": cid, "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "base_url": base_url.rstrip("/"), "token": token}, None


def _resolve_conn(args) -> dict:
    reg, _ = _connections_registry()
    cid, entry = _select_connection(reg, getattr(args, "connection", None))
    conn, problem = _build_conn(cid, entry, args)
    if problem:
        _die(problem["exit"], problem["code"], problem["message"], problem.get("hint"))
    return conn


def _connections_report() -> dict:
    """The resolution report — every connection, every value, its winning tier
    and source, secrets masked. Local only: no network, no login attempt."""
    reg, reg_path = _connections_registry()
    report: dict = {"default": None, "connections": {}}
    if reg is None:
        keys = []
        for k in CRED_KEYS:
            value, tier, source = _resolve_env_key(k["key"])
            keys.append(_key_report(k["key"], k["secret"], k["required"],
                                    value, tier, source))
        report["default"] = "default"
        report["connections"]["default"] = {"allow_write": WRITE_DEFAULT, "keys": keys}
        return report
    conns = reg["connections"]
    report["default"] = reg.get("default") or \
        (next(iter(conns)) if len(conns) == 1 else None)
    for cid, entry in conns.items():
        entry = entry if isinstance(entry, dict) else {}
        keys = []
        value = entry.get("base_url")
        keys.append(_key_report("base_url", False, True, value, "connection",
                                reg_path if value else None))
        secret_env = entry.get("secret_env")
        if secret_env:
            value, tier, source = _resolve_env_key(secret_env)
            keys.append(_key_report(secret_env, True, True, value, tier, source))
        else:
            keys.append(_key_report("secret_env", False, True, None, None, None))
        report["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": keys}
    return report


def _cmd_connections() -> None:
    _emit(_connections_report())


# ── HTTP with 429/5xx backoff ───────────────────────────────────────────────

def _client(conn: dict) -> httpx.Client:
    return httpx.Client(
        base_url=conn["base_url"] + API_VERSION,
        timeout=TIMEOUT,
        headers={
            "Authorization": f"Bearer {conn['token']}",
            "Accept": "application/json",
            "Content-Type": "application/json",
        },
    )


def _request(client: httpx.Client, method: str, path: str,
             params: dict | None = None, json_body: dict | None = None):
    last_status: int | None = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = client.request(method, path, params=params, json=json_body)
        except httpx.TimeoutException:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "timeout", f"request timed out: {method} {path}",
                 "Coolify was unresponsive")
        except httpx.RequestError as e:
            _die(5, "network_error", f"network error: {e}",
                 "check COOLIFY_BASE_URL / connectivity")

        last_status = resp.status_code
        if resp.status_code == 429:
            retry_after = float(resp.headers.get("Retry-After", str(attempt * 1.5)))
            if attempt < MAX_RETRIES:
                time.sleep(retry_after)
                continue
            _die(5, "rate_limited", "rate-limited by Coolify", status=429)
        if resp.status_code >= 500:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "server_error", f"Coolify returned {resp.status_code}",
                 (resp.text or "")[:300], status=resp.status_code)

        if resp.status_code >= 400:
            body = (resp.text or "").strip()
            msg = body[:400] or "unknown error"
            try:
                j = resp.json()
                if isinstance(j, dict):
                    msg = j.get("message") or j.get("error") or msg
            except ValueError:
                pass
            if resp.status_code in (401, 403):
                _die(2, "unauthorized", msg,
                     "COOLIFY_TOKEN invalid or lacks the required ability",
                     status=resp.status_code)
            if resp.status_code == 404:
                _die(3, "not_found", msg, "verify the resource uuid",
                     status=resp.status_code)
            _die(6, "invalid_request", msg, status=resp.status_code)

        if resp.status_code == 204 or not (resp.text or "").strip():
            return {}
        try:
            return resp.json()
        except ValueError:
            return resp.text.strip()

    _die(5, "exhausted_retries", f"exhausted {MAX_RETRIES} attempts on {method} {path}",
         status=last_status)


# ── commands ────────────────────────────────────────────────────────────────

LIFECYCLE_PATHS = {"application": "applications", "service": "services",
                   "database": "databases"}


def _check_connection(conn: dict) -> dict:
    """One connection's round-trip, reported rather than died — doctor covers
    every connection, so a broken one becomes a finding, not a stop."""
    out: dict = {"base_url": conn["base_url"]}
    try:
        with _client(conn) as c:
            r = c.get("/version")
            if r.status_code >= 400:
                cat = 2 if r.status_code in (401, 403) else 5
                return out | {"ok": False, "category": cat,
                              "error": f"/version returned {r.status_code}"}
            out["version"] = (r.text or "").strip().strip('"')
            r = c.get("/teams/current")
            if r.status_code >= 400:
                cat = 2 if r.status_code in (401, 403) else 5
                return out | {"ok": False, "category": cat,
                              "error": f"/teams/current returned {r.status_code}"}
            try:
                team = r.json()
            except ValueError:
                team = {}
            if isinstance(team, dict):
                out["team"] = {"id": team.get("id"), "name": team.get("name")}
    except httpx.RequestError as e:
        return out | {"ok": False, "category": 5, "error": f"network error: {e}"}
    except ValueError as e:
        return out | {"ok": False, "category": 5, "error": f"bad response: {e}"}
    return out | {"ok": True}


def cmd_doctor(args) -> None:
    """Every connection bare; one with --connection. Exit 0 only when every
    examined connection is healthy, else the first failure's category."""
    _doctor_gate(_connections_report(), getattr(args, "connection", None))
    reg, _ = _connections_registry()
    if args.connection is not None or reg is None:
        targets = [_select_connection(reg, args.connection)]
    else:
        targets = list(reg["connections"].items())
    connections: dict = {}
    fail_exit = 0
    for cid, entry in targets:
        conn, problem = _build_conn(cid, entry, args)
        if problem:
            res = {"ok": False, "category": problem["exit"], "error": problem["message"]}
            if problem.get("hint"):
                res["hint"] = problem["hint"]
        else:
            res = _check_connection(conn)
        if not res.get("ok") and not fail_exit:
            fail_exit = res.get("category") or 5
        res.pop("category", None)
        connections[cid] = res
    _emit({"ok": fail_exit == 0, "connections": connections})
    if fail_exit:
        sys.exit(fail_exit)


def cmd_collection(c, base_path: str, uuid: str | None):
    """List a resource collection (slimmed), or get one by uuid (full detail)."""
    if uuid:
        return _request(c, "GET", f"/{base_path}/{uuid}")
    return _slim_list(_request(c, "GET", f"/{base_path}"))


def cmd_logs(c, uuid: str, lines: int):
    return _request(c, "GET", f"/applications/{uuid}/logs", params={"lines": lines})


def cmd_deploy(c, uuid: str, force: bool, tag: str | None):
    params: dict = {"uuid": uuid}
    if force:
        params["force"] = "true"
    if tag:
        params["tag"] = tag
    return _request(c, "GET", "/deploy", params=params)


def cmd_lifecycle(c, action: str, uuid: str, rtype: str):
    base = LIFECYCLE_PATHS[rtype]
    return _request(c, "GET", f"/{base}/{uuid}/{action}")


def _normalize_env_list(response):
    """Normalize env list response - handles both bare list and dict-with-data formats.
    Coolify 4.1.2 returns a bare JSON list; older or future versions may wrap in {"data": [...]}.
    """
    if isinstance(response, list):
        return response
    if isinstance(response, dict) and "data" in response:
        return response["data"]
    return []


def cmd_env_list(c, uuid: str):
    """List environment variables for an application."""
    return _request(c, "GET", f"/applications/{uuid}/envs")


def cmd_env_set(c, uuid: str, key: str, value: str):
    """Set or update an environment variable. Updates all entries (preview + non-preview)
    with this key if any exist; creates a new one if none exist."""
    # List existing env vars to find all matching entries
    existing = _request(c, "GET", f"/applications/{uuid}/envs")
    env_list = _normalize_env_list(existing)

    # Find all entries with this key (both preview and non-preview)
    matching = [
        e for e in env_list
        if isinstance(e, dict) and e.get("key") == key
    ]

    if matching:
        # Update all matching entries to keep preview/non-preview siblings aligned
        results = []
        for entry in matching:
            result = _request(c, "PATCH", f"/applications/{uuid}/envs",
                            json_body={"key": key, "value": value, "is_preview": entry.get("is_preview", False)})
            results.append(result)
        return {"updated": len(matching), "key": key, "results": results}
    else:
        # Create new entry
        return _request(c, "POST", f"/applications/{uuid}/envs",
                       json_body={"key": key, "value": value})


def cmd_env_rm(c, uuid: str, key: str):
    """Remove all environment variable entries matching KEY (preview + non-preview).
    Reports what was deleted to avoid leaving orphaned entries."""
    # List existing env vars to find all matching entries
    existing = _request(c, "GET", f"/applications/{uuid}/envs")
    env_list = _normalize_env_list(existing)

    # Find all entries with this key (both preview and non-preview)
    matching = [
        e for e in env_list
        if isinstance(e, dict) and e.get("key") == key
    ]

    if not matching:
        _die(3, "not_found", f"environment variable {key!r} not found",
             f"use `coolify env list {uuid}` to see available variables")

    # Delete all matching entries
    deleted = []
    for entry in matching:
        env_uuid = entry.get("uuid")
        is_preview = entry.get("is_preview", False)
        _request(c, "DELETE", f"/applications/{uuid}/envs/{env_uuid}")
        deleted.append({"uuid": env_uuid, "is_preview": is_preview})

    return {"deleted": len(matching), "key": key, "entries": deleted}


def cmd_env_list_typed(c, uuid: str, rtype: str):
    """List environment variables for an application or service."""
    base = "applications" if rtype == "application" else "services"
    return _request(c, "GET", f"/{base}/{uuid}/envs")


def cmd_env_set_typed(c, uuid: str, key: str, value: str, rtype: str):
    """Set or update an environment variable for an application or service."""
    base = "applications" if rtype == "application" else "services"
    # List existing env vars to find all matching entries
    existing = _request(c, "GET", f"/{base}/{uuid}/envs")
    env_list = _normalize_env_list(existing)

    # Find all entries with this key (both preview and non-preview)
    matching = [
        e for e in env_list
        if isinstance(e, dict) and e.get("key") == key
    ]

    if matching:
        # Update all matching entries to keep preview/non-preview siblings aligned
        results = []
        for entry in matching:
            result = _request(c, "PATCH", f"/{base}/{uuid}/envs",
                            json_body={"key": key, "value": value, "is_preview": entry.get("is_preview", False)})
            results.append(result)
        return {"updated": len(matching), "key": key, "results": results}
    else:
        # Create new entry
        return _request(c, "POST", f"/{base}/{uuid}/envs",
                       json_body={"key": key, "value": value})


def cmd_env_rm_typed(c, uuid: str, key: str, rtype: str):
    """Remove all environment variable entries matching KEY for an application or service."""
    base = "applications" if rtype == "application" else "services"
    # List existing env vars to find all matching entries
    existing = _request(c, "GET", f"/{base}/{uuid}/envs")
    env_list = _normalize_env_list(existing)

    # Find all entries with this key (both preview and non-preview)
    matching = [
        e for e in env_list
        if isinstance(e, dict) and e.get("key") == key
    ]

    if not matching:
        _die(3, "not_found", f"environment variable {key!r} not found",
             f"use `coolify env list {uuid} --type {rtype}` to see available variables")

    # Delete all matching entries
    deleted = []
    for entry in matching:
        env_uuid = entry.get("uuid")
        is_preview = entry.get("is_preview", False)
        _request(c, "DELETE", f"/{base}/{uuid}/envs/{env_uuid}")
        deleted.append({"uuid": env_uuid, "is_preview": is_preview})

    return {"deleted": len(matching), "key": key, "entries": deleted}


def cmd_env_bulk(c, uuid: str, env_data: str, rtype: str):
    """Bulk update environment variables (PATCH). env_data is newline-separated KEY=VALUE pairs."""
    base = "applications" if rtype == "application" else "services"
    # Parse KEY=VALUE pairs from input
    env_vars = []
    for line in env_data.strip().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        env_vars.append({"key": key.strip(), "value": value.strip()})

    if not env_vars:
        _die(6, "input", "no valid KEY=VALUE pairs found in input")

    return _request(c, "PATCH", f"/{base}/{uuid}/envs/bulk", json_body=env_vars)


def cmd_projects_create(c, name: str, description: str | None):
    """Create a new project."""
    payload = {"name": name}
    if description:
        payload["description"] = description
    result = _request(c, "POST", "/projects", json_body=payload)
    return result


def cmd_app_create(c, args):
    """Create an application with various source types."""
    import base64

    # Build the payload - common fields
    payload = {
        "project_uuid": args.project,
        "server_uuid": args.server,
        "environment_name": args.environment,
    }

    # Optional common fields
    if hasattr(args, 'name') and args.name:
        payload["name"] = args.name
    if hasattr(args, 'domains') and args.domains:
        payload["domains"] = args.domains
    if hasattr(args, 'ports_exposes') and args.ports_exposes:
        payload["ports_exposes"] = args.ports_exposes
    if hasattr(args, 'instant_deploy') and args.instant_deploy:
        payload["instant_deploy"] = True
    if hasattr(args, 'destination') and args.destination:
        payload["destination_uuid"] = args.destination

    # Determine source type and endpoint
    if hasattr(args, 'image') and args.image:
        # Registry image
        endpoint = "/applications/dockerimage"
        parts = args.image.rsplit(":", 1)
        payload["docker_registry_image_name"] = parts[0]
        payload["docker_registry_image_tag"] = parts[1] if len(parts) > 1 else "latest"
    elif hasattr(args, 'dockerfile') and args.dockerfile:
        # Inline dockerfile
        endpoint = "/applications/dockerfile"
        if args.dockerfile == "-":
            dockerfile_content = sys.stdin.read()
        else:
            dockerfile_content = Path(args.dockerfile).read_text()
        payload["dockerfile"] = dockerfile_content
    elif hasattr(args, 'git_repository') and args.git_repository:
        # Git-based - determine which endpoint
        payload["git_repository"] = args.git_repository
        payload["git_branch"] = args.git_branch
        if hasattr(args, 'build_pack') and args.build_pack:
            payload["build_pack"] = args.build_pack
        if hasattr(args, 'docker_compose_location') and args.docker_compose_location:
            payload["docker_compose_location"] = args.docker_compose_location
        if hasattr(args, 'dockerfile_location') and args.dockerfile_location:
            payload["dockerfile_location"] = args.dockerfile_location

        if hasattr(args, 'private_deploy_key') and args.private_deploy_key:
            endpoint = "/applications/private-deploy-key"
            payload["private_key_uuid"] = args.private_deploy_key
        elif hasattr(args, 'github_app') and args.github_app:
            endpoint = "/applications/private-github-app"
            payload["github_app_uuid"] = args.github_app
        else:
            endpoint = "/applications/public"
    else:
        _die(6, "input", "must specify one source type: --image, --dockerfile, or --git-repository")

    return _request(c, "POST", endpoint, json_body=payload)


def cmd_service_create(c, args):
    """Create a service from docker-compose file."""
    import base64

    # Read compose file
    if args.compose == "-":
        compose_content = sys.stdin.read()
    else:
        compose_content = Path(args.compose).read_text()

    # Base64 encode the compose content
    compose_b64 = base64.b64encode(compose_content.encode()).decode()

    payload = {
        "project_uuid": args.project,
        "server_uuid": args.server,
        "environment_name": args.environment,
        "docker_compose_raw": compose_b64,
    }

    if args.name:
        payload["name"] = args.name
    if args.instant_deploy:
        payload["instant_deploy"] = True
    if args.destination:
        payload["destination_uuid"] = args.destination

    return _request(c, "POST", "/services", json_body=payload)


# ── dispatch ────────────────────────────────────────────────────────────────

def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through

    p = argparse.ArgumentParser(prog="coolify", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("--connection", default=None,
                   help="select a named connection from the registry")
    p.add_argument("--base-url", dest="base_url", default=None,
                   help="Coolify instance base URL (overrides env/config)")
    p.add_argument("--token", default=None,
                   help="API token (prefer config/env; avoid on CLI)")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help")
    sub.add_parser("doctor")
    sub.add_parser("resources")

    # projects with create subcommand
    sp = sub.add_parser("projects")
    sp.add_argument("uuid", nargs="?", default=None)
    sp.add_argument("subcmd", nargs="?", default=None, choices=["create"])
    sp.add_argument("--name", default=None)
    sp.add_argument("--description", default=None)

    for verb in ("applications", "services", "databases",
                 "servers", "deployments"):
        sp = sub.add_parser(verb)
        sp.add_argument("uuid", nargs="?", default=None)

    sp = sub.add_parser("logs")
    sp.add_argument("uuid")
    sp.add_argument("--lines", type=int, default=100)

    sp = sub.add_parser("deploy")
    sp.add_argument("uuid")
    sp.add_argument("--force", action="store_true", help="rebuild without cache")
    sp.add_argument("--tag", default=None, help="deploy by image tag")

    for verb in ("start", "stop", "restart"):
        sp = sub.add_parser(verb)
        sp.add_argument("uuid")
        sp.add_argument("--type", dest="rtype", default="application",
                        choices=["application", "service", "database"])

    # app create
    sp = sub.add_parser("app", help="create application")
    app_sub = sp.add_subparsers(dest="app_cmd", required=True)
    sp_create = app_sub.add_parser("create", help="create application")
    sp_create.add_argument("--project", required=True, help="project UUID")
    sp_create.add_argument("--server", required=True, help="server UUID")
    sp_create.add_argument("--environment", required=True, help="environment name")
    sp_create.add_argument("--name", help="application name")
    sp_create.add_argument("--domains", help="comma-separated domains")
    sp_create.add_argument("--ports-exposes", dest="ports_exposes", help="exposed ports")
    sp_create.add_argument("--instant-deploy", dest="instant_deploy", action="store_true")
    sp_create.add_argument("--destination", help="destination UUID")
    # Source type flags
    sp_create.add_argument("--git-repository", dest="git_repository", help="git repository URL")
    sp_create.add_argument("--git-branch", dest="git_branch", help="git branch")
    sp_create.add_argument("--build-pack", dest="build_pack",
                          choices=["nixpacks", "railpack", "static", "dockerfile", "dockercompose"])
    sp_create.add_argument("--docker-compose-location", dest="docker_compose_location")
    sp_create.add_argument("--dockerfile-location", dest="dockerfile_location")
    sp_create.add_argument("--private-deploy-key", dest="private_deploy_key", help="deploy key UUID")
    sp_create.add_argument("--github-app", dest="github_app", help="GitHub app UUID")
    sp_create.add_argument("--image", help="registry image (name:tag)")
    sp_create.add_argument("--dockerfile", help="inline dockerfile (file path or - for stdin)")

    # service create
    sp = sub.add_parser("service", help="create service")
    service_sub = sp.add_subparsers(dest="service_cmd", required=True)
    sp_create = service_sub.add_parser("create", help="create service")
    sp_create.add_argument("--compose", required=True, help="docker-compose file (path or - for stdin)")
    sp_create.add_argument("--project", required=True, help="project UUID")
    sp_create.add_argument("--server", required=True, help="server UUID")
    sp_create.add_argument("--environment", required=True, help="environment name")
    sp_create.add_argument("--name", help="service name")
    sp_create.add_argument("--instant-deploy", dest="instant_deploy", action="store_true")
    sp_create.add_argument("--destination", help="destination UUID")

    sp = sub.add_parser("env", help="manage application/service environment variables")
    env_sub = sp.add_subparsers(dest="env_cmd", required=True)

    sp_list = env_sub.add_parser("list", help="list environment variables")
    sp_list.add_argument("uuid")
    sp_list.add_argument("--type", dest="rtype", default="application",
                        choices=["application", "service"])

    sp_set = env_sub.add_parser("set", help="set environment variable")
    sp_set.add_argument("uuid")
    sp_set.add_argument("key")
    sp_set.add_argument("value", nargs="?", default=None,
                        help="value (omit to read from stdin)")
    sp_set.add_argument("--type", dest="rtype", default="application",
                        choices=["application", "service"])

    sp_rm = env_sub.add_parser("rm", help="remove environment variable")
    sp_rm.add_argument("uuid")
    sp_rm.add_argument("key")
    sp_rm.add_argument("--type", dest="rtype", default="application",
                        choices=["application", "service"])

    sp_bulk = env_sub.add_parser("bulk", help="bulk update environment variables")
    sp_bulk.add_argument("uuid")
    sp_bulk.add_argument("--type", dest="rtype", default="application",
                        choices=["application", "service"])

    args = p.parse_args()
    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n")); return
    if args.cmd == "doctor":
        cmd_doctor(args); return

    conn = _resolve_conn(args)

    # Determine if this is a write operation for gate check
    is_write = args.cmd in WRITE_VERBS
    if args.cmd == "projects" and hasattr(args, "subcmd") and args.subcmd == "create":
        is_write = True
    elif args.cmd in ("app", "service"):
        is_write = True

    if is_write:
        _write_gate(conn["id"], conn["allow_write"], args.cmd)

    with _client(conn) as c:
        if args.cmd == "resources":
            _emit(_slim_list(_request(c, "GET", "/resources")))
        elif args.cmd == "projects":
            if hasattr(args, "subcmd") and args.subcmd == "create":
                if not args.name:
                    _die(6, "input", "projects create requires --name")
                _emit(cmd_projects_create(c, args.name, args.description))
            else:
                _emit(cmd_collection(c, args.cmd, args.uuid))
        elif args.cmd in ("applications", "services", "databases",
                          "servers", "deployments"):
            _emit(cmd_collection(c, args.cmd, args.uuid))
        elif args.cmd == "logs":
            _emit(cmd_logs(c, args.uuid, args.lines))
        elif args.cmd == "deploy":
            _emit(cmd_deploy(c, args.uuid, args.force, args.tag))
        elif args.cmd in ("start", "stop", "restart"):
            _emit(cmd_lifecycle(c, args.cmd, args.uuid, args.rtype))
        elif args.cmd == "app":
            if args.app_cmd == "create":
                _emit(cmd_app_create(c, args))
            else:
                _die(6, "unknown_command", f"no handler for app {args.app_cmd!r}")
        elif args.cmd == "service":
            if args.service_cmd == "create":
                _emit(cmd_service_create(c, args))
            else:
                _die(6, "unknown_command", f"no handler for service {args.service_cmd!r}")
        elif args.cmd == "env":
            if args.env_cmd == "list":
                _emit(cmd_env_list_typed(c, args.uuid, args.rtype))
            elif args.env_cmd == "set":
                value = args.value
                if value is None:
                    import getpass
                    value = getpass.getpass("")
                _emit(cmd_env_set_typed(c, args.uuid, args.key, value, args.rtype))
            elif args.env_cmd == "rm":
                _emit(cmd_env_rm_typed(c, args.uuid, args.key, args.rtype))
            elif args.env_cmd == "bulk":
                env_data = sys.stdin.read()
                _emit(cmd_env_bulk(c, args.uuid, env_data, args.rtype))
            else:
                _die(6, "unknown_command", f"no handler for env {args.env_cmd!r}")
        else:
            _die(6, "unknown_command", f"no handler for {args.cmd!r}")


if __name__ == "__main__":
    main()
