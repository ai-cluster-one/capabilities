# callva — credentials (copy to $XDG_CONFIG_HOME/callva/credentials.env,
# default ~/.config/callva/credentials.env, and fill). This is the tier-3
# (user config) source in the 4-tier cascade:
#   flags > project .env(.local) > THIS user config > process env.
# A consuming project can override per-project by setting these in its own .env.
# PUBLIC REPO: never commit real values. Leave blank here; fill only the copy.

# CallVA API key — the default identity every call uses. Bearer token for the
# External API. Mint one in the CallVA dashboard. Never pass it on the command
# line; the CLI reads it by name through the cascade.
CALLVA_API_KEY=

# Base URL (optional). Defaults to https://api.callva.one/api/v1 when unset.
# Override only to target a staging / self-hosted deployment.
# CALLVA_API_URL=

# Alternate identities (optional). The CLI selects which key holds the API key
# with `--key-env <KEY>` — e.g. to act as a different CallVA account/tenant. Add
# the key here (or in the project .env) and name it on the call; the value never
# touches the command line. Example:
# CALLVA_ALT_API_KEY=
