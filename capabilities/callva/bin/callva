        "code": automations_code, "deploy": automations_deploy, "run": automations_run,
        "runs": automations_runs, "all-runs": automations_all_runs,
        "run-detail": automations_run_detail, "runtime-info": automations_runtime_info,
    },
    "webhook-logs": {
        "list": webhook_logs_list, "get": webhook_logs_get, "filters": webhook_logs_filters,
    },
    "variables": {
        "list": variables_list, "create": variables_create,
        "update": variables_update, "delete": variables_delete,
    },
    "settings": {"list": settings_list, "get": settings_get},
    "projects": {"list": projects_list, "get": projects_get},
    "phone-numbers": {"list": phone_numbers_list, "get": phone_numbers_get},
    "providers": {"list": providers_list, "types": providers_types},
}


def _extract_globals(argv):
    """Pull --full / --key-env / --api-url (and a legacy --json no-op) out of argv so
    they work in any position. The API key value never appears here — only its NAME."""
    full = False
    key_env = "CALLVA_API_KEY"
    api_url = None
    cleaned = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--full":
            full = True; i += 1; continue
        if a == "--json":  # legacy no-op: JSON is the default output now
            i += 1; continue
        if a == "--key-env" and i + 1 < len(argv):
            key_env = argv[i + 1]; i += 2; continue
        if a.startswith("--key-env="):
            key_env = a.split("=", 1)[1]; i += 1; continue
        if a == "--api-url" and i + 1 < len(argv):
            api_url = argv[i + 1]; i += 2; continue
        if a.startswith("--api-url="):
            api_url = a.split("=", 1)[1]; i += 1; continue
        cleaned.append(a); i += 1
    return cleaned, full, key_env, api_url


def main():
    global FULL
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    cleaned, FULL, key_env, api_url = _extract_globals(sys.argv[1:])

    if not cleaned or cleaned[0] == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return

    args = build_parser().parse_args(cleaned)

    api_key = _load_api_key(key_env)
    base = (api_url or _resolve("CALLVA_API_URL") or DEFAULT_API_URL).rstrip("/")

    with _client(api_key, base) as client:
        _STATE["client"] = client
        _STATE["base"] = base
        _STATE["key_env"] = key_env

        handler = DISPATCH.get(args.resource)
        if callable(handler):
            value = handler(args)
        elif isinstance(handler, dict):
            fn = handler.get(getattr(args, "action", None))
            if not fn:
                _die(6, "unknown_action", f"unknown action: {args.resource} {getattr(args, 'action', None)}")
            value = fn(args)
        else:
            _die(6, "unknown_resource", f"unknown resource: {args.resource}")

        if value is not None:
            _emit(value)


if __name__ == "__main__":
    main()
