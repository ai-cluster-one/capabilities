# ===================================================================
# SETTINGS
# ===================================================================


def settings_list(_args):
    result = api("GET", "/external/settings/project")

    def slim(r):
        data = r.get("data", {})
        settings = data.get("settings", []) if isinstance(data, dict) else []
        filtered = dict(r)
        filtered_data = dict(data)
        filtered_data["settings"] = [
            _pick(s, ["key", "label", "category", "effective_value", "inherited_from"])
            for s in settings
        ]
        filtered_data.pop("sections", None)
        filtered["data"] = filtered_data
        return filtered

    return _result(result, slim=slim)


def settings_get(args):
    result = api("GET", "/external/settings/project")
    data = result.get("data", {})
    settings = data.get("settings", []) if isinstance(data, dict) else []
    match = next((s for s in settings if s.get("key") == args.key), None)
    if not match:
        _die(3, "not_found", f"setting not found: {args.key}",
             "run `callva settings list` to see available keys")
    return match


