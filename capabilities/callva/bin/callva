# ===================================================================
# CALLS
# ===================================================================


def _apply_filters(query, filters):
    """Fold repeatable -f key=value filters into a query dict."""
    for filt in filters or []:
        k, _, v = filt.partition("=")
        if v:
            query[k] = v


def calls_list(args):
    query = {"sort": args.sort}
    if args.per_page:
        query["per_page"] = str(args.per_page)
    if args.page:
        query["page"] = str(args.page)
    _apply_filters(query, args.filter)
    result = api("GET", "/external/calls", query=query)

    def slim_call(c):
        core = ["id", "name", "phone", "status", "result", "direction",
                "duration", "created_at", "company_name", "invoice_amount"]
        s = _pick(c, core)
        for k, v in c.items():
            if k not in s and v is not None and k not in (
                "tenant_id", "project_id", "updated_at"
            ):
                s[k] = v
        return s

    return _result(result, slim=lambda r: _apply_slim(r, slim_call))


def calls_get(args):
    r = api("GET", f"/external/calls/{args.id}")
    return r.get("data", r)


def calls_create(args):
    r = api("POST", "/external/calls", args.payload or {})
    return r.get("data", r)


def calls_update(args):
    r = api("PATCH", f"/external/calls/{args.id}", _data(args.payload))
    return r.get("data", r)


def calls_delete(args):
    api("DELETE", f"/external/calls/{args.id}")
    return {"deleted": args.id}


def calls_batch(args):
    data = {"ids": args.ids, "updates": _data(args.payload)}
    r = api("PATCH", "/external/calls/batch", data)
    return r.get("data", r)


def calls_webhook_logs(args):
    query = {}
    if args.per_page:
        query["per_page"] = str(args.per_page)
    if args.page:
        query["page"] = str(args.page)
    if args.sort:
        query["sort"] = args.sort
    for filt in args.filter or []:
        k, _, v = filt.partition("=")
        if v and k != "related_call_id":  # forced by route
            query[k] = v
    result = api("GET", f"/external/calls/{args.call_id}/webhook-logs", query=query)
    return _result(result, slim=lambda r: _apply_slim(
        r, lambda log: _slim_webhook_log(log, include_call=False)))


def calls_automation_runs(args):
    query = {}
    if args.per_page:
        query["per_page"] = str(args.per_page)
    if args.page:
        query["page"] = str(args.page)
    _apply_filters(query, args.filter)
    if args.no_include_args:
        query["include_args"] = "false"
    result = api("GET", f"/external/calls/{args.call_id}/automation-runs", query=query)
    return _result(result, slim=lambda r: _apply_slim(r, lambda run: _pick(run, [
        "id", "automation_id", "automation_name", "status",
        "triggered_by", "duration_ms", "started_at", "args"])))


