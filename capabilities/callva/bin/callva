#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""callva — agent-first CLI for the CallVA voice-AI platform.

This tool is designed to be invoked by agents. Run `callva help` to load the
full usage contract on demand — do not rely on memorised knowledge of its
surface. It is a pure CRUD / I/O adapter over the CallVA External API: voice
agents, assets (prompts), calls, transcripts, recordings, analytics, custom
fields, webhook schedules, automations (Windmill scripts), webhook logs,
variables, settings, projects, phone numbers, and providers.

Credentials resolve through the standard cascade — flags > a project
.env(.local) > $XDG_CONFIG_HOME/callva/credentials.env > the process env;
first non-empty wins:
  CALLVA_API_KEY=<your CallVA API key>   secret — never passed on argv
  CALLVA_API_URL=<base URL>              optional; default
                                         https://api.callva.one/api/v1

Global options (accepted anywhere on the line — before or after the command):
  --full              return the full, unfiltered API response (list endpoints
                      are slimmed to the agent-useful fields by default)
  --key-env <KEY>     resolve the API key from a different env/cred KEY (default
                      CALLVA_API_KEY) — act as a different CallVA account/tenant.
                      Only the key NAME travels; the value never touches argv.
  --api-url <URL>     override the base URL for this invocation

Output is JSON on stdout. List endpoints are slimmed to the fields an agent
needs; pass --full for the raw API response. `get` / detail commands always
return the full resource. `recordings stream` writes binary audio.

Commands (`-f key=value` is repeatable for list filters):

  doctor                              authenticated round-trip — proves the key
                                      resolves, the API is reachable, and what
                                      project the key sees
  help                                print this contract

  agents list [--is-active B]
  agents default
  agents get <id>
  agents update <id> [--name N] [--voice V] [--prompt T | --prompt-file F]
                     [--greeting-type prompt|exact|instruction]
                     [--greeting-exact T] [--greeting-instruction T]
                     [--agent-speaks-first B] [--config JSON | --data JSON]
  agents delete <id>

  assets list [--type prompt|schema|payload] [--per-page N]
  assets get <id>
  assets create --name N --type T (--content C | --content-file F) [--inactive]
  assets update <id> [--name N] [--content C | --content-file F] [--is-active B]
  assets delete <id>

  calls list [--per-page N] [--page N] [--sort F] [-f k=v ...]
  calls get <id>
  calls create --data JSON
  calls update <id> --data JSON
  calls delete <id>
  calls batch <id> [<id> ...] --data JSON
  calls webhook-logs <call_id> [--per-page N] [--page N] [--sort F] [-f k=v ...]
  calls automation-runs <call_id> [--per-page N] [--page N] [-f k=v ...]
                        [--no-include-args]

  transcripts get <call_id>
  transcripts store <call_id> (--data JSON | --data-file F)
  transcripts delete <call_id>
  transcripts url <call_id>

  call <destination> --agent-id ID [--phone-number-id ID] [--call-id ID]
                     [--overrides JSON]

  stats aggregate --op count|sum|avg|min|max [--field F] [--group-by F]
                  [--interval day|week|month] [-f k=v ...]
  stats trends --from DATE --to DATE

  recordings stream <call_id> --url URL [--output FILE]   (binary; stdout if no
                                                           --output)

  fields list [--entity-type T]
  fields create --data JSON
  fields update <id> --data JSON
  fields delete <id>
  fields impact <id>

  field-groups list
  field-groups create --data JSON
  field-groups update <id> --data JSON
  field-groups delete <id>
  field-groups reorder --data JSON
  field-groups add-field <id> <field_id>
  field-groups remove-field <id> <field_id>
  field-groups reorder-fields <id> --data JSON
  field-groups update-field <id> <field_id> --data JSON

  schedules list
  schedules get <id>
  schedules create --data JSON
  schedules update <id> --data JSON      (full PUT — send the complete payload,
                                          all rules included)
  schedules delete <id>
  schedules preview <id> <datetime>
  schedules executions <id> [--per-page N]

  automations list [--per-page N]
  automations get <id>
  automations create --name N [--description D]
  automations update <id> [--name N] [--description D] [--is-active B]
                          [--settings JSON | --data JSON]
  automations delete <id>
  automations code <id>
  automations deploy <id> (--file F | --code C) [--language deno]
  automations run <id> [--args JSON | --args-file F]
  automations runs <id> [--per-page N]
  automations all-runs [--per-page N] [--page N] [-f k=v ...]
                       [--args-filter JSON] [--result-filter JSON]
                       [--include-args]
  automations run-detail <id> <job_id>
  automations runtime-info

  webhook-logs list [--per-page N] [--page N] [--sort F] [-f k=v ...]
  webhook-logs get <id>
  webhook-logs filters

  variables list
  variables create --name N --value V [--description D] [--is-secret B]
  variables update <path> --value V
  variables delete <path>

  settings list
  settings get <key>

  projects list [--is-active B] [--per-page N]
  projects get <id>

  phone-numbers list [--is-active B] [--per-page N]
  phone-numbers get <id>

  providers list [--is-active B] [--provider-type T] [--per-page N]
  providers types

Conventions:
  - Filtering on list/stats commands is always `-f key=value` (repeatable):
    e.g. `calls list -f status=complete -f result=confirmed`. There are no bare
    per-field flags like `--status`.
  - `stats aggregate` filters dates with `-f created_at_gte=<date>`; `--from` /
    `--to` belong to `stats trends` only.
  - Use file flags (`--content-file`, `--prompt-file`, `--file`, `--data-file`,
    `--args-file`) for large content; `-` reads stdin.
  - `--data` / `--overrides` / `--settings` take a JSON object.

Contract commands (the same on every capability):
  callva stub                                 One-line awareness text.
  callva manifest --json                      Machine-readable declaration.
  callva guide [<topic>]                      Guide topics / one guide body,
                                              fetched live from the docs base.
  callva ids list|get <l>|set <l> <v>|rm <l>  The project identifiers envelope
         [--note <text>]                      (.capabilities/callva/identifiers.json).
  callva refs                                 Menu of the project's reference
                                              files for this capability.

Project settings: non-secret config (e.g. api_url) may live in
.capabilities/callva/settings.json; a project .env still overrides it.

I/O contract:
  - Success: JSON on stdout, exit 0.
  - Error:   {"error": {"code", "message", "hint"?, "status"?}} on stderr,
             non-zero exit.

Exit codes:
  0  success
  2  auth (missing / rejected credentials, 401 / 403)
  3  not found (404)
  4  disabled by project policy (.capabilities/settings.json — ask the user,
     never enable it yourself)
  5  server / network (timeout, connection error, 429 after retries, 5xx)
  6  input / validation (malformed argument, bad payload, 400 / 422)
"""

import argparse
import json
import os
import sys
import time
import urllib.parse
from pathlib import Path
from typing import NoReturn

import httpx

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

DEFAULT_API_URL = "https://api.callva.one/api/v1"
TIMEOUT = httpx.Timeout(60.0)
MAX_RETRIES = 3

# --- Capability declaration (protocol 1) — one home for every contract fact --

NAME = "callva"
PROTOCOL = 1
SUMMARY = ("CallVA voice-AI platform CLI over the External API — "
           "read/create/update/delete agents, assets (prompts), calls, "
           "transcripts, recordings, call analytics, custom fields, webhook "
           "schedules, automations (Windmill scripts), webhook logs, "
           "variables, settings, projects, phone numbers, and providers.")
SCOPE = "project"   # credential scope: "project" | "user"
CRED_KEYS = [
    {"key": "CALLVA_API_KEY", "secret": True, "required": True,
     "note": "External API key (default identity; alternates via --key-env)"},
    {"key": "CALLVA_API_URL", "secret": False, "required": False,
     "note": "API base URL; default https://api.callva.one/api/v1"},
]
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CONFIG_DIR = _CONFIG_HOME / "callva"
CREDENTIALS_ENV = CONFIG_DIR / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

# Set by --full; list endpoints slim to agent-useful fields unless True.
FULL = False

# Holds the live client + resolved base URL, so handlers call api() freely.
_STATE: dict = {}


# ---------------------------------------------------------------------------
# Credential cascade  (flags > project .env(.local) > user config > process env)
# ---------------------------------------------------------------------------


def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    for d in (here, *here.parents):
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _resolve(key: str, default: str | None = None) -> str | None:
    """Resolve a non-secret value by key name: project .env(.local), then the
    project settings envelope (key minus the NAME_ prefix, lowercased), then
    user config, then process env."""
    return (_project_env().get(key)
            or _project_settings().get(key.removeprefix(NAME.upper() + "_").lower())
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or default)


def _load_api_key(key_name: str) -> str:
    """Resolve the CallVA API key by env-var NAME through the cascade — a project
    .env(.local), then ~/.config/callva/credentials.env, then the process env;
    first non-empty wins. The key value never travels on the command line; only
    --key-env selects which NAME holds it (default CALLVA_API_KEY)."""
    tok = (_project_env().get(key_name)
           or _parse_env_file(CREDENTIALS_ENV).get(key_name)
           or os.environ.get(key_name)
           or "").strip()
    if tok:
        return tok
    if key_name == "CALLVA_API_KEY":
        _die(2, "missing_api_key",
             f"CALLVA_API_KEY not found in a project .env, {CREDENTIALS_ENV}, or the environment",
             "add CALLVA_API_KEY=<your CallVA API key> to the user config or a project .env")
    _die(2, "missing_api_key",
         f"{key_name} not found in a project .env, {CREDENTIALS_ENV}, or the environment",
         f"add {key_name}=<key> to the user config or a project .env to use --key-env {key_name}")


# --- Capability contract (protocol 1) — shared verbatim across capabilities --

def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks."""
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _project_settings() -> dict:
    """Capability-owned, non-secret project config: .capabilities/<NAME>/settings.json."""
    envdir = _env_dir()
    if envdir is None:
        return {}
    try:
        return json.loads((envdir / "settings.json").read_text())
    except (OSError, ValueError):
        return {}


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import httpx as _hx
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        resp = _hx.get(url, headers=headers, timeout=10.0, follow_redirects=True)
        if resp.status_code == 200:
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(resp.text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(resp.text); return
        if resp.status_code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if resp.status_code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        raise _hx.HTTPError(f"upstream returned {resp.status_code}")
    except _hx.HTTPError as e:
        if cache.exists():
            sys.stderr.write(json.dumps(
                {"warning": f"upstream unreachable; serving cached copy ({e})"},
                ensure_ascii=False) + "\n")
            _emit(cache.read_text()); return
        _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    out = []
    if envdir and envdir.is_dir():
        for md in sorted(envdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    else:
        return
    sys.exit(0)


# ---------------------------------------------------------------------------
# Output / errors  (success = JSON on stdout; failure = envelope on stderr)
# ---------------------------------------------------------------------------


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


# ---------------------------------------------------------------------------
# HTTP client
# ---------------------------------------------------------------------------


def _client(api_key: str, base_url: str) -> httpx.Client:
    return httpx.Client(
        base_url=base_url,
        headers={"Authorization": f"Bearer {api_key}"},
        timeout=TIMEOUT,
    )


def _api_message(data) -> str | None:
    """Best-effort human message from a CallVA error body."""
    if isinstance(data, dict):
        if data.get("message"):
            return data["message"]
        errs = data.get("errors")
        if isinstance(errs, dict):
            for v in errs.values():
                if isinstance(v, list) and v:
                    return str(v[0])
                return str(v)
        if isinstance(errs, list) and errs:
            first = errs[0]
            return first.get("message") if isinstance(first, dict) else str(first)
    if isinstance(data, str) and data:
        return data
    return None


def _map_4xx(status: int, data, path: str, allow_404: bool):
    if allow_404 and status == 404:
        return None
    msg = _api_message(data) or f"HTTP {status}"
    if status in (401, 403):
        _die(2, "unauthorized", msg,
             "CALLVA_API_KEY may be invalid or lack access to this resource", status=status)
    if status == 404:
        _die(3, "not_found", msg,
             "verify the id exists and the key can see it", status=status)
    if status in (400, 422):
        _die(6, "invalid_request", msg, None, status=status)
    _die(5, "api_error", msg, None, status=status)


def _request(client: httpx.Client, method: str, path: str,
             params: dict | None = None, json_body: dict | None = None,
             allow_404: bool = False):
    """Authenticated request with bounded, backed-off retries. Returns parsed JSON."""
    clean = {k: v for k, v in (params or {}).items() if v is not None}
    last_status: int | None = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = client.request(method, path, params=clean or None, json=json_body)
        except httpx.TimeoutException:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "timeout", f"request timed out: {method} {path}",
                 "the CallVA API was unresponsive")
        except httpx.RequestError as e:
            _die(5, "network_error", f"network error: {e}", "check connectivity")

        last_status = resp.status_code
        if resp.status_code == 429:
            retry_after = float(resp.headers.get("Retry-After", str(attempt * 1.5)))
            if attempt < MAX_RETRIES:
                time.sleep(retry_after)
                continue
            _die(5, "rate_limited", f"rate-limited after {MAX_RETRIES} attempts",
                 "back off and retry later", status=429)
        if resp.status_code >= 500:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "server_error", f"CallVA returned {resp.status_code}",
                 None, status=resp.status_code)

        raw = resp.text
        if not raw:
            if resp.status_code >= 400:
                return _map_4xx(resp.status_code, {}, path, allow_404)
            return {"success": True}
        try:
            data = resp.json()
        except ValueError:
            if resp.status_code >= 400:
                _map_4xx(resp.status_code, raw, path, allow_404)
            _die(5, "invalid_response", f"non-JSON response from {method} {path}",
                 status=resp.status_code)

        if resp.status_code >= 400:
            return _map_4xx(resp.status_code, data, path, allow_404)
        return data

    _die(5, "exhausted_retries", f"exhausted {MAX_RETRIES} attempts on {method} {path}",
         status=last_status)


def _download(client: httpx.Client, path: str, params: dict | None, output: str | None):
    """Stream binary content (recordings) to a file or stdout."""
    clean = {k: v for k, v in (params or {}).items() if v is not None}
    try:
        with client.stream("GET", path, params=clean or None) as resp:
            if resp.status_code >= 400:
                body = resp.read()
                try:
                    parsed = json.loads(body.decode("utf-8"))
                except (ValueError, UnicodeDecodeError):
                    parsed = body.decode("utf-8", "replace")
                return _map_4xx(resp.status_code, parsed, path, False)
            ctype = resp.headers.get("Content-Type", "audio/mpeg")
            length = resp.headers.get("Content-Length", "unknown")
            if output:
                with open(output, "wb") as f:
                    for chunk in resp.iter_bytes(8192):
                        f.write(chunk)
                return {"file": output, "content_type": ctype, "size": length}
            for chunk in resp.iter_bytes(8192):
                sys.stdout.buffer.write(chunk)
            return None
    except httpx.TimeoutException:
        _die(5, "timeout", f"recording download timed out: {path}",
             "the CallVA API was unresponsive")
    except httpx.RequestError as e:
        _die(5, "network_error", f"network error: {e}", "check connectivity")


def api(method, path, data=None, query=None, allow_404=False):
    return _request(_STATE["client"], method, path,
                    params=query, json_body=data, allow_404=allow_404)


def api_download(path, output, query=None):
    return _download(_STATE["client"], path, query, output)


# ---------------------------------------------------------------------------
# Result shaping — slim list responses to agent-useful fields unless --full
# ---------------------------------------------------------------------------


def _result(result, slim=None):
    """Apply a slim projection unless --full was given."""
    return slim(result) if (slim and not FULL) else result


def _pick(obj, keys):
    """Extract only the specified keys from a dict."""
    return {k: obj[k] for k in keys if k in obj}


def _slim_options(options):
    """Collapse options to just values: [{"value":"a","label":"A"}] -> ["a"]."""
    if not options or not isinstance(options, list):
        return options
    return [o.get("value", o) for o in options if isinstance(o, dict)]


def _apply_slim(result, item_fn):
    """Apply a per-item slim function to the `data` array of a list response.
    Preserves pagination, meta, success, and message keys."""
    data = result.get("data")
    if isinstance(data, list):
        filtered = dict(result)
        filtered["data"] = [item_fn(item) for item in data]
        return filtered
    return result


# ---------------------------------------------------------------------------
# Argument helpers
# ---------------------------------------------------------------------------


def resolve_content(args):
    """Resolve content from --content or --content-file flags."""
    cf = getattr(args, "content_file", None)
    c = getattr(args, "content", None)
    if cf:
        return sys.stdin.read() if cf == "-" else open(cf).read()
    return c


def parse_bool(value):
    if value.lower() in ("true", "1", "yes"):
        return True
    if value.lower() in ("false", "0", "no"):
        return False
    raise argparse.ArgumentTypeError(f"Invalid boolean: {value}")


def parse_json_arg(value):
    try:
        return json.loads(value)
    except json.JSONDecodeError as e:
        raise argparse.ArgumentTypeError(f"Invalid JSON: {e}")


def parse_json_file(value):
    if value == "-":
        return json.loads(sys.stdin.read())
    with open(value) as f:
        return json.load(f)


def _data(value):
    """A non-empty --data/--payload object, or die with a validation error."""
    if not value:
        _die(6, "missing_payload", "provide the payload as --data '{...}'")
    return value


