# ===================================================================
# WEBHOOK SCHEDULES
# ===================================================================


def schedules_list(_args):
    result = api("GET", "/external/webhook-schedule")

    def slim_schedule(s):
        slimmed = _pick(s, ["id", "name", "webhook_url", "webhook_method", "is_active"])
        slimmed["rules"] = [
            _pick(rl, ["name", "action", "days_of_week", "time_from", "time_to",
                       "execution_interval", "is_active", "is_exclusive"])
            for rl in (s.get("rules") or [])
        ]
        return slimmed

    return _result(result, slim=lambda r: _apply_slim(r, slim_schedule))


def schedules_get(args):
    r = api("GET", f"/external/webhook-schedule/{args.id}")
    return r.get("data", r)


def schedules_create(args):
    r = api("POST", "/external/webhook-schedule", _data(args.payload))
    return r.get("data", r)


