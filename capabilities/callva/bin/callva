def _extract_globals(argv):
    """Pull --full / --key-env / --api-url / --connection (and a legacy --json
    no-op) out of argv so they work in any position. The API key value never
    appears here — only its NAME."""
    full = False
    key_env = None       # --key-env override; None = not passed
    api_url = None
    connection = None    # --connection; accepted anywhere on argv
    cleaned = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--full":
            full = True; i += 1; continue
        if a == "--json":  # legacy no-op: JSON is the default output now
            i += 1; continue
        if a == "--key-env" and i + 1 < len(argv):
            key_env = argv[i + 1]; i += 2; continue
        if a.startswith("--key-env="):
            key_env = a.split("=", 1)[1]; i += 1; continue
        if a == "--api-url" and i + 1 < len(argv):
            api_url = argv[i + 1]; i += 2; continue
        if a.startswith("--api-url="):
            api_url = a.split("=", 1)[1]; i += 1; continue
        if a == "--connection" and i + 1 < len(argv):
            connection = argv[i + 1]; i += 2; continue
        if a.startswith("--connection="):
            connection = a.split("=", 1)[1]; i += 1; continue
        cleaned.append(a); i += 1
    return cleaned, full, key_env, api_url, connection


def main():
    global FULL
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    cleaned, FULL, key_env, api_url, wanted_conn = _extract_globals(sys.argv[1:])

    if not cleaned or cleaned[0] == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return

    args = build_parser().parse_args(cleaned)

    reg, _ = _connections_registry()
    if args.resource == "doctor":
        cmd_doctor(reg, wanted_conn, key_env, api_url)
        return

    cid, entry = _select_connection(reg, wanted_conn)
    verb = (f"{args.resource} {args.action}"
            if getattr(args, "action", None) else args.resource)
    conn, problem = _build_conn(cid, entry, key_env, api_url)
    if problem:
        _die(problem["exit"], problem["code"], problem["message"],
             problem.get("hint"))
    _write_gate(cid, conn["allow_write"], verb)   # before any client exists

    with _client(conn["api_key"], conn["base"]) as client:
        _STATE["client"] = client
        _STATE["base"] = conn["base"]
        _STATE["key_env"] = conn["key_env"]

        handler = DISPATCH.get(args.resource)
        if callable(handler):
            value = handler(args)
        elif isinstance(handler, dict):
            fn = handler.get(getattr(args, "action", None))
            if not fn:
                _die(6, "unknown_action", f"unknown action: {args.resource} {getattr(args, 'action', None)}")
            value = fn(args)
        else:
            _die(6, "unknown_resource", f"unknown resource: {args.resource}")

        if value is not None:
            _emit(value)


if __name__ == "__main__":
    main()
