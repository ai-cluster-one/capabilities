def automations_get(args):
    r = api("GET", f"/external/automations/{args.id}")
    return r.get("data", r)


def automations_create(args):
    data = {"name": args.name}
    if args.description:
        data["description"] = args.description
    r = api("POST", "/external/automations", data)
    return r.get("data", r)


def automations_update(args):
    data = {}
    if args.payload:
        data = args.payload
    else:
        if args.name is not None:
            data["name"] = args.name
        if args.description is not None:
            data["description"] = args.description
        if args.is_active is not None:
            data["is_active"] = args.is_active
        if getattr(args, "settings_json", None) is not None:
            data["settings"] = args.settings_json
    if not data:
        _die(6, "nothing_to_update",
             "no fields to update; use --name, --description, --is-active, --settings, or --data")
    r = api("PUT", f"/external/automations/{args.id}", data)
    return r.get("data", r)


def automations_delete(args):
    api("DELETE", f"/external/automations/{args.id}")
    return {"deleted": args.id}


def automations_code(args):
    r = api("GET", f"/external/automations/{args.id}/code")
    return r.get("data", r)


def automations_deploy(args):
    if args.code_file:
        code = sys.stdin.read() if args.code_file == "-" else open(args.code_file).read()
    elif args.code:
        code = args.code
    else:
        _die(6, "missing_code", "provide code via --file or --code")
    r = api("PUT", f"/external/automations/{args.id}/code",
            {"code": code, "language": args.language})
    return r.get("data", r)


def automations_run(args):
    run_args = getattr(args, "run_args", None)
    body = {"input": run_args} if run_args is not None else None
    r = api("POST", f"/external/automations/{args.id}/run", data=body)
    return r.get("data", r)


