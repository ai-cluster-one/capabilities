# telegram — credentials (copy to $XDG_CONFIG_HOME/telegram/credentials.env,
# default ~/.config/telegram/credentials.env, and fill). This is the tier-3
# (user config) source in the 4-tier cascade:
#   flags > project .env(.local) > THIS user config > process env.
# A consuming project can override per-project by setting these in its own .env.
# PUBLIC REPO: never commit real values. Leave blank here; fill only the copy.

# Telegram app credentials — create an app at https://my.telegram.org/apps and
# copy its api_id (numeric) and api_hash. These identify the APP, not the
# account; the account is authorized once by `telegram login` (phone → code → optional
# 2FA), which writes the session file alongside this one. Never pass on argv.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Session file path (no extension). Optional — defaults to ~/.config/telegram/session,
# so the login session lives beside this file. Set only to keep it elsewhere;
# overridable per-invocation with `telegram --session <PATH>`.
# TELEGRAM_SESSION=

# Deepgram API key — only `telegram transcribe` reads it. Leave blank unless this
# install transcribes exported voice/audio. Never pass on argv.
# DEEPGRAM_API_KEY=
