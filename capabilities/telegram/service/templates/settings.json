{
  "connection": null,
  "assistant_name": "Assistant",
  "direct_messages": {
    "mode": "allowed_users",
    "default_role": "direct_user"
  },
  "allowed_users": {},
  "allowed_groups": {},
  "control": {
    "roles": {
      "supervisor": {
        "commands": ["status", "set", "stop", "help"]
      },
      "channel_admin": {
        "commands": ["status", "set", "help"]
      },
      "direct_user": {
        "commands": ["status", "help"]
      },
      "group_member": {
        "commands": ["status", "help"]
      }
    }
  },
  "authority": {
    "roles": {
      "supervisor": {
        "allowed_capabilities": {
          "*": true
        }
      },
      "direct_user": {
        "allowed_capabilities": {}
      },
      "group_member": {
        "allowed_capabilities": {
          "telegram": {
            "scope": "current_chat"
          },
          "routine": true
        }
      }
    }
  },
  "defaults": {
    "tail_size": 40,
    "sync_interval": 20,
    "sync_stale_after": 60,
    "debounce": 5,
    "worker_timeout": 120,
    "progress_after": 15,
    "max_parallel_jobs": 2,
    "group_aliases": ["Assistant"],
    "worker": "stub",
    "workers": {
      "claude": {
        "model": null,
        "effort": null
      },
      "codex": {
        "model": null,
        "reasoning_effort": null,
        "service_tier": null
      },
      "stub": {
        "model": null
      }
    }
  }
}
