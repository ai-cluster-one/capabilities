#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""
mail — personal Mail.app CLI (JXA-backed; read + draft only; no send).

No credentials on disk. Uses Mail.app's already-configured accounts. First
invocation requires a one-time macOS Automation grant:
  System Settings → Privacy & Security → Automation → your terminal → Mail

Commands:
  mail help
      Print this document.

  mail doctor
      Readiness — proves the macOS Automation grant by listing accounts.

  mail accounts [--json]
      List accounts Mail.app knows about.

  mail mailboxes <account> [--json]
      List mailboxes (folders) for an account.

  mail read <account> [--mailbox NAME] [--limit N] [--since ISO] [--json]
      Read recent messages from a mailbox (newest first).

  mail search <account> <query> [--mailbox NAME]
       [--field subject|sender|content|any] [--limit N] [--json]
      Search within an account. Default field is 'any' (subject OR sender).
      Content search is supported but slow.

  mail show <account> <message-id> [--json] [--html] [--raw]
      Show one message by RFC-822 Message-ID, including headers + body.
      --html prints the HTML body (link URLs intact); --raw prints the
      full RFC-822 source.

  mail links <account> <message-id> [--match TEXT] [--json]
      List hyperlinks (anchor text + URL) from a message's HTML body.
      --match filters to links whose text or URL contains TEXT.

  mail attachments <account> <message-id> [--save DIR] [--index N] [--json]
      List a message's attachments, or save them to DIR. --index N saves
      only the attachment at that index.

  mail fetch <url> --out PATH [--header 'Name: value' ...] [--timeout SEC]
      Download a URL to disk (follows redirects). Use to pull a PDF behind
      a 'Download receipt' link surfaced by `mail links`.

  mail draft <account> --to ADDR [--to ADDR ...] [--cc ADDR] [--bcc ADDR]
       --subject TEXT [--in-reply-to MESSAGE-ID] [--body TEXT | --body -]
      Compose a draft and save it to the account's Drafts folder.
      NO SEND. Use '--body -' to read body from stdin.

  mail export <account> --mailbox NAME --out PATH [--limit N] [--since ISO]
      Dump a mailbox to JSON (for .assets/messages/email/<conv>/messages.json).

<account> matches case-insensitively against the account's Mail.app name or
any of its configured email addresses.

Contract commands (the same on every capability):
  mail stub                                 One-line awareness text.
  mail manifest --json                      Machine-readable declaration.
  mail connections                          Connection resolution report. mail
                                            holds no credential (auth is the
                                            macOS Automation grant), so each
                                            connection reports an empty key set.
  mail guide [<topic>]                      Guide topics / one guide body,
                                            fetched live from the docs base.
  mail ids list|get <l>|set <l> <v>|rm <l>  The project identifiers envelope
       [--note <text>]                      (.capabilities/mail/identifiers.json).
  mail refs                                 Menu of the project's reference
                                            files for this capability.

Exit codes:
  0  success
  2  auth — the macOS Automation grant is missing (doctor)
  3  not found (contract verbs)
  4  disabled by project policy (.capabilities/settings.json — ask the user,
     never enable it yourself)
  5  server / network (contract verbs)
  6  input / validation
  Domain commands print human-readable output and exit 1 on failure — the
  recorded deviation in this capability's deviations.md.
"""

import argparse
import email
import json
import os
import re
import subprocess
import sys
import urllib.request
from email import policy
from html.parser import HTMLParser
from pathlib import Path
from typing import NoReturn


JXA_PRELUDE = r"""
ObjC.import('Foundation');

function env(name) {
  const v = $.NSProcessInfo.processInfo.environment.objectForKey(name);
  if (v.isNil()) return null;
  const s = ObjC.unwrap(v);
  return s === '' ? null : s;
}

function die(msg) { throw new Error(msg); }

function findAccount(target) {
  if (!target) die('No account specified');
  const Mail = Application('Mail');
  const needle = target.toLowerCase();
  for (const a of Mail.accounts()) {
    const name = (a.name() || '').toLowerCase();
    const emails = (a.emailAddresses() || []).map(e => (e || '').toLowerCase());
    if (name.includes(needle)) return a;
    if (emails.some(e => e.includes(needle))) return a;
  }
  die(`No Mail.app account matching: ${target}`);
}

function findMailbox(acct, name) {
  if (!name) name = 'INBOX';
  const target = name.toLowerCase();
  const mailboxes = acct.mailboxes();
  for (const mb of mailboxes) {
    if ((mb.name() || '').toLowerCase() === target) return mb;
  }
  for (const mb of mailboxes) {
    if ((mb.name() || '').toLowerCase().includes(target)) return mb;
  }
  die(`No mailbox "${name}" in account ${acct.name()}`);
}

function safeDateISO(d) {
  if (!d) return null;
  try { return d.toISOString(); } catch (e) { return null; }
}

function messageSummary(m) {
  let mbName = null;
  try { mbName = m.mailbox().name(); } catch (e) {}
  return {
    id: m.id(),
    messageId: m.messageId(),
    subject: m.subject(),
    sender: m.sender(),
    dateReceived: safeDateISO(m.dateReceived()),
    dateSent: safeDateISO(m.dateSent()),
    readStatus: m.readStatus(),
    mailbox: mbName
  };
}

function recipientList(m, kind) {
  const out = [];
  try {
    const recips = kind === 'to' ? m.toRecipients() :
                   kind === 'cc' ? m.ccRecipients() :
                                   m.bccRecipients();
    for (const r of recips) out.push({address: r.address(), name: r.name()});
  } catch (e) {}
  return out;
}

function messageFull(m) {
  const base = messageSummary(m);
  base.toRecipients = recipientList(m, 'to');
  base.ccRecipients = recipientList(m, 'cc');
  try { base.replyTo = m.replyTo(); } catch (e) { base.replyTo = null; }
  try { base.content = m.content(); } catch (e) { base.content = null; }
  try { base.allHeaders = m.allHeaders(); } catch (e) { base.allHeaders = null; }
  return base;
}

function accountSenderString(acct) {
  const emails = acct.emailAddresses() || [];
  const addr = emails[0];
  if (!addr) die(`Account ${acct.name()} has no email addresses configured`);
  const full = acct.fullName();
  return full ? `${full} <${addr}>` : addr;
}
"""


# --- Capability declaration (protocol 2) — one home for every contract fact --

NAME = "mail"
PROTOCOL = 2
SUMMARY = ("Mail.app CLI over macOS Automation — read/search mail across "
           "configured accounts, show a message, save attachments, draft "
           "(never send), and export a mailbox to JSON.")
SCOPE = "user"      # credential scope: "project" | "user"
CRED_KEYS: list = []   # no credentials — auth is the one-time macOS Automation grant
WRITE_VERBS: list = []  # nothing leaves the machine (drafts never send) — the write gate never fires
WRITE_DEFAULT = True
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "mail" / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))


# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _auth_context() -> dict | None:
    """Optional runtime authority envelope passed by an ingress/service.

    Absence means the ordinary project gate is the whole policy. Presence means
    a request-scoped authority layer exists and must fail closed before any
    credential or network work happens.
    """
    raw = os.environ.get("CAPABILITIES_AUTH_CONTEXT")
    if not raw:
        return None
    try:
        if raw.lstrip().startswith("{"):
            data = json.loads(raw)
        else:
            data = json.loads(Path(raw).read_text())
    except (OSError, ValueError) as e:
        _die(4, "auth_context_unreadable",
             "runtime authority context could not be read",
             f"{raw}: {e}")
    if not isinstance(data, dict):
        _die(4, "auth_context_invalid",
             "runtime authority context is not an object")
    return data


def _auth_capability_allowed(rule) -> bool:
    if rule is True or rule == "*":
        return True
    if rule in (False, None):
        return False
    if isinstance(rule, dict):
        if rule.get("deny") is True:
            return False
        if rule.get("enabled") is False or rule.get("allow") is False:
            return False
        return True
    return False


def _auth_gate() -> None:
    ctx = _auth_context()
    if ctx is None:
        return
    allowed = ctx.get("allowed_capabilities")
    if allowed is None:
        return
    if allowed is True or allowed == "*":
        return
    if isinstance(allowed, list):
        if NAME in allowed or "*" in allowed:
            return
    elif isinstance(allowed, dict):
        if _auth_capability_allowed(allowed.get(NAME, allowed.get("*"))):
            return
    else:
        _die(4, "auth_context_invalid",
             "runtime authority context has invalid allowed_capabilities")
    source = ctx.get("source") or "runtime"
    role = ctx.get("sender_role") or ctx.get("role") or "unknown"
    chat = ctx.get("chat_id") or "unknown"
    _die(4, "capability_not_authorized",
         f"{NAME} is not authorized for this {source} request",
         f"role={role}; chat_id={chat}; adjust runtime authority policy instead of bypassing the gate")


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks.

    If an ingress supplied CAPABILITIES_AUTH_CONTEXT, that request-scoped gate
    is stricter and also runs here, before credentials or network calls.
    """
    _auth_gate()
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import urllib.error as _ue
    import urllib.request as _ur
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        req = _ur.Request(url, headers=headers)
        with _ur.urlopen(req, timeout=10.0) as resp:
            text = resp.read().decode(resp.headers.get_content_charset() or "utf-8")
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(text); return
    except _ue.HTTPError as e:
        if e.code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if e.code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        err = f"upstream returned {e.code}"
    except _ue.URLError as e:
        err = str(e.reason)
    except OSError as e:
        err = str(e)
    if cache.exists():
        sys.stderr.write(json.dumps(
            {"warning": f"upstream unreachable; serving cached copy ({err})"},
            ensure_ascii=False) + "\n")
        _emit(cache.read_text()); return
    _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _render_ids_markdown(data: dict) -> str:
    """Render the {label: {value, note}} envelope as the labelled markdown
    list the manager's `capabilities ids <NAME>` also produces — one shared
    format across the ids surface and the identifiers section of `help`."""
    lines: list[str] = []
    for label, entry in sorted(data.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        v = entry.get("value")
        vs = f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"
        line = f"- **{label}**: {vs}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    return "\n".join(lines)


def _identifiers_section() -> str:
    """The Identifiers block appended to the bare top-level help — deterministic
    first-touch surfacing of `.capabilities/<NAME>/identifiers.json` so an
    agent following the `<NAME> help` startup protocol loads the discovered
    labels/values/notes into context at once. Empty when no project envelope
    or nothing recorded (do not bloat help with an empty section)."""
    envdir = _env_dir()
    if envdir is None:
        return ""
    ids_file = envdir / "identifiers.json"
    if not ids_file.exists():
        return ""
    try:
        data = json.loads(ids_file.read_text())
    except (OSError, ValueError):
        return ""
    if not isinstance(data, dict) or not data:
        return ""
    header = (
        "\n═══ Identifiers ═════════════════════════════════════════════════════════════\n\n"
        f"Structural lookups discovered for `{NAME}` in this project. Fetch a single\n"
        f"raw value with `{NAME} ids get <label>`; the full envelope is also at\n"
        f"`capabilities ids {NAME}`.\n\n"
    )
    return header + _render_ids_markdown(data) + "\n"


def _cmd_help() -> None:
    """Bare top-level help: the CLI's HELP body (module-level `HELP` if
    defined, else the module docstring), then the project's Identifiers
    section. Only fires when no extra args follow — per-verb help stays
    untouched so `<NAME> help <subcommand>` is not intercepted."""
    g = globals()
    text = g.get("HELP") or g.get("__doc__") or ""
    if text.startswith("\n"):
        text = text.lstrip("\n")
    sys.stdout.write(text)
    if text and not text.endswith("\n"):
        sys.stdout.write("\n")
    section = _identifiers_section()
    if section:
        sys.stdout.write(section)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved.

    `help` is a contract verb only when bare (no extra args) — the top-level
    dump plus the Identifiers section. `<NAME> help <subcommand>` falls
    through to the CLI so per-verb help stays clean."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    elif cmd == "help" and len(argv) == 1:
        _cmd_help()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


# >>> contract: connections (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

def _resolve_env_key(key: str) -> tuple[str | None, str | None, Path | None]:
    """Resolve one env key through cascade tiers 2-4: project .env(.local) →
    user credentials.env → process env. Returns (value, tier, source)."""
    root = _project_root()
    if root is not None:
        for fname in (".env.local", ".env"):
            val = _parse_env_file(root / fname).get(key)
            if val:
                return val, "project", root / fname
    val = _parse_env_file(CREDENTIALS_ENV).get(key)
    if val:
        return val, "user", CREDENTIALS_ENV
    val = os.environ.get(key)
    if val:
        return val, "env", None
    return None, None, None


def _mask(value: str) -> str:
    return ("…" + value[-4:]) if len(value) >= 8 else "****"


def _connections_registry() -> tuple[dict | None, Path | None]:
    """The connections envelope and its path: project envelope first, else the
    user config home. First found wins, never merged; (None, None) when neither
    declares one (the implicit default connection applies)."""
    envdir = _env_dir()
    candidates = ([envdir / "connections.json"] if envdir else []) + \
                 [_CONFIG_HOME / NAME / "connections.json"]
    for reg_file in candidates:
        if not reg_file.is_file():
            continue
        try:
            raw = json.loads(reg_file.read_text())
        except (ValueError, OSError) as e:
            _die(6, "bad_config", f"cannot read {reg_file}: {e}")
        if not isinstance(raw, dict) or not isinstance(raw.get("connections"), dict) \
                or not raw["connections"]:
            _die(6, "bad_config", f"{reg_file} is not a connections envelope",
                 'expected {"default": "<id>", "connections": { ... }}')
        return raw, reg_file
    return None, None


def _select_connection(reg: dict | None, wanted: str | None) -> tuple[str, dict | None]:
    """flag → default pointer → sole entry → die 6. No registry → the implicit
    default. A connection's own `address` field selects it too (used where a
    connection carries a human-recognizable address; absent fields never match)."""
    if reg is None:
        if wanted and wanted != "default":
            _die(6, "unknown_connection",
                 "no connections registry; the sole connection is 'default'",
                 "the implicit default resolves from the credential cascade")
        return "default", None
    conns = reg["connections"]
    if wanted:
        if wanted in conns:
            return wanted, conns[wanted]
        for cid, entry in conns.items():
            if (entry or {}).get("address", "").lower() == wanted.lower():
                return cid, entry
        _die(6, "unknown_connection", f"no connection matches {wanted!r}",
             f"known: {', '.join(conns)}")
    default = reg.get("default")
    if default:
        if default not in conns:
            _die(6, "bad_default", f"default points to unknown connection {default!r}",
                 f"known: {', '.join(conns)}")
        return default, conns[default]
    if len(conns) == 1:
        cid = next(iter(conns))
        return cid, conns[cid]
    _die(6, "ambiguous_connection",
         f"registry defines {len(conns)} connections and no default; "
         f"pass --connection <id>",
         f"known: {', '.join(conns)}")


def _write_gate(conn_id: str, allow_write: bool, verb: str) -> None:
    """Policy from the committed registry; nothing in the cascade lifts it."""
    if verb in WRITE_VERBS and not allow_write:
        _die(4, "read_only",
             f"connection {conn_id!r} does not allow writes",
             "Do not lift the gate yourself — ask the user; granting is "
             "`allow_write: true` on this connection in connections.json.")


def _key_report(key: str, secret: bool, required: bool,
                value: str | None, tier: str | None, source) -> dict:
    return {"key": key, "secret": secret, "required": required,
            "set": bool(value), "tier": tier if value else None,
            "source": str(source) if (value and source) else None,
            "value": (_mask(value) if secret else value) if value else None}


def _missing_required(keys: list) -> list:
    """Required report rows (from _key_report) that did not resolve through the
    cascade — empty ⇒ credentials present. The primitive behind doctor's
    network-free readiness gate, read from the same per-key resolution
    `connections` reports, so the gate and the report can never disagree."""
    return [k["key"] for k in keys if k["required"] and not k["set"]]


def _doctor_gate(report: dict, wanted: str | None) -> None:
    """doctor's network-free readiness gate. Refuse with exit 2 — naming the
    unresolved required keys, before any round-trip — when a connection under
    test cannot resolve its required config through the cascade, so readiness is
    judged by the same resolution `connections` reports, never a parallel check.
    Checks the selected connection, else every connection in the report."""
    conns = report.get("connections") or {}
    targets = [wanted] if (wanted and wanted in conns) else list(conns)
    problems: dict = {}
    for cid in targets:
        miss = _missing_required((conns.get(cid) or {}).get("keys") or [])
        if miss:
            problems[cid] = miss
    if problems:
        detail = "; ".join(f"{c}: {', '.join(ks)}" for c, ks in sorted(problems.items()))
        _die(2, "credentials_missing",
             f"unresolved required config — {detail}",
             f"set each in the project .env/.env.local, the user credentials.env, "
             f"or process env; `{NAME} connections` shows where every value resolves")

# <<< contract: connections <<<


# --- Connections (capability-specific) --------------------------------------

def _connections_report() -> dict:
    """The resolution report. mail holds no credential and reaches no remote
    service — auth is the one-time macOS Automation grant — so a registry, if
    present, only names connections; each reports an empty key set (CRED_KEYS is
    empty). With no registry the sole connection is the implicit `default`.
    Local only: no network, no Mail.app call."""
    reg, reg_path = _connections_registry()
    report: dict = {"default": None, "connections": {}}
    if reg is None:
        keys = [_key_report(k["key"], k["secret"], k["required"],
                            *_resolve_env_key(k["key"])) for k in CRED_KEYS]
        report["default"] = "default"
        report["connections"]["default"] = {"allow_write": WRITE_DEFAULT, "keys": keys}
        return report
    conns = reg["connections"]
    report["default"] = reg.get("default") or \
        (next(iter(conns)) if len(conns) == 1 else None)
    for cid, entry in conns.items():
        entry = entry if isinstance(entry, dict) else {}
        keys = [_key_report(k["key"], k["secret"], k["required"],
                            *_resolve_env_key(k["key"])) for k in CRED_KEYS]
        report["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": keys}
    return report


def _cmd_connections() -> None:
    _emit(_connections_report())


def run_jxa(script_body: str, env_extras: dict | None = None, timeout: int = 600):
    """Execute a JXA script via osascript; return parsed JSON or None."""
    full_script = JXA_PRELUDE + "\n" + script_body
    env = os.environ.copy()
    if env_extras:
        for k, v in env_extras.items():
            env[k] = "" if v is None else str(v)
    try:
        result = subprocess.run(
            ["osascript", "-l", "JavaScript", "-e", full_script],
            capture_output=True, text=True, timeout=timeout, env=env,
        )
    except FileNotFoundError:
        sys.exit("osascript not found — this CLI only works on macOS.")
    if result.returncode != 0:
        err = result.stderr.strip()
        if "-1743" in err or "Not authorized to send Apple events" in err:
            sys.exit(
                "Mail.app automation is not authorized for this terminal.\n"
                "  Grant: System Settings → Privacy & Security → Automation\n"
                "         → [your terminal app] → enable Mail\n"
                "  Then run the command again.\n"
                f"  ({err})"
            )
        sys.exit(f"osascript failed: {err}")
    out = result.stdout.strip()
    if not out:
        return None
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return out


SOURCE_FETCH = r"""
const acct = findAccount(env('ACCOUNT'));
const target = env('MSG_ID');
let found = null;
for (const mb of acct.mailboxes()) {
  try {
    const hits = mb.messages.whose({messageId: target})();
    if (hits.length > 0) { found = hits[0]; break; }
  } catch (e) {}
}
if (!found) die(`Message not found: ${target}`);
JSON.stringify({source: found.source()});
"""


def fetch_source(account, message_id):
    """Return the raw RFC-822 source for a message, found by Message-ID."""
    res = run_jxa(SOURCE_FETCH, {"ACCOUNT": account, "MSG_ID": message_id})
    if not res or not res.get("source"):
        sys.exit(f"Could not read raw source for message: {message_id}")
    return res["source"]


def parse_source(raw):
    return email.message_from_string(raw, policy=policy.default)


def html_body(msg):
    """The text/html body part decoded to str, or None."""
    part = msg.get_body(preferencelist=("html",))
    if part is None:
        return None
    try:
        return part.get_content()
    except Exception:
        payload = part.get_payload(decode=True) or b""
        return payload.decode(part.get_content_charset() or "utf-8", "replace")


class _LinkParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.links = []
        self._href = None
        self._buf = []

    def handle_starttag(self, tag, attrs):
        if tag == "a":
            href = dict(attrs).get("href")
            if href:
                self._href = href
                self._buf = []

    def handle_data(self, data):
        if self._href is not None:
            self._buf.append(data)

    def handle_endtag(self, tag):
        if tag == "a" and self._href is not None:
            text = " ".join("".join(self._buf).split())
            self.links.append({"text": text, "url": self._href})
            self._href = None
            self._buf = []


def extract_links(html):
    if not html:
        return []
    p = _LinkParser()
    p.feed(html)
    return p.links


def list_attachments(msg):
    out = []
    for i, att in enumerate(msg.iter_attachments()):
        payload = att.get_payload(decode=True) or b""
        out.append({
            "index": i,
            "filename": att.get_filename(),
            "content_type": att.get_content_type(),
            "disposition": att.get_content_disposition(),
            "size": len(payload),
        })
    return out


def safe_name(name):
    name = os.path.basename(name or "")
    cleaned = re.sub(r"[^A-Za-z0-9._ -]", "_", name).strip()
    return cleaned or "attachment"


def cmd_doctor():
    """Cheapest authenticated round-trip: the Automation grant + account list."""
    _doctor_gate(_connections_report(), None)
    script = r"""
    const Mail = Application('Mail');
    JSON.stringify({accounts: Mail.accounts().length});
    """
    info = run_jxa(script) or {}
    if "accounts" not in info:
        _die(2, "automation_denied",
             "Mail.app did not answer — the macOS Automation grant is missing",
             "System Settings → Privacy & Security → Automation → your terminal → Mail")
    _emit({"ok": True, "accounts": info["accounts"]})


def cmd_accounts(args):
    script = r"""
    const Mail = Application('Mail');
    const out = Mail.accounts().map(a => ({
      name: a.name(),
      id: a.id(),
      enabled: a.enabled(),
      emailAddresses: a.emailAddresses(),
      userName: a.userName(),
      fullName: a.fullName()
    }));
    JSON.stringify(out);
    """
    accounts = run_jxa(script) or []
    if args.json:
        print(json.dumps(accounts, ensure_ascii=False, indent=2))
        return
    print(f"# {len(accounts)} account(s) in Mail.app")
    for a in accounts:
        flag = "" if a.get("enabled") else " [disabled]"
        emails = ", ".join(a.get("emailAddresses") or [])
        print(f"  {a['name']}{flag}")
        if a.get("fullName"):
            print(f"    full name: {a['fullName']}")
        print(f"    email(s):  {emails or '(none)'}")


def cmd_mailboxes(args):
    script = r"""
    const acct = findAccount(env('ACCOUNT'));
    const out = acct.mailboxes().map(m => {
      let unread = null;
      try { unread = m.unreadCount(); } catch (e) {}
      return { name: m.name(), unreadCount: unread };
    });
    JSON.stringify({ account: acct.name(), mailboxes: out });
    """
    result = run_jxa(script, {"ACCOUNT": args.account})
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
        return
    print(f"# {result['account']}  ({len(result['mailboxes'])} mailboxes)")
    for m in result["mailboxes"]:
        unread = f"  [{m['unreadCount']} unread]" if m.get("unreadCount") else ""
        print(f"  {m['name']}{unread}")


def cmd_read(args):
    script = r"""
    const acct = findAccount(env('ACCOUNT'));
    const mb = findMailbox(acct, env('MAILBOX'));
    const limit = parseInt(env('LIMIT') || '50');
    const sinceIso = env('SINCE');
    const sinceDate = sinceIso ? new Date(sinceIso) : null;
    const n = mb.messages.length;
    const out = [];
    for (let i = 0; i < n && out.length < limit; i++) {
      const m = mb.messages[i];
      const d = m.dateReceived();
      if (sinceDate && d && d < sinceDate) break;
      out.push(messageSummary(m));
    }
    JSON.stringify(out);
    """
    msgs = run_jxa(script, {
        "ACCOUNT": args.account,
        "MAILBOX": args.mailbox,
        "LIMIT": str(args.limit),
        "SINCE": args.since or "",
    }) or []
    if args.json:
        print(json.dumps(msgs, ensure_ascii=False, indent=2))
        return
    label = f"{args.account}:{args.mailbox}"
    print(f"# {label}  ({len(msgs)} messages)")
    for m in msgs:
        ts = (m.get("dateReceived") or "")[:16].replace("T", " ")
        unread = "●" if not m.get("readStatus") else " "
        subj = (m.get("subject") or "(no subject)").replace("\n", " ")
        sender = m.get("sender") or "(unknown)"
        mid = m.get("messageId") or ""
        print(f"{unread} [{ts}] {sender}")
        print(f"    {subj}")
        if mid:
            print(f"    id: {mid}")


def cmd_search(args):
    script = r"""
    const acct = findAccount(env('ACCOUNT'));
    const mbName = env('MAILBOX');
    const query = env('QUERY') || '';
    const field = env('FIELD') || 'any';
    const limit = parseInt(env('LIMIT') || '100');

    let clause;
    if (field === 'subject')      clause = {subject: {_contains: query}};
    else if (field === 'sender')  clause = {sender:  {_contains: query}};
    else if (field === 'content') clause = {content: {_contains: query}};
    else clause = {_or: [
      {subject: {_contains: query}},
      {sender:  {_contains: query}}
    ]};

    function searchMailbox(mb) {
      try {
        const hits = mb.messages.whose(clause)();
        return hits.slice(0, limit);
      } catch (e) { return []; }
    }

    let messages = [];
    if (mbName) {
      messages = searchMailbox(findMailbox(acct, mbName));
    } else {
      for (const mb of acct.mailboxes()) {
        const hits = searchMailbox(mb);
        for (const m of hits) {
          messages.push(m);
          if (messages.length >= limit) break;
        }
        if (messages.length >= limit) break;
      }
    }
    JSON.stringify(messages.map(messageSummary));
    """
    msgs = run_jxa(script, {
        "ACCOUNT": args.account,
        "MAILBOX": args.mailbox or "",
        "QUERY": args.query,
        "FIELD": args.field,
        "LIMIT": str(args.limit),
    }) or []
    if args.json:
        print(json.dumps(msgs, ensure_ascii=False, indent=2))
        return
    scope = args.mailbox or "all mailboxes"
    print(f"# search {args.query!r} in {args.account}:{scope}  ({len(msgs)} hits)")
    for m in msgs:
        ts = (m.get("dateReceived") or "")[:16].replace("T", " ")
        subj = (m.get("subject") or "(no subject)").replace("\n", " ")
        sender = m.get("sender") or "(unknown)"
        mbox = m.get("mailbox") or ""
        mid = m.get("messageId") or ""
        print(f"[{ts}] ({mbox}) {sender}")
        print(f"    {subj}")
        if mid:
            print(f"    id: {mid}")


def cmd_show(args):
    if getattr(args, "raw", False):
        print(fetch_source(args.account, args.message_id))
        return
    if getattr(args, "html", False):
        msg = parse_source(fetch_source(args.account, args.message_id))
        body = html_body(msg)
        print(body if body is not None else "(no HTML body in this message)")
        return
    script = r"""
    const acct = findAccount(env('ACCOUNT'));
    const target = env('MSG_ID');
    let found = null;
    for (const mb of acct.mailboxes()) {
      try {
        const hits = mb.messages.whose({messageId: target})();
        if (hits.length > 0) { found = hits[0]; break; }
      } catch (e) {}
    }
    if (!found) die(`Message not found: ${target}`);
    JSON.stringify(messageFull(found));
    """
    m = run_jxa(script, {"ACCOUNT": args.account, "MSG_ID": args.message_id})
    if args.json:
        print(json.dumps(m, ensure_ascii=False, indent=2))
        return
    print(f"From:    {m.get('sender')}")
    tos = [f"{(r.get('name') or '').strip()} <{r['address']}>".strip()
           for r in m.get('toRecipients') or []]
    print(f"To:      {', '.join(tos) if tos else '(none)'}")
    if m.get("ccRecipients"):
        ccs = [f"{(r.get('name') or '').strip()} <{r['address']}>".strip()
               for r in m["ccRecipients"]]
        print(f"Cc:      {', '.join(ccs)}")
    print(f"Subject: {m.get('subject')}")
    print(f"Date:    {m.get('dateSent') or m.get('dateReceived')}")
    print(f"Id:      {m.get('messageId')}")
    print(f"Mailbox: {m.get('mailbox')}")
    print()
    print(m.get("content") or "")


def cmd_links(args):
    msg = parse_source(fetch_source(args.account, args.message_id))
    links = extract_links(html_body(msg))
    if getattr(args, "match", None):
        needle = args.match.lower()
        links = [l for l in links
                 if needle in (l["text"] or "").lower()
                 or needle in l["url"].lower()]
    if args.json:
        print(json.dumps(links, ensure_ascii=False, indent=2))
        return
    if not links:
        print("(no links found)")
        return
    for i, l in enumerate(links):
        print(f"[{i}] {l['text'] or '(no text)'}")
        print(f"    {l['url']}")


def cmd_attachments(args):
    msg = parse_source(fetch_source(args.account, args.message_id))

    if args.save:
        out_dir = Path(args.save).expanduser().resolve()
        out_dir.mkdir(parents=True, exist_ok=True)
        saved = []
        for i, att in enumerate(msg.iter_attachments()):
            if args.index is not None and i != args.index:
                continue
            payload = att.get_payload(decode=True) or b""
            dest = out_dir / safe_name(att.get_filename() or f"attachment-{i}")
            dest.write_bytes(payload)
            saved.append({"index": i, "path": str(dest), "size": len(payload)})
        if args.json:
            print(json.dumps(saved, ensure_ascii=False, indent=2))
            return
        if not saved:
            print("(no matching attachments to save)")
            return
        for s in saved:
            print(f"saved [{s['index']}] → {s['path']}  ({s['size']} bytes)")
        return

    atts = list_attachments(msg)
    if args.json:
        print(json.dumps(atts, ensure_ascii=False, indent=2))
        return
    if not atts:
        print("(no attachments)")
        return
    for a in atts:
        print(f"[{a['index']}] {a['filename'] or '(unnamed)'}  "
              f"{a['content_type']}  {a['size']} bytes  ({a['disposition']})")


def cmd_fetch(args):
    out_path = Path(args.out).expanduser().resolve()
    out_path.parent.mkdir(parents=True, exist_ok=True)
    headers = {"User-Agent": "Mozilla/5.0 (mail-cli)"}
    for h in args.header or []:
        if ":" in h:
            k, v = h.split(":", 1)
            headers[k.strip()] = v.strip()
    req = urllib.request.Request(args.url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=args.timeout) as resp:
            data = resp.read()
            final_url = resp.geturl()
            ctype = resp.headers.get("Content-Type", "")
    except Exception as e:
        sys.exit(f"fetch failed: {e}")
    out_path.write_bytes(data)
    print(f"Fetched {len(data)} bytes → {out_path}")
    if final_url != args.url:
        print(f"  (final URL: {final_url})")
    if ctype:
        print(f"  content-type: {ctype}")


def cmd_draft(args):
    if args.body == "-":
        body = sys.stdin.read()
    elif args.body is None:
        body = ""
    else:
        body = args.body

    script = r"""
    const Mail = Application('Mail');
    const acct = findAccount(env('ACCOUNT'));
    const senderStr = accountSenderString(acct);
    const subject = env('SUBJECT') || '';
    const body = env('BODY') || '';
    const to = JSON.parse(env('TO_JSON') || '[]');
    const cc = JSON.parse(env('CC_JSON') || '[]');
    const bcc = JSON.parse(env('BCC_JSON') || '[]');
    const inReplyTo = env('IN_REPLY_TO');

    let msg;
    if (inReplyTo) {
      let orig = null;
      for (const mb of acct.mailboxes()) {
        try {
          const hits = mb.messages.whose({messageId: inReplyTo})();
          if (hits.length > 0) { orig = hits[0]; break; }
        } catch (e) {}
      }
      if (!orig) die(`Message not found for reply: ${inReplyTo}`);
      msg = Mail.reply(orig, {openingWindow: false, replyToAll: false});
      if (body) msg.content = body;
      if (subject) msg.subject = subject;
    } else {
      msg = Mail.OutgoingMessage({
        subject: subject,
        content: body,
        sender: senderStr,
        visible: false
      });
      Mail.outgoingMessages.push(msg);
    }

    for (const addr of to)  msg.toRecipients.push(Mail.ToRecipient({address: addr}));
    for (const addr of cc)  msg.ccRecipients.push(Mail.CcRecipient({address: addr}));
    for (const addr of bcc) msg.bccRecipients.push(Mail.BccRecipient({address: addr}));

    msg.save();

    JSON.stringify({
      status: 'saved',
      account: acct.name(),
      sender: senderStr,
      subject: msg.subject(),
      to: to, cc: cc, bcc: bcc,
      inReplyTo: inReplyTo || null
    });
    """
    result = run_jxa(script, {
        "ACCOUNT": args.account,
        "SUBJECT": args.subject or "",
        "BODY": body,
        "TO_JSON": json.dumps(args.to or []),
        "CC_JSON": json.dumps(args.cc or []),
        "BCC_JSON": json.dumps(args.bcc or []),
        "IN_REPLY_TO": args.in_reply_to or "",
    })
    print(f"Draft saved to {result['account']} Drafts folder.")
    print(f"  From:     {result['sender']}")
    print(f"  To:       {', '.join(result['to']) or '(none)'}")
    if result.get("cc"):
        print(f"  Cc:       {', '.join(result['cc'])}")
    if result.get("bcc"):
        print(f"  Bcc:      {', '.join(result['bcc'])}")
    print(f"  Subject:  {result['subject']}")
    if result.get("inReplyTo"):
        print(f"  Reply to: {result['inReplyTo']}")
    print()
    print("Review in Mail.app → Drafts. No email was sent.")


def cmd_export(args):
    out_path = Path(args.out).expanduser().resolve()
    out_path.parent.mkdir(parents=True, exist_ok=True)

    script = r"""
    const acct = findAccount(env('ACCOUNT'));
    const mb = findMailbox(acct, env('MAILBOX'));
    const limit = parseInt(env('LIMIT') || '0');
    const sinceIso = env('SINCE');
    const sinceDate = sinceIso ? new Date(sinceIso) : null;
    const n = mb.messages.length;
    const max = limit > 0 ? limit : n;
    const out = [];
    for (let i = 0; i < n && out.length < max; i++) {
      const m = mb.messages[i];
      const d = m.dateReceived();
      if (sinceDate && d && d < sinceDate) break;
      out.push(messageFull(m));
    }
    JSON.stringify({
      account: acct.name(),
      mailbox: mb.name(),
      exported_at: new Date().toISOString(),
      message_count: out.length,
      messages: out
    });
    """
    payload = run_jxa(script, {
        "ACCOUNT": args.account,
        "MAILBOX": args.mailbox,
        "LIMIT": str(args.limit or 0),
        "SINCE": args.since or "",
    })
    out_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2))
    print(f"Exported {payload['message_count']} messages from "
          f"{payload['account']}:{payload['mailbox']} → {out_path}")


def main():
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    p = argparse.ArgumentParser(
        prog="mail",
        description="Personal Mail.app CLI (JXA; read + draft, no send).",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help", help="Print the full usage contract.")
    sub.add_parser("doctor", help="Prove the macOS Automation grant.")

    pa = sub.add_parser("accounts", help="List Mail.app accounts.")
    pa.add_argument("--json", action="store_true")

    pm = sub.add_parser("mailboxes", help="List mailboxes for an account.")
    pm.add_argument("account")
    pm.add_argument("--json", action="store_true")

    pr = sub.add_parser("read", help="Read recent messages.")
    pr.add_argument("account")
    pr.add_argument("--mailbox", default="INBOX")
    pr.add_argument("--limit", type=int, default=50)
    pr.add_argument("--since", help="ISO datetime; stop at this date")
    pr.add_argument("--json", action="store_true")

    ps = sub.add_parser("search", help="Search within an account.")
    ps.add_argument("account")
    ps.add_argument("query")
    ps.add_argument("--mailbox", help="Restrict to one mailbox (default: all)")
    ps.add_argument("--field", choices=["subject", "sender", "content", "any"],
                    default="any")
    ps.add_argument("--limit", type=int, default=100)
    ps.add_argument("--json", action="store_true")

    psh = sub.add_parser("show", help="Show one message by Message-ID.")
    psh.add_argument("account")
    psh.add_argument("message_id")
    psh.add_argument("--json", action="store_true")
    psh.add_argument("--html", action="store_true",
                     help="Print the raw HTML body (preserves link URLs).")
    psh.add_argument("--raw", action="store_true",
                     help="Print the full raw RFC-822 source.")

    pl = sub.add_parser("links", help="List hyperlinks in a message's HTML body.")
    pl.add_argument("account")
    pl.add_argument("message_id")
    pl.add_argument("--match", help="Only links whose text or URL contains this")
    pl.add_argument("--json", action="store_true")

    pat = sub.add_parser("attachments", help="List or save message attachments.")
    pat.add_argument("account")
    pat.add_argument("message_id")
    pat.add_argument("--save", metavar="DIR",
                     help="Save attachments to this directory instead of listing")
    pat.add_argument("--index", type=int,
                     help="With --save, only save the attachment at this index")
    pat.add_argument("--json", action="store_true")

    pf = sub.add_parser("fetch", help="Download a URL to a file (follow a link).")
    pf.add_argument("url")
    pf.add_argument("--out", required=True)
    pf.add_argument("--header", action="append",
                    help="Extra request header 'Name: value'. Repeat for many.")
    pf.add_argument("--timeout", type=int, default=60)

    pd = sub.add_parser("draft", help="Create a draft (never sends).")
    pd.add_argument("account")
    pd.add_argument("--to", action="append", required=True,
                    help="Recipient address. Repeat for multiple.")
    pd.add_argument("--cc", action="append", default=None)
    pd.add_argument("--bcc", action="append", default=None)
    pd.add_argument("--subject", required=True)
    pd.add_argument("--in-reply-to",
                    help="Message-ID to thread this as a reply to")
    pd.add_argument("--body", help="Body text; use '-' to read from stdin")

    pe = sub.add_parser("export", help="Dump a mailbox to JSON.")
    pe.add_argument("account")
    pe.add_argument("--mailbox", required=True)
    pe.add_argument("--out", required=True)
    pe.add_argument("--limit", type=int, default=0)
    pe.add_argument("--since", help="ISO datetime; stop at this date")

    args = p.parse_args()

    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return
    if args.cmd == "doctor":
        cmd_doctor()
        return

    dispatch = {
        "accounts": cmd_accounts,
        "mailboxes": cmd_mailboxes,
        "read": cmd_read,
        "search": cmd_search,
        "show": cmd_show,
        "links": cmd_links,
        "attachments": cmd_attachments,
        "fetch": cmd_fetch,
        "draft": cmd_draft,
        "export": cmd_export,
    }
    dispatch[args.cmd](args)


if __name__ == "__main__":
    main()
