@expenses.command("list")
@click.option("--limit", default=20, show_default=True, type=int)
@click.option("--search", default="", help="Filter by supplier / number / status")
def expenses_list(limit: int, search: str) -> None:
    """List recent purchase invoices."""
    cookies, account = session_or_die()
    cols = [
        ("", "_select"),
        ("client_name", "client_name"),
        ("status", "status"),
        ("number", "number"),
        ("sum_with_vat", "sum_with_vat"),
        ("created", "created"),
        ("id", "_id"),
        ("", "_actions"),
    ]
    data = datatables_payload(cols, order_col=6, length=limit, search=search)
    with build_http(cookies, account, ajax=True) as http:
        http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
        r = http.post(f"{BASE}/{account}/purchases/listdata", data=data)
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
        payload = r.json()
    rows = payload.get("data", [])
    click.secho(f"{payload.get('recordsTotal', len(rows))} total · {len(rows)} returned", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'NUMBER':<25}  {'CREATED':<12}  {'SUPPLIER':<40}  {'SUM':>14}  STATUS", bold=True)
    for row in rows:
        click.echo(
            f"{str(row.get('id','?')):>5}  "
            f"{strip_html(row.get('number'))[:25]:<25}  "
            f"{strip_html(row.get('created'))[:12]:<12}  "
            f"{strip_html(row.get('client_name'))[:40]:<40}  "
            f"{strip_html(row.get('sum_with_vat'))[:14]:>14}  "
            f"{strip_html(row.get('status'))[:30]}"
        )


def _purchases_add_soup(http: httpx.Client, account: str) -> BeautifulSoup:
    r = http.get(f"{BASE}/{account}/purchases/add")
    if r.status_code in (301, 302):
        raise AuthError(
            f"Session expired (HTTP {r.status_code} → {r.headers.get('location','')}).\n"
            "  → simplbooks refresh /path/to/fresh-curl.txt"
        )
    if r.status_code != 200:
        raise click.ClickException(f"GET /purchases/add returned {r.status_code}")
    return BeautifulSoup(r.text, "html.parser")


def purchase_vat_types(http: httpx.Client, account: str, refresh: bool = False) -> dict:
    """The account's live PURCHASE vat types (scraped from the /purchases/add
    `vat_types` JS map, cached to purchases_meta.json). Cache-first unless refresh;
    the baked PURCHASE_VAT_TYPES is only a last-resort fallback if the scrape fails."""
    if not refresh and PURCHASES_META_CACHE.exists():
        try:
            cached = json.loads(PURCHASES_META_CACHE.read_text())
            if cached:
                return cached
        except (ValueError, json.JSONDecodeError):
            pass
    vt = extract_vat_types(str(_purchases_add_soup(http, account)))
    if vt:
        PURCHASES_META_CACHE.write_text(json.dumps(vt, ensure_ascii=False, indent=2))
        return vt
    return PURCHASE_VAT_TYPES


@expenses.command("meta")
@click.option("--json", "as_json", is_flag=True, help="Emit raw JSON.")
@click.option("--refresh", is_flag=True, help="Re-scrape /purchases/add for the live vat_types map.")
def expenses_meta(as_json: bool, refresh: bool) -> None:
    """Show the account's PURCHASE vat types, read live from SimpleBooks.

    Scraped from the /purchases/add `vat_types` map and cached; this is the live
    set, not a constant. Expense account IDs are chart-of-accounts entries —
    use `simplbooks accounts list chart` and filter for 5xxx codes.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        vat_data = purchase_vat_types(http, account, refresh=refresh)

    if as_json:
        click.echo(json.dumps(vat_data, ensure_ascii=False, indent=2))
        return

    click.secho(f"Purchase VAT types ({len(vat_data)}):", bold=True)
    for vid in sorted(vat_data.keys(), key=lambda k: int(k)):
        v = vat_data[vid]
        pct = "—" if v.get("vat_percent") is None else f"{v['vat_percent']}%"
        click.echo(f"  {vid:>4}  {pct:<4}  {v['name']}")
    click.echo()
    click.secho("Common usages:", bold=True)
    click.echo("  11   → SaaS / hosting / any service from another EU country (reverse-charge)")
    click.echo("  34   → 24% EE domestic purchase (current rate)")
    click.echo("   9   → 0% intra-community GOODS acquisition")
    click.echo("  14   → 0% Import (non-EU)")
    click.echo()
    click.secho("Expense account IDs: `simplbooks accounts list chart` (filter for 5xxx codes).", bold=True)


_SHOW_FILE_PREVIEW_RE = re.compile(
    r"showFilePreview\(\s*'([^']+)'\s*,\s*'([^']+)'\s*\)",
)


def _parse_purchase_attachments(html: str, account: str) -> list[dict]:
    """Attachment entries on a purchase view/edit page → [{file_id, type, url, name}].

    SB does not render a real href for the stored copy — the "Vaata arve
    koopiat" anchor sits under `Arve koopia` in the summary grid with
    `onclick="showFilePreview('<file_id>', '<type>'); return false;"`. We
    parse those calls anywhere in the document, build the authoritative
    URL `.../purchases/view_file/<file_id>`, and let the download command
    resolve the real filename from the response's Content-Disposition.
    Verified against a live view page; the endpoint returns the stored
    file with `Content-Type: application/pdf` and a filename header.
    """
    out: list[dict] = []
    seen: set[str] = set()
    for match in _SHOW_FILE_PREVIEW_RE.finditer(html):
        file_id, ftype = match.group(1), match.group(2)
        if file_id in seen:
            continue
        seen.add(file_id)
        url = urljoin(f"{BASE}/{account}/", f"purchases/view_file/{file_id}")
        out.append({
            "file_id": file_id,
            "type": ftype,
            "url": url,
            "name": f"{file_id}.{ftype}",
        })
    return out


def _expenses_show_view(html: str, as_json: bool, account: str) -> None:
    """Render a purchase from its /purchases/view page — the read surface for
    payment-locked invoices. The page shows display values: row account and
    vat-type ids are not in its markup (the vat-type name rides in a tooltip)."""
    soup = BeautifulSoup(html, "html.parser")

    pairs: dict[str, str] = {}
    for grid in soup.select("div.summary-grid"):
        cells = [d.get_text(" ", strip=True) for d in grid.find_all("div", recursive=False)]
        for lab, val in zip(cells[::2], cells[1::2]):
            pairs.setdefault(lab, val)

    titles = [d.get_text(" ", strip=True) for d in soup.select("div.text-success.card-title")]
    supplier_name = titles[0] if titles else ""
    status = titles[2] if len(titles) > 2 else ""
    link = soup.find("a", href=re.compile(r"/clients/view/(\d+)"))
    supplier_id = re.search(r"/clients/view/(\d+)", link["href"]).group(1) if link else ""

    rows: list[dict] = []
    for t in soup.find_all("table"):
        heads = [th.get_text(" ", strip=True) for th in t.find_all("th")]
        if heads[:2] != ["Artikkel", "Kirjeldus"]:
            continue
        for tr in t.find_all("tr"):
            tds = tr.find_all("td")
            if len(tds) < 6:
                continue
            vat_el = tds[4].find(attrs={"title": True})
            rows.append({
                "name": tds[1].get_text(" ", strip=True),
                "amount": tds[2].get_text(" ", strip=True),
                "gross": tds[3].get_text(" ", strip=True),
                "vat": tds[4].get_text(" ", strip=True),
                "vat_type_name": vat_el["title"] if vat_el else "",
                "net": tds[5].get_text(" ", strip=True),
            })
        break

    attachments = _parse_purchase_attachments(html, account)

    info = {
        "supplier_id": supplier_id,
        "supplier_name": supplier_name,
        "status": status,
        "number": pairs.get("Arve number", ""),
        "internal_number": pairs.get("Dokumendi number", ""),
        "created": pairs.get("Arve kuupäev", ""),
        "transaction_date": pairs.get("Kande kuupäev", ""),
        "due": pairs.get("Maksetähtaeg", ""),
        "currency": pairs.get("Valuuta", ""),
        "net_total": pairs.get("Arve summa", ""),
        "vat_total": pairs.get("Arve käibemaks", ""),
        "gross_total": pairs.get("Arve kokku", ""),
        "attachments": attachments,
        "source": "view page (payment-locked; row account/vat-type ids not exposed)",
    }

    if as_json:
        click.echo(json.dumps({**info, "rows": rows}, indent=2, ensure_ascii=False))
        return

    click.echo(f"Supplier : {info['supplier_name']} [{info['supplier_id']}]   status: {info['status']}")
    click.echo(f"Number   : {info['number']}   (internal: {info['internal_number']})")
    click.echo(f"Dates    : created {info['created']}  txn {info['transaction_date']}  due {info['due']}")
    click.echo(
        f"Totals   : net {info['net_total']}  VAT {info['vat_total']}  "
        f"gross {info['gross_total']} {info['currency']}"
    )
    click.echo()
    click.secho(f"{'#':<3} {'NAME':<40} {'VAT TYPE':<22} {'VAT%':<5} {'AMT':>6} {'NET':>12}", bold=True)
    for i, rw in enumerate(rows, 1):
        click.echo(
            f"{i:<3} {rw['name'][:40]:<40} {rw['vat_type_name'][:22]:<22} {rw['vat']:<5} "
            f"{rw['amount']:>6} {rw['net']:>12}"
        )
    click.echo()
    if attachments:
        click.echo(f"Attach   : {len(attachments)} — "
                   + ", ".join(a["name"] for a in attachments))
    else:
        click.echo("Attach   : (none)")
    click.echo("(read from the view page — invoice is payment-locked; "
               "row account / vat-type ids are not exposed there)")


@expenses.command("show")
@click.argument("expense_id", type=int)
@click.option("--json", "as_json", is_flag=True, help="Emit JSON.")
def expenses_show(expense_id: int, as_json: bool) -> None:
    """Read an existing purchase invoice's header + line items.

    Reads the edit form, which carries the exact stored values including each
    row's account and vat-type ids. A payment-bound invoice is locked out of
    editing (SB redirects to its view page), so it is read from the rendered
    view instead — same header data, but rows expose display values only.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        r = http.get(f"{BASE}/{account}/purchases/edit/{expense_id}")
        if r.status_code in (301, 302):
            loc = r.headers.get("location", "")
            if f"/purchases/view/{expense_id}" not in loc:
                raise click.ClickException(
                    f"Purchase {expense_id} not accessible (redirect → {loc})."
                )
            rv = http.get(f"{BASE}/{account}/purchases/view/{expense_id}")
            if rv.status_code != 200:
                raise click.ClickException(
                    f"GET /purchases/view/{expense_id} → HTTP {rv.status_code}"
                )
            _expenses_show_view(rv.text, as_json, account)
            return
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}")
        edit_html = r.text
        soup = BeautifulSoup(edit_html, "html.parser")

    def field(name: str) -> str:
        inp = soup.find("input", {"name": name})
        if inp:
            return inp.get("value", "") or ""
        sel = soup.find("select", {"name": name})
        if sel:
            opt = sel.find("option", attrs={"selected": True})
            return (opt.get("value", "") or "") if opt else ""
        ta = soup.find("textarea", {"name": name})
        if ta:
            return ta.text or ""
        return ""

    attachments = _parse_purchase_attachments(edit_html, account)

    info = {
        "supplier_id": field("data[Purchase][client_id]"),
        "supplier_name": field("data[Purchase][client_name]"),
        "supplier_country": field("data[Purchase][client_address_country]"),
        "supplier_vat_no": field("data[Purchase][client_vat_no]"),
        "supplier_reg_no": field("data[Purchase][client_reg_no]"),
        "number": field("data[Purchase][number]"),
        "internal_number": field("data[Purchase][internal_number]"),
        "created": field("data[Purchase][created]"),
        "transaction_date": field("data[Purchase][transaction_date]"),
        "due": field("data[Purchase][due]"),
        "currency": field("data[Purchase][currency_name]"),
        "vat_total": field("data[Purchase][vat]"),
        "row_sum_with_vat": field("data[Purchase][row_sum_with_vat]"),
        "attachments": attachments,
    }

    rows: list[dict] = []
    row_keys = set()
    pat = re.compile(r"data\[PurchaseRows\]\[(\d+)\]\[PurchaseRow\]\[(\w+)\]")
    for el in soup.find_all(["input", "select", "textarea"]):
        name = el.get("name") or ""
        m = pat.match(name)
        if m:
            row_keys.add(m.group(1))
    for key in sorted(row_keys):
        rows.append({
            "key": key,
            "expense_account_id": field(f"data[PurchaseRows][{key}][PurchaseRow][expense_account_id]"),
            "vat_type_id": field(f"data[PurchaseRows][{key}][PurchaseRow][vat_type_id]"),
            "vat": field(f"data[PurchaseRows][{key}][PurchaseRow][vat]"),
            "name": field(f"data[PurchaseRows][{key}][PurchaseRow][name]"),
            "amount": field(f"data[PurchaseRows][{key}][PurchaseRow][amount]"),
            "unit": field(f"data[PurchaseRows][{key}][PurchaseRow][unit]"),
            "sum": field(f"data[PurchaseRows][{key}][PurchaseRow][sum]"),
        })

    if as_json:
        click.echo(json.dumps({**info, "rows": rows}, indent=2, ensure_ascii=False))
        return

    click.echo(f"Supplier : {info['supplier_name']} [{info['supplier_id']}] ({info['supplier_country']})")
    click.echo(f"VAT no   : {info['supplier_vat_no']}   Reg no : {info['supplier_reg_no']}")
    click.echo(f"Number   : {info['number']}   (internal: {info['internal_number']})")
    click.echo(f"Dates    : created {info['created']}  txn {info['transaction_date']}  due {info['due']}")
    click.echo(f"VAT tot  : {info['vat_total']} {info['currency']}  (row_sum_with_vat={info['row_sum_with_vat']})")
    click.echo()
    click.secho(f"{'#':<3} {'NAME':<40} {'VAT_T':<6} {'VAT%':<5} {'AMT':>6} {'SUM':>14} ACCT", bold=True)
    for i, r in enumerate(rows, 1):
        click.echo(
            f"{i:<3} {r['name'][:40]:<40} {r['vat_type_id']:<6} {r['vat']:<5} "
            f"{r['amount']:>6} {r['sum']:>14}  {r['expense_account_id']}"
        )
    click.echo()
    if attachments:
        click.echo(f"Attach   : {len(attachments)} — "
                   + ", ".join(a["name"] for a in attachments))
    else:
        click.echo("Attach   : (none)")


def _filename_from_response(r: httpx.Response, fallback: str) -> str:
    """Content-Disposition filename → anchor path → fallback."""
    disp = r.headers.get("content-disposition", "")
    m = re.search(r"filename\*=(?:UTF-8''|)([^;]+)", disp, re.IGNORECASE)
    if not m:
        m = re.search(r'filename="?([^";]+)"?', disp, re.IGNORECASE)
    if m:
        name = m.group(1).strip().strip('"')
        if name:
            return name
    return fallback


@expenses.command("download")
@click.argument("expense_id", type=int)
@click.option("--out", "out_path", default=None,
              help="Output path. Default: the server-supplied filename in CWD.")
@click.option("--index", "attach_index", default=1, show_default=True, type=int,
              help="Which attachment (1-based) when a purchase has more than one.")
def expenses_download(expense_id: int, out_path: str | None, attach_index: int) -> None:
    """Download a purchase's stored copy (the file uploaded via `expenses create`).

    Attachments are behind the authed session, not on a public URL — this pulls
    the anchor SB renders on `/purchases/view/<id>` and streams the bytes to
    disk. Purchases without a stored copy exit cleanly.
    """
    if attach_index < 1:
        raise click.ClickException("--index is 1-based; pass 1 or higher.")
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        view = http.get(f"{BASE}/{account}/purchases/view/{expense_id}")
        if view.status_code in (301, 302):
            raise AuthError(
                f"Purchase {expense_id} not accessible "
                f"(redirect → {view.headers.get('location','')})."
            )
        if view.status_code != 200:
            raise click.ClickException(
                f"GET /purchases/view/{expense_id} → HTTP {view.status_code}"
            )
        attachments = _parse_purchase_attachments(view.text, account)
        if not attachments:
            click.secho(f"Purchase {expense_id} has no attachment.", fg="yellow")
            return
        if attach_index > len(attachments):
            raise click.ClickException(
                f"--index {attach_index} out of range; purchase {expense_id} "
                f"has {len(attachments)} attachment(s)."
            )
        chosen = attachments[attach_index - 1]
        http.headers["Referer"] = f"{BASE}/{account}/purchases/view/{expense_id}"
        r = http.get(chosen["url"])
        if r.status_code in (301, 302):
            raise AuthError(
                f"Attachment fetch redirected (session stale?) → "
                f"{r.headers.get('location','')}."
            )
        if r.status_code != 200:
            raise click.ClickException(
                f"GET {chosen['url']} → HTTP {r.status_code}"
            )
        fallback_name = f"{chosen['file_id']}.{chosen.get('type') or 'pdf'}"
        default_name = _filename_from_response(r, fallback_name)
        target = Path(out_path) if out_path else Path(default_name)
        target.write_bytes(r.content)
    click.secho(f"✓ Saved {target}", fg="green", bold=True)


def _random_row_key() -> str:
    """20-digit numeric string, matching SimpleBooks' purchase-row keys."""
    return str(random.randint(10**19, 10**20 - 1))


def _page_errors(html: str) -> list[str]:
    """SB's rendered error/warning banners: <div class="alert alert-danger|-warning">.

    These banners are the server's real message channel for refused mutations
    (rendered into an HTTP 200 page, or via session flash onto the next page
    loaded). Flash.error("…") strings in page JS are static callback handlers
    — never parse those for server outcomes. Hidden template banners (d-none /
    display:none) don't count.
    """
    soup = BeautifulSoup(html, "html.parser")
    out: list[str] = []
    for div in soup.select("div.alert"):
        classes = set(div.get("class") or [])
        if not ({"alert-danger", "alert-warning"} & classes):
            continue
        if "d-none" in classes or "none" in (div.get("style") or ""):
            continue
        text = div.get_text(" ", strip=True)
        if text and text not in out:
            out.append(text)
    return out


def build_purchase_fields(
    *,
    csrf: str,
    supplier: dict,
    number: str,
    internal_number: str,
    invoice_date: datetime,
    due_date: datetime,
    currency_code: str,
    currency_rate: float,
    lines: list[dict],
    vat_total: str,
    row_sum_with_vat: bool,
    rounding: str = "0",
    payment_description: str = "",
    comments: str = "",
    creator: str | None = None,
) -> list[tuple[str, str]]:
    """Build the multipart text fields for /purchases/create.

    `lines` is a list of dicts with keys:
      expense_account_id, vat_type_id, vat (rate), name, amount, unit, sum
    """
    inv_dot = invoice_date.strftime("%d.%m.%Y")
    due_dot = due_date.strftime("%d.%m.%Y")
    now_dash = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    fields: list[tuple[str, str]] = [
        ("_csrfToken", csrf),
        ("data[Purchase][id]", "0"),
        ("data[draft_id]", ""),
        ("data[Purchase][base_currency_id]", "2"),
        ("data[Purchase][base_currency_code]", "EUR"),
        ("data[Purchase][paid]", "0"),
        ("data[Purchase][credit_purchase_for]", "0"),
        ("data[Purchase][not_subject_to_vat]", "0"),
        ("data[purchase_order_id]", "0"),
        ("data[Purchase][creator]", str(creator or "")),
        ("data[Purchase][created_time]", now_dash),
        ("data[Purchase][cash_accounting_method]", "0"),
        ("data[Purchase][email_attachment_id]", ""),
        ("data[Purchase][imported_document_id]", ""),
        ("data[Purchase][temp_imported_document_id]", ""),
        ("data[Purchase][client_data_needs_update]", "0"),
        ("data[Purchase][client_update_data]", "0"),
        ("data[Purchase][client_id]", str(supplier["id"])),
        ("data[Purchase][client_name]", str(supplier.get("name", ""))),
        ("data[Purchase][number]", number),
        ("data[Purchase][internal_number]", internal_number),
        ("data[Purchase][created]", inv_dot),
        ("data[Purchase][transaction_date]", inv_dot),
        ("data[Purchase][due]", due_dot),
        ("data[Purchase][currency_name]", currency_code),
        ("data[Purchase][currency_rate]", f"{currency_rate:.4f}"),
        # reference is SB's Viitenumber — a checksummed numeric payment-reference
        # field; free text in it makes the save fail. Free-form text belongs in
        # payment_description (Makse kirjeldus).
        ("data[Purchase][reference]", ""),
        ("data[Purchase][payment_description]", payment_description),
        ("data[Purchase][client_account_no]", ""),
        ("data[Purchase][client_swift_code]", ""),
        ("data[Purchase][client_fill_missing_data]", "1"),
    ]

    for ln in lines:
        key = _random_row_key()
        fields += [
            (f"data[PurchaseRows][{key}][PurchaseRow][id]", "0"),
            (f"data[PurchaseRows][{key}][PurchaseRow][purchase_id]", "0"),
            (f"data[PurchaseRows][{key}][PurchaseRow][article_id]", "0"),
            (f"data[PurchaseRows][{key}][PurchaseRow][is_inventory]", "0"),
            (f"data[PurchaseRows][{key}][PurchaseRow][expense_account_id]", str(ln["expense_account_id"])),
            (f"data[PurchaseRows][{key}][PurchaseRow][code]", ""),
            (f"data[PurchaseRows][{key}][PurchaseRow][name]", str(ln["name"])),
            (f"data[PurchaseRows][{key}][PurchaseRow][vat_type_id]", str(ln["vat_type_id"])),
            (f"data[PurchaseRows][{key}][PurchaseRow][vat]", str(ln.get("vat", "0"))),
            (f"data[PurchaseRows][{key}][PurchaseRow][amount]", str(ln.get("amount", "1"))),
            (f"data[PurchaseRows][{key}][PurchaseRow][unit]", str(ln.get("unit", "tk"))),
            (f"data[PurchaseRows][{key}][PurchaseRow][discount]", "0"),
            (f"data[PurchaseRows][{key}][PurchaseRow][sum]", to_estonian_number(ln["sum"])),
        ]

    fields += [
        ("data[Purchase][row_sum_with_vat]", "1" if row_sum_with_vat else "0"),
        ("data[Purchase][vat]", to_estonian_number(vat_total)),
        ("data[Purchase][rounding]", to_estonian_number(rounding)),
        ("Purchase[comments]", comments),
        ("data[Purchase][client_reg_no]", strip_html(supplier.get("reg_no"))),
        ("data[Purchase][client_vat_no]", strip_html(supplier.get("vat_no"))),
        ("data[Purchase][client_email]", strip_html(supplier.get("email"))),
        ("data[Purchase][client_bank]", ""),
        ("data[Purchase][client_address_street]", strip_html(supplier.get("address_street"))),
        ("data[Purchase][client_address_city]", strip_html(supplier.get("address_city"))),
        ("data[Purchase][client_address_county]", strip_html(supplier.get("address_county"))),
        ("data[Purchase][client_address_country]", strip_html(supplier.get("address_country"))),
        ("data[Purchase][client_address_postal_code]", strip_html(supplier.get("address_postal_code"))),
    ]
    return fields


@expenses.command("create")
@click.option("--supplier-id", required=True, type=int)
@click.option("--number", required=True, help="Supplier-issued invoice number (e.g. MWQSHUMO-2026-04).")
@click.option("--internal-number", default="", help="Your internal sequence; defaults to --number.")
@click.option("--date", "invoice_date", required=True, help="Invoice date YYYY-MM-DD.")
@click.option("--due", "due_date", default=None, help="Due date YYYY-MM-DD. Defaults to invoice date.")
@click.option("--currency", default="EUR", show_default=True)
@click.option("--rate", "currency_rate", default=1.0, show_default=True, type=float,
              help="Document-currency → EUR multiplier. The CLI converts each --line "
                   "sum to EUR locally and books the invoice in EUR (SB does not apply "
                   "the rate server-side, so the conversion MUST happen here). The "
                   "source currency, rate, and document-currency totals are appended "
                   "to the invoice comments for audit. Default 1.0 leaves EUR invoices "
                   "unchanged. For a foreign-currency invoice settled via a EUR bank "
                   "debit, set --rate = (actual EUR settled) / (foreign-currency "
                   "invoice total) so the EUR-equivalent ties to the real debit to the cent.")
@click.option("--vat-total", default=None,
              help="Total VAT amount. Defaults to the row-derived total (0 when all rows "
                   "are 0%-rate, e.g. reverse-charge). Pass explicitly only to correct "
                   "supplier rounding gaps. SB rejects a --vat-total that differs from the "
                   "rows' computed VAT by more than rounding as an illegal 'VAT-modification', "
                   "failing the whole save; 0%-rate reverse-charge rows legitimately pass 0.")
@click.option("--rounding", default="0", show_default=True,
              help="Supplier's own rounding adjustment (the 'Ümardamine' row on the PDF). "
                   "Positive means SB's net+VAT total under-shoots the supplier's stated gross "
                   "by this amount; negative means it over-shoots. Use to close cent gaps when "
                   "the supplier's line-by-line net × (1 + VAT) doesn't match their KOKKU line.")
@click.option("--row-sum-with-vat/--row-sum-net", default=True, show_default=True,
              help="Interpret each --line 'sum' as GROSS (VAT-inclusive) by default. "
                   "Pass --row-sum-net to interpret 'sum' as NET (VAT-exclusive) instead.")
@click.option("--line", "lines_raw", multiple=True, required=True,
              help="Repeatable. Format: acct=<account_id>:vat_type=<id>:vat=<rate>:name=<desc>:sum=<amount>")
@click.option("--attachment", "attachment_path", type=click.Path(exists=True, dir_okay=False), default=None,
              help="PDF / image of the source invoice to attach.")
@click.option("--reference", default="",
              help='Free-form supplier reference / payment note — lands in the form\'s '
                   '"Makse kirjeldus" (payment description) field.')
@click.option("--comments", "comments", default="",
              help='Lisainfo — free-text note shown on the invoice (the "Lisainfo" field, '
                   'the purchase-invoice equivalent of a sales invoice\'s Lisainfo).')
@click.option("--creator", default=None,
              help="Issuer user id (else the logged-in user, read from the form).")
@click.option("--dry-run", is_flag=True,
              help="Resolve everything and print the payload WITHOUT creating the invoice.")
def expenses_create(supplier_id: int, number: str, internal_number: str, invoice_date: str,
                    due_date: str | None, currency: str, currency_rate: float,
                    vat_total: str | None, rounding: str,
                    row_sum_with_vat: bool, lines_raw: tuple[str, ...], attachment_path: str | None,
                    reference: str, comments: str, creator: str, dry_run: bool) -> None:
    """Create a purchase invoice (ostuarve), optionally attaching the source PDF.

    Each --line is a colon-separated set of `key=value` pairs:
      acct=<coa-id>:vat_type=34:vat=24:name=Office supplies:sum=82,18
    """
    if currency_rate <= 0:
        raise click.ClickException(f"--rate must be a positive number, got {currency_rate}.")

    cookies, account = session_or_die()
    cache = load_clients_cache()
    if str(supplier_id) not in cache:
        raise click.ClickException(
            f"Supplier {supplier_id} not in cache. Refresh with `simplbooks clients list`."
        )
    supplier = cache[str(supplier_id)]

    inv_dt = datetime.strptime(invoice_date, "%Y-%m-%d")
    due_dt = datetime.strptime(due_date, "%Y-%m-%d") if due_date else inv_dt

    lines: list[dict] = []
    for raw in lines_raw:
        parts = {}
        for kv in raw.split(":"):
            if "=" not in kv:
                continue
            k, v = kv.split("=", 1)
            parts[k.strip()] = v.strip()
        try:
            lines.append({
                "expense_account_id": parts["acct"],
                "vat_type_id": parts["vat_type"],
                "vat": parts.get("vat", "0"),
                "name": parts["name"],
                "amount": parts.get("amount", "1"),
                "unit": parts.get("unit", "tk"),
                "sum": parts["sum"],
            })
        except KeyError as e:
            raise click.ClickException(f"--line missing required key {e}: {raw!r}")

    internal_number = internal_number or number

    # SB's /purchases/create ignores currency_rate for the ledger and does not
    # persist the foreign document currency, so a true foreign-currency purchase
    # cannot be held server-side. When --rate != 1.0 we convert each row to EUR
    # client-side and book a plain EUR purchase, recording the source currency,
    # rate, and document-currency totals in the invoice comments for audit.
    fx_doc_total: Decimal | None = None
    fx_eur_total: Decimal | None = None
    fx_source_currency = currency
    fx_rate = currency_rate
    if currency_rate != 1.0:
        rate_dec = Decimal(str(currency_rate))
        fx_doc_total = Decimal("0")
        fx_eur_total = Decimal("0")
        for ln in lines:
            doc_sum = Decimal(normalize_number(ln["sum"]))
            eur_sum = (doc_sum * rate_dec).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)
            fx_doc_total += doc_sum
            fx_eur_total += eur_sum
            ln["sum"] = str(eur_sum)
        fx_note = (
            f"Source currency: {fx_source_currency}; rate {fx_rate:.7f}; "
            f"document total {fx_source_currency} {to_estonian_number(fx_doc_total)} -> "
            f"EUR {to_estonian_number(fx_eur_total)}"
        )
        comments = f"{comments}\n{fx_note}".strip() if comments else fx_note
        # Row sums are now EUR; book as a plain EUR purchase.
        currency = "EUR"
        currency_rate = 1.0

    if vat_total is None:
        vat_total = compute_vat_total(lines, row_sum_with_vat)
        vat_label = f"{vat_total} (computed from rows)"
    else:
        vat_label = vat_total

    with build_http(cookies, account) as http:
        page = fetch_add_page(http, account, "purchases/add")
        csrf = csrf_from_page(page, "purchases/add")
        # The purchase form leaves creator 0; fall back to the real logged-in user.
        creator = creator or creator_from_page(page) or logged_in_user_id(http, account)
        fields = build_purchase_fields(
            csrf=csrf,
            supplier=supplier,
            number=number,
            internal_number=internal_number,
            invoice_date=inv_dt,
            due_date=due_dt,
            currency_code=currency,
            currency_rate=currency_rate,
            lines=lines,
            vat_total=vat_total,
            row_sum_with_vat=row_sum_with_vat,
            rounding=rounding,
            payment_description=reference,
            comments=comments,
            creator=creator,
        )
        if dry_run:
            fmap = dict(fields)
            interp = ("GROSS (VAT-inclusive); pass --row-sum-net to treat as net"
                      if row_sum_with_vat
                      else "NET (VAT-exclusive); omit --row-sum-net to treat as gross")
            click.secho("DRY RUN — purchase invoice NOT created. Resolved payload:", fg="yellow", bold=True)
            click.echo(f"  Supplier : {supplier.get('name')} [{supplier_id}]")
            click.echo(f"  Number   : {number}  (internal {internal_number})")
            click.echo(f"  Date     : {invoice_date}  due {due_date or invoice_date}")
            click.echo(f"  creator  : {fmap.get('data[Purchase][creator]')}  (--creator > logged-in user)")
            click.echo(f"  Interpret: sum interpreted as {interp}")
            click.echo(f"  Lines    : {len(lines)}")
            doc_net = Decimal("0")
            doc_gross = Decimal("0")
            for i, ln in enumerate(lines, 1):
                s = Decimal(normalize_number(ln["sum"]))
                ln_vat = Decimal(compute_vat_total([ln], row_sum_with_vat))
                if row_sum_with_vat:
                    ln_gross, ln_net = s, s - ln_vat
                else:
                    ln_net, ln_gross = s, s + ln_vat
                doc_net += ln_net
                doc_gross += ln_gross
                click.echo(
                    f"    [{i}] sum={to_estonian_number(s)}  "
                    f"net={to_estonian_number(ln_net)}  "
                    f"vat={to_estonian_number(ln_vat)}  "
                    f"gross={to_estonian_number(ln_gross)}"
                )
            click.echo(
                f"  Totals   : net={to_estonian_number(doc_net)}  "
                f"vat={to_estonian_number(vat_total)}  "
                f"gross={to_estonian_number(doc_gross)}  ({vat_label})"
            )
            if fx_doc_total is not None:
                click.echo(
                    f"  FX       : rate={fx_rate:.7f}  "
                    f"doc total {fx_source_currency} {to_estonian_number(fx_doc_total)} "
                    f"-> EUR {to_estonian_number(fx_eur_total)} "
                    f"(booked in EUR; SB does not apply the rate server-side)"
                )
            click.echo(f"  Attach   : {attachment_path or '(none)'}")
            return

        parts: list[tuple[str, tuple]] = [(n, (None, v)) for n, v in fields]

        if attachment_path:
            fname = Path(attachment_path).name
            data_bytes = Path(attachment_path).read_bytes()
            ctype = "application/pdf" if fname.lower().endswith(".pdf") else "application/octet-stream"
            parts.append(("data[Purchase][copy]", (fname, data_bytes, ctype)))
        else:
            parts.append(("data[Purchase][copy]", ("", b"", "application/octet-stream")))

        http.headers["Referer"] = f"{BASE}/{account}/purchases/add"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/purchases/create", files=parts)

    m = re.search(r"/purchases/view/(\d+)", r.headers.get("location", ""))
    if m:
        pid = m.group(1)
        click.secho(f"✓ Created expense {pid} (number {number})", fg="green", bold=True)
        click.echo(f"  Supplier : {supplier.get('name')} [{supplier_id}]")
        click.echo(f"  Date     : {invoice_date}")
        click.echo(f"  Lines    : {len(lines)}  VAT total: {vat_label}")
        if fx_doc_total is not None:
            click.echo(
                f"  FX       : converted {fx_source_currency} "
                f"{to_estonian_number(fx_doc_total)} -> EUR "
                f"{to_estonian_number(fx_eur_total)} @ {fx_rate:.7f} "
                f"(booked in EUR; rate + source-currency totals recorded in comments)"
            )
        if attachment_path:
            click.echo(f"  Attached : {attachment_path}")
        click.echo(f"  URL      : {BASE}/{account}/purchases/view/{pid}")
        return
    fail = CONFIG_DIR / "last_expense_create_failure.html"
    fail.write_text(r.text)
    msgs = _page_errors(r.text)
    raise click.ClickException(
        f"Create failed: HTTP {r.status_code}."
        + (" SB says: " + " | ".join(msgs) if msgs else "")
        + f" Response saved → {fail}"
    )


# ─── expenses update (edit existing purchase invoice) ───────────────────────
#
# SB endpoints (mirror /purchases/create):
#   GET  /<acct>/purchases/edit/<id>   — pre-populated form, same field names
#                                        as /add. Existing rows carry their
#                                        original [PurchaseRow][id] (not 0).
#   POST /<acct>/purchases/update      — multipart/form-data, accepts the
#                                        same field set with the row ids
#                                        preserved for unchanged lines.
#
# The update flow is: scrape every input/select/textarea value from the edit
# form into a (name, value) pair list, apply the user's patch in-place, then
# POST the full list back. SB treats absent fields as "delete" for some
# attributes (e.g. dropping a row id removes the row), so we always carry
# forward the full existing set rather than sending a sparse diff.

def _scrape_purchase_edit_form(http: httpx.Client, account: str, purchase_id: int) -> tuple[list[tuple[str, str]], dict, str]:
    """Fetch /purchases/edit/<id> and return (fields, row_index, csrf).

    - `fields` is the full ordered list of (name, value) pairs reconstructed from
      the form, ready to re-POST after patching.
    - `row_index` maps row-key → list of (fields-list index, attribute name) so
      callers can mutate row attributes by key without re-walking the list.
    - `csrf` is the freshly-scraped token.
    """
    r = http.get(f"{BASE}/{account}/purchases/edit/{purchase_id}")
    if _session_stale(r):
        auto_login_attempt(interactive=False)
        creds = load_credentials()
        http.cookies = httpx.Cookies(parse_cookie_string(creds["SIMPLBOOKS_COOKIE"]))
        r = http.get(f"{BASE}/{account}/purchases/edit/{purchase_id}")
    if r.status_code != 200:
        raise click.ClickException(f"GET /purchases/edit/{purchase_id} returned {r.status_code}")
    soup = BeautifulSoup(r.text, "html.parser")
    form = soup.find("form", {"id": "purchase-form"})
    if not form:
        raise click.ClickException(f"No #purchase-form on /purchases/edit/{purchase_id} — page layout changed?")

    csrf_input = form.find("input", {"name": "_csrfToken"}) or soup.find("input", {"name": "_csrfToken"})
    if not csrf_input or not csrf_input.get("value"):
        raise click.ClickException("No _csrfToken on purchase edit form.")
    csrf = csrf_input["value"]

    fields: list[tuple[str, str]] = []
    row_pat = re.compile(r"data\[PurchaseRows\]\[(\d+)\]\[PurchaseRow\]\[(\w+)\]")
    row_index: dict[str, dict[str, int]] = {}
    for el in form.find_all(["input", "select", "textarea"]):
        name = el.get("name")
        if not name:
            continue
        # File inputs (e.g. data[Purchase][copy]) — skip in scrape; we re-attach via the upload field at POST time.
        if el.get("type") == "file":
            continue
        # Submit / button inputs aren't required by /purchases/update.
        if el.get("type") in ("submit", "button"):
            continue
        if el.name == "select":
            opt = el.find("option", selected=True)
            value = opt.get("value", "") if opt else ""
        elif el.name == "textarea":
            value = el.get_text()
        else:
            # type=checkbox: only include when checked
            if el.get("type") == "checkbox" and not el.has_attr("checked"):
                continue
            value = el.get("value", "")
        fields.append((name, value))
        m = row_pat.match(name)
        if m:
            row_index.setdefault(m.group(1), {})[m.group(2)] = len(fields) - 1

    # JS-populated selects (currency_name, certain vat_type selects) render as
    # empty <select> tags and get their options injected client-side. The
    # current value lives elsewhere in the form — recover it.
    def _get_field_value(target_name: str) -> str:
        for n, v in fields:
            if n == target_name:
                return v
        return ""

    def _ensure_field(target_name: str, fallback_value: str) -> None:
        if _get_field_value(target_name):
            return
        for i, (n, v) in enumerate(fields):
            if n == target_name:
                fields[i] = (n, fallback_value)
                return
        fields.append((target_name, fallback_value))

    # currency_name select is empty in HTML; the canonical current value lives in base_currency_code.
    _ensure_field("data[Purchase][currency_name]", _get_field_value("data[Purchase][base_currency_code]") or "EUR")

    return fields, row_index, csrf


def _set_field(fields: list[tuple[str, str]], name: str, value: str) -> None:
    """Set or append a (name, value) pair, replacing the first match if present."""
    for i, (n, _) in enumerate(fields):
        if n == name:
            fields[i] = (n, value)
            return
    fields.append((name, value))


def _parse_kv_line(raw: str) -> dict[str, str]:
    parts: dict[str, str] = {}
    for kv in raw.split(":"):
        if "=" not in kv:
            continue
        k, v = kv.split("=", 1)
        parts[k.strip()] = v.strip()
    return parts


def _purchase_bindings(purchase_id: int) -> list[tuple[str, int]]:
    """Scrape /purchases/view/<id> and return [(kind, id), ...] for bound payments/incomings.

    kind is 'Incoming' or 'Payment' to match _do_bind's direction arg.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        r = http.get(f"{BASE}/{account}/purchases/view/{purchase_id}")
        if r.status_code != 200:
            return []
        text = r.text
    out: list[tuple[str, int]] = []
    seen: set[tuple[str, int]] = set()
    for href in re.findall(r'href="[^"]*/(incomings|payments)/view/(\d+)"', text):
        kind = "Incoming" if href[0] == "incomings" else "Payment"
        key = (kind, int(href[1]))
        if key not in seen:
            seen.add(key)
            out.append(key)
    return out


def _purchase_remove_all_bindings(purchase_id: int) -> None:
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        csrf = fetch_fresh_csrf(http, account, path="purchases/add")
        http.headers["Referer"] = f"{BASE}/{account}/purchases/view/{purchase_id}"
        http.headers["Origin"] = BASE
        body = urlencode([("_csrfToken", csrf)])
        r = http.post(
            f"{BASE}/{account}/purchases/remove_all_bindings/{purchase_id}?next_action=edit",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
    if r.status_code not in (200, 302):
        fail = CONFIG_DIR / "last_remove_bindings_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"purchases/remove_all_bindings/{purchase_id} failed: HTTP {r.status_code}. Response → {fail}"
        )


@expenses.command("update")
@click.argument("purchase_id", type=int)
@click.option("--number", default=None, help="Change supplier-issued invoice number.")
@click.option("--internal-number", default=None, help="Change internal sequence number.")
@click.option("--date", "new_date", default=None, help="Change invoice date YYYY-MM-DD.")
@click.option("--due", "new_due", default=None, help="Change due date YYYY-MM-DD.")
@click.option("--vat-total", default=None, help="Override stored total VAT.")
@click.option("--rounding", default=None,
              help="Set the supplier's rounding-adjustment cents (positive or negative). "
                   "Use to close cent gaps when supplier's KOKKU doesn't tie to net+VAT.")
@click.option("--reference", default=None,
              help='Replace the free-form payment note (the "Makse kirjeldus" field).')
@click.option("--add-line", "add_lines", multiple=True,
              help="Append a new line. Same format as `expenses create --line`: "
                   "acct=<id>:vat_type=<id>:vat=<rate>:name=<desc>:sum=<amount>[:amount=N][:unit=tk]")
@click.option("--set-line", "set_lines", multiple=True,
              help="Edit an EXISTING line in place by its 1-based index (the order shown by "
                   "`expenses show`). Format: '<idx>:acct=<id>[:vat_type=<id>][:vat=<rate>]"
                   "[:name=<desc>][:sum=<amt>][:amount=N][:unit=tk]'. Repeatable. "
                   "Re-point an account: --set-line '1:acct=<coa-id>'.")
@click.option("--attach", "attach_path", type=click.Path(exists=True, dir_okay=False), default=None,
              help="Attach (set/replace) the source-document PDF/image on this purchase.")
@click.option("--force-unbind/--no-force-unbind", default=False, show_default=True,
              help="Paid purchases are locked for editing in SB. Pass --force-unbind to "
                   "unbind the bound payment(s)/incoming(s), perform the edit, then re-bind "
                   "the same entries. Use to fix a booked-and-paid ostuarve.")
@click.option("--set", "set_pairs", multiple=True,
              help="Raw form field override, repeatable. Example: "
                   "--set 'data[Purchase][cash_accounting_method]=1'")
def expenses_update(purchase_id, number, internal_number, new_date, new_due, vat_total,
                     rounding, reference, add_lines, set_lines, attach_path,
                     force_unbind, set_pairs) -> None:
    """Edit an existing purchase invoice (ostuarve).

    Scrapes /purchases/edit/<id> for the full current form state, applies the
    requested changes in-place, and POSTs to /purchases/update.

    Common use: fix a 1-cent gap between net+VAT and supplier KOKKU by setting
    --rounding 0,01.

    Examples:

      # Bump the rounding adjustment by 1 cent.
      simplbooks expenses update 1731 --rounding 0,01

      # Add a second line (e.g. an Ümardamine row when --rounding isn't enough).
      simplbooks expenses update 1731 \\
        --add-line 'acct=<coa-id>:vat_type=15:vat=0:name=Ümardamine:sum=0,01'

      # Re-point an existing line's expense account (idx as shown by `expenses show`).
      simplbooks expenses update 1763 --set-line '1:acct=<coa-id>'

      # Re-point the account, close the 1-cent VAT gap, and attach the source PDF in one call.
      simplbooks expenses update 1763 --set-line '1:acct=<coa-id>' --vat-total 10,65 --attach invoice.pdf

      # Fix a PAID invoice (locked): unbind its payment, fix number+period+PDF, re-bind.
      simplbooks expenses update 1764 --force-unbind \\
        --number 3B6A7575-0016 --date 2026-05-03 --attach invoice.pdf

      # Change the invoice date / due date.
      simplbooks expenses update 1731 --date 2026-05-18 --due 2026-05-25
    """
    cookies, account = session_or_die()

    # A paid purchase is locked: /purchases/edit/<id> 302-redirects to the view page.
    # --force-unbind snapshots the bound payment(s)/incoming(s), removes them so the form
    # unlocks, then re-binds the same entries after a successful save (mirrors invoices update).
    saved_bindings: list[tuple[str, int]] = []
    needs_rebind = False
    if force_unbind:
        saved_bindings = _purchase_bindings(purchase_id)
        if saved_bindings:
            click.secho(
                f"  Unbinding {len(saved_bindings)} "
                f"entr{'y' if len(saved_bindings) == 1 else 'ies'} from purchase {purchase_id} first…",
                fg="yellow",
            )
            _purchase_remove_all_bindings(purchase_id)
            needs_rebind = True

    with build_http(cookies, account) as http:
        fields, _row_index, csrf = _scrape_purchase_edit_form(http, account, purchase_id)

        # _csrfToken on edit form may be the GET-time token; rescrape from /purchases/add to be safe.
        csrf = fetch_fresh_csrf(http, account, path="purchases/add")
        _set_field(fields, "_csrfToken", csrf)

        if number is not None:
            _set_field(fields, "data[Purchase][number]", number)
        if internal_number is not None:
            _set_field(fields, "data[Purchase][internal_number]", internal_number)
        if new_date is not None:
            d = datetime.strptime(new_date, "%Y-%m-%d").strftime("%d.%m.%Y")
            _set_field(fields, "data[Purchase][created]", d)
            _set_field(fields, "data[Purchase][transaction_date]", d)
        if new_due is not None:
            d = datetime.strptime(new_due, "%Y-%m-%d").strftime("%d.%m.%Y")
            _set_field(fields, "data[Purchase][due]", d)
        if vat_total is not None:
            _set_field(fields, "data[Purchase][vat]", to_estonian_number(vat_total))
        if rounding is not None:
            _set_field(fields, "data[Purchase][rounding]", to_estonian_number(rounding))
        if reference is not None:
            _set_field(fields, "data[Purchase][payment_description]", reference)

        for raw in add_lines:
            ln = _parse_kv_line(raw)
            for required in ("acct", "vat_type", "name", "sum"):
                if required not in ln:
                    raise click.ClickException(f"--add-line missing required key '{required}': {raw!r}")
            key = _random_row_key()
            fields += [
                (f"data[PurchaseRows][{key}][PurchaseRow][id]", "0"),
                (f"data[PurchaseRows][{key}][PurchaseRow][purchase_id]", str(purchase_id)),
                (f"data[PurchaseRows][{key}][PurchaseRow][article_id]", "0"),
                (f"data[PurchaseRows][{key}][PurchaseRow][is_inventory]", "0"),
                (f"data[PurchaseRows][{key}][PurchaseRow][expense_account_id]", ln["acct"]),
                (f"data[PurchaseRows][{key}][PurchaseRow][code]", ""),
                (f"data[PurchaseRows][{key}][PurchaseRow][name]", ln["name"]),
                (f"data[PurchaseRows][{key}][PurchaseRow][vat_type_id]", ln["vat_type"]),
                (f"data[PurchaseRows][{key}][PurchaseRow][vat]", ln.get("vat", "0")),
                (f"data[PurchaseRows][{key}][PurchaseRow][amount]", ln.get("amount", "1")),
                (f"data[PurchaseRows][{key}][PurchaseRow][unit]", ln.get("unit", "tk")),
                (f"data[PurchaseRows][{key}][PurchaseRow][discount]", "0"),
                (f"data[PurchaseRows][{key}][PurchaseRow][sum]", to_estonian_number(ln["sum"])),
            ]

        # Edit existing lines in place. The scraped `_row_index` keys the form's
        # PurchaseRow keys; ordering by sorted(key) matches the 1-based index the
        # user reads from `expenses show`, so --set-line '<idx>:…' targets the same row.
        if set_lines:
            ordered_keys = sorted(_row_index.keys())
            alias = {"acct": "expense_account_id", "account": "expense_account_id",
                     "vat_type": "vat_type_id"}
            for raw in set_lines:
                head, _, rest = raw.partition(":")
                try:
                    idx = int(head)
                except ValueError:
                    raise click.ClickException(
                        f"--set-line must start with a 1-based line index: {raw!r}")
                if not 1 <= idx <= len(ordered_keys):
                    raise click.ClickException(
                        f"--set-line index {idx} out of range — purchase {purchase_id} "
                        f"has {len(ordered_keys)} line(s).")
                attrs = _parse_kv_line(rest)
                if not attrs:
                    raise click.ClickException(f"--set-line {idx} has no field=value pairs: {raw!r}")
                key = ordered_keys[idx - 1]
                for k, v in attrs.items():
                    attr = alias.get(k, k)
                    if attr == "sum":
                        v = to_estonian_number(v)
                    _set_field(fields, f"data[PurchaseRows][{key}][PurchaseRow][{attr}]", v)

        for raw in set_pairs:
            if "=" not in raw:
                raise click.ClickException(f"--set must be NAME=VALUE: {raw!r}")
            k, v = raw.split("=", 1)
            _set_field(fields, k, v)

        # /purchases/update expects multipart/form-data. The optional source-document
        # file slot (data[Purchase][copy]): --attach sets/replaces it; otherwise send an
        # empty part exactly as the rendered form does, leaving any existing file untouched.
        parts = [(n, (None, v)) for n, v in fields]
        if attach_path:
            fname = Path(attach_path).name
            data_bytes = Path(attach_path).read_bytes()
            ctype = "application/pdf" if fname.lower().endswith(".pdf") else "application/octet-stream"
            parts.append(("data[Purchase][copy]", (fname, data_bytes, ctype)))
        else:
            parts.append(("data[Purchase][copy]", ("", b"", "application/octet-stream")))

        http.headers["Referer"] = f"{BASE}/{account}/purchases/edit/{purchase_id}"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/purchases/update", files=parts)

    if r.status_code not in (200, 302):
        fail = CONFIG_DIR / "last_expense_update_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(f"Update failed: HTTP {r.status_code}. Response → {fail}")
    loc = r.headers.get("location", "")
    if "/purchases/view/" not in loc and "/purchases/edit/" not in loc:
        # 200 with a body might mean validation errors — sniff for them.
        fail = CONFIG_DIR / "last_expense_update_failure.html"
        fail.write_text(r.text)
        msgs = _page_errors(r.text)
        raise click.ClickException(
            f"Update may have failed silently (HTTP {r.status_code}, loc={loc!r})."
            + (" SB says: " + " | ".join(msgs) if msgs else "")
            + f" Response → {fail}"
        )
    click.secho(f"✓ Updated purchase {purchase_id}", fg="green", bold=True)
    if set_lines:
        click.echo(f"  Edited line(s): {', '.join(r.split(':', 1)[0] for r in set_lines)}")
    if attach_path:
        click.echo(f"  Attached : {attach_path}")
    if needs_rebind:
        for kind, bid in saved_bindings:
            _do_bind(kind, bid, [purchase_id])
            click.echo(f"  re-bound {kind.lower()} {bid} → purchase {purchase_id}")
    click.echo(f"  URL: {BASE}/{account}/purchases/view/{purchase_id}")


@expenses.command("delete")
@click.argument("purchase_id", type=int)
def expenses_delete(purchase_id) -> None:
    """Delete a purchase invoice (ostuarve) by id. Irreversible — removes the
    document. Any bound payments should be unbound first."""
    _do_delete("purchases", purchase_id, csrf_path="purchases/add")
    click.secho(f"✓ Deleted expense {purchase_id}", fg="green")


@expenses.command("send-payment")
@click.argument("purchase_id", type=int)
@click.option("--amount", default=None,
              help="Payment amount. Defaults to the invoice's pre-filled total.")
@click.option("--from-account", "from_account", default=None,
              help="Paying bank-cashbook id. Defaults to the invoice's pre-selected account.")
@click.option("--date", "payment_date", default=None,
              help="Payment date dd.mm.yyyy. Defaults to today.")
@click.option("--target", default=None,
              help="Bank integration target to push the order to (required).")
def expenses_send_payment(purchase_id, amount, from_account, payment_date, target) -> None:
    """Stage a purchase invoice as a payment order to the bank.

    Pushes the invoice to the configured bank integration. On success the
    invoice flips to "Pangas ootel" (pending in bank); the order then waits in
    the bank's netbank for an authorised person to confirm and sign — this
    never signs, only stages.

    Prerequisites, or the bank rejects it: the own bank account must carry a
    SWIFT/BIC in SimplBooks bank settings, and the supplier contact must carry
    an IBAN (`simplbooks clients update <id> --iban`).

    The push is reversible (SB's "Tühista makse panka saatmise märge") until
    the order is signed in the bank.

      simplbooks expenses send-payment 1733
      simplbooks expenses send-payment 1733 --amount 166,82 --date 09.06.2026
    """
    if not (target and target.strip()):
        raise click.ClickException(
            "No bank target — pass --target <bank> (the bank integration to push the order to)."
        )
    target = target.strip()
    cookies, account = session_or_die()
    view_url = f"{BASE}/{account}/purchases/view/{purchase_id}"
    with build_http(cookies, account) as http:
        r = http.get(view_url)
        if r.status_code in (301, 302):
            raise AuthError(
                f"Purchase {purchase_id} not accessible (redirect → {r.headers.get('location','')})."
            )
        if r.status_code != 200:
            raise click.ClickException(f"GET /purchases/view/{purchase_id} → HTTP {r.status_code}")
        soup = BeautifulSoup(r.text, "html.parser")

        # Scrape SB's own pre-filled send_payment form — canonical amount + paying account.
        amt_inp = soup.find("input", {"name": "payment_amount"})
        prefilled_amount = (amt_inp.get("value") if amt_inp else "") or ""
        acct_sel = soup.find("select", {"name": "income_account_id"})
        prefilled_account = ""
        if acct_sel:
            opt = acct_sel.find("option", attrs={"selected": True})
            prefilled_account = (opt.get("value") if opt else "") or ""
        csrf_inp = soup.find("input", {"name": "_csrfToken"})
        csrf = (csrf_inp.get("value") if csrf_inp else "") or ""
        if not csrf:
            raise click.ClickException("No _csrfToken on the invoice page — layout changed?")

        pay_amount = to_estonian_number(amount) if amount else prefilled_amount
        pay_account = str(from_account) if from_account else prefilled_account
        if not pay_amount:
            raise click.ClickException("No payment amount (none pre-filled, --amount not given).")
        if not pay_account:
            raise click.ClickException("No paying account (none pre-selected, --from-account not given).")

        if payment_date:
            custom_date, pay_date = "1", payment_date
        else:
            custom_date, pay_date = "0", datetime.now().strftime("%d.%m.%Y")

        fields = [
            ("target", target),
            ("object_ids", str(purchase_id)),
            ("income_account_id", pay_account),
            ("payment_amount", pay_amount),
            ("custom_date", custom_date),
            ("payment_date", pay_date),
            ("_csrfToken", csrf),
        ]
        http.headers["Referer"] = view_url
        http.headers["Origin"] = BASE
        r = http.post(
            f"{BASE}/{account}/purchases/send_payment",
            content=urlencode(fields),
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )

    # Truth comes from reading the invoice back: SB accepts a payment order
    # with either a 302 → /purchases (list) OR a 302 → /purchases/view/<id>,
    # and the redirect shape alone is not authoritative. The refreshed view
    # marks a staged order with "Pangas ootel" and offers a "Tühista makse
    # panka saatmise" reversal — either is proof the push landed. A clean
    # redirect to /purchases (list) still counts as success without needing
    # the read-back.
    loc = r.headers.get("location", "")
    clean_redirect = (
        r.status_code in (301, 302)
        and f"/purchases/view/{purchase_id}" not in loc
        and loc.rstrip("/").endswith("/purchases")
    )
    staged = clean_redirect
    if not staged:
        with build_http(cookies, account) as http2:
            rb = http2.get(view_url)
        if rb.status_code == 200 and (
            "Pangas ootel" in rb.text
            or "Tühista makse panka saatmise" in rb.text
        ):
            staged = True

    if staged:
        click.secho(f"✓ Payment staged for purchase {purchase_id} → {target}", fg="green", bold=True)
        click.echo(f"  amount   : {pay_amount}")
        click.echo(f"  from     : account {pay_account}")
        click.echo(f"  date     : {pay_date}")
        click.echo('  Invoice now "Pangas ootel" — confirm and sign in the bank\'s netbank.')
        return

    # Failure — surface the bank's flash message if we can.
    err = ""
    try:
        with build_http(cookies, account) as http2:
            fm = re.search(r"Makse saatmine [^<\"']+", http2.get(view_url).text)
            if fm:
                err = fm.group(0).strip()
    except Exception:
        pass
    fail = CONFIG_DIR / "last_send_payment_failure.html"
    fail.write_text(r.text)
    raise click.ClickException(
        f"Send rejected (HTTP {r.status_code}, loc={loc!r}). "
        + (f'Bank message: "{err}". ' if err else "")
        + "Check own-account SWIFT + supplier IBAN. Response → " + str(fail)
    )


# ─── payments / incomings (bank movements) ──────────────────────────────────
#
# `/payments/*`  → outgoing money (supplier payments / expense reimbursements).
#                  object_type = Purchase | ExpenseReport.
# `/incomings/*` → incoming money (customers paying sales invoices).
#
# The two forms are mirror-symmetric except for the field-name prefix:
#   data[Payment][payment_sum]   vs   data[Incoming][income_sum]
#   data[Payment][payment_date]  vs   data[Incoming][income_date]
#   (income_account_id, client_*, currency_*, etc. share the same name)
#
# Both create endpoints return a 302 Location redirect to /payments/view/<id>
# or /incomings/view/<id>; we parse the id out of that. Bindings to invoices /
# purchases happen via a separate /do_binding POST.

def _money_fields(
    *,
    direction: str,                # "Payment" or "Incoming"
    csrf: str,
    client: dict,
    income_account_id: int,
    sum_amount,
    date: datetime,
    description: str = "",
    currency: str = "EUR",
    object_type: str = "Purchase",
) -> list[tuple[str, str]]:
    is_payment = direction == "Payment"
    sum_key = "payment_sum" if is_payment else "income_sum"
    date_key = "payment_date" if is_payment else "income_date"
    fields: list[tuple[str, str]] = [
        (f"data[{direction}][id]", "0"),
        (f"data[{direction}][base_currency_id]", "2"),
        (f"data[{direction}][base_currency_code]", "EUR"),
        (f"data[{direction}][creator]", "0"),
        (f"data[{direction}][created_time]", ""),
        (f"data[{direction}][regenerate_cash_order_no]", "0"),
        (f"data[{direction}][client_data_needs_update]", "0"),
        (f"data[{direction}][client_update_data]", "0"),
        (f"data[{direction}][client_id]", str(client["id"])),
        (f"data[{direction}][client_name]", str(client.get("name", "") or "")),
    ]
    if is_payment:
        fields.append(("data[Payment][object_type]", object_type))
    fields += [
        (f"data[{direction}][income_account_id]", str(income_account_id)),
        (f"data[{direction}][{sum_key}]", str(sum_amount)),
        (f"data[{direction}][currency_name]", currency),
        (f"data[{direction}][currency_rate]", "1,0000"),
        (f"data[{direction}][{date_key}]", date.strftime("%d.%m.%Y")),
        (f"data[{direction}][description]", description),
        (f"data[{direction}][client_reg_no]", strip_html(client.get("reg_no"))),
        (f"data[{direction}][client_vat_no]", strip_html(client.get("vat_no"))),
        (f"data[{direction}][client_email]", strip_html(client.get("email"))),
        (f"data[{direction}][client_account_no]", ""),
        (f"data[{direction}][client_swift_code]", ""),
        (f"data[{direction}][client_bank]", ""),
        (f"data[{direction}][client_address_street]", strip_html(client.get("address_street"))),
        (f"data[{direction}][client_address_city]", strip_html(client.get("address_city"))),
        (f"data[{direction}][client_address_county]", strip_html(client.get("address_county"))),
        (f"data[{direction}][client_address_country]", strip_html(client.get("address_country"))),
        (f"data[{direction}][client_address_postal_code]", strip_html(client.get("address_postal_code"))),
        ("_csrfToken", csrf),
    ]
    return fields


def _create_money(
    direction: str, client_id: int, account_id: int, sum_amount,
    date_str: str, description: str, object_type: str = "Purchase",
) -> int:
    cookies, account = session_or_die()
    cache = load_clients_cache()
    if str(client_id) not in cache:
        _refresh_clients_cache(limit=10000)
        cache = load_clients_cache()
        if str(client_id) not in cache:
            raise click.ClickException(
                f"Client {client_id} not found even after a full clients refresh — check the id."
            )
    client = cache[str(client_id)]
    dt = datetime.strptime(date_str, "%Y-%m-%d")
    form_path = "payments/add" if direction == "Payment" else "incomings/add"
    create_path = "payments/create" if direction == "Payment" else "incomings/create"
    view_path = "payments/view" if direction == "Payment" else "incomings/view"

    with build_http(cookies, account) as http:
        csrf = fetch_fresh_csrf(http, account, path=form_path)
        fields = _money_fields(
            direction=direction, csrf=csrf, client=client,
            income_account_id=account_id, sum_amount=sum_amount, date=dt,
            description=description, object_type=object_type,
        )
        http.headers["Referer"] = f"{BASE}/{account}/{form_path}"
        http.headers["Origin"] = BASE
        body = urlencode(fields)
        r = http.post(
            f"{BASE}/{account}/{create_path}",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )

    loc = r.headers.get("location", "")
    m = re.search(rf"/{view_path}/(\d+)", loc)
    if not m:
        fail = CONFIG_DIR / f"last_{direction.lower()}_create_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"Create {direction} failed: HTTP {r.status_code} loc={loc!r}. Response → {fail}"
        )
    return int(m.group(1))


def _resolve_cashbook_name(account_id: int) -> str:
    """Resolve a cashbook id (income_accounts) to its display name.

    payments/incomings rows expose the paying cashbook only as `account_name`
    (`account_id` is left blank in listdata), so client-side filtering has to
    match on the resolved name. Raises when the id is not a live cashbook —
    otherwise the caller would silently see zero rows.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account, ajax=True) as http:
        rows = _accounts_listdata(http, account, "income_accounts", 500)
    id_to_name = {str(r.get("id")): strip_html(r.get("name")) for r in rows}
    name = id_to_name.get(str(account_id))
    if not name:
        raise click.ClickException(
            f"--account-id {account_id} is not a cashbook. "
            "See `simplbooks accounts list cashbook` for valid ids."
        )
    return name


def _list_money(endpoint: str, search: str = "", limit: int = 200) -> list[dict]:
    """Fetch /<endpoint>/listdata (payments or incomings). Returns the rows array.

    SB's server-side DataTables search tokenizes on `_`, so a full-string
    substring search like a Stripe idempotency key (`txn_3Rabcd…`) returns
    empty even when the row's description begins with it — while partial
    tokens (`Stripe`, `Billing`) match fine. When the search value contains
    `_`, we search server-side on the longest `_`-delimited segment (still
    highly selective on its own) and re-narrow client-side by full-substring
    match, so an exact idempotency-key lookup is reliable."""
    cookies, account = session_or_die()
    cols = [
        ("payment_id" if endpoint == "payments" else "incoming_id",) * 2,
        ("client_name", "client_name"),
        ("status", "status"),
        ("date", "date"),
        ("sum", "sum"),
        ("currency_name", "currency_name"),
        ("account_name", "account_name"),
        ("account_id", "account_id"),
        ("description", "description"),
    ]
    if search and "_" in search:
        server_search = max(search.split("_"), key=len)
        client_needle = search
        # Widen the server window because we'll narrow further client-side —
        # otherwise the row we care about can sit just past `limit`.
        server_length = max(limit, 500)
    else:
        server_search = search
        client_needle = ""
        server_length = limit
    data = datatables_payload(list(cols), order_col=3, length=server_length, search=server_search)
    with build_http(cookies, account, ajax=True) as http:
        http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
        r = http.post(f"{BASE}/{account}/{endpoint}/listdata", data=data)
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
        rows = r.json().get("data", [])
    if client_needle:
        low = client_needle.lower()
        def _hay(row: dict) -> str:
            return " ".join(
                strip_html(str(row.get(k) or "")) for k in
                ("description", "client_name", "account_name",
                 "status", "sum", "date")
            ).lower()
        rows = [row for row in rows if low in _hay(row)]
    return rows[:limit]


def _parse_kanne_date(row: dict):
    """transaction_date ('DD.MM.YYYY', maybe HTML-wrapped) → date, or None."""
    raw = strip_html(row.get("transaction_date"))
    try:
        return datetime.strptime(raw[:10], "%d.%m.%Y").date()
    except (ValueError, TypeError):
        return None


def _list_kanne(search: str = "", limit: int = 200,
                date_from: str | None = None, date_to: str | None = None) -> list[dict]:
    """Fetch /financial_transactions/listdata rows (newest first).

    The listdata endpoint has no server-side date range. Without a range we
    return the most-recent `limit` rows (cheap path). With a range we page
    backwards through the desc-by-date result set until we've walked past
    `date_from`, accumulating the in-range rows — otherwise a window older
    than the most-recent `limit` rows would be silently invisible.
    """
    cookies, account = session_or_die()
    cols = [
        ("transaction_group_id", "transaction_group_id"),
        ("transaction_note", "transaction_note"),
        ("transaction_date", "transaction_date"),
        ("sum_plus", "sum_plus"),
        ("sum_minus", "sum_minus"),
        ("base_object", "base_object"),
    ]
    url = f"{BASE}/{account}/financial_transactions/listdata"

    if not date_from and not date_to:
        data = datatables_payload(cols, order_col=2, length=limit, search=search)
        with build_http(cookies, account, ajax=True) as http:
            http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
            r = http.post(url, data=data)
            if r.status_code != 200:
                raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
            return r.json().get("data", [])

    from_d = datetime.strptime(date_from, "%Y-%m-%d").date() if date_from else None
    to_d = datetime.strptime(date_to, "%Y-%m-%d").date() if date_to else None

    def _in_range(row: dict) -> bool:
        d = _parse_kanne_date(row)
        if d is None:
            return True  # un-parseable date → don't silently drop it
        if from_d and d < from_d:
            return False
        if to_d and d > to_d:
            return False
        return True

    PAGE = 1000
    MAX_PAGES = 50  # safety backstop: at most 50k rows scanned
    in_range: list[dict] = []
    start = 0
    with build_http(cookies, account, ajax=True) as http:
        http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
        for _ in range(MAX_PAGES):
            data = datatables_payload(cols, order_col=2, length=PAGE, search=search)
            data["start"] = str(start)
            r = http.post(url, data=data)
            if r.status_code != 200:
                raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
            rows = r.json().get("data", [])
            if not rows:
                break
            in_range.extend(row for row in rows if _in_range(row))
            oldest = _parse_kanne_date(rows[-1])
            start += len(rows)
            if len(rows) < PAGE:
                break  # reached the end of the result set
            # rows arrive newest→oldest; once the page floor drops below the
            # window, everything beyond is older still — stop paging.
            if from_d is not None and oldest is not None and oldest < from_d:
                break
        else:
            click.secho(
                f"⚠ scanned {MAX_PAGES * PAGE} rows without reaching "
                f"{date_from or 'the start of history'}; results may be incomplete.",
                fg="yellow", err=True,
            )
    return in_range


def _do_delete(controller: str, obj_id: int, csrf_path: str) -> None:
    """POST /<controller>/delete/<id> with CSRF — used by payments, incomings, kanne.

    SB answers a refused delete (e.g. a payment-locked ostuarve) with an error
    banner behind HTTP 200, so the status code proves nothing. Truth comes from
    reading the object back: if its page still renders, the delete didn't happen.
    """
    cookies, account = session_or_die()
    probe_path = "edit" if controller == "financial_transactions" else "view"
    with build_http(cookies, account) as http:
        csrf = fetch_fresh_csrf(http, account, path=csrf_path)
        http.headers["Referer"] = f"{BASE}/{account}/{controller}"
        http.headers["Origin"] = BASE
        body = urlencode([("_csrfToken", csrf)])
        r = http.post(
            f"{BASE}/{account}/{controller}/delete/{obj_id}",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
        if r.status_code not in (200, 302):
            fail = CONFIG_DIR / f"last_{controller}_delete_failure.html"
            fail.write_text(r.text)
            raise click.ClickException(
                f"Delete failed: HTTP {r.status_code}. Response → {fail}"
            )
        errs = _page_errors(r.text)
        rb = http.get(f"{BASE}/{account}/{controller}/{probe_path}/{obj_id}")
    if rb.status_code == 200:
        errs += [m for m in _page_errors(rb.text) if m not in errs]
        fail = CONFIG_DIR / f"last_{controller}_delete_failure.html"
        fail.write_text(rb.text)
        raise click.ClickException(
            f"Delete refused — {controller}/{obj_id} still exists."
            + (" SB says: " + " | ".join(errs) if errs else "")
            + f" Response → {fail}"
        )
    if "accounts/login" in rb.headers.get("location", ""):
        raise click.ClickException(
            f"Delete unverified — session expired on the read-back of "
            f"{controller}/{obj_id}; check its state by hand."
        )


def _parse_bound_docs(html: str, doc_path: str) -> dict[int, str]:
    """Parse a payment/incoming view's bound-documents table.

    Returns {document id: 'Katte summa' cell text} for each row linking to
    /<doc_path>/view/<id> ('' if the column isn't found).
    """
    soup = BeautifulSoup(html, "html.parser")
    href_re = re.compile(rf"/{doc_path}/view/(\d+)")
    out: dict[int, str] = {}
    for a in soup.find_all("a", href=href_re):
        row = a.find_parent("tr")
        table = a.find_parent("table")
        if not (row and table):
            continue
        doc_id = int(href_re.search(a["href"]).group(1))
        headers = [th.get_text(strip=True) for th in table.find_all("th")]
        tds = row.find_all("td")
        katte = ""
        if "Katte summa" in headers:
            idx = headers.index("Katte summa")
            if idx < len(tds):
                katte = tds[idx].get_text(strip=True).replace("\xa0", " ")
        out[doc_id] = katte
    return out


def _do_bind(direction: str, money_id: int, bind_ids: list[int]) -> dict[int, str]:
    cookies, account = session_or_die()
    is_payment = direction == "Payment"
    money_key = "payment_id" if is_payment else "incoming_id"
    bind_key = "bind_to_purchase[]" if is_payment else "bind_to_invoice[]"
    form_path = "payments/add" if is_payment else "incomings/add"
    do_path = "payments/do_binding" if is_payment else "incomings/do_binding"
    bind_referer = (
        f"payments/bind_with_purchase/{money_id}" if is_payment
        else f"incomings/bind_with_invoice/{money_id}"
    )

    with build_http(cookies, account) as http:
        csrf = fetch_fresh_csrf(http, account, path=form_path)
        fields: list[tuple[str, str]] = [
            (money_key, str(money_id)),
            ("dobinding", "1"),
        ]
        for bid in bind_ids:
            fields.append((bind_key, str(bid)))
        fields.append(("_csrfToken", csrf))

        http.headers["Referer"] = f"{BASE}/{account}/{bind_referer}"
        http.headers["Origin"] = BASE
        body = urlencode(fields)
        r = http.post(
            f"{BASE}/{account}/{do_path}",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )

        if r.status_code not in (200, 302):
            fail = CONFIG_DIR / f"last_{direction.lower()}_bind_failure.html"
            fail.write_text(r.text)
            raise click.ClickException(
                f"Bind failed: HTTP {r.status_code}. Response → {fail}"
            )

        # SB accepts a no-op binding (e.g. no free remainder) with HTTP 200 and
        # at most an error banner, so read the money document back and verify
        # each requested id actually got an allocation.
        view_path = "payments" if is_payment else "incomings"
        doc_path = "purchases" if is_payment else "invoices"
        errs = _page_errors(r.text)
        rb = http.get(f"{BASE}/{account}/{view_path}/view/{money_id}")

    if rb.status_code != 200:
        raise click.ClickException(
            f"Bind unverified — GET {view_path}/view/{money_id} returned "
            f"HTTP {rb.status_code}; check the binding by hand."
        )
    errs += [m for m in _page_errors(rb.text) if m not in errs]
    bound = _parse_bound_docs(rb.text, doc_path)

    def _is_zero(text: str) -> bool:
        try:
            return _amount_float(text) == 0.0
        except (ValueError, click.ClickException):
            return False

    missing = [b for b in bind_ids if b not in bound or _is_zero(bound[b])]
    if missing:
        fail = CONFIG_DIR / f"last_{direction.lower()}_bind_failure.html"
        fail.write_text(rb.text)
        raise click.ClickException(
            f"Bind not applied — no allocation for {doc_path} {missing} on "
            f"{view_path[:-1]} {money_id}."
            + (" SB says: " + " | ".join(errs) if errs
               else " (Typical cause: the money document has no free remainder.)")
            + f" Response → {fail}"
        )
    return {b: bound[b] for b in bind_ids}


@cli.group()
def payments() -> None:
    """Outgoing bank movements (supplier payments, expense reimbursements).

    An unbound payment is a first-class supplier prepayment; bind it to a
    purchase invoice later, once the document arrives.
    """


@payments.command("list")
@click.option("--search", default="", help="Substring search across description / client / etc.")
@click.option("--account-id", default=None, type=int, help="Filter (client-side) by bank/cashbook id.")
@click.option("--limit", default=200, show_default=True, type=int)
@click.option("--json", "as_json", is_flag=True)
def payments_list(search, account_id, limit, as_json) -> None:
    """List outgoing payments (server-side global search; client-side account filter)."""
    rows = _list_money("payments", search=search, limit=limit)
    if account_id is not None:
        name = _resolve_cashbook_name(account_id)
        rows = [r for r in rows
                if strip_html(r.get("account_name")) == name
                or str(r.get("account_id") or "") == str(account_id)]
    if as_json:
        click.echo(json.dumps(rows, ensure_ascii=False, indent=2))
        return
    click.secho(f"{len(rows)} returned", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'DATE':<12}  {'CLIENT':<32}  {'SUM':>10}  {'ACCOUNT':<22}  DESCRIPTION", bold=True)
    for r in rows:
        click.echo(
            f"{str(r.get('id','?')):>5}  "
            f"{strip_html(r.get('date'))[:12]:<12}  "
            f"{strip_html(r.get('client_name'))[:32]:<32}  "
            f"{strip_html(r.get('sum'))[:10]:>10}  "
            f"{strip_html(r.get('account_name'))[:22]:<22}  "
            f"{strip_html(r.get('description'))[:80]}"
        )


@payments.command("create")
@click.option("--client-id", required=True, type=int, help="SB client id of the counter-party (supplier).")
@click.option("--account-id", required=True, type=int, help="Bank/cashbook id (`accounts list cashbook` for ids).")
@click.option("--sum", "sum_amount", required=True, help="Amount, plain or Estonian decimal (e.g. 10 or 10,85).")
@click.option("--date", "date_str", required=True, help="Payment date YYYY-MM-DD.")
@click.option("--description", default="")
@click.option("--object-type", type=click.Choice(["Purchase", "ExpenseReport"]),
              default="Purchase", show_default=True)
def payments_create(client_id, account_id, sum_amount, date_str, description, object_type) -> None:
    """Create an outgoing payment (makse). Returns new payment id.

    A payment does NOT require a purchase invoice to exist — an unbound
    payment is a first-class SB primitive that books as a supplier
    prepayment: SB credits the paying bank/cashbook and debits the
    supplier-prepayment account (the `Ettemaksed tarnijatele` family), so
    the money sits as a claim on the supplier rather than netted against
    payables. Bind it later with `payments bind` when the invoice arrives.
    `--object-type` selects the settlement target (Purchase default, or
    ExpenseReport).
    """
    pid = _create_money("Payment", client_id, account_id, sum_amount, date_str, description, object_type)
    cookies, account = session_or_die()
    click.secho(f"✓ Created payment {pid}", fg="green", bold=True)
    click.echo(f"  URL: {BASE}/{account}/payments/view/{pid}")


@payments.command("bind")
@click.argument("payment_id", type=int)
@click.option("--to-purchase", "purchase_ids", multiple=True, type=int, required=True,
              help="Purchase invoice id(s) to bind. Repeatable.")
def payments_bind(payment_id, purchase_ids) -> None:
    """Link an outgoing payment to one or more purchase invoices.

    Bind allocates only the payment's FREE (unallocated) remainder against
    each invoice's open balance; a cent residual stays as free prepayment.
    Binding is a separate, later step from creating — an unbound payment
    sits as a supplier prepayment until a document arrives to bind it to.

    A bound allocation is NOT editable in place: to move or re-split an
    already-bound payment, delete it and re-create it, then re-bind. There
    is no unbind-in-place.
    """
    bound = _do_bind("Payment", payment_id, list(purchase_ids))
    click.secho(f"✓ Bound payment {payment_id}", fg="green")
    for pid, katte in bound.items():
        click.echo(f"  purchase {pid}: allocated {katte or '?'}")


@payments.command("delete")
@click.argument("payment_id", type=int)
def payments_delete(payment_id) -> None:
    """Delete a payment by id."""
    _do_delete("payments", payment_id, csrf_path="payments/add")
    click.secho(f"✓ Deleted payment {payment_id}", fg="green")


@cli.group()
def incomings() -> None:
    """Incoming bank movements (customers paying sales invoices)."""


@incomings.command("list")
@click.option("--search", default="", help="Substring search across description / client / etc.")
@click.option("--account-id", default=None, type=int, help="Filter (client-side) by bank/cashbook id.")
@click.option("--limit", default=200, show_default=True, type=int)
@click.option("--json", "as_json", is_flag=True)
def incomings_list(search, account_id, limit, as_json) -> None:
    """List incoming payments."""
    rows = _list_money("incomings", search=search, limit=limit)
    if account_id is not None:
        name = _resolve_cashbook_name(account_id)
        rows = [r for r in rows
                if strip_html(r.get("account_name")) == name
                or str(r.get("account_id") or "") == str(account_id)]
    if as_json:
        click.echo(json.dumps(rows, ensure_ascii=False, indent=2))
        return
    click.secho(f"{len(rows)} returned", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'DATE':<12}  {'CLIENT':<32}  {'SUM':>10}  {'ACCOUNT':<22}  DESCRIPTION", bold=True)
    for r in rows:
        click.echo(
            f"{str(r.get('id','?')):>5}  "
            f"{strip_html(r.get('date'))[:12]:<12}  "
            f"{strip_html(r.get('client_name'))[:32]:<32}  "
            f"{strip_html(r.get('sum'))[:10]:>10}  "
            f"{strip_html(r.get('account_name'))[:22]:<22}  "
            f"{strip_html(r.get('description'))[:80]}"
        )


@incomings.command("create")
@click.option("--client-id", required=True, type=int, help="SB client id of the customer.")
@click.option("--account-id", required=True, type=int, help="Bank/cashbook id (`accounts list cashbook` for ids).")
@click.option("--sum", "sum_amount", required=True, help="Amount.")
@click.option("--date", "date_str", required=True, help="YYYY-MM-DD.")
@click.option("--description", default="")
def incomings_create(client_id, account_id, sum_amount, date_str, description) -> None:
    """Create an incoming payment (laekumine). Returns new incoming id."""
    iid = _create_money("Incoming", client_id, account_id, sum_amount, date_str, description)
    cookies, account = session_or_die()
    click.secho(f"✓ Created incoming {iid}", fg="green", bold=True)
    click.echo(f"  URL: {BASE}/{account}/incomings/view/{iid}")


@incomings.command("bind")
@click.argument("incoming_id", type=int)
@click.option("--to-invoice", "invoice_ids", multiple=True, type=int, required=True,
              help="Sales invoice id(s) to bind. Repeatable.")
def incomings_bind(incoming_id, invoice_ids) -> None:
    """Link an incoming payment to one or more sales invoices."""
    bound = _do_bind("Incoming", incoming_id, list(invoice_ids))
    click.secho(f"✓ Bound incoming {incoming_id}", fg="green")
    for iid, katte in bound.items():
        click.echo(f"  invoice {iid}: allocated {katte or '?'}")


@incomings.command("delete")
@click.argument("incoming_id", type=int)
def incomings_delete(incoming_id) -> None:
    """Delete an incoming by id."""
    _do_delete("incomings", incoming_id, csrf_path="incomings/add")
    click.secho(f"✓ Deleted incoming {incoming_id}", fg="green")


# ─── kanne (journal entries / financial_transactions) ────────────────────────

def _amount_float(s) -> float:
    return float(to_estonian_number(s).replace(" ", "").replace(",", "."))


KANNE_LINE_RE = re.compile(r"data\[FinancialTransactions\]\[(\w+)\]\[(\w+)\]")
KANNE_HDR_RE = re.compile(r"data\[FinancialTransaction\]\[(\w+)\]")


def _resolve_accounts(http: httpx.Client, account: str) -> dict[str, dict]:
    """Map financial_account_id (str) → {code, name} over the full kontoplaan.

    Used to render kanne legs with account names instead of bare ids. Missing
    ids (e.g. an inactive account) fall back to the id at the call site.
    """
    out: dict[str, dict] = {}
    for r in _accounts_listdata(http, account, "financial_accounts", limit=2000):
        out[str(r.get("id"))] = {
            "code": strip_html(r.get("code")),
            "name": strip_html(r.get("name")),
        }
    return out


def _scrape_kanne_edit_form(
    http: httpx.Client, account: str, kanne_id: int
) -> tuple[list[tuple[str, str]], dict[str, dict], dict[str, dict], str]:
    """Fetch /financial_transactions/edit/<id> → (fields, lines, row_index, csrf).

    - `fields`     — full ordered (name, value) list, ready to re-POST after patching.
    - `lines`      — idx → {attr: value} for each `data[FinancialTransactions][idx][..]` leg.
    - `row_index`  — idx → {attr: fields-list index} so a caller can mutate a leg in place.
    - `csrf`       — the form's token (re-scrape from /add before POST to be safe).
    """
    r = http.get(f"{BASE}/{account}/financial_transactions/edit/{kanne_id}")
    if _session_stale(r):
        auto_login_attempt(interactive=False)
        creds = load_credentials()
        http.cookies = httpx.Cookies(parse_cookie_string(creds["SIMPLBOOKS_COOKIE"]))
        r = http.get(f"{BASE}/{account}/financial_transactions/edit/{kanne_id}")
    if r.status_code != 200:
        raise click.ClickException(
            f"GET /financial_transactions/edit/{kanne_id} returned {r.status_code} "
            f"(does kanne {kanne_id} exist?)"
        )
    soup = BeautifulSoup(r.text, "html.parser")
    form = soup.find("form", {"id": "FinancialTransactionForm"})
    if not form:
        raise click.ClickException(
            f"No #FinancialTransactionForm on /financial_transactions/edit/{kanne_id} — page layout changed?")

    fields: list[tuple[str, str]] = []
    lines: dict[str, dict] = {}
    row_index: dict[str, dict] = {}
    for el in form.find_all(["input", "select", "textarea"]):
        name = el.get("name")
        if not name:
            continue
        itype = (el.get("type") or "").lower()
        if itype in ("file", "submit", "button", "reset"):
            continue
        if el.name == "select":
            opt = el.find("option", selected=True)
            value = opt.get("value", "") if opt else ""
        elif el.name == "textarea":
            value = el.get_text()
        else:
            if itype == "checkbox" and not el.has_attr("checked"):
                continue
            value = el.get("value", "")
        fields.append((name, value or ""))
        m = KANNE_LINE_RE.fullmatch(name)
        if m:
            idx, attr = m.group(1), m.group(2)
            lines.setdefault(idx, {})[attr] = value or ""
            row_index.setdefault(idx, {})[attr] = len(fields) - 1

    csrf_input = form.find("input", {"name": "_csrfToken"}) or soup.find("input", {"name": "_csrfToken"})
    if not csrf_input or not csrf_input.get("value"):
        raise click.ClickException("No _csrfToken on kanne edit form — page layout changed?")
    return fields, lines, row_index, csrf_input["value"]


def _kanne_header(fields: list[tuple[str, str]]) -> dict[str, str]:
    """Pull data[FinancialTransaction][..] header fields into a flat dict."""
    hdr: dict[str, str] = {}
    for n, v in fields:
        m = KANNE_HDR_RE.fullmatch(n)
        if m:
            hdr[m.group(1)] = v
    return hdr


def _kanne_balance(lines: dict[str, dict]) -> tuple[float, float]:
    debit = sum(_amount_float(l.get("transaction_sum_debit", "0") or "0") for l in lines.values())
    credit = sum(_amount_float(l.get("transaction_sum_credit", "0") or "0") for l in lines.values())
    return debit, credit


@cli.group()
def kanne() -> None:
    """Manual journal entries (Kanded) — double-entry between accounts."""


@kanne.command("list")
@click.option("--search", default="", help="Substring search across transaction_note etc.")
@click.option("--from", "date_from", default=None, help="Only kanne on/after this date (YYYY-MM-DD).")
@click.option("--to", "date_to", default=None, help="Only kanne on/before this date (YYYY-MM-DD).")
@click.option("--limit", default=200, show_default=True, type=int)
@click.option("--json", "as_json", is_flag=True)
def kanne_list(search, date_from, date_to, limit, as_json) -> None:
    """List financial transactions (manual journal entries).

    --from/--to bound on transaction_date. The listdata endpoint has no
    server-side date range, so a bounded query pages backwards through the
    (desc-by-date) result set until it has covered the window — a range older
    than the most-recent rows is found, not silently missed. Note: the row
    does NOT carry the per-leg accounts — use `kanne show <id>` for those.
    """
    rows = _list_kanne(search=search, limit=limit, date_from=date_from, date_to=date_to)

    if (date_from or date_to) and len(rows) > limit:
        click.secho(
            f"⚠ {len(rows)} rows in range; showing the {limit} most recent "
            f"(raise --limit for the rest).", fg="yellow", err=True,
        )
        rows = rows[:limit]

    if as_json:
        click.echo(json.dumps(rows, ensure_ascii=False, indent=2))
        return
    click.secho(f"{len(rows)} returned", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'DATE':<12}  {'+SUM':>10}  {'-SUM':>10}  NOTE", bold=True)
    for r in rows:
        click.echo(
            f"{str(r.get('id','?')):>5}  "
            f"{strip_html(r.get('transaction_date'))[:12]:<12}  "
            f"{strip_html(r.get('sum_plus'))[:10]:>10}  "
            f"{strip_html(r.get('sum_minus'))[:10]:>10}  "
            f"{strip_html(r.get('transaction_note'))[:80]}"
        )


@kanne.command("create")
@click.option("--date", "date_str", required=True, help="Transaction date YYYY-MM-DD.")
@click.option("--note", default="", help="Top-level kanne description.")
@click.option("--line", "lines_raw", multiple=True, required=True,
              help="Repeatable. Format: side=debit|credit:account=<id>:sum=<amount>[:note=...]")
def kanne_create(date_str, note, lines_raw) -> None:
    """Create a double-entry journal transaction.

    The sum of all `debit` lines must equal the sum of all `credit` lines.

    Example — move 1 000,00 between two cashbooks (ids from `accounts list cashbook`):

        simplbooks kanne create --date 2026-01-02 --note 'Inter-account transfer' \\
          --line 'side=debit:account=<id-a>:sum=1000,00:note=transfer' \\
          --line 'side=credit:account=<id-b>:sum=1000,00:note=transfer'

    The `account` is the financial_account id (`simplbooks accounts list cashbook`
    for cashbook ids; full chart via `accounts list chart`).
    """
    cookies, account = session_or_die()
    dt = datetime.strptime(date_str, "%Y-%m-%d")

    rows: list[dict] = []
    for raw in lines_raw:
        parts: dict[str, str] = {}
        for kv in raw.split(":"):
            if "=" not in kv:
                continue
            k, v = kv.split("=", 1)
            parts[k.strip()] = v.strip()
        if parts.get("side") not in ("debit", "credit"):
            raise click.ClickException(f"--line side must be debit|credit: {raw!r}")
        try:
            rows.append({
                "side": parts["side"],
                "account_id": parts["account"],
                "sum": parts["sum"],
                "note": parts.get("note", ""),
            })
        except KeyError as e:
            raise click.ClickException(f"--line missing key {e}: {raw!r}")

    debit_total = sum(_amount_float(r["sum"]) for r in rows if r["side"] == "debit")
    credit_total = sum(_amount_float(r["sum"]) for r in rows if r["side"] == "credit")
    if abs(debit_total - credit_total) > 0.001:
        raise click.ClickException(
            f"Debit total {debit_total:.2f} != credit total {credit_total:.2f} — "
            f"double-entry must balance."
        )

    with build_http(cookies, account) as http:
        csrf = fetch_fresh_csrf(http, account, path="financial_transactions/add")
        parts: list[tuple[str, tuple]] = [
            ("data[FinancialTransaction][id]", (None, "0")),
            ("data[draft_id]", (None, "")),
            ("data[FinancialTransaction][transaction_group_id]", (None, "0")),
            ("data[FinancialTransaction][base_object_id]", (None, "0")),
            ("data[FinancialTransaction][import_archive_hash]", (None, "")),
            ("data[FinancialTransaction][imported_document_id]", (None, "")),
            ("data[FinancialTransaction][transaction_note]", (None, note)),
            ("data[FinancialTransaction][transaction_date]", (None, dt.strftime("%d.%m.%Y"))),
            ("data[FinancialTransaction][base_object_type]", (None, "None")),
            ("data[FinancialTransactionsExistingRootDocument]", (None, "")),
            ("data[FinancialTransactionsRootDocumentFile]", ("", b"", "application/octet-stream")),
        ]
        for order, row in enumerate(rows):
            key = _random_row_key()
            debit = to_estonian_number(row["sum"]) if row["side"] == "debit" else "0,00"
            credit = to_estonian_number(row["sum"]) if row["side"] == "credit" else "0,00"
            parts += [
                (f"data[FinancialTransactions][{key}][id]", (None, "0")),
                (f"data[FinancialTransactions][{key}][financial_account_side]", (None, row["side"])),
                (f"data[FinancialTransactions][{key}][initial_sum]", (None, str(row["sum"]))),
                (f"data[FinancialTransactions][{key}][showing_order]", (None, str(order))),
                (f"data[FinancialTransactions][{key}][bank_row]", (None, "")),
                (f"data[FinancialTransactions][{key}][financial_account_id]", (None, str(row["account_id"]))),
                (f"data[FinancialTransactions][{key}][account_note]", (None, row["note"])),
                (f"data[FinancialTransactions][{key}][vat_percent]", (None, "0")),
                (f"data[FinancialTransactions][{key}][transaction_sum_debit]", (None, debit)),
                (f"data[FinancialTransactions][{key}][transaction_sum_credit]", (None, credit)),
            ]
        parts.append(("_csrfToken", (None, csrf)))

        http.headers["Referer"] = f"{BASE}/{account}/financial_transactions/create"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/financial_transactions/create", files=parts)

    loc = r.headers.get("location", "")
    m = re.search(r"/financial_transactions/view/(\d+)", loc)
    if not m:
        fail = CONFIG_DIR / "last_kanne_create_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"Kanne create failed: HTTP {r.status_code} loc={loc!r}. Response → {fail}"
        )
    kid = m.group(1)
    click.secho(f"✓ Created kanne {kid}", fg="green", bold=True)
    click.echo(f"  Date  : {date_str}    Note: {note}")
    click.echo(f"  Lines : {len(rows)}    debit={debit_total:.2f}  credit={credit_total:.2f}")
    click.echo(f"  URL   : {BASE}/{account}/financial_transactions/view/{kid}")


@kanne.command("show")
@click.argument("kanne_id", type=int)
@click.option("--json", "as_json", is_flag=True)
def kanne_show(kanne_id, as_json) -> None:
    """Show one kanne in full — both legs, resolved account names, balance check.

    The read-one primitive: `kanne list` cannot show which accounts an entry
    touched; this can. Read it before `kanne update` so you patch the right leg.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        fields, lines, _ri, _csrf = _scrape_kanne_edit_form(http, account, kanne_id)
    hdr = _kanne_header(fields)
    with build_http(cookies, account, ajax=True) as http:
        acct_map = _resolve_accounts(http, account)

    existing_doc = next(
        (v for n, v in fields if n == "data[FinancialTransactionsExistingRootDocument]"), ""
    )

    def _ord(kv):
        return int(kv[0]) if kv[0].isdigit() else 9999

    legs = []
    for idx, ln in sorted(lines.items(), key=_ord):
        aid = str(ln.get("financial_account_id") or "")
        info = acct_map.get(aid, {})
        legs.append({
            "idx": idx,
            "line_id": ln.get("id"),
            "account_id": aid,
            "account_code": info.get("code", ""),
            "account_name": info.get("name", ""),
            "debit": ln.get("transaction_sum_debit", "0,00"),
            "credit": ln.get("transaction_sum_credit", "0,00"),
            "note": ln.get("account_note", ""),
        })
    debit, credit = _kanne_balance(lines)

    if as_json:
        click.echo(json.dumps({
            "id": kanne_id,
            "group_id": hdr.get("transaction_group_id"),
            "date": hdr.get("transaction_date"),
            "note": hdr.get("transaction_note"),
            "base_object_type": hdr.get("base_object_type"),
            "import_archive_hash": hdr.get("import_archive_hash") or None,
            "document": existing_doc or None,
            "lines": legs,
            "balance": {"debit": round(debit, 2), "credit": round(credit, 2),
                        "ok": abs(debit - credit) < 0.005},
        }, ensure_ascii=False, indent=2))
        return

    click.secho(f"Kanne {kanne_id}", fg="cyan", bold=True)
    click.echo(f"  Group : {hdr.get('transaction_group_id','?')}    Date: {hdr.get('transaction_date','?')}")
    click.echo(f"  Note  : {hdr.get('transaction_note','')}")
    src = hdr.get("base_object_type") or "None"
    imp = hdr.get("import_archive_hash")
    click.echo(f"  Source: {'manual' if src in ('None','') else src}"
               f"{'  (bank-import linked)' if imp else ''}")
    click.echo(f"  Doc   : {existing_doc or '(none)'}")
    click.echo()
    click.secho(f"{'#':>2}  {'ACCOUNT':<42}  {'DEBIT':>11}  {'CREDIT':>11}  NOTE", bold=True)
    for leg in legs:
        acct = f"{leg['account_id']:>4} {leg['account_code']} {leg['account_name']}".strip()
        click.echo(
            f"{leg['idx']:>2}  {acct[:42]:<42}  "
            f"{leg['debit']:>11}  {leg['credit']:>11}  {leg['note']}"
        )
    tie = "✓" if abs(debit - credit) < 0.005 else "✗ DOES NOT BALANCE"
    click.echo(f"{'':>2}  {'balance':<42}  {debit:>11.2f}  {credit:>11.2f}  {tie}")


@kanne.command("update")
@click.argument("kanne_id", type=int)
@click.option("--date", "date_str", default=None, help="Change transaction date (YYYY-MM-DD).")
@click.option("--note", default=None, help="Replace the top-level transaction_note.")
@click.option("--set-line", "set_lines", multiple=True,
              help="Patch a leg in place. '<idx>:account=<id>[:debit=<amt>][:credit=<amt>][:note=<t>]'. "
                   "idx is the leg number from `kanne show`. Repeatable.")
@click.option("--add-line", "add_lines", multiple=True,
              help="Append a leg. 'side=debit|credit:account=<id>:sum=<amt>[:note=...]'. Repeatable.")
@click.option("--remove-line", "remove_lines", multiple=True,
              help="Remove a leg by idx (from `kanne show`). Repeatable.")
@click.option("--attach", "attach_path", default=None,
              type=click.Path(exists=True, dir_okay=False),
              help="Attach a source document (PDF) to the kanne.")
@click.option("--set", "set_pairs", multiple=True,
              help="Raw form field override NAME=VALUE (escape hatch). Repeatable.")
def kanne_update(kanne_id, date_str, note, set_lines, add_lines, remove_lines,
                 attach_path, set_pairs) -> None:
    """Edit an existing kanne in place (preserves leg ids + double-entry).

    Scrapes /financial_transactions/edit/<id>, patches the requested fields,
    re-validates that debit==credit, and re-POSTs. Leg ids are preserved, so
    the entry keeps its identity (no delete-and-recreate).

    Headline use — reclassify a leg from one account to another:

        simplbooks kanne update 20046 --set-line '1:account=<account-id>'

    Other edits:

        simplbooks kanne update 20046 --note 'SaaS subscription - 24.80 USD'
        simplbooks kanne update 20046 --date 2026-05-29
        simplbooks kanne update 20046 --attach /path/to/receipt.pdf
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        fields, lines, _row_index, _csrf = _scrape_kanne_edit_form(http, account, kanne_id)

        if date_str is not None:
            d = datetime.strptime(date_str, "%Y-%m-%d").strftime("%d.%m.%Y")
            _set_field(fields, "data[FinancialTransaction][transaction_date]", d)
        if note is not None:
            _set_field(fields, "data[FinancialTransaction][transaction_note]", note)

        for raw in set_lines:
            head, _, rest = raw.partition(":")
            idx = head.strip()
            if idx not in lines:
                raise click.ClickException(
                    f"--set-line: no leg with idx {idx!r} (see `kanne show {kanne_id}`).")
            kv = _parse_kv_line(rest)
            base = f"data[FinancialTransactions][{idx}]"
            if "account" in kv:
                _set_field(fields, f"{base}[financial_account_id]", kv["account"])
                lines[idx]["financial_account_id"] = kv["account"]
            if "note" in kv:
                _set_field(fields, f"{base}[account_note]", kv["note"])
            if "debit" in kv:
                amt = to_estonian_number(kv["debit"])
                _set_field(fields, f"{base}[transaction_sum_debit]", amt)
                _set_field(fields, f"{base}[transaction_sum_credit]", "0,00")
                _set_field(fields, f"{base}[initial_sum]", str(kv["debit"]))
                _set_field(fields, f"{base}[financial_account_side]", "debit")
                lines[idx]["transaction_sum_debit"] = amt
                lines[idx]["transaction_sum_credit"] = "0,00"
            if "credit" in kv:
                amt = to_estonian_number(kv["credit"])
                _set_field(fields, f"{base}[transaction_sum_credit]", amt)
                _set_field(fields, f"{base}[transaction_sum_debit]", "0,00")
                _set_field(fields, f"{base}[initial_sum]", str(kv["credit"]))
                _set_field(fields, f"{base}[financial_account_side]", "credit")
                lines[idx]["transaction_sum_credit"] = amt
                lines[idx]["transaction_sum_debit"] = "0,00"

        for idx in remove_lines:
            idx = idx.strip()
            if idx not in lines:
                raise click.ClickException(f"--remove-line: no leg with idx {idx!r}.")
            prefix = f"data[FinancialTransactions][{idx}]["
            fields = [(n, v) for (n, v) in fields if not n.startswith(prefix)]
            lines.pop(idx, None)

        for raw in add_lines:
            ln = _parse_kv_line(raw)
            for req in ("side", "account", "sum"):
                if req not in ln:
                    raise click.ClickException(f"--add-line missing '{req}': {raw!r}")
            if ln["side"] not in ("debit", "credit"):
                raise click.ClickException(f"--add-line side must be debit|credit: {raw!r}")
            key = _random_row_key()
            debit = to_estonian_number(ln["sum"]) if ln["side"] == "debit" else "0,00"
            credit = to_estonian_number(ln["sum"]) if ln["side"] == "credit" else "0,00"
            fields += [
                (f"data[FinancialTransactions][{key}][id]", "0"),
                (f"data[FinancialTransactions][{key}][financial_account_side]", ln["side"]),
                (f"data[FinancialTransactions][{key}][initial_sum]", str(ln["sum"])),
                (f"data[FinancialTransactions][{key}][showing_order]", str(len(lines))),
                (f"data[FinancialTransactions][{key}][bank_row]", ""),
                (f"data[FinancialTransactions][{key}][financial_account_id]", ln["account"]),
                (f"data[FinancialTransactions][{key}][account_note]", ln.get("note", "")),
                (f"data[FinancialTransactions][{key}][vat_percent]", "0"),
                (f"data[FinancialTransactions][{key}][transaction_sum_debit]", debit),
                (f"data[FinancialTransactions][{key}][transaction_sum_credit]", credit),
            ]
            lines[key] = {"transaction_sum_debit": debit, "transaction_sum_credit": credit,
                          "financial_account_id": ln["account"]}

        for raw in set_pairs:
            if "=" not in raw:
                raise click.ClickException(f"--set must be NAME=VALUE: {raw!r}")
            k, v = raw.split("=", 1)
            _set_field(fields, k, v)

        debit, credit = _kanne_balance(lines)
        if abs(debit - credit) > 0.005:
            raise click.ClickException(
                f"Refusing to save: debit {debit:.2f} != credit {credit:.2f}. "
                f"A kanne must balance — adjust --set-line / --add-line / --remove-line."
            )
        if not lines:
            raise click.ClickException("Refusing to save a kanne with no legs.")

        csrf = fetch_fresh_csrf(http, account, path="financial_transactions/add")
        _set_field(fields, "_csrfToken", csrf)

        parts: list[tuple[str, tuple]] = [(n, (None, v)) for (n, v) in fields]
        if attach_path:
            p = Path(attach_path)
            parts.append(("data[FinancialTransactionsRootDocumentFile]",
                          (p.name, p.read_bytes(), "application/pdf")))
        else:
            parts.append(("data[FinancialTransactionsRootDocumentFile]",
                          ("", b"", "application/octet-stream")))

        http.headers["Referer"] = f"{BASE}/{account}/financial_transactions/edit/{kanne_id}"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/financial_transactions/update", files=parts)

    loc = r.headers.get("location", "")
    if r.status_code not in (200, 302) or "/financial_transactions/view/" not in loc:
        fail = CONFIG_DIR / "last_kanne_update_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"Kanne update failed: HTTP {r.status_code} loc={loc!r}. Response → {fail}")
    click.secho(f"✓ Updated kanne {kanne_id}", fg="green", bold=True)
    click.echo(f"  Balance: debit {debit:.2f}  credit {credit:.2f}")
    click.echo(f"  URL    : {BASE}/{account}/financial_transactions/view/{kanne_id}")


@kanne.command("delete")
@click.argument("kanne_id", type=int)
def kanne_delete(kanne_id) -> None:
    """Delete a kanne (financial_transaction) by id."""
    _do_delete("financial_transactions", kanne_id, csrf_path="financial_transactions/add")
    click.secho(f"✓ Deleted kanne {kanne_id}", fg="green")


# ─── bank_transactions (PSD2 worklist) ──────────────────────────────────────
#
# The bank's PSD2 connector drops raw bank rows into SimpleBooks. They land
# in /bank_transactions/process as a worklist of un-saved entries, each one
# representing one bank movement that needs to be turned into either:
#   - incoming  (inflow bound to one or more sales invoices)
#   - payment   (outflow bound to one or more purchase invoices)
#   - financial_transaction (manual kanne, 2-sided double-entry)
#   - payout / taxes_payout (salary + tax-office; not yet implemented here)
#   - or deleted (payment-processor payout duplicates, mis-imports)
#
# The page is server-rendered HTML with one `<form class="transaction-form">`
# per row. Each form contains:
#   - data-id (BT id), data-date (ISO), data-sum (always positive)
#   - an object-type select whose options encode direction (incoming/payment)
#   - one `<script type="text/template">` per object-type variant with the
#     full field-set SB would post if the user saved as that variant
#   - inline JS `var errors = {...}; var warnings = {...}` listing validation
#     issues per row (e.g. "Klient on määramata")
#
# Multi-binding quirk: `data[Payment][purchase_id]` is a comma-joined string
# of ids (not a `[]` array). Same for `data[Incoming][invoice_id]`. Found by
# reading the JS that fires when the bindings modal closes:
#   $bindedObjectIdInput.val(selected_ids.join(','))
#
# Endpoints (CakePHP, x-www-form-urlencoded, _csrfToken required):
#   POST /<acct>/bank_transactions/delete            id=<bt_id>
#   POST /<acct>/bank_transactions/save              data[BankTransaction][id]=<bt_id>
#                                                    data[BankTransaction][object_type]=<variant>
#                                                    data[<Variant>][...]
#   POST /<acct>/bank_transactions/save_processed_data   (partial / WIP; not used)
#
# Two ID-spaces (ids differ per account — list them, never assume):
#   - cashbook ids  → `Incoming.income_account_id`, `Payment.income_account_id`.
#     What `accounts list cashbook` returns.
#   - chart-of-accounts ids → `FinancialTransaction.transactions[<rid>][financial_account_id]`.
#     What `accounts list chart` returns. For the kanne variant only.

BT_BASE_PATH = "bank_transactions/process"


def _bt_parse_amount(s: str) -> float:
    """'+812,19' → 812.19   '-1 393,00' → -1393.00   '812.19' → 812.19"""
    t = s.strip().replace("\xa0", " ").replace(" ", "")
    if t.startswith("+"):
        t = t[1:]
    sign = -1.0 if t.startswith("-") else 1.0
    t = t.lstrip("-")
    if "," in t and "." not in t:
        t = t.replace(",", ".")
    elif "," in t and "." in t:
        # 1,234.50 style
        t = t.replace(",", "")
    return sign * float(t)


def _bt_status(form_soup) -> str:
    """The status badge that doesn't have `d-none` in its class wins."""
    for span in form_soup.select(".status-container .status-label"):
        cls = span.get("class") or []
        if "d-none" in cls:
            continue
        for c in cls:
            if c.startswith("status-") and c != "status-label":
                return c.removeprefix("status-")
    return "unknown"


def _bt_extract_inline_js_dict(form_html: str, var_name: str) -> dict[str, str]:
    """Pull a `var errors = {...};` / `var warnings = {...};` literal out of inline JS.
    Returns {} when absent or empty. Values are unicode-decoded.
    """
    m = re.search(rf"var\s+{re.escape(var_name)}\s*=\s*(\{{.*?\}});", form_html, re.S)
    if not m:
        return {}
    raw = m.group(1)
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def _bt_template_html(form_soup, object_type: str) -> str:
    """Return the HTML inside the <script type=text/template> for a given object_type."""
    block = form_soup.find("div", {"data-object": object_type})
    if not block:
        return ""
    tmpl = block.find("script", {"class": "object-row-template"})
    return tmpl.decode_contents() if tmpl else ""


def _bt_extract_value(html: str, name_pattern: str) -> str:
    """Find the first <input ... name="..." value="..."> matching name_pattern. Returns value or ''."""
    m = re.search(
        rf'name="{name_pattern}"[^>]*?value="([^"]*)"', html
    )
    if m:
        return m.group(1)
    m = re.search(
        rf'value="([^"]*)"[^>]*?name="{name_pattern}"', html
    )
    return m.group(1) if m else ""


def _bt_parse_form(form_soup) -> dict:
    """Turn one <form class=transaction-form> into a structured row dict."""
    bt_id = int(form_soup.get("data-id") or 0)
    date_iso = form_soup.get("data-date") or ""
    raw_sum = float(form_soup.get("data-sum") or 0)
    form_html = str(form_soup)

    # Object types available + default (selected="selected").
    object_type_select = form_soup.find("select", class_="object-type-select")
    available: list[str] = []
    default_type = ""
    if object_type_select:
        for opt in object_type_select.find_all("option"):
            val = opt.get("value", "")
            if val:
                available.append(val)
            if opt.get("selected") is not None or opt.get("selected") == "selected":
                default_type = val

    # Direction inferred from which object_type variants are offered.
    if "incoming" in available:
        direction = "in"
        signed_sum = raw_sum
    elif "payment" in available:
        direction = "out"
        signed_sum = -raw_sum
    else:
        # Pure kanne row — fall back to header text.
        header = form_soup.find("div", class_="card-header")
        header_text = header.get_text(" ", strip=True) if header else ""
        if "-" in header_text and "+" not in header_text:
            direction = "out"
            signed_sum = -raw_sum
        else:
            direction = "in"
            signed_sum = raw_sum

    # Party + IBAN live inside <script type="text/template"> blocks, which BeautifulSoup
    # treats as opaque text. Parse the relevant template HTML and pull out the small
    # `.text-secondary` siblings under the client/payee + account inputs.
    party_name = ""
    bank_iban = ""
    for ot in (default_type, "financial_transaction", "incoming", "payment"):
        if not ot:
            continue
        inner_html = _bt_template_html(form_soup, ot)
        if not inner_html:
            continue
        inner = BeautifulSoup(inner_html, "html.parser")
        for small in inner.select(".small.text-secondary"):
            txt = small.get_text(strip=True)
            if not txt:
                continue
            if re.match(r"^[A-Z]{2}\d{2}[A-Z0-9]{10,30}$", txt):
                if not bank_iban:
                    bank_iban = txt
            elif not party_name:
                party_name = txt
        if party_name:
            break
    # Fallback: the disabled `FinancialTransactionPartyName<id>` input (also inside
    # the FT template — its value attribute is captured by regex).
    if not party_name:
        ft_html_for_party = _bt_template_html(form_soup, "financial_transaction")
        m = re.search(
            rf'id="FinancialTransactionPartyName{bt_id}"[^>]*value="([^"]*)"', ft_html_for_party
        )
        if m:
            party_name = m.group(1)

    # transaction_note (free-text description from the bank).
    note_input = form_soup.find("input", attrs={"name": "data[FinancialTransaction][transaction_note]"})
    if note_input:
        transaction_note = note_input.get("value", "")
    else:
        # On rows where the FT template lives inside <script>, fall back to template scrape.
        ft_html = _bt_template_html(form_soup, "financial_transaction")
        transaction_note = _bt_extract_value(ft_html, r"data\[FinancialTransaction\]\[transaction_note\]")

    # Bank-side COA id (the bank cashbook's COA id) — same in the kanne template.
    ft_html = _bt_template_html(form_soup, "financial_transaction")
    coa_id = _bt_extract_value(ft_html, r"data\[FinancialTransaction\]\[income_financial_account_id\]")

    # Bank-side cashbook id, picked from whichever income-account-select has `selected`.
    # Lives inside the incoming / payment template, so we re-parse one of them.
    cashbook_id = ""
    for ot in ("incoming", "payment"):
        inner_html = _bt_template_html(form_soup, ot)
        if not inner_html:
            continue
        inner = BeautifulSoup(inner_html, "html.parser")
        sel = inner.find("select", class_="income-account-select")
        if not sel:
            continue
        opt = sel.find("option", selected=True)
        if opt and opt.get("value"):
            cashbook_id = opt.get("value")
            break

    # Status from non-hidden status badge.
    status = _bt_status(form_soup)

    # Inline JS errors + warnings, keyed by field name (e.g. "Incoming.client_id").
    errors = _bt_extract_inline_js_dict(form_html, "errors")
    warnings = _bt_extract_inline_js_dict(form_html, "warnings")

    # Pre-selected client / invoice / purchase ids (typically empty — SB rarely auto-matches).
    incoming_html = _bt_template_html(form_soup, "incoming")
    payment_html = _bt_template_html(form_soup, "payment")
    return {
        "id": bt_id,
        "date": date_iso,
        "sum": round(signed_sum, 2),
        "direction": direction,
        "currency": "EUR",
        "party_name": party_name,
        "bank_iban": bank_iban,
        "transaction_note": transaction_note,
        "default_object_type": default_type,
        "available_object_types": available,
        "status": status,
        "errors": errors,
        "warnings": warnings,
        "income_financial_account_id": int(coa_id) if coa_id.isdigit() else None,
        "income_account_id": int(cashbook_id) if cashbook_id.isdigit() else None,
        "suggested_incoming_client_id": int(_bt_extract_value(incoming_html, r"data\[Incoming\]\[client_id\]") or 0) or None,
        "suggested_incoming_invoice_id": int(_bt_extract_value(incoming_html, r"data\[Incoming\]\[invoice_id\]") or 0) or None,
        "suggested_payment_client_id": int(_bt_extract_value(payment_html, r"data\[Payment\]\[client_id\]") or 0) or None,
        "suggested_payment_purchase_id": int(_bt_extract_value(payment_html, r"data\[Payment\]\[purchase_id\]") or 0) or None,
    }


def _bt_fetch_process_page(http: httpx.Client, account: str, *, limit: int = 200,
                            direction: str = "", status: str = "",
                            date_from: str = "", date_to: str = "") -> BeautifulSoup:
    """GET /bank_transactions/process with filters. Returns parsed soup."""
    params: list[tuple[str, str]] = [("limit", str(limit))]
    if direction:
        params.append(("filters[direction]", direction))
    if status:
        params.append(("filters[status]", status))
    if date_from:
        params.append(("filters[date_from]", date_from))
    if date_to:
        params.append(("filters[date_to]", date_to))
    qs = urlencode(params)
    r = http.get(f"{BASE}/{account}/{BT_BASE_PATH}?{qs}")
    if _session_stale(r):
        auto_login_attempt(interactive=False)
        creds = load_credentials()
        http.cookies = httpx.Cookies(parse_cookie_string(creds["SIMPLBOOKS_COOKIE"]))
        r = http.get(f"{BASE}/{account}/{BT_BASE_PATH}?{qs}")
    if r.status_code != 200:
        raise click.ClickException(f"GET /bank_transactions/process returned {r.status_code}")
    return BeautifulSoup(r.text, "html.parser")


def _bt_fetch_csrf(soup: BeautifulSoup) -> str:
    inp = soup.find("input", {"name": "_csrfToken"})
    if not inp or not inp.get("value"):
        raise click.ClickException("No _csrfToken on /bank_transactions/process — page layout changed?")
    return inp["value"]


def _bt_load_one(bt_id: int) -> tuple[dict, str, dict[str, str], str]:
    """Fetch the BT row by id. Returns (row_dict, csrf, cookies, account)."""
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        soup = _bt_fetch_process_page(http, account, limit=500)
    csrf = _bt_fetch_csrf(soup)
    forms = soup.find_all("form", class_="transaction-form")
    for f in forms:
        if str(f.get("data-id")) == str(bt_id):
            return _bt_parse_form(f), csrf, cookies, account
    raise click.ClickException(
        f"Bank transaction {bt_id} not in the worklist. Either it's already saved/deleted, "
        f"or use `simplbooks bank-transactions list` to see what's pending."
    )


@cli.group("bank-transactions")
def bank_transactions() -> None:
    """PSD2 worklist primitives: list / show / delete / save the rows in /bank_transactions/process.

    The worklist is the SB-side staging area for raw bank rows imported via PSD2.
    Each row gets evaluated one at a time (counterparty, amount, period, description),
    then turned into a SimpleBooks incoming / payment / kanne — or deleted if it's
    a duplicate (e.g. a payment-processor payout already mirrored as a kanne).

    See the consuming project's simplbooks reference for the decision tree.
    """


@bank_transactions.command("list")
@click.option("--direction", type=click.Choice(["in", "out"]), default=None,
              help="Filter to inflows or outflows only.")
@click.option("--status", type=click.Choice(["valid", "invalid", "warning", "duplicate"]),
              default=None, help="Filter by SB's auto-validation status.")
@click.option("--from", "date_from", default="", help="Start date YYYY-MM-DD (inclusive).")
@click.option("--to", "date_to", default="", help="End date YYYY-MM-DD (inclusive).")
@click.option("--limit", default=500, show_default=True, type=int,
              help="Server-side row cap. The worklist usually has <100 rows.")
@click.option("--json", "as_json", is_flag=True, help="Emit JSON instead of a table.")
def bt_list(direction, status, date_from, date_to, limit, as_json) -> None:
    """List rows in the PSD2 worklist.

    Each row is a not-yet-processed bank transaction. SB has typically not
    auto-matched a SB client_id for these — the agent does that work via
    `clients` / `expenses list` / `invoices list` and then `save`.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        soup = _bt_fetch_process_page(
            http, account, limit=limit,
            direction=direction or "", status=status or "",
            date_from=date_from, date_to=date_to,
        )
    rows = [_bt_parse_form(f) for f in soup.find_all("form", class_="transaction-form")]
    if as_json:
        click.echo(json.dumps(rows, ensure_ascii=False, indent=2))
        return

    click.secho(f"{len(rows)} row(s) in worklist", fg="cyan")
    click.echo()
    click.secho(
        f"{'ID':>5}  {'DATE':<11}  {'DIR':<3}  {'SUM':>11}  {'STATUS':<9}  "
        f"{'TYPE':<10}  {'PARTY':<26}  NOTE",
        bold=True,
    )
    for r in rows:
        sign = "+" if r["sum"] >= 0 else "-"
        sum_disp = f"{sign}{abs(r['sum']):,.2f}".replace(",", " ")
        click.echo(
            f"{r['id']:>5}  "
            f"{r['date']:<11}  "
            f"{r['direction']:<3}  "
            f"{sum_disp:>11}  "
            f"{r['status']:<9}  "
            f"{r['default_object_type']:<10}  "
            f"{(r['party_name'] or '?')[:26]:<26}  "
            f"{(r['transaction_note'] or '')[:60]}"
        )


@bank_transactions.command("show")
@click.argument("bt_id", type=int)
@click.option("--json", "as_json", is_flag=True)
def bt_show(bt_id, as_json) -> None:
    """Show one worklist row in detail (all fields + errors + warnings)."""
    row, _, _, _ = _bt_load_one(bt_id)
    if as_json:
        click.echo(json.dumps(row, ensure_ascii=False, indent=2))
        return

    sign = "+" if row["sum"] >= 0 else "-"
    sum_disp = f"{sign}{abs(row['sum']):,.2f}".replace(",", " ")
    click.secho(f"Bank transaction {row['id']}", bold=True)
    click.echo(f"  Date              : {row['date']}")
    click.echo(f"  Sum               : {sum_disp} {row['currency']}  ({row['direction']})")
    click.echo(f"  Bank account IBAN : {row['bank_iban'] or '?'}")
    click.echo(f"  Party             : {row['party_name'] or '?'}")
    click.echo(f"  Note (from bank)  : {row['transaction_note'] or ''}")
    click.echo(f"  Status            : {row['status']}")
    click.echo(f"  Default save mode : {row['default_object_type']} "
               f"(available: {', '.join(row['available_object_types'])})")
    click.echo(f"  COA bank-side id  : {row['income_financial_account_id']}  "
               f"(cashbook id: {row['income_account_id']})")
    if any([row['suggested_incoming_client_id'], row['suggested_incoming_invoice_id'],
            row['suggested_payment_client_id'], row['suggested_payment_purchase_id']]):
        click.echo("  Pre-selected by SB:")
        if row['suggested_incoming_client_id']:
            click.echo(f"    incoming.client_id  : {row['suggested_incoming_client_id']}")
        if row['suggested_incoming_invoice_id']:
            click.echo(f"    incoming.invoice_id : {row['suggested_incoming_invoice_id']}")
        if row['suggested_payment_client_id']:
            click.echo(f"    payment.client_id   : {row['suggested_payment_client_id']}")
        if row['suggested_payment_purchase_id']:
            click.echo(f"    payment.purchase_id : {row['suggested_payment_purchase_id']}")
    if row['errors']:
        click.secho("  Errors:", fg="red")
        for k, v in row['errors'].items():
            click.echo(f"    {k}: {v}")
    if row['warnings']:
        click.secho("  Warnings:", fg="yellow")
        for k, v in row['warnings'].items():
            click.echo(f"    {k}: {v}")


@bank_transactions.command("delete")
@click.argument("bt_id", type=int)
def bt_delete(bt_id) -> None:
    """Delete a bank-transaction row without saving it.

    Use when the row is a duplicate (e.g. a payment-processor payout already
    mirrored as a kanne) or a mis-imported entry that should be discarded.

    NOTE: this only removes the worklist entry; it does NOT touch any
    already-booked incoming / payment / kanne the row may correspond to.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        soup = _bt_fetch_process_page(http, account, limit=500)
        csrf = _bt_fetch_csrf(soup)
        http.headers["Referer"] = f"{BASE}/{account}/{BT_BASE_PATH}"
        http.headers["Origin"] = BASE
        body = urlencode([("id", str(bt_id)), ("_csrfToken", csrf)])
        r = http.post(
            f"{BASE}/{account}/bank_transactions/delete",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
    if r.status_code not in (200, 302):
        fail = CONFIG_DIR / "last_bank_transactions_delete_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"Delete failed: HTTP {r.status_code}. Response → {fail}"
        )
    click.secho(f"✓ Deleted bank transaction {bt_id}", fg="green")


def _bt_money_save_fields(
    *,
    direction: str,                # "Incoming" or "Payment"
    bt_id: int,
    csrf: str,
    client: dict,
    bind_ids: list[int],
    income_account_id: int,
    sum_amount: str,
    date: datetime,
    description: str,
    object_type: str = "Purchase",  # only used for Payment
) -> list[tuple[str, str]]:
    is_payment = direction == "Payment"
    sum_key = "payment_sum" if is_payment else "income_sum"
    date_key = "payment_date" if is_payment else "income_date"
    bind_key = "purchase_id" if is_payment else "invoice_id"

    fields: list[tuple[str, str]] = [
        ("data[BankTransaction][id]", str(bt_id)),
        ("data[BankTransaction][object_type]", "payment" if is_payment else "incoming"),
        (f"data[{direction}][base_currency_id]", "2"),
        (f"data[{direction}][currency_name]", "EUR"),
        (f"data[{direction}][currency_rate]", "1"),
        (f"data[{direction}][{sum_key}]", to_estonian_number(sum_amount)),
        (f"data[{direction}][{date_key}]", date.strftime("%d.%m.%Y")),
        (f"data[{direction}][client_id]", str(client["id"])),
        (f"data[{direction}][{bind_key}]", ",".join(str(b) for b in bind_ids)),
        (f"data[{direction}][income_account_id]", str(income_account_id)),
        (f"data[{direction}][description]", description),
    ]
    if is_payment:
        fields.append(("data[Payment][object_type]", object_type))
        fields.append(("data[Payment][expense_report_id]", ""))
    fields.append(("_csrfToken", csrf))
    return fields


def _bt_post_save(cookies: dict, account: str, fields: list[tuple[str, str]]) -> httpx.Response:
    with build_http(cookies, account) as http:
        http.headers["Referer"] = f"{BASE}/{account}/{BT_BASE_PATH}"
        http.headers["Origin"] = BASE
        body = urlencode(fields)
        return http.post(
            f"{BASE}/{account}/bank_transactions/save",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )


def _bt_check_save_response(r: httpx.Response, kind: str) -> None:
    if r.status_code not in (200, 302):
        fail = CONFIG_DIR / f"last_bank_transactions_save_{kind}_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"bank_transactions/save ({kind}) failed: HTTP {r.status_code}. Response → {fail}"
        )
    # 200 responses on save can still contain a JSON error body — sniff it.
    txt = r.text.strip()
    if txt.startswith("{"):
        try:
            payload = json.loads(txt)
        except json.JSONDecodeError:
            return
        if payload.get("status") == "error" or payload.get("errors"):
            raise click.ClickException(
                f"bank_transactions/save ({kind}) rejected: {json.dumps(payload, ensure_ascii=False)}"
            )


def _bt_recover_money_id(
    r: httpx.Response, direction: str, *,
    bt_id: int, sum_amount: str, date_str: str, description: str,
) -> int:
    """Recover the id of the money object that /bank_transactions/save just made.

    PRIMARY: parse the 302 Location header — same pattern as _create_money.
    FALLBACK: bounded /listdata lookup, matched on amount + date + description.
    If exactly one row matches, trust it; otherwise refuse to guess and surface
    the manual bind command instead. We never bind to an ambiguous id.
    """
    endpoint = "payments" if direction == "Payment" else "incomings"
    loc = r.headers.get("location", "")
    m = re.search(rf"/{endpoint}/view/(\d+)", loc)
    if m:
        return int(m.group(1))

    try:
        rows = _list_money(endpoint, search=description or "", limit=100)
    except click.ClickException:
        rows = []
    want_date = datetime.strptime(date_str, "%Y-%m-%d").strftime("%d.%m.%Y")
    try:
        want_sum = _amount_float(sum_amount)
    except (ValueError, click.ClickException):
        want_sum = None

    def _matches(row: dict) -> bool:
        if strip_html(row.get("date") or "")[:10] != want_date:
            return False
        try:
            s = _amount_float(row.get("sum") or "")
        except (ValueError, click.ClickException):
            return False
        if want_sum is None or abs(s - want_sum) > 0.005:
            return False
        if description and description not in strip_html(row.get("description") or ""):
            return False
        return True

    cands = [row for row in rows if _matches(row)]
    if len(cands) == 1:
        return int(cands[0]["id"])

    flag = "--to-purchase" if direction == "Payment" else "--to-invoice"
    detail = "no list match" if not cands else f"{len(cands)} ambiguous matches"
    raise click.ClickException(
        f"BT {bt_id} saved as {endpoint[:-1]} (unbound), but the created id "
        f"could not be safely recovered ({detail}). Find it by hand and bind: "
        f"simplbooks {endpoint} bind <{endpoint[:-1]}-id> {flag} <id>"
    )


@bank_transactions.command("save")
@click.argument("bt_id", type=int)
@click.option("--as", "save_as", required=True,
              type=click.Choice(["incoming", "payment", "kanne"]),
              help="Variant to save the row as.")
@click.option("--client-id", type=int, default=None,
              help="SB client id (required for incoming/payment).")
@click.option("--invoice-id", "invoice_ids", type=int, multiple=True,
              help="Sales invoice id to bind (repeatable; for --as incoming).")
@click.option("--purchase-id", "purchase_ids", type=int, multiple=True,
              help="Purchase invoice id to bind (repeatable; for --as payment).")
@click.option("--counter-account", type=int, default=None,
              help="COA id of the offsetting account (for --as kanne).")
@click.option("--account-id", type=int, default=None,
              help="Bank cashbook id for incoming/payment (default: the one SB pre-selected, "
                   "usually the main bank cashbook).")
@click.option("--sum", "sum_amount", default=None,
              help="Override amount. Defaults to the BT row's own sum.")
@click.option("--date", "date_str", default=None,
              help="Override date YYYY-MM-DD. Defaults to the BT row's own date.")
@click.option("--description", default=None,
              help="Override description. Defaults to a sensible string: "
                   "bank transaction_note for incoming/payment, '<party> · <note>' for kanne.")
@click.option("--payment-object-type", type=click.Choice(["Purchase", "ExpenseReport"]),
              default="Purchase", show_default=True,
              help="Only for --as payment: what the bound id refers to.")
def bt_save(bt_id, save_as, client_id, invoice_ids, purchase_ids, counter_account,
             account_id, sum_amount, date_str, description, payment_object_type) -> None:
    """Save a worklist row as an incoming, payment, or kanne.

    Examples:

      # 1. Customer paid sales invoice 9876
      simplbooks bank-transactions save 7090 --as incoming \\
        --client-id 257 --invoice-id 9876

      # 2. Supplier paid via bank transfer, multiple purchase invoices in one transfer
      simplbooks bank-transactions save 6750 --as payment \\
        --client-id 368 --purchase-id 1685 --purchase-id 1686

      # 3. Owner loan repayment (no invoice; offset to owner-loan account)
      simplbooks bank-transactions save 7062 --as kanne \\
        --counter-account <coa-id> --description 'Omanikule laenu tagastamine'
    """
    row, csrf, cookies, account = _bt_load_one(bt_id)

    # Sum / date defaults from the BT row itself.
    effective_sum = sum_amount if sum_amount is not None else f"{abs(row['sum']):.2f}"
    effective_date = date_str or row['date']
    dt = datetime.strptime(effective_date, "%Y-%m-%d")

    if save_as in ("incoming", "payment"):
        if not client_id:
            raise click.ClickException("--client-id is required for --as incoming|payment.")
        cache = load_clients_cache()
        if str(client_id) not in cache:
            raise click.ClickException(
                f"Client {client_id} not in cache. Run `simplbooks clients list` first."
            )
        client = cache[str(client_id)]
        cashbook_id = account_id if account_id is not None else row['income_account_id']
        if not cashbook_id:
            raise click.ClickException(
                "SB pre-selected no cashbook for this worklist row; pass --account-id "
                "(see `accounts list cashbook`)."
            )
        bind_ids = list(invoice_ids if save_as == "incoming" else purchase_ids)
        if save_as == "incoming" and purchase_ids:
            raise click.ClickException("--purchase-id is only valid with --as payment.")
        if save_as == "payment" and invoice_ids:
            raise click.ClickException("--invoice-id is only valid with --as incoming.")
        desc = description if description is not None else (row['transaction_note'] or "")

        direction = "Incoming" if save_as == "incoming" else "Payment"
        # Save CLEAN: never embed bind ids in /bank_transactions/save. SB
        # accepts the form with a purchase_id/invoice_id and silently no-ops
        # or partial-applies the binding, so save can report 200 while the
        # money document still carries an unallocated remainder. The verified
        # binding path is _do_bind — it posts to do_binding and reads the
        # 'Katte summa' column back per target.
        fields = _bt_money_save_fields(
            direction=direction, bt_id=bt_id, csrf=csrf,
            client=client, bind_ids=[],
            income_account_id=cashbook_id,
            sum_amount=effective_sum, date=dt, description=desc,
            object_type=payment_object_type,
        )
        r = _bt_post_save(cookies, account, fields)
        _bt_check_save_response(r, save_as)
        money_id = _bt_recover_money_id(
            r, direction, bt_id=bt_id,
            sum_amount=effective_sum, date_str=effective_date, description=desc,
        )
        endpoint = "payments" if direction == "Payment" else "incomings"
        click.secho(f"✓ Saved BT {bt_id} as {save_as} ({endpoint[:-1]} {money_id})",
                    fg="green", bold=True)
        click.echo(f"  Client    : {client_id}  ({strip_html(client.get('name', ''))})")
        click.echo(f"  Sum       : {effective_sum} EUR  on {effective_date}")
        click.echo(f"  Bank acct : cashbook {cashbook_id}")
        if not bind_ids:
            return
        try:
            bound = _do_bind(direction, money_id, bind_ids)
        except click.ClickException as e:
            flag = "--to-purchase" if direction == "Payment" else "--to-invoice"
            args = " ".join(f"{flag} {b}" for b in bind_ids)
            raise click.ClickException(
                f"{e.message} BT {bt_id} was saved as {endpoint[:-1]} "
                f"{money_id} (unbound). Retry the bind by hand: "
                f"simplbooks {endpoint} bind {money_id} {args}"
            )
        label = "invoices" if save_as == "incoming" else "purchases"
        click.secho(f"✓ Bound {endpoint[:-1]} {money_id} → {label} {bind_ids}",
                    fg="green")
        for tid, katte in bound.items():
            click.echo(f"  {label[:-1]} {tid}: allocated {katte or '?'}")
        return

    # save_as == "kanne"
    if counter_account is None:
        raise click.ClickException(
            "--counter-account is required for --as kanne. "
            "It is the chart-of-accounts id of the offsetting side "
            "(e.g. owner-loan liability, internal-transfer counter-bank). "
            "Use `simplbooks accounts list chart` to find it."
        )
    bank_coa = row['income_financial_account_id']
    if not bank_coa:
        raise click.ClickException(
            f"Cannot determine bank-side COA id for BT {bt_id}. "
            "The /bank_transactions/process form did not expose income_financial_account_id."
        )
    note = description if description is not None else (
        f"{row['party_name']} · {row['transaction_note']}".strip(" ·")
        if row['party_name'] or row['transaction_note'] else ""
    )
    sum_est = to_estonian_number(effective_sum)
    # Direction: inflow → bank-side debit; outflow → bank-side credit.
    bank_side = "debit" if row['sum'] >= 0 else "credit"
    counter_side = "credit" if bank_side == "debit" else "debit"
    sum_signed = effective_sum if row['sum'] >= 0 else f"-{effective_sum}"

    bank_key = _random_row_key()
    counter_key = _random_row_key()
    fields: list[tuple[str, str]] = [
        ("data[BankTransaction][id]", str(bt_id)),
        ("data[BankTransaction][object_type]", "financial_transaction"),
        ("data[FinancialTransaction][base_currency_id]", "2"),
        ("data[FinancialTransaction][currency_name]", "EUR"),
        ("data[FinancialTransaction][currency_rate]", "1"),
        ("data[FinancialTransaction][income_financial_account_id]", str(bank_coa)),
        ("data[FinancialTransaction][transaction_sum]", to_estonian_number(sum_signed)),
        ("data[FinancialTransaction][transaction_date]", dt.strftime("%d.%m.%Y")),
        ("data[FinancialTransaction][transaction_note]", note),
        ("data[FinancialTransaction][predefined_transaction_group_id]", ""),
        ("data[FinancialTransaction][vat_calculation_method]", ""),
        ("data[FinancialTransaction][root_document_name]", ""),
        ("data[FinancialTransaction][root_document_content]", ""),
        ("data[FinancialTransaction][imported_document_id]", ""),
    ]
    # Bank side row.
    fields += [
        (f"data[FinancialTransaction][transactions][{bank_key}][id]", "0"),
        (f"data[FinancialTransaction][transactions][{bank_key}][financial_account_side]", bank_side),
        (f"data[FinancialTransaction][transactions][{bank_key}][initial_sum]", effective_sum),
        (f"data[FinancialTransaction][transactions][{bank_key}][showing_order]", "0"),
        (f"data[FinancialTransaction][transactions][{bank_key}][bank_row]", "1"),
        (f"data[FinancialTransaction][transactions][{bank_key}][financial_account_id]", str(bank_coa)),
        (f"data[FinancialTransaction][transactions][{bank_key}][vat_percent]", "0"),
        (f"data[FinancialTransaction][transactions][{bank_key}][transaction_sum_debit]",
         sum_est if bank_side == "debit" else "0,00"),
        (f"data[FinancialTransaction][transactions][{bank_key}][transaction_sum_credit]",
         sum_est if bank_side == "credit" else "0,00"),
    ]
    # Counter side row.
    fields += [
        (f"data[FinancialTransaction][transactions][{counter_key}][id]", "0"),
        (f"data[FinancialTransaction][transactions][{counter_key}][financial_account_side]", counter_side),
        (f"data[FinancialTransaction][transactions][{counter_key}][initial_sum]", effective_sum),
        (f"data[FinancialTransaction][transactions][{counter_key}][showing_order]", "1"),
        (f"data[FinancialTransaction][transactions][{counter_key}][bank_row]", ""),
        (f"data[FinancialTransaction][transactions][{counter_key}][financial_account_id]", str(counter_account)),
        (f"data[FinancialTransaction][transactions][{counter_key}][vat_percent]", "0"),
        (f"data[FinancialTransaction][transactions][{counter_key}][transaction_sum_debit]",
         sum_est if counter_side == "debit" else "0,00"),
        (f"data[FinancialTransaction][transactions][{counter_key}][transaction_sum_credit]",
         sum_est if counter_side == "credit" else "0,00"),
    ]
    fields.append(("_csrfToken", csrf))

    r = _bt_post_save(cookies, account, fields)
    _bt_check_save_response(r, "kanne")
    click.secho(f"✓ Saved BT {bt_id} as kanne", fg="green", bold=True)
    click.echo(f"  Date       : {effective_date}")
    click.echo(f"  Note       : {note}")
    click.echo(f"  Bank side  : COA {bank_coa} ({bank_side})  {effective_sum} EUR")
    click.echo(f"  Counter    : COA {counter_account} ({counter_side})  {effective_sum} EUR")


def main() -> None:
    global _CONN
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through

    # `--connection`/`-c <id>` is a global selector accepted anywhere on the
    # line (extracted before click so it works after the subcommand, like every
    # other capability's connection flag). It selects the registry entry; the
    # minted SIMPLBOOKS_ACCOUNT hash is a distinct concept resolved from the
    # session/cascade, not by this flag.
    argv = sys.argv[1:]
    connection_flag: str | None = None
    cleaned: list[str] = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("--connection", "-c") and i + 1 < len(argv):
            connection_flag = argv[i + 1]; i += 2; continue
        if a.startswith("--connection="):
            connection_flag = a.split("=", 1)[1]; i += 1; continue
        if a.startswith("-c="):
            connection_flag = a.split("=", 1)[1]; i += 1; continue
        cleaned.append(a); i += 1
    sys.argv = [sys.argv[0], *cleaned]

    _CONN = _resolve_connection(connection_flag)
    cli()


if __name__ == "__main__":
    main()
