@invoices.command("list")
@click.option("--limit", default=20, show_default=True, type=int)
@click.option("--search", default="", help="Filter by number / client / status")
def invoices_list(limit: int, search: str) -> None:
    """List recent invoices."""
    cookies, account = session_or_die()
    cols = [
        ("", "_select"),
        ("client_name", "client_name"),
        ("status", "status"),
        ("number", "number"),
        ("sum_and_vat", "sum_and_vat"),
        ("currency_name", "currency_name"),
        ("created", "created"),
        ("due", "due"),
        ("reference", "reference"),
        ("id", "_id"),
        ("", "_actions"),
    ]
    data = datatables_payload(cols, order_col=9, length=limit, search=search)
    with build_http(cookies, account, ajax=True) as http:
        http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
        r = http.post(f"{BASE}/{account}/invoices/listdata", data=data)
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
        payload = r.json()
    rows = payload.get("data", [])
    click.secho(f"{payload.get('recordsTotal', len(rows))} total · {len(rows)} returned", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'NUMBER':<10}  {'CREATED':<12}  {'CLIENT':<40}  {'SUM':>14}  STATUS", bold=True)
    for row in rows:
        click.echo(
            f"{str(row.get('id','?')):>5}  "
            f"{strip_html(row.get('number'))[:10]:<10}  "
            f"{strip_html(row.get('created'))[:12]:<12}  "
            f"{strip_html(row.get('client_name'))[:40]:<40}  "
            f"{strip_html(row.get('sum_and_vat'))[:14]:>14}  "
            f"{strip_html(row.get('status'))[:30]}"
        )


@invoices.command("show")
@click.argument("invoice_id", type=int)
@click.option("--json", "as_json", is_flag=True, help="Emit JSON instead of a table.")
def invoices_show(invoice_id: int, as_json: bool) -> None:
    """Fetch a single invoice's line items + client metadata.

    Reads via the /invoices/add/<id> copy form (deterministic input names),
    so prices and descriptions come from the original invoice."""
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        r = http.get(f"{BASE}/{account}/invoices/add/{invoice_id}")
        if r.status_code in (301, 302):
            raise click.ClickException(
                f"Invoice {invoice_id} not accessible (redirect → {r.headers.get('location','')}). "
                "Likely deleted."
            )
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}")
        soup = BeautifulSoup(r.text, "html.parser")

    def field(name: str) -> str:
        inp = soup.find("input", {"name": name})
        if inp:
            return inp.get("value", "") or ""
        sel = soup.find("select", {"name": name})
        if sel:
            opt = sel.find("option", attrs={"selected": True}) or sel.find("option", attrs={"selected": "selected"})
            return (opt.get("value", "") or "") if opt else ""
        ta = soup.find("textarea", {"name": name})
        if ta:
            return ta.text or ""
        return ""

    info = {
        "client_id": field("data[Invoice][client_id]"),
        "client_name": field("data[Invoice][client_name]"),
        "client_country": field("data[Invoice][client_address_country]"),
        "client_vat_no": field("data[Invoice][client_vat_no]"),
        "client_reg_no": field("data[Invoice][client_reg_no]"),
    }

    indices: set[int] = set()
    for inp in soup.find_all("input", attrs={"name": re.compile(r"^Task\[[^\]]+\]\[name\]$")}):
        m = re.match(r"^Task\[([^\]]+)\]", inp.get("name", ""))
        if m:
            indices.add(m.group(1))

    line_items = []
    for idx in sorted(indices, key=lambda x: (len(str(x)), str(x))):
        item = {
            "description": field(f"Task[{idx}][name]"),
            "price_per_unit": field(f"Task[{idx}][price_per_unit]"),
            "amount": field(f"Task[{idx}][amount]"),
            "unit": field(f"Task[{idx}][unit]"),
            "vat_rate": field(f"Task[{idx}][vat]"),
            "vat_type_id": field(f"Task[{idx}][vat_type_id]"),
            "income_account_id": field(f"Task[{idx}][income_account_id]"),
        }
        if item["description"] or (item["price_per_unit"] and item["price_per_unit"] != "0,00"):
            line_items.append(item)

    if as_json:
        click.echo(json.dumps({**info, "line_items": line_items}, indent=2, ensure_ascii=False))
        return

    click.echo(f"Client : {info['client_name']} [{info['client_id']}] ({info['client_country']})")
    click.echo(f"VAT no : {info['client_vat_no']}   Reg no : {info['client_reg_no']}")
    click.echo()
    click.secho(f"  {'DESCRIPTION':<50}  {'PRICE':>10}  {'AMT':>4}  {'VAT%':>4}  {'VTYP':>4}  {'ACCT':>4}", bold=True)
    for li in line_items:
        click.echo(
            f"  {li['description'][:50]:<50}  "
            f"{li['price_per_unit']:>10}  {li['amount']:>4}  "
            f"{li['vat_rate']:>4}  {li['vat_type_id']:>4}  {li['income_account_id']:>4}"
        )


@invoices.command("meta")
@click.option("--json", "as_json", is_flag=True, help="Emit raw JSON.")
@click.option("--refresh", is_flag=True, help="Re-scrape /invoices/add for the live vat_types map.")
def invoices_meta(as_json: bool, refresh: bool) -> None:
    """Show the account's live SALES vat types (id → rate, income account, name).

    Scraped from the /invoices/add `vat_types` map and cached to sales_meta.json.
    This is the source `invoices create` resolves the income account + VAT rate
    from — so the books-side mapping always comes from SimpleBooks, not a constant.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        vt = sales_vat_types(http, account, refresh=refresh)
    if not vt:
        raise click.ClickException(
            "Could not read the vat_types map from /invoices/add — page layout changed?"
        )
    if as_json:
        click.echo(json.dumps(vt, ensure_ascii=False, indent=2))
        return
    click.secho(f"Sales VAT types ({len(vt)}):", bold=True)
    click.echo(f"  {'ID':>4}  {'RATE':>5}  {'INCOME':>6}  NAME")
    for vid in sorted(vt, key=lambda k: int(k)):
        v = vt[vid]
        pct = v.get("vat_percent")
        pct = "—" if pct is None else f"{pct}%"
        click.echo(f"  {vid:>4}  {pct:>5}  {str(v.get('income_account_id','') or ''):>6}  {v.get('name','')}")


def build_invoice_fields(*, csrf, client_row, number, description, price,
                         tax_class, quantity, unit, due_days, worker, reference,
                         vat_types, creator, invoice_date=None, vat_type=None,
                         income_account=None, bank_account=None) -> list[tuple[str, str]]:
    tc = TAX_CLASSES[tax_class]
    vt_id, inc_acct, vat_rate = _resolve_tax(tax_class, vat_types, vat_type, income_account)
    bank_acct = _bank_account(bank_account)
    now = datetime.now()
    inv = invoice_date or now
    today_dot = inv.strftime("%d.%m.%Y")
    today_dash = now.strftime("%Y-%m-%d %H:%M:%S")  # audit timestamp, always "now"
    due_dot = (inv + timedelta(days=due_days)).strftime("%d.%m.%Y")
    price_et = to_estonian_number(price)
    cid = str(client_row["id"])
    footer_line = _cfg("SIMPLBOOKS_INVOICE_FOOTER") or DEFAULT_FOOTER
    footer = (tc["footer_prefix"] or "") + (reference or "") + ("\n\n" if reference else "") + footer_line

    fields: list[tuple[str, str]] = [
        ("_csrfToken", csrf), ("id", ""), ("draft_id", "0"), ("sales_order_id", "0"),
        ("price_offer_id", "0"), ("base_currency_id", "2"), ("base_currency_code", "EUR"),
        ("paid", "0000-00-00"), ("sent", "0000-00-00"), ("credit_invoice_for", "0"),
        ("proforma", "0"), ("proforma_percent", "0"), ("proforma_invoice_id", "0"),
        ("not_subject_to_vat", "0"), ("creator", str(creator or "")), ("created_time", today_dash),
        ("cash_accounting_method", "0"), ("row_based_vat", "0"),
        ("data[Invoice][client_data_needs_update]", "0"),
        ("data[Invoice][client_update_data]", "0"),
        ("data[Invoice][client_id]", cid),
        ("data[Invoice][client_name]", str(client_row.get("name", ""))),
        ("data[Invoice][client_location_id]", ""), ("data[Invoice][contact_reference]", ""),
        ("number", number), ("created", today_dot), ("transaction_date", today_dot),
        ("due", due_dot), ("currency_name", "EUR"), ("data[Invoice][currency_rate]", "1.0000"),
        ("overdue_charge_period", "day"), ("overdue_charge_percent", "0,50"),
        ("language", str(tc["language"])), ("document_template_id", "4"),
        ("default_bank_account", bank_acct),
        ("Task[0][id]", ""), ("Task[0][invoice_id]", ""), ("Task[0][client_id]", cid),
        ("Task[0][warehouse_id]", "0"), ("Task[0][is_inventory]", "0"),
        ("Task[0][vat]", vat_rate), ("Task[0][article_id]", "0"),
        ("Task[0][code]", ""), ("Task[0][article]", ""),
        ("Task[0][name]", description), ("Task[0][vat_type_id]", vt_id),
        ("Task[0][amount]", quantity), ("Task[0][unit]", unit), ("Task[0][discount]", "0"),
        ("Task[0][price_per_unit]", price_et),
        ("Task[0][Asset][id]", ""), ("Task[0][Asset][name]", ""), ("Task[0][contents]", ""),
        ("Task[0][income_account_id]", inc_acct),
        ("Task[0][worker]", worker), ("Task[0][date_of_doing]", today_dot),
    ]
    if tc["row_sum_with_vat"]:
        fields.append(("row_sum_with_vat", str(tc["row_sum_with_vat"])))
    fields += [
        ("rounding", "0,00"), ("additional_info", footer),
        ("data[Invoice][client_reg_no]", strip_html(client_row.get("reg_no"))),
        ("data[Invoice][client_vat_no]", strip_html(client_row.get("vat_no"))),
        ("data[Invoice][client_email]", strip_html(client_row.get("email"))),
        ("data[Invoice][client_account_no]", ""), ("data[Invoice][client_swift_code]", ""),
        ("data[Invoice][client_bank]", ""),
        ("data[Invoice][client_address_street]", strip_html(client_row.get("address_street"))),
        ("data[Invoice][client_address_city]", strip_html(client_row.get("address_city"))),
        ("data[Invoice][client_address_county]", strip_html(client_row.get("address_county"))),
        ("data[Invoice][client_address_country]", strip_html(client_row.get("address_country"))),
        ("data[Invoice][client_address_postal_code]", strip_html(client_row.get("address_postal_code"))),
    ]
    return fields


def _harvest_form_fields(soup: BeautifulSoup, html_text: str) -> list[tuple[str, str]]:
    """Harvest every named input/textarea/select from a SB edit form.

    SB renders empty `<select>` elements that get populated by inline
    `new SB.Select('#DOMID', { items: ['VALUE'] })` JS; we extract those JS
    initialisers and apply them by DOM id so the round-tripped POST doesn't
    wipe values like vat_type_id, account_id, etc.
    """
    # Pre-extract SB.Select items[] arrays by DOM id.
    sb_select_items: dict[str, str] = {}
    for m in re.finditer(
        r"new\s+SB\.Select\(['\"]#(\w+)['\"]\s*,\s*\{.*?items:\s*\[([^\]]*)\]",
        html_text, re.DOTALL,
    ):
        dom_id = m.group(1)
        items_raw = m.group(2).strip()
        first = re.search(r"['\"]?([\w-]+)['\"]?", items_raw)
        sb_select_items[dom_id] = first.group(1) if first else ""

    out: list[tuple[str, str]] = []
    form = soup.find("form", {"id": "invoice-form"}) or soup
    for el in form.find_all(["input", "textarea", "select"]):
        name = el.get("name")
        if not name:
            continue
        tag = el.name
        if tag == "input":
            itype = (el.get("type") or "text").lower()
            if itype in ("submit", "button", "reset", "file"):
                continue
            if itype in ("checkbox", "radio"):
                if el.get("checked") is not None:
                    out.append((name, el.get("value", "1") or "1"))
                continue
            out.append((name, el.get("value", "") or ""))
        elif tag == "textarea":
            out.append((name, (el.string or el.text or "") or ""))
        elif tag == "select":
            opt = el.find("option", attrs={"selected": True})
            if opt:
                out.append((name, opt.get("value", "") or ""))
            else:
                dom_id = el.get("id")
                if dom_id and dom_id in sb_select_items:
                    out.append((name, sb_select_items[dom_id]))
                else:
                    out.append((name, ""))
    return out


@invoices.command("update")
@click.argument("invoice_id", type=int)
@click.option("--reference", "additional_info", default=None,
              help="Set the invoice's 'Lisainfo' (additional_info) field. Overwrites.")
@click.option("--append-reference", default=None,
              help="Append to the existing additional_info (separator ' · ').")
@click.option("--number", "new_number", default=None, help="Change invoice number.")
@click.option("--date", "new_date", default=None, help="Change invoice date (YYYY-MM-DD).")
@click.option("--due", "new_due", default=None, help="Change due date (YYYY-MM-DD).")
@click.option("--client-id", "new_client_id", type=int, default=None,
              help="Change the customer. Pulls full client data from the local cache.")
@click.option("--set", "set_pairs", multiple=True,
              help="Generic field override: --set 'name=value'. Repeatable. Use exact form field name "
                   "(e.g. 'data[Invoice][client_vat_no]=EE123', 'Task[0][price_per_unit]=2,42', "
                   "'overdue_charge_percent=0,30').")
@click.option("--force-unbind/--no-force-unbind", default=False, show_default=True,
              help="If the invoice has bound payments/incomings (which lock editing), "
                   "unbind them, perform the edit, then re-bind. Use with caution.")
@click.option("--add-line", "add_lines", multiple=True,
              help="Append a Task line. Format: 'name=X:price=Y:vat=R:vat_type=ID:account=ID[:amount=N:unit=tk]'. "
                   "Repeatable. For rounding: 'name=Ümardamine:price=-0,01:vat=0:vat_type=15:account=<income-account-id>'.")
def invoices_update(invoice_id, additional_info, append_reference, new_number,
                    new_date, new_due, new_client_id, set_pairs, force_unbind,
                    add_lines) -> None:
    """Update top-level fields on an existing invoice. Preserves line items.

    Supports common fields via dedicated flags + generic --set for anything else.
    `simplbooks invoices update 173 --reference '...'  --set 'overdue_charge_percent=0,30'`

    Paid invoices are locked for editing in SB. Pass --force-unbind to automatically
    unbind, edit, and re-bind the previously-bound entries around the update.
    """
    overrides: dict[str, str] = {}
    for kv in set_pairs:
        if "=" not in kv:
            raise click.ClickException(f"--set expects 'name=value', got {kv!r}")
        k, v = kv.split("=", 1)
        overrides[k.strip()] = v
    if new_number is not None:
        overrides["number"] = new_number
    if new_date is not None:
        dt = datetime.strptime(new_date, "%Y-%m-%d")
        overrides["created"] = dt.strftime("%d.%m.%Y")
        overrides["transaction_date"] = dt.strftime("%d.%m.%Y")
    if new_due is not None:
        overrides["due"] = datetime.strptime(new_due, "%Y-%m-%d").strftime("%d.%m.%Y")
    if new_client_id is not None:
        cache = load_clients_cache()
        if str(new_client_id) not in cache:
            raise click.ClickException(
                f"Client {new_client_id} not in cache. Run `simplbooks clients list --limit 500`."
            )
        c = cache[str(new_client_id)]
        overrides.update({
            "data[Invoice][client_id]": str(new_client_id),
            "data[Invoice][client_name]": str(c.get("name", "") or ""),
            "data[Invoice][client_reg_no]": strip_html(c.get("reg_no")),
            "data[Invoice][client_vat_no]": strip_html(c.get("vat_no")),
            "data[Invoice][client_email]": strip_html(c.get("email")),
            "data[Invoice][client_address_street]": strip_html(c.get("address_street")),
            "data[Invoice][client_address_city]": strip_html(c.get("address_city")),
            "data[Invoice][client_address_county]": strip_html(c.get("address_county")),
            "data[Invoice][client_address_country]": strip_html(c.get("address_country")),
            "data[Invoice][client_address_postal_code]": strip_html(c.get("address_postal_code")),
            "data[Invoice][client_data_needs_update]": "1",
        })

    # Parse --add-line entries into Task field-sets
    new_lines: list[dict] = []
    for raw in add_lines:
        parts: dict[str, str] = {}
        for kv in raw.split(":"):
            if "=" not in kv:
                continue
            k, v = kv.split("=", 1)
            parts[k.strip()] = v.strip()
        try:
            new_lines.append({
                "name": parts["name"],
                "price": parts["price"],
                "vat": parts.get("vat", "0"),
                "vat_type_id": parts["vat_type"],
                "account": parts["account"],
                "amount": parts.get("amount", "1"),
                "unit": parts.get("unit", "tk"),
            })
        except KeyError as e:
            raise click.ClickException(f"--add-line missing required key {e}: {raw!r}")

    if not (overrides or additional_info is not None or append_reference is not None or new_lines):
        raise click.ClickException("Pass at least one update flag.")

    cookies, account = session_or_die()

    # Snapshot bindings + unbind if invoice is locked (or if user forced it)
    saved_bindings: list[tuple[str, int]] = []
    needs_rebind = False
    if force_unbind:
        saved_bindings = _invoice_bindings(invoice_id)
        if saved_bindings:
            click.secho(
                f"  Unbinding {len(saved_bindings)} entries from invoice {invoice_id} first...",
                fg="yellow",
            )
            _invoice_remove_all_bindings(invoice_id)
            needs_rebind = True

    with build_http(cookies, account) as http:
        r = http.get(f"{BASE}/{account}/invoices/edit/{invoice_id}")
        if r.status_code in (301, 302):
            loc = r.headers.get("location", "")
            hint = ""
            if f"/invoices/view/{invoice_id}" in loc:
                hint = " — invoice may be locked because of bound payments; retry with --force-unbind."
            raise click.ClickException(
                f"GET /invoices/edit/{invoice_id} → HTTP {r.status_code} loc={loc!r}.{hint}"
            )
        if r.status_code != 200:
            raise click.ClickException(f"GET /invoices/edit/{invoice_id} → HTTP {r.status_code}")
        soup = BeautifulSoup(r.text, "html.parser")
        fields = _harvest_form_fields(soup, r.text)

        # Currency selects render empty (options populated by JS) — fall back to EUR
        # since base_currency_id=2 always means EUR in this account.
        fields = [
            (n, "EUR" if n in ("currency_name", "base_currency_code") and not v else v)
            for n, v in fields
        ]

        # additional_info is a bare-named textarea (not under data[Invoice][...])
        existing_info = next((v for n, v in fields if n == "additional_info"), "")
        if additional_info is not None:
            new_info = additional_info
        elif append_reference:
            sep = " · " if existing_info else ""
            new_info = (existing_info or "") + sep + append_reference
        else:
            new_info = existing_info

        names_in_form = {n for n, _ in fields}
        fields = [
            (n, new_info if n == "additional_info" else overrides.get(n, v))
            for n, v in fields
        ]
        for k, v in overrides.items():
            if k not in names_in_form:
                fields.append((k, v))

        # Append new Task lines (--add-line)
        client_id_val = next((v for n, v in fields if n == "data[Invoice][client_id]"), "")
        txn_date_val = next((v for n, v in fields if n == "transaction_date"), "")
        for ln in new_lines:
            key = _random_row_key()
            fields += [
                (f"Task[{key}][id]", ""),
                (f"Task[{key}][invoice_id]", str(invoice_id)),
                (f"Task[{key}][client_id]", client_id_val),
                (f"Task[{key}][warehouse_id]", "0"),
                (f"Task[{key}][is_inventory]", "0"),
                (f"Task[{key}][vat]", str(ln["vat"])),
                (f"Task[{key}][article_id]", "0"),
                (f"Task[{key}][code]", ""),
                (f"Task[{key}][article]", ""),
                (f"Task[{key}][name]", ln["name"]),
                (f"Task[{key}][vat_type_id]", str(ln["vat_type_id"])),
                (f"Task[{key}][amount]", str(ln["amount"])),
                (f"Task[{key}][unit]", str(ln["unit"])),
                (f"Task[{key}][discount]", "0"),
                (f"Task[{key}][price_per_unit]", to_estonian_number(ln["price"])),
                (f"Task[{key}][Asset][id]", ""),
                (f"Task[{key}][Asset][name]", ""),
                (f"Task[{key}][contents]", ""),
                (f"Task[{key}][income_account_id]", str(ln["account"])),
                (f"Task[{key}][worker]", _worker_name(page_html=r.text)),
                (f"Task[{key}][date_of_doing]", txn_date_val),
            ]

        # Refresh CSRF from this same edit page
        csrf_inp = soup.find("input", {"name": "_csrfToken"})
        if csrf_inp and csrf_inp.get("value"):
            new_csrf = csrf_inp["value"]
            fields = [(n, new_csrf if n == "_csrfToken" else v) for n, v in fields]

        # POST as multipart (the form's enctype) — include an empty file part
        parts: list[tuple[str, tuple]] = [(n, (None, v)) for n, v in fields]
        # `Invoice[copy]` is the optional attachment slot on the form
        if not any(n == "data[Invoice][copy]" for n, _ in fields):
            parts.append(("data[Invoice][copy]", ("", b"", "application/octet-stream")))

        http.headers["Referer"] = f"{BASE}/{account}/invoices/edit/{invoice_id}"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/invoices/update", files=parts)

    loc = r.headers.get("location", "")
    if r.status_code == 302 and f"/invoices/view/{invoice_id}" in loc:
        click.secho(f"✓ Updated invoice {invoice_id}", fg="green", bold=True)
        if additional_info is not None or append_reference:
            click.echo(f"  additional_info → {new_info!r}")
        for k, v in overrides.items():
            click.echo(f"  {k} → {v!r}")
        if needs_rebind:
            for kind, bid in saved_bindings:
                _do_bind(kind, bid, [invoice_id])
                click.echo(f"  re-bound {kind.lower()} {bid} → invoice {invoice_id}")
        return
    fail = CONFIG_DIR / "last_invoice_update_failure.html"
    fail.write_text(r.text)
    raise click.ClickException(
        f"Update failed: HTTP {r.status_code} loc={loc!r}. Response saved → {fail}"
    )


def _invoice_bindings(invoice_id: int) -> list[tuple[str, int]]:
    """Scrape /invoices/view/<id> and return [(kind, id), ...] for bound payments/incomings.

    kind is 'Incoming' or 'Payment' to match _do_bind's direction arg.
    """
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        r = http.get(f"{BASE}/{account}/invoices/view/{invoice_id}")
        if r.status_code != 200:
            return []
        text = r.text
    out: list[tuple[str, int]] = []
    seen: set[tuple[str, int]] = set()
    for href in re.findall(r'href="[^"]*/(incomings|payments)/view/(\d+)"', text):
        kind = "Incoming" if href[0] == "incomings" else "Payment"
        key = (kind, int(href[1]))
        if key not in seen:
            seen.add(key)
            out.append(key)
    return out


def _invoice_remove_all_bindings(invoice_id: int) -> None:
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        csrf = fetch_fresh_csrf(http, account, path="invoices/add")
        http.headers["Referer"] = f"{BASE}/{account}/invoices/view/{invoice_id}"
        http.headers["Origin"] = BASE
        body = urlencode([("_csrfToken", csrf)])
        r = http.post(
            f"{BASE}/{account}/invoices/remove_all_bindings/{invoice_id}",
            content=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
    if r.status_code not in (200, 302):
        fail = CONFIG_DIR / "last_remove_bindings_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"remove_all_bindings/{invoice_id} failed: HTTP {r.status_code}. Response → {fail}"
        )


@invoices.command("unbind")
@click.argument("invoice_id", type=int)
def invoices_unbind(invoice_id) -> None:
    """Remove all bindings (incomings/payments) from an invoice."""
    _invoice_remove_all_bindings(invoice_id)
    click.secho(f"✓ Removed all bindings from invoice {invoice_id}", fg="green")


@invoices.command("delete")
@click.argument("invoice_id", type=int)
def invoices_delete(invoice_id) -> None:
    """Delete a sales invoice by id. Irreversible — removes the document and its
    number from the sequence. Any bound incomings/payments should be unbound first."""
    _do_delete("invoices", invoice_id, csrf_path="invoices/add")
    click.secho(f"✓ Deleted invoice {invoice_id}", fg="green")


@invoices.command("create")
@click.option("--client-id", required=True, type=int)
@click.option("--description", required=True)
@click.option("--price", required=True)
@click.option("--tax-class", type=click.Choice(list(TAX_CLASSES.keys())), default="ee-domestic", show_default=True)
@click.option("--number", default=None,
              help="Invoice number; defaults to SimpleBooks' next sequential number.")
@click.option("--quantity", default="1", show_default=True)
@click.option("--unit", default="tk", show_default=True)
@click.option("--due-days", default=7, show_default=True, type=int)
@click.option("--worker", default=None,
              help="Line worker (issuer) name; defaults to the logged-in user (read from the form).")
@click.option("--reference", default="")
@click.option("--date", "invoice_date", default=None, help="Invoice date YYYY-MM-DD. Defaults to today.")
@click.option("--vat-type-id", "vat_type_id", default=None,
              help="Override the regime's sales vat_type_id (see `invoices meta`).")
@click.option("--income-account-id", "income_account_id", default=None,
              help="Override the income account (else read live from the vat_types map).")
@click.option("--bank-account", "bank_account", default=None,
              help="Own bank account id shown on the invoice (required; see `accounts list cashbook`).")
@click.option("--creator", default=None,
              help="Issuer user id (else the logged-in user, read from the form).")
@click.option("--dry-run", is_flag=True,
              help="Resolve everything and print the payload WITHOUT creating the invoice.")
def invoices_create(client_id, description, price, tax_class, number,
                    quantity, unit, due_days, worker, reference, invoice_date,
                    vat_type_id, income_account_id, bank_account, creator, dry_run) -> None:
    """Create a new invoice."""
    cookies, account = session_or_die()
    cache = load_clients_cache()
    if str(client_id) not in cache:
        raise click.ClickException(
            f"Client {client_id} not in cache. Refresh with `simplbooks clients list`."
        )
    client_row = cache[str(client_id)]
    parsed_date = datetime.strptime(invoice_date, "%Y-%m-%d") if invoice_date else None

    with build_http(cookies, account) as http:
        page = fetch_add_page(http, account, "invoices/add")
        csrf = csrf_from_page(page)
        vt_map = extract_vat_types(page)
        if vt_map:
            SALES_META_CACHE.write_text(json.dumps(vt_map, ensure_ascii=False, indent=2))
        else:  # page didn't carry the map — fall back to the cache
            vt_map = sales_vat_types(http, account)
        creator_id = creator or creator_from_page(page)
        worker = _worker_name(worker, page)
        if number is None:
            number = default_invoice_number(page)
            if not number:
                raise click.ClickException(
                    "Couldn't read SimpleBooks' suggested invoice number from the add "
                    "form. → pass --number explicitly."
                )
        fields = build_invoice_fields(
            csrf=csrf, client_row=client_row, number=number, description=description,
            price=price, tax_class=tax_class, quantity=quantity, unit=unit,
            due_days=due_days, worker=worker, reference=reference,
            vat_types=vt_map, creator=creator_id,
            invoice_date=parsed_date, vat_type=vat_type_id,
            income_account=income_account_id, bank_account=bank_account,
        )
        if dry_run:
            fmap = dict(fields)
            click.secho("DRY RUN — invoice NOT created. Resolved payload:", fg="yellow", bold=True)
            click.echo(f"  Client        : {client_row.get('name')} [{client_id}]")
            click.echo(f"  Number        : {number}")
            click.echo(f"  Tax class     : {tax_class}")
            click.echo(f"  vat_type_id   : {fmap.get('Task[0][vat_type_id]')}")
            click.echo(f"  vat rate      : {fmap.get('Task[0][vat]')}")
            click.echo(f"  income acct   : {fmap.get('Task[0][income_account_id]')}  (--income-account-id > live default)")
            click.echo(f"  bank account  : {fmap.get('default_bank_account')}")
            click.echo(f"  creator       : {fmap.get('creator')}  (--creator > logged-in user)")
            click.echo(f"  worker        : {fmap.get('Task[0][worker]')}")
            click.echo(f"  price/unit    : {fmap.get('Task[0][price_per_unit]')} × {fmap.get('Task[0][amount]')} {fmap.get('Task[0][unit]')}")
            return
        parts: list[tuple[str, tuple]] = [(n, (None, v)) for n, v in fields]
        parts.append(("copy", ("", b"", "application/octet-stream")))
        http.headers["Referer"] = f"{BASE}/{account}/invoices/add"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/invoices/create", files=parts)

    m = re.search(r"/invoices/view/(\d+)", r.headers.get("location", ""))
    if m:
        inv_id = m.group(1)
        click.secho(f"✓ Created invoice {inv_id} (number {number})", fg="green", bold=True)
        click.echo(f"  Client : {client_row.get('name')} [{client_id}]")
        click.echo(f"  Date   : {invoice_date or 'today'}")
        click.echo(f"  Amount : {to_estonian_number(price)} EUR × {quantity} ({tax_class})")
        click.echo(f"  URL    : {BASE}/{account}/invoices/view/{inv_id}")
        return
    fail = CONFIG_DIR / "last_create_failure.html"
    fail.write_text(r.text)
    raise click.ClickException(f"Create failed: HTTP {r.status_code}. Response saved → {fail}")


# ─── accounts (chart-of-accounts + cashbooks) ───────────────────────────────

# SimpleBooks naming gotcha:
#   /financial_accounts  → the FULL chart of accounts (kontoplaan), 240+ entries
#                          covering 1xxx assets, 2xxx liabilities, 3xxx equity,
#                          4xxx revenue, 5xxx expenses, 6xxx other.
#   /income_accounts     → the small set of "Pangakontod ja kassad" cashbooks
#                          (cash + the account's bank accounts) used as payment
#                          landing spots.
ACCOUNT_KINDS: dict[str, str] = {
    "chart":    "financial_accounts",   # full kontoplaan; default
    "cashbook": "income_accounts",      # 6 bank-like payment destinations
}

