═══ Tax classes ════════════════════════════════════════════════════════════

  A regime is a presentation choice (invoice language, reverse-charge mode,
  footer) anchored to a sales vat_type_id. The VAT RATE is read LIVE from the
  account's vat_types map for that type (`invoices meta`). The income ACCOUNT
  defaults to the live map's value, overridable per regime by config (books
  policy) or per invoice by --income-account-id; override the type --vat-type-id.

  ee-domestic   Estonia, standard VAT          sales vat_type 32
  eu-reverse    EU B2B, 0% reverse-charge      sales vat_type 10
                (requires VAT no on client)
  non-eu        Export, 0%                     sales vat_type 13

═══ Price format ═══════════════════════════════════════════════════════════

Accepts '100', '100.00', '1234.50', '1234,50', '1 234,50'. Internally
normalised to Estonian format ('1 234,50') for the SimpleBooks form.

═══ Contract commands (the same on every capability) ═══════════════════════

  simplbooks stub                                 one-line awareness text
  simplbooks manifest --json                      machine-readable declaration
  simplbooks connections                          where every connection's values
                                                  resolve from — tier, source,
                                                  secrets masked (local, no network)
  simplbooks guide [<topic>]                      guide topics / one guide body
  simplbooks ids list|get <l>|set <l> <v>|rm <l>  the project identifiers envelope
             [--note <text>]                      (.capabilities/simplbooks/identifiers.json)
  simplbooks refs                                 menu of the project's reference files

═══ Exit codes ═════════════════════════════════════════════════════════════

  0  success
  1  generic error (validation, network, CSRF)
  2  auth (missing creds, login rejected, or PIN required — see message)
  4  policy refusal — disabled by project policy (.capabilities/settings.json),
     or a write verb on a read-only connection (ask the user, never lift the
     gate or enable the capability yourself)
  (contract verbs add 3 not-found / 5 network / 6 input)
"""

# ─── Tax classification map ─────────────────────────────────────────────────

# A regime is a presentation choice (invoice language, reverse-charge row mode,
# footer prefix) anchored to a SimpleBooks sales vat_type_id — part of the
# platform's Estonian VAT-type taxonomy (the "Teenuste müük / EÜ teenused /
# Teenuste eksport" service-sale types), not a consumer fingerprint. The VAT RATE
# for each type is read live from the account's `vat_types` map (never baked). The
# income ACCOUNT is a books-policy choice: the live map only carries SimpleBooks'
# naive default (usually one revenue account for every type), so a regime that
# books elsewhere — e.g. EU reverse-charge / export to their own 0% revenue rows —
# is supplied per invoice via --income-account-id (the caller sources it from its
# own books policy). No account id is baked into the tool and there is no env fallback.
TAX_CLASSES: dict[str, dict[str, str | None]] = {
    "ee-domestic": {"vat_type_id": "32",
                    "language": "et_EE", "row_sum_with_vat": None, "footer_prefix": ""},
    "eu-reverse":  {"vat_type_id": "10",
                    "language": "en_GB", "row_sum_with_vat": "1",
                    "footer_prefix": "Reverse charge EU directive 2006/112\n\n"},
    "non-eu":      {"vat_type_id": "13",
                    "language": "et_EE", "row_sum_with_vat": None, "footer_prefix": ""},
}

# The invoice footer is a consumer-chosen courtesy line, overridable via config.
DEFAULT_FOOTER = "Täname õigeaegselt tasutud arve eest!"

# ─── Credentials I/O ────────────────────────────────────────────────────────

class AuthError(click.ClickException):
    exit_code = 2


# The four credential keys, in the order login/refresh persists them.
CASCADE_KEYS = ("SIMPLBOOKS_EMAIL", "SIMPLBOOKS_PASSWORD", "SIMPLBOOKS_ACCOUNT", "SIMPLBOOKS_COOKIE")


def _clean_env_value(v: str) -> str:
    """Normalize an env-file value: a quoted value is kept literal (quotes stripped);
    an unquoted value drops a trailing inline comment (whitespace + `#…`), matching
    the common .env convention so a trailing comment never corrupts the value."""
    v = v.strip()
    if len(v) >= 2 and ((v[0] == "'" and v[-1] == "'") or (v[0] == '"' and v[-1] == '"')):
        return v[1:-1]
    return re.sub(r"\s+#.*$", "", v).strip()


def load_credentials() -> dict[str, str]:
    """Identity (EMAIL/PASSWORD) resolves through the cascade — project .env(.local),
    then the global credentials.env, then process env. The minted session
    (ACCOUNT/COOKIE) resolves from its per-identity session file in the state home
    first; the cascade stays available as the one-shot injection path (the deployed
    box, an env-prefix invocation)."""
    out: dict[str, str] = {}
    if _CONN and _CONN.get("entry") is not None:
        # A named registry connection supplies the identity: email literally,
        # password through its secret_env. The implicit default (entry=None)
        # keeps the flat cascade below.
        if _CONN.get("email"):
            out["SIMPLBOOKS_EMAIL"] = _CONN["email"]
        if _CONN.get("password"):
            out["SIMPLBOOKS_PASSWORD"] = _CONN["password"]
    else:
        for key in ("SIMPLBOOKS_EMAIL", "SIMPLBOOKS_PASSWORD"):
            v = (_project_env_value(key) or _read_cred(key) or os.environ.get(key))
            if v:
                out[key] = v
    session = _parse_env_file(_session_file(out.get("SIMPLBOOKS_EMAIL", "")))
    for key in ("SIMPLBOOKS_ACCOUNT", "SIMPLBOOKS_COOKIE"):
        v = (session.get(key) or _project_env_value(key) or _read_cred(key)
             or os.environ.get(key))
        if v:
            out[key] = v
    if not out.get("SIMPLBOOKS_EMAIL") and not out.get("SIMPLBOOKS_COOKIE"):
        raise AuthError(
            f"No SimpleBooks credentials — neither {CREDENTIALS_ENV} nor the SIMPLBOOKS_*\n"
            "  environment variables supply them.\n"
            "  → laptop: run `simplbooks login` (or `simplbooks refresh /path/to/curl.txt`)\n"
            "  → deployed box: inject SIMPLBOOKS_EMAIL + SIMPLBOOKS_PASSWORD (+ ACCOUNT/COOKIE) in the env"
        )
    return out


def _resolve_connection(wanted: str | None) -> dict:
    """Select the connection for this invocation and fold in its identity. The
    implicit default (no registry) carries entry=None and resolves email/password
    from the flat cascade exactly as before; a named registry connection supplies
    the email literally and the password through secret_env (cascade tiers 2-4).
    Returns {id, entry, email, password, allow_write}. Stored in _CONN so the
    session and credential helpers source the right identity and key the session
    per-connection. The resolve-for-use path (this) may die on a malformed entry;
    the connections report (`_cmd_connections`) never does."""
    reg, _ = _connections_registry()
    cid, entry = _select_connection(reg, wanted)
    if entry is None:
        email = (_project_env_value("SIMPLBOOKS_EMAIL") or _read_cred("SIMPLBOOKS_EMAIL")
                 or os.environ.get("SIMPLBOOKS_EMAIL") or "")
        return {"id": cid, "entry": None, "email": email or None,
                "password": None, "allow_write": WRITE_DEFAULT}
    email = entry.get("email")
    if not email:
        _die(6, "incomplete_connection",
             f"connection {cid!r} is missing 'email'",
             f"add the login email to this connection in connections.json")
    secret_env = entry.get("secret_env")
    if not secret_env:
        _die(6, "no_secret_env",
             f"connection {cid!r} is missing 'secret_env'",
             "name the env var that holds this identity's SimpleBooks password")
    password = _resolve_env_key(secret_env)[0]
    return {"id": cid, "entry": entry, "email": email,
            "password": password,
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT))}


def _read_cred(key: str) -> str | None:
    """Read one key from credentials.env (no session/assertion side-effects)."""
    if CREDENTIALS_ENV.exists():
        for line in CREDENTIALS_ENV.read_text().splitlines():
            s = line.strip()
            if not s or s.startswith("#") or "=" not in s:
                continue
            k, _, v = s.partition("=")
            if k.strip() == key:
                return _clean_env_value(v) or None
    return None


def _worker_name(override: str | None = None, page_html: str | None = None) -> str:
    """Resolve the invoice line worker (issuer) name, identity-free, through the
    cascade: --worker > SIMPLBOOKS_WORKER (optional project .env pin) > the logged-in
    user's name read live from the add/edit form. Derived synchronously from the page
    the caller already holds — nothing persisted, so it always reflects the active
    session and never collides across consumers of the shared tool."""
    if override and override.strip():
        return override.strip()
    w = _cfg("SIMPLBOOKS_WORKER")
    if w:
        return w
    if page_html:
        derived = worker_from_page(page_html)
        if derived:
            return derived
    raise click.ClickException(
        "No worker name — couldn't derive it from the logged-in user; "
        "set SIMPLBOOKS_WORKER or pass --worker."
    )


def _project_env_value(key: str) -> str | None:
    """Read KEY from the consuming project's nearest .env.local / .env, walking up
    from CWD and stopping at $HOME or the filesystem root (never above either). The
    first directory that holds either file is the project root; .env.local wins over
    .env there. This is tier-2 of the cascade — it lets a project supply its own
    non-secret config without touching global config."""
    home = Path.home()
    cwd = Path.cwd()
    for d in (cwd, *cwd.parents):
        local, base = d / ".env.local", d / ".env"
        if local.is_file() or base.is_file():
            for f in (local, base):
                if not f.is_file():
                    continue
                for line in f.read_text().splitlines():
                    s = line.strip()
                    if not s or s.startswith("#") or "=" not in s:
                        continue
                    k, _, v = s.partition("=")
                    if k.strip() == key:
                        return _clean_env_value(v) or None
            return None  # nearest project root found; its env doesn't set the key
        if d == home or d == d.parent:  # stop at $HOME or filesystem root
            break
    return None


def _cfg(key: str, override: str | None = None) -> str | None:
    """Resolve a non-secret config value, identity-free, through the cascade:
    explicit override > project .env(.local) > user config (credentials.env) >
    process env. None if unset everywhere."""
    v = override or _project_env_value(key) or _read_cred(key) or os.environ.get(key)
    return v.strip() if v and v.strip() else None


def _bank_account(override: str | None = None) -> str:
    """Resolve this account's own bank/cashbook id used on sales invoices from the
    --bank-account flag. No id is baked in and there is no env fallback — it is an
    account-specific chart row the caller supplies per invoice."""
    if override and override.strip():
        return override.strip()
    raise click.ClickException(
        "No bank account — pass --bank-account <id> "
        "(find it with `simplbooks accounts list cashbook`)."
    )


def _resolve_tax(tax_class: str, vat_types: dict, vat_type: str | None = None,
                 income_account: str | None = None) -> tuple[str, str, str]:
    """Resolve (vat_type_id, income_account_id, vat_rate) for a regime against the
    account's LIVE vat_types map. The vat_type is the regime anchor (override with
    --vat-type-id) and the rate comes straight from the live map. The income
    account resolves: --income-account-id > the live map's default. The override is
    supplied per invoice by the caller (a books-policy choice, e.g. EU/export to a
    0% revenue row); no id is baked into the tool and there is no env fallback."""
    vt = str(vat_type or TAX_CLASSES[tax_class]["vat_type_id"])
    meta = vat_types.get(vt) or {}
    live_income = str(meta["income_account_id"]) if meta.get("income_account_id") is not None else None
    ia = income_account or live_income
    rate = str(meta["vat_percent"]) if meta.get("vat_percent") is not None else None
    if not ia:
        raise click.ClickException(
            f"No income account for vat_type {vt} — the live vat_types map gave none "
            f"and --income-account-id was not passed.\n"
            f"  → pass --income-account-id <id> (find it with `simplbooks accounts list chart`)."
        )
    if rate is None:
        # The live map should always carry the rate; fall back to 0 only defensively.
        rate = "0"
    return vt, ia, rate


def parse_cookie_string(s: str) -> dict[str, str]:
    cookies: dict[str, str] = {}
    for pair in s.split(";"):
        if "=" in pair:
            k, _, v = pair.strip().partition("=")
            cookies[k] = v
    return cookies


# ─── Auto-login (primary) ───────────────────────────────────────────────────

def _scrape_login_form(html: str) -> dict[str, str]:
    soup = BeautifulSoup(html, "html.parser")
    out: dict[str, str] = {}
    for name in ("_csrfToken", "_Token[fields]", "_Token[unlocked]"):
        inp = soup.find("input", {"name": name})
        out[name] = (inp.get("value") or "") if inp else ""
    if not out["_csrfToken"] or not out["_Token[fields]"]:
        raise click.ClickException("Couldn't scrape CSRF/Token from login page (layout changed?).")
    return out


def _login_step1(email: str, password: str) -> tuple[str, dict[str, str], str]:
    """POST credentials. Returns (status, cookies, redirect_location).

    status is 'authed' (login completed, redirect → app.simplbooks.com) or
    'pin_required' (redirect → /accounts/insert-pin-code?...).
    """
    base_headers = {
        "User-Agent": UA,
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "en-US,en;q=0.9",
    }
    with httpx.Client(headers=base_headers, follow_redirects=False, timeout=30) as http:
        r = http.get(LOGIN_URL)
        if r.status_code != 200:
            raise click.ClickException(f"GET {LOGIN_URL} returned {r.status_code}")
        tokens = _scrape_login_form(r.text)
        r2 = http.post(
            LOGIN_URL,
            data={
                "_csrfToken": tokens["_csrfToken"],
                "email": email,
                "password": password,
                "_Token[fields]": tokens["_Token[fields]"],
                "_Token[unlocked]": tokens["_Token[unlocked]"],
                "g-recaptcha-response": "",
            },
            headers={
                "Origin": "https://secure.simplbooks.com",
                "Referer": LOGIN_URL,
                "Content-Type": "application/x-www-form-urlencoded",
            },
        )
        if r2.status_code != 302:
            soup = BeautifulSoup(r2.text, "html.parser")
            err = soup.find(class_=re.compile(r"alert|error|invalid", re.I))
            msg = err.get_text(strip=True) if err else f"unexpected status {r2.status_code}"
            raise AuthError(f"Login rejected: {msg}")
        loc = r2.headers.get("location", "")
        cookies_now = dict(http.cookies)

    if "insert-pin-code" in loc:
        return "pin_required", cookies_now, loc
    if "app.simplbooks.com" in loc:
        # Follow the SSO handoff (redirects through to dashboard) to gather
        # SB_APP / SB_APP_CSRF cookies, which are only set on app.simplbooks.com.
        with httpx.Client(cookies=cookies_now, headers=base_headers,
                          follow_redirects=True, timeout=30) as http2:
            http2.get(loc)
            return "authed", dict(http2.cookies), loc
    raise AuthError(f"Login redirected to unexpected URL: {loc}")


def _login_step2(cookies: dict[str, str], pin_url: str, pin: str) -> tuple[dict[str, str], str]:
    """POST PIN to complete the gate. Returns (cookies, app_url)."""
    base_headers = {
        "User-Agent": UA,
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "en-US,en;q=0.9",
    }
    with httpx.Client(cookies=cookies, headers=base_headers,
                      follow_redirects=False, timeout=30) as http:
        r = http.get(pin_url, headers={"Referer": LOGIN_URL})
        if r.status_code != 200:
            raise AuthError(
                f"PIN page returned {r.status_code}. The PIN link likely expired — "
                "run `simplbooks login` again to get a fresh code."
            )
        tokens = _scrape_login_form(r.text)
        r2 = http.post(
            pin_url,
            data={
                "_csrfToken": tokens["_csrfToken"],
                "pin_code": pin,
                "_Token[fields]": tokens["_Token[fields]"],
                "_Token[unlocked]": tokens["_Token[unlocked]"],
            },
            headers={
                "Origin": "https://secure.simplbooks.com",
                "Referer": pin_url,
                "Content-Type": "application/x-www-form-urlencoded",
            },
        )
        if r2.status_code != 302:
            raise AuthError("PIN rejected — wrong code or expired. Run `simplbooks login` to retry.")
        loc = r2.headers.get("location", "")
        cookies_after_pin = dict(http.cookies)

    if "app.simplbooks.com" not in loc:
        raise AuthError(f"Unexpected redirect after PIN: {loc}")
    with httpx.Client(cookies=cookies_after_pin, headers=base_headers,
                      follow_redirects=True, timeout=30) as http2:
        http2.get(loc)
        return dict(http2.cookies), loc


def _save_pin_state(cookies: dict[str, str], pin_url: str) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    PIN_STATE_FILE.write_text(json.dumps({"cookies": cookies, "pin_url": pin_url}))
    os.chmod(PIN_STATE_FILE, 0o600)


def _load_pin_state() -> dict | None:
    if not PIN_STATE_FILE.exists():
        return None
    try:
        return json.loads(PIN_STATE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return None


def _clear_pin_state() -> None:
    if PIN_STATE_FILE.exists():
        PIN_STATE_FILE.unlink()


def _persist_session(cookies: dict[str, str], account: str) -> None:
    """Write the minted session (account hash + cookie) to its one home — the
    per-identity session file in the state home. credentials.env and the project
    .env are human-written only; a script never writes back into them."""
    cookie_str = "; ".join(f"{k}={v}" for k, v in cookies.items())
    sf = _session_file()
    sf.parent.mkdir(parents=True, exist_ok=True)
    sf.write_text(
        "# simplbooks live session — written by login/refresh. Never commit.\n"
        f"SIMPLBOOKS_ACCOUNT='{account}'\n"
        f"SIMPLBOOKS_COOKIE='{cookie_str}'\n")
    os.chmod(sf, 0o600)


def auto_login_attempt(interactive: bool = False) -> bool:
    """Try to re-authenticate using stored EMAIL/PASSWORD.

    Returns True if a fresh session was persisted.
    Raises AuthError otherwise. On PIN gate: saves pending state, and
    either prompts (interactive=True + TTY) or raises with next-step
    guidance (otherwise).
    """
    try:
        creds = load_credentials()
    except AuthError:
        creds = {}  # let the specific "auto-login unavailable" message below own this path
    email = creds.get("SIMPLBOOKS_EMAIL")
    password = creds.get("SIMPLBOOKS_PASSWORD")
    if not email or not password:
        raise AuthError(
            "Auto-login unavailable: SIMPLBOOKS_EMAIL / SIMPLBOOKS_PASSWORD not set.\n"
            f"  → add them to {CREDENTIALS_ENV}, then run `simplbooks login`.\n"
            "  → or fall back to: simplbooks refresh /path/to/curl.txt"
        )

    click.echo("→ auto-login: posting credentials…", err=True)
    status, cookies, redir = _login_step1(email, password)
    if status == "authed":
        account = account_hash_from_url(redir)
        _persist_session(cookies, account)
        _clear_pin_state()
        click.secho("✓ logged in", fg="green", err=True)
        return True

    # PIN gate
    _save_pin_state(cookies, redir)
    if interactive and sys.stdin.isatty():
        click.echo(f"→ SimplBooks sent a 6-digit PIN to {email}", err=True)
        pin = click.prompt("  PIN", type=str).strip()
        cookies_after, app_url = _login_step2(cookies, redir, pin)
        account = account_hash_from_url(app_url)
        _persist_session(cookies_after, account)
        _clear_pin_state()
        click.secho("✓ logged in (PIN verified)", fg="green", err=True)
        return True
    raise AuthError(
        f"PIN required — SimplBooks sent a 6-digit code to {email}.\n"
        "  → check email, then run (do NOT re-run `simplbooks login`):\n"
        "    simplbooks login --pin <code>"
    )


# ─── Session validation ─────────────────────────────────────────────────────

def session_or_die() -> tuple[dict[str, str], str]:
    creds = load_credentials()
    cookie_str = creds.get("SIMPLBOOKS_COOKIE")
    account = creds.get("SIMPLBOOKS_ACCOUNT")
    # If cookie/account are missing but email+password are present, try auto-login.
    if (not cookie_str or not account) and creds.get("SIMPLBOOKS_EMAIL") and creds.get("SIMPLBOOKS_PASSWORD"):
        auto_login_attempt(interactive=False)
        creds = load_credentials()
        cookie_str = creds.get("SIMPLBOOKS_COOKIE")
        account = creds.get("SIMPLBOOKS_ACCOUNT")
    if not cookie_str or not account:
        raise AuthError(
            "credentials.env is missing SIMPLBOOKS_COOKIE or SIMPLBOOKS_ACCOUNT.\n"
            "  → primary: add SIMPLBOOKS_EMAIL + SIMPLBOOKS_PASSWORD, run `simplbooks login`\n"
            "  → fallback: simplbooks refresh /path/to/curl.txt"
        )
    cookies = parse_cookie_string(cookie_str)
    if "SB_APP" not in cookies:
        raise AuthError("SB_APP cookie missing in SIMPLBOOKS_COOKIE — run `simplbooks login`.")
    return cookies, account


# ─── Curl parsing (for refresh) ─────────────────────────────────────────────

def parse_curl(text: str) -> dict:
    cleaned = re.sub(r"\\\s*\n", " ", text).strip()
    tokens = shlex.split(cleaned)
    if not tokens or tokens[0] != "curl":
        raise click.ClickException("Input doesn't start with `curl` — paste a Copy-as-cURL.")
    url = None
    headers: dict[str, str] = {}
    cookies: dict[str, str] = {}
    i = 1
    while i < len(tokens):
        t = tokens[i]
        if t in ("-X", "--request"):
            i += 2
        elif t in ("-H", "--header"):
            k, _, v = tokens[i + 1].partition(":")
            headers[k.strip()] = v.strip()
            i += 2
        elif t in ("-b", "--cookie"):
            cookies.update(parse_cookie_string(tokens[i + 1]))
            i += 2
        elif t in ("--data", "--data-raw", "--data-binary", "-d"):
            i += 2
        elif t.startswith("http"):
            url = t
            i += 1
        else:
            i += 1
    ch = headers.pop("Cookie", None) or headers.pop("cookie", None)
    if ch:
        cookies.update(parse_cookie_string(ch))
    if not url:
        raise click.ClickException("No URL in the captured curl.")
    return {"url": url, "cookies": cookies}


def account_hash_from_url(url: str) -> str:
    first = urlparse(url).path.lstrip("/").split("/", 1)[0]
    if not re.fullmatch(r"[0-9a-f]{32}", first):
        raise click.ClickException(f"Couldn't extract a 32-char account hash from {url!r}")
    return first

# ─── HTTP helpers ───────────────────────────────────────────────────────────

def build_http(cookies: dict, account: str, ajax: bool = False) -> httpx.Client:
    # SimpleBooks redirects same-origin GETs that include an Origin header.
    # Browsers omit Origin on same-origin GETs, so we do too. AJAX/POST gets it back.
    headers = {
        "User-Agent": UA,
        "Accept-Language": "en-US,en;q=0.9",
        "Referer": f"{BASE}/{account}/invoices",
    }
    if ajax:
        headers["Accept"] = "application/json, text/javascript, */*; q=0.01"
        headers["X-Requested-With"] = "XMLHttpRequest"
        headers["Origin"] = BASE
    else:
        headers["Accept"] = "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
    return httpx.Client(cookies=cookies, headers=headers, follow_redirects=False, timeout=30)


def _session_stale(r: httpx.Response) -> bool:
    """SSO redirect (301/302, caught by is_redirect) or a hard 401 — session expired, a re-login retry is warranted."""
    return r.is_redirect or r.status_code == 401


def fetch_add_page(http: httpx.Client, account: str, path: str = "invoices/add") -> str:
    """GET an add-form page, recovering once via auto-login if the session is
    stale. Returns the page HTML — callers extract csrf / vat_types / creator."""
    r = http.get(f"{BASE}/{account}/{path}")
    if _session_stale(r):
        # Session is stale. Try auto-login + retry once with refreshed cookies.
        # auto_login_attempt raises AuthError if it can't recover — that propagates.
        auto_login_attempt(interactive=False)
        creds = load_credentials()
        new_cookies = parse_cookie_string(creds["SIMPLBOOKS_COOKIE"])
        http.cookies = httpx.Cookies(new_cookies)
        r = http.get(f"{BASE}/{account}/{path}")
        if _session_stale(r):
            raise AuthError(
                f"Session still invalid after auto-login (HTTP {r.status_code}).\n"
                "  → fallback: simplbooks refresh /path/to/fresh-curl.txt"
            )
    if r.status_code != 200:
        raise click.ClickException(f"GET /{path} returned {r.status_code}")
    return r.text


def csrf_from_page(html: str, path: str = "invoices/add") -> str:
    inp = BeautifulSoup(html, "html.parser").find("input", {"name": "_csrfToken"})
    if not inp or not inp.get("value"):
        raise click.ClickException(f"No _csrfToken on /{path} — page layout changed?")
    return inp["value"]


def fetch_fresh_csrf(http: httpx.Client, account: str, path: str = "invoices/add") -> str:
    return csrf_from_page(fetch_add_page(http, account, path), path)


def extract_vat_types(html: str) -> dict:
    """Pull the live `vat_types` map SimpleBooks emits in the invoice-form JS:
    { "<vat_type_id>": {"income_account_id": N, "vat_percent": N, "name": "…"}, … }.
    This is the authoritative source for sales vat types AND their income accounts;
    returns {} if the page doesn't carry it. The page emits valid JSON, so decode
    it with raw_decode (string-aware — immune to braces inside a type name)."""
    m = re.search(r"\bvat_types\s*=\s*", html)
    if not m:
        return {}
    i = html.find("{", m.end())
    if i < 0:
        return {}
    try:
        obj, _ = json.JSONDecoder().raw_decode(html, i)
        return obj if isinstance(obj, dict) else {}
    except (ValueError, json.JSONDecodeError):
        return {}


def creator_from_page(html: str) -> str | None:
    """Read the logged-in user's id from an add form's creator field, so the issuer
    attribution follows whoever is driving the CLI (no baked user id). The sales
    form names the field `creator` and pre-fills the real id; the purchase form
    names it `data[Purchase][creator]` and leaves it 0 (set client-side). Match
    either, but treat a non-positive value as unset (None) so callers can fall back."""
    soup = BeautifulSoup(html, "html.parser")
    inp = soup.find("input", {"name": "creator"}) or soup.find("input", {"name": "data[Purchase][creator]"})
    v = (inp.get("value") if inp else None) or ""
    v = str(v).strip()
    return v if (v.isdigit() and int(v) > 0) else None


def worker_from_page(html: str) -> str | None:
    """The line worker SimpleBooks defaults a new row to — the logged-in user's
    display name. Primary source is the add/edit form's row-init JS
    (`$('#TaskWorker' + taskRowId).val('<name>')`); falls back to the account
    menu's name. None if neither is present."""
    m = re.search(r"#TaskWorker'\s*\+\s*taskRowId\)\.val\('([^']*)'\)", html)
    if m and m.group(1).strip():
        return m.group(1).strip()
    soup = BeautifulSoup(html, "html.parser")
    el = (soup.select_one("[aria-labelledby='user-profile-link'] .fw-bold")
          or soup.select_one(".dropdown-item .fw-bold"))
    if el:
        name = el.get_text(strip=True)
        if name:
            return name
    return None


def default_invoice_number(html: str) -> str | None:
    """The next sequential invoice number SimpleBooks pre-fills into the add form's
    `number` input — the account's own numbering, not an invented one. None if the
    field can't be read."""
    soup = BeautifulSoup(html, "html.parser")
    inp = soup.find("input", {"name": "number"})
    v = str((inp.get("value") if inp else None) or "").strip()
    return v or None


def logged_in_user_id(http: httpx.Client, account: str) -> str | None:
    """The logged-in user's id, read from the invoice add form's `creator` field —
    the reliable source (the purchase form leaves creator 0). Used to attribute a
    purchase invoice to the real user. None if unreadable."""
    try:
        return creator_from_page(fetch_add_page(http, account, "invoices/add"))
    except (click.ClickException, httpx.HTTPError):
        return None


def sales_vat_types(http: httpx.Client, account: str, refresh: bool = False) -> dict:
    """The account's live sales vat_types map (id -> {income_account_id, vat_percent,
    name}), scraped from /invoices/add and cached to sales_meta.json. Without
    refresh the cache is used when present; refresh re-scrapes."""
    if not refresh and SALES_META_CACHE.exists():
        try:
            cached = json.loads(SALES_META_CACHE.read_text())
            if cached:
                return cached
        except (ValueError, json.JSONDecodeError):
            pass
    vt = extract_vat_types(fetch_add_page(http, account, "invoices/add"))
    if vt:
        SALES_META_CACHE.write_text(json.dumps(vt, ensure_ascii=False, indent=2))
    return vt

# ─── Utility helpers ────────────────────────────────────────────────────────

def normalize_number(price) -> str:
    """Accept Estonian (comma-decimal) or plain numeric input; return a dot-decimal string."""
    s = str(price).strip()
    if "," in s and "." not in s:
        s = s.replace(" ", "").replace(",", ".")
    elif "," in s and "." in s:
        s = s.replace(",", "").replace(" ", "")
    else:
        s = s.replace(" ", "")
    return s


def to_estonian_number(price) -> str:
    val = float(normalize_number(price))
    return f"{val:,.2f}".replace(",", "\x00").replace(".", ",").replace("\x00", " ")


def compute_vat_total(lines: list[dict], row_sum_with_vat: bool) -> str:
    """Row-derived VAT total: gross rows → sum·rate/(100+rate), net rows → sum·rate/100.

    SB validates the posted Purchase[vat] against its own recalculation and rejects
    values off by more than rounding (the field is meant for cent corrections only),
    so the default must land on the row-derived figure, never 0.
    """
    total = Decimal("0")
    for ln in lines:
        rate = Decimal(normalize_number(ln.get("vat", "0") or "0"))
        if rate == 0:
            continue
        s = Decimal(normalize_number(ln["sum"]))
        if row_sum_with_vat:
            total += s * rate / (100 + rate)
        else:
            total += s * rate / 100
    return str(total.quantize(Decimal("0.01"), rounding=ROUND_HALF_UP))


def strip_html(value) -> str:
    return re.sub(r"<[^>]+>", "", str(value or "")).strip()


def datatables_payload(columns: list[tuple[str, str]], order_col: int, length: int, search: str = "") -> dict:
    data: dict[str, str] = {"draw": "1"}
    for i, (cdata, cname) in enumerate(columns):
        data[f"columns[{i}][data]"] = cdata
        data[f"columns[{i}][name]"] = cname
        data[f"columns[{i}][searchable]"] = "true" if cdata else "false"
        data[f"columns[{i}][orderable]"] = "true" if cdata else "false"
        data[f"columns[{i}][search][value]"] = ""
        data[f"columns[{i}][search][regex]"] = "false"
    data["order[0][column]"] = str(order_col)
    data["order[0][dir]"] = "desc"
    data["start"] = "0"
    data["length"] = str(length)
    data["search[value]"] = search
    data["search[regex]"] = "false"
    return data


def load_clients_cache() -> dict[str, dict]:
    if not CLIENTS_CACHE.exists():
        raise click.ClickException(
            f"No client cache at {CLIENTS_CACHE}. Run `simplbooks clients list` first."
        )
    return {str(c["id"]): c for c in json.loads(CLIENTS_CACHE.read_text())}


def _refresh_clients_cache(search: str = "", limit: int = 200) -> tuple[list[dict], int]:
    """Fetch /clients/listdata, overwrite CLIENTS_CACHE, return (rows, recordsTotal)."""
    cookies, account = session_or_die()
    cols = [
        ("", "_select"),
        ("name", "name"),
        ("reg_no", "reg_no"),
        ("vat_no", "vat_no"),
        ("address_street", "address_street"),
        ("address_city", "address_city"),
        ("address_county", "address_county"),
        ("address_country", "address_country"),
        ("phone", "phone"),
        ("fax", "fax"),
        ("email", "email"),
        ("webpage", "webpage"),
        ("id", "_id"),
        ("", "_actions"),
    ]
    data = datatables_payload(cols, order_col=12, length=limit, search=search)
    with build_http(cookies, account, ajax=True) as http:
        http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
        r = http.post(f"{BASE}/{account}/clients/listdata", data=data)
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
        payload = r.json()
    rows = payload.get("data", [])
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CLIENTS_CACHE.write_text(json.dumps(rows, indent=2, ensure_ascii=False))
    return rows, payload.get("recordsTotal", len(rows))

# ─── CLI ────────────────────────────────────────────────────────────────────

class _GatedCommand(click.Command):
    """Every leaf command passes the per-connection write gate at dispatch —
    before its body runs, so the gate is independent of any per-command
    pre-validation. The leaf name is this command's own name (e.g. `create`),
    so reads (whose names are not in WRITE_VERBS) pass untouched and exactly the
    write leaves are refused (exit 4) on a connection without allow_write."""
    def invoke(self, ctx: click.Context):
        if _CONN is not None:
            _write_gate(_CONN["id"], _CONN["allow_write"], self.name)
        return super().invoke(ctx)


class _GatedGroup(click.Group):
    """Propagates the gated classes through the whole command tree: a subgroup
    declared with `@<group>.group()` is itself a _GatedGroup and its leaves are
    _GatedCommands, so the gate is wired once here and inherited everywhere."""
    command_class = _GatedCommand
    group_class = type


_GatedGroup.group_class = _GatedGroup


@click.group(cls=_GatedGroup)
def cli() -> None:
    """simplbooks — agent-first CLI for SimpleBooks."""


@cli.command("help")
def cmd_help() -> None:
    """Print the full agent usage contract."""
    click.echo(HELP)


@cli.command("doctor")
def cmd_doctor() -> None:
    """Validate session health. Exit 0 if OK, 2 if creds are missing/stale and unrecoverable."""
    _doctor_gate(_connections_report(), None)

    cookies, account = session_or_die()
    click.echo(f"account hash     : {account}")
    click.echo(f"cookies          : {len(cookies)} ({', '.join(sorted(cookies)[:5])}{'…' if len(cookies)>5 else ''})")

    with build_http(cookies, account) as http:
        r = http.get(f"{BASE}/{account}/invoices/add")
        click.echo(f"GET /invoices/add: HTTP {r.status_code}")
        if _session_stale(r):
            click.secho(f"⚠ session expired (HTTP {r.status_code})", fg="yellow")
            # auto_login_attempt raises AuthError on failure → click handles exit 2.
            auto_login_attempt(interactive=False)
            cookies, account = session_or_die()
            http.cookies = httpx.Cookies(cookies)
            r = http.get(f"{BASE}/{account}/invoices/add")
            click.echo(f"after auto-login : HTTP {r.status_code}")
            if _session_stale(r):
                click.secho("✗ session still invalid after auto-login", fg="red")
                click.echo("  → fallback: simplbooks refresh /path/to/fresh-curl.txt")
                sys.exit(2)
        if r.status_code != 200:
            click.secho(f"✗ unexpected status {r.status_code}", fg="red")
            sys.exit(1)
        soup = BeautifulSoup(r.text, "html.parser")
        inp = soup.find("input", {"name": "_csrfToken"})
        if not (inp and inp.get("value")):
            click.secho("✗ no _csrfToken found — page layout changed?", fg="red")
            sys.exit(1)
        click.echo(f"CSRF scrape      : OK ({inp['value'][:20]}…)")

    click.secho("\n✓ session healthy", fg="green", bold=True)


@cli.command("login")
@click.option("--pin", default=None, help="6-digit PIN to complete a pending PIN flow.")
def cmd_login(pin: str | None) -> None:
    """Authenticate using stored SIMPLBOOKS_EMAIL + SIMPLBOOKS_PASSWORD.

    Without --pin: posts credentials. On clean login, persists session and exits.
    On PIN gate (new IP/device): saves pending state. If TTY, prompts inline.
    Otherwise exits 2 with instructions to re-run with --pin.

    With --pin: completes a pending PIN flow. Does NOT re-post the password —
    re-posting would invalidate the active PIN and trigger a new email.
    """
    if pin is not None:
        pending = _load_pin_state()
        if not pending:
            raise click.ClickException(
                "No pending PIN flow. Run `simplbooks login` first to trigger a PIN."
            )
        cookies_after, app_url = _login_step2(pending["cookies"], pending["pin_url"], pin.strip())
        account = account_hash_from_url(app_url)
        _persist_session(cookies_after, account)
        _clear_pin_state()
        click.secho(f"✓ logged in (PIN verified) — account {account}", fg="green")
        return
    auto_login_attempt(interactive=True)


@cli.command("refresh")
@click.argument("source", type=click.Path(dir_okay=False), default="-")
def cmd_refresh(source: str) -> None:
    """Fallback: parse a Copy-as-cURL paste and rewrite cookie/account.

    Preserves SIMPLBOOKS_EMAIL/PASSWORD lines if present. Prefer
    `simplbooks login` when EMAIL+PASSWORD are configured.
    """
    if source == "-":
        text = sys.stdin.read()
        if not text.strip():
            raise click.ClickException("Empty stdin. Pipe a curl in, or pass a file path.")
    else:
        p = Path(source)
        if not p.exists():
            raise click.ClickException(f"No such file: {p}")
        text = p.read_text()

    parsed = parse_curl(text)
    account = account_hash_from_url(parsed["url"])
    cookies = parsed["cookies"]
    if "SB_APP" not in cookies:
        raise click.ClickException("Parsed curl is missing the SB_APP cookie — was it a SimpleBooks request?")

    _persist_session(cookies, account)
    _clear_pin_state()
    click.secho(f"✓ wrote {CREDENTIALS_ENV}", fg="green")
    click.echo(f"  account: {account}")
    click.echo(f"  cookies: {len(cookies)}")
    click.echo("\n  Run `simplbooks doctor` to confirm.")

