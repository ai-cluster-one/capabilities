@clients.command("list")
@click.option("--search", default="", help="Filter by name / reg no / VAT no / etc.")
@click.option("--limit", default=200, show_default=True, type=int)
def clients_list(search: str, limit: int) -> None:
    """List clients (also caches them locally for `invoices create`)."""
    rows, total = _refresh_clients_cache(search=search, limit=limit)
    click.secho(f"{total} total · {len(rows)} returned · cached → {CLIENTS_CACHE}", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'NAME':<40}  {'REG NO':<12}  {'VAT NO':<14}  COUNTRY", bold=True)
    for row in rows:
        click.echo(
            f"{str(row.get('id','?')):>5}  "
            f"{strip_html(row.get('name'))[:40]:<40}  "
            f"{strip_html(row.get('reg_no'))[:12]:<12}  "
            f"{strip_html(row.get('vat_no'))[:14]:<14}  "
            f"{strip_html(row.get('address_country'))[:6]}"
        )

@clients.command("search")
@click.argument("query")
def clients_search(query: str) -> None:
    """Search the Estonian business registry by partial company name."""
    cookies, account = session_or_die()
    with build_http(cookies, account, ajax=True) as http:
        r = http.get(f"{BASE}/{account}/clients/autocomplete_register", params={"query": query})
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
        data = r.json().get("data", {})
    if not data:
        click.echo("No matches in the EE business registry.")
        return
    click.secho(f"{'REG CODE':<10}  NAME{' ':<36}  R-ID", bold=True)
    for rid, entry in data.items():
        click.echo(f"{entry.get('reg_code',''):<10}  {entry.get('name','')[:40]:<40}  {rid[:30]}…")


@clients.command("lookup")
@click.argument("reg_code")
def clients_lookup(reg_code: str) -> None:
    """Fetch full company details from the EE business registry by reg code."""
    cookies, account = session_or_die()
    with build_http(cookies, account, ajax=True) as http:
        r = http.get(f"{BASE}/{account}/clients/getfromregister", params={"reg_code": reg_code})
        if r.status_code != 200:
            raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
        data = r.json()
    if not data:
        click.echo("No data returned for that reg_code.")
        return
    click.echo(json.dumps(data, indent=2, ensure_ascii=False))


@clients.command("create")
@click.option("--reg-code", default=None, help="EE reg code; auto-fills from registry.")
@click.option("--name", default=None)
@click.option("--reg-no", default="")
@click.option("--vat-no", default="")
@click.option("--country", default="EE", show_default=True)
@click.option("--street", default="")
@click.option("--city", default="")
@click.option("--county", default="")
@click.option("--postal-code", default="")
@click.option("--email", default="")
@click.option("--phone", default="")
@click.option("--language", default="et_EE", show_default=True)
def clients_create(reg_code, name, reg_no, vat_no, country, street, city,
                   county, postal_code, email, phone, language) -> None:
    """Create a client. Use --reg-code to auto-fill from EE registry, or pass fields manually."""
    cookies, account = session_or_die()
    r_id = None

    if reg_code:
        with build_http(cookies, account, ajax=True) as http:
            r = http.get(f"{BASE}/{account}/clients/getfromregister", params={"reg_code": reg_code})
            if r.status_code != 200 or not r.json():
                raise click.ClickException(f"Registry lookup failed: HTTP {r.status_code}")
            reg_data = r.json()[0]
            ac_r = http.get(f"{BASE}/{account}/clients/autocomplete_register",
                            params={"query": reg_data["name"][:8]})
            if ac_r.status_code == 200:
                for rid, entry in ac_r.json().get("data", {}).items():
                    if entry.get("reg_code") == reg_code:
                        r_id = rid
                        break
        name = name or reg_data["name"]
        reg_no = reg_no or reg_data.get("reg_nr", "")
        vat_no = vat_no or reg_data.get("vat_no", "")
        country = country if country != "EE" else reg_data.get("address_country", "EE")
        street = street or reg_data.get("address_street", "")
        city = city or reg_data.get("address_city", "")
        county = county or reg_data.get("address_county", "")
        postal_code = postal_code or reg_data.get("address_postcode", "")
        email = email or reg_data.get("email", "")
        phone = phone or reg_data.get("phone", "")

    if not name:
        raise click.ClickException("--name required (or use --reg-code for EE registry lookup)")

    body = {
        "data[Client][id]": "0",
        "data[Client][name]": name,
        "data[Client][reg_no]": reg_no,
        "data[Client][vat_no]": vat_no,
        "data[Client][is_client]": "1",
        "data[Client][address_street]": street,
        "data[Client][address_city]": city,
        "data[Client][address_county]": county,
        "data[Client][address_country]": country,
        "data[Client][address_postal_code]": postal_code,
        "data[Client][e_mail]": email,
        "data[Client][phone]": phone,
        "data[Client][webpage]": "",
        "data[Client][fax]": "",
        "data[Client][bank]": "",
        "data[Client][account_no]": "",
        "data[Client][swift_code]": "",
        "data[Client][edi_identifier]": "",
        "data[Client][client_settings_due_days]": "",
        "data[Client][client_settings_purchase_due_days]": "",
        "data[Client][client_settings_price_offer_due_days]": "",
        "data[Client][client_settings_supply_days]": "",
        "data[Client][client_settings_discount]": "",
        "data[Client][client_settings_overdue_percent]": "",
        "data[Client][client_settings_language]": language,
        "data[Client][invoice_document_template_id]": "0",
        "data[Client][price_offer_document_template_id]": "0",
        "data[Client][sales_order_document_template_id]": "0",
        "data[Client][client_settings_sales_vat_type_id]": "0",
        "data[Client][client_settings_purchase_vat_type_id]": "0",
        "data[Client][trade_receivables_account_id]": "0",
        "data[Client][trade_creditors_account_id]": "0",
        "data[Client][expense_account_id]": "0",
    }
    if r_id:
        body["client-name"] = r_id

    with build_http(cookies, account) as http:
        body["_csrfToken"] = fetch_fresh_csrf(http, account, path="clients/add")
        http.headers["Referer"] = f"{BASE}/{account}/clients/add"
        http.headers["Origin"] = BASE
        r = http.post(f"{BASE}/{account}/clients/create", data=body)

    m = re.search(r"/clients/view/(\d+)", r.headers.get("location", ""))
    if m:
        cid = m.group(1)
        click.secho(f"✓ Created client {cid}", fg="green", bold=True)
        click.echo(f"  Name    : {name}")
        click.echo(f"  Reg no  : {reg_no}")
        click.echo(f"  VAT no  : {vat_no}")
        click.echo(f"  Address : {street}, {city} {postal_code}, {country}")
        click.echo(f"  URL     : {BASE}/{account}/clients/view/{cid}")
        return
    fail = CONFIG_DIR / "last_create_failure.html"
    fail.write_text(r.text)
    raise click.ClickException(f"Create failed: HTTP {r.status_code}. Response saved → {fail}")


