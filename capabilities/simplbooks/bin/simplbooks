@cli.group()
def accounts() -> None:
    """Chart-of-accounts + bank/clearing accounts."""


def _accounts_listdata(http: httpx.Client, account: str, endpoint: str, limit: int) -> list[dict]:
    cols = [
        ("", "_select"),
        ("code", "code"),
        ("name", "name"),
        ("active", "active"),
        ("reports", "reports"),
        ("id", "_id"),
        ("", "_actions"),
    ]
    data = datatables_payload(cols, order_col=1, length=limit, search="")
    data["order[0][dir]"] = "asc"
    data["columns[3][search][value]"] = "=1"
    data["show_only_active"] = "1"
    http.headers["X-CSRF-Token"] = fetch_fresh_csrf(http, account)
    r = http.post(f"{BASE}/{account}/{endpoint}/listdata", data=data)
    if r.status_code != 200:
        raise click.ClickException(f"HTTP {r.status_code}: {r.text[:300]}")
    return r.json().get("data", [])


@accounts.command("list")
@click.argument("kind", type=click.Choice(list(ACCOUNT_KINDS.keys())), default="chart")
@click.option("--limit", default=200, show_default=True, type=int)
@click.option("--json", "as_json", is_flag=True)
def accounts_list(kind: str, limit: int, as_json: bool) -> None:
    """List accounts: `cashbook` (bank-like clearing accounts) or `chart` (the
    full chart of accounts — income 4xxx, expense 5xxx)."""
    cookies, account = session_or_die()
    endpoint = ACCOUNT_KINDS[kind]
    with build_http(cookies, account, ajax=True) as http:
        rows = _accounts_listdata(http, account, endpoint, limit)

    if as_json:
        click.echo(json.dumps(rows, indent=2, ensure_ascii=False))
        return

    click.secho(f"{kind} accounts: {len(rows)} returned ({endpoint})", fg="cyan")
    click.echo()
    click.secho(f"{'ID':>5}  {'CODE':<10}  {'NAME':<60}  ACTIVE", bold=True)
    for row in rows:
        click.echo(
            f"{str(row.get('id','?')):>5}  "
            f"{strip_html(row.get('code'))[:10]:<10}  "
            f"{strip_html(row.get('name'))[:60]:<60}  "
            f"{strip_html(row.get('active'))[:5]}"
        )


# ─── financial reports (read-only: trial balance / balances at a date) ──────

def _report_num(x) -> float:
    """A report cell → float. SB emits '' for an empty debit/credit side, and
    occasionally a string with a non-breaking space / comma decimal."""
    if x in ("", None):
        return 0.0
    if isinstance(x, (int, float)):
        return float(x)
    s = str(x).replace(" ", "").replace(" ", "").replace(",", ".")
    try:
        return float(s)
    except ValueError:
        return 0.0


def _report_date(s: str) -> str:
    """Accept YYYY-MM-DD or DD.MM.YYYY; return SB's DD.MM.YYYY."""
    s = s.strip()
    for fmt in ("%Y-%m-%d", "%d.%m.%Y"):
        try:
            return datetime.strptime(s, fmt).strftime("%d.%m.%Y")
        except ValueError:
            continue
    raise click.ClickException(f"Bad date {s!r} — use YYYY-MM-DD or DD.MM.YYYY.")


def _report_export_data(http: httpx.Client, account: str, endpoint: str,
                        period_from: str, period_to: str,
                        extra: dict | None = None) -> dict | list:
    """POST a /financial_reports/<endpoint> page for a period and decode the
    base64 `export_data` hidden field it embeds. Balance-type reports decode to
    { "header": [...], "rows": [...] }; the mainledger account card decodes to a
    flat list of HEAD/ROW/PREFOOT/FOOT arrays. SB renders the report server-side
    using the account's saved report config; we override the period and any
    `extra` report[...] fields (e.g. report[financial_account_id]). Same cookies
    for GET (scrape _csrfToken + report[id]) and POST, so the token matches the
    CSRF cookie."""
    url = f"{BASE}/{account}/financial_reports/{endpoint}"
    page = http.get(url)
    if page.status_code != 200:
        raise click.ClickException(
            f"GET financial_reports/{endpoint}: HTTP {page.status_code} "
            "(session stale? run `simplbooks doctor`).")
    soup = BeautifulSoup(page.text, "html.parser")
    csrf = soup.find("input", {"name": "_csrfToken"})
    if not csrf or not csrf.get("value"):
        raise click.ClickException(f"No _csrfToken on {endpoint} — layout changed?")
    data = {
        "_csrfToken": csrf["value"],
        "report[period_from]": period_from,
        "report[period_to]": period_to,
    }
    rid = soup.find("input", {"name": "report[id]"})
    if rid and rid.get("value"):
        data["report[id]"] = rid["value"]
    if extra:
        data.update(extra)
    http.headers["Referer"] = url
    r = http.post(url, data=data)
    if r.status_code != 200:
        raise click.ClickException(f"POST financial_reports/{endpoint}: HTTP {r.status_code}")
    m = re.search(r'name="export_data"\s+value="([^"]+)"', r.text)
    if not m:
        raise click.ClickException(
            f"No export_data in {endpoint} response — session stale or layout changed?")
    return json.loads(base64.b64decode(m.group(1)))


def _parse_trial_balance(payload: dict) -> list[dict]:
    """Käibeandmik export_data → one dict per row. Column layout (13 cols,
    verified against two adjacent periods — a period's closing equals the next
    period's opening): cells[0]='CODE Name'; cells[1]/[2]=opening debit/credit;
    cells[11]/[12]=closing (accumulated) debit/credit. Subtotal/group rows carry
    account_id=None (e.g. 'Varad', 'Kohustused ja omakapital')."""
    out = []
    for row in payload.get("rows", []):
        c = row.get("cells") or []
        if not c:
            continue
        label = str(c[0]).strip()
        aid = row.get("account_id")
        opening = _report_num(c[1]) - _report_num(c[2])
        closing = _report_num(c[11]) - _report_num(c[12])
        code, name = "", label
        if aid is not None:
            parts = label.split(" ", 1)
            code = parts[0]
            name = parts[1] if len(parts) > 1 else ""
        out.append({
            "account_id": aid, "code": code, "name": name,
            "is_group": aid is None,
            "opening": round(opening, 2), "closing": round(closing, 2),
        })
    return out


@cli.group()
def reports() -> None:
    """Read-only financial reports (käibeandmik / account balances at a date)."""


@reports.command("trial-balance")
@click.option("--from", "period_from", required=True,
              help="Period start (YYYY-MM-DD or DD.MM.YYYY).")
@click.option("--to", "period_to", required=True,
              help="Period end (YYYY-MM-DD or DD.MM.YYYY).")
@click.option("--account", "acct_filter", default=None,
              help="Show only accounts whose code or name contains this (a code or name fragment).")
@click.option("--all", "show_all", is_flag=True,
              help="Show every account, including those flat at zero (default hides them).")
@click.option("--json", "as_json", is_flag=True)
def reports_trial_balance(period_from: str, period_to: str, acct_filter: str | None,
                          show_all: bool, as_json: bool) -> None:
    """Käibeandmik — every account's opening + closing balance over a period.

    The CLOSING column is the account's balance AS OF --to: the reconciliation
    workhorse (read a bank account, a payment-processor clearing account, any
    control account, at any date). A positive value is a debit (asset/expense)
    balance, negative a credit (liability/equity/income) balance. The footer sums all closing
    debits vs credits and confirms the books balance (gap ≈ 0)."""
    pf, pt = _report_date(period_from), _report_date(period_to)
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        payload = _report_export_data(http, account, "turnoverstatement", pf, pt)
    all_rows = _parse_trial_balance(payload)

    # Balance check is over EVERY leaf account, independent of the display filter.
    leaves = [r for r in all_rows if not r["is_group"]]
    tot_d = round(sum(r["closing"] for r in leaves if r["closing"] > 0), 2)
    tot_c = round(sum(-r["closing"] for r in leaves if r["closing"] < 0), 2)
    gap = round(tot_d - tot_c, 2)

    rows = all_rows
    if acct_filter:
        f = acct_filter.lower()
        rows = [r for r in rows if f in r["code"].lower() or f in r["name"].lower()]

    if as_json:
        click.echo(json.dumps({
            "period_from": pf, "period_to": pt,
            "closing_debit_total": tot_d, "closing_credit_total": tot_c, "gap": gap,
            "rows": [r for r in rows if not r["is_group"]],
        }, indent=2, ensure_ascii=False))
        return

    click.secho(f"Käibeandmik (trial balance)  {pf} → {pt}", fg="cyan", bold=True)
    click.echo()
    click.secho(f"{'CODE':<8} {'ACCOUNT':<46} {'OPENING':>14} {'CLOSING':>14}", bold=True)
    for r in rows:
        if r["is_group"]:
            continue
        if not show_all and abs(r["closing"]) < 0.005 and abs(r["opening"]) < 0.005:
            continue
        click.echo(f"{r['code']:<8} {r['name'][:46]:<46} "
                   f"{r['opening']:>14,.2f} {r['closing']:>14,.2f}")
    click.echo()
    summary = (f"Σ closing debit {tot_d:,.2f}   Σ closing credit {tot_c:,.2f}   "
               f"gap {gap:+,.2f}")
    if abs(gap) < 0.01:
        click.secho("✓ balanced — " + summary, fg="green")
    else:
        click.secho("⚠ off-balance — " + summary, fg="yellow")


def _parse_account_ledger(payload: list) -> dict:
    """mainledger (Pearaamat / account card) export_data → structured ledger.

    The payload is a flat list of tagged arrays:
      ["HEAD", ["Kande nr.",..], ["<code> <name>",..], ["Selgitus",..], ["Kuupäev",..],
               ["Deebet",..], ["Kreedit",..], ["Saldo",..]]
      ["ROW", <kanne_nr|"">, <description>, <note>, <DD.MM.YYYY>, <debit>, <credit>, <running_saldo>]
      ["PREFOOT", "", "<period movements>", "", <date>, <debit_sum>, <credit_sum>, <net>]
      ["FOOT", "", "<closing>", "", <date>, <debit_tot>, <credit_tot>, <closing_saldo>]
    The first ROW (description "algsaldo") is the opening balance. Saldo is the
    running balance signed as debit-positive."""
    account_label, opening, closing, period = "", None, None, {}
    moves: list[dict] = []
    for r in payload:
        if not r:
            continue
        tag = r[0]
        if tag == "HEAD":
            account_label = str(r[2][0]).strip() if len(r) > 2 and r[2] else ""
            continue
        if tag in ("ROW", "PREFOOT", "FOOT"):
            kanne, desc, note = r[1], str(r[2]).strip(), str(r[3]).strip()
            date, debit, credit, saldo = r[4], _report_num(r[5]), _report_num(r[6]), _report_num(r[7])
        else:
            continue
        if tag == "ROW" and desc == "algsaldo":
            opening = saldo
            continue
        if tag == "PREFOOT":
            period = {"debit": round(debit, 2), "credit": round(credit, 2),
                      "net": round(saldo, 2)}
            continue
        if tag == "FOOT":
            closing = saldo
            continue
        moves.append({
            "doc_nr": kanne if kanne != "" else None,
            "date": date, "description": desc, "note": note,
            "debit": round(debit, 2), "credit": round(credit, 2),
            "saldo": round(saldo, 2),
        })
    return {"account": account_label, "opening": opening, "closing": closing,
            "period": period, "moves": moves}


@reports.command("account-ledger")
@click.argument("account_id", type=int)
@click.option("--from", "period_from", required=True,
              help="Period start (YYYY-MM-DD or DD.MM.YYYY).")
@click.option("--to", "period_to", required=True,
              help="Period end (YYYY-MM-DD or DD.MM.YYYY).")
@click.option("--json", "as_json", is_flag=True)
def reports_account_ledger(account_id: int, period_from: str, period_to: str,
                           as_json: bool) -> None:
    """Pearaamat — one account's line-by-line movements over a period.

    The account card (kontokaart): opening balance, every entry that touched the
    account with a running saldo, then the period's debit/credit totals and the
    closing balance. The drill-down behind a trial-balance figure — see WHICH
    entries moved an account when reconciling a control/clearing/bank account or
    chasing where a balance came from.

    ACCOUNT_ID is the COA id (the `id` column of `accounts list chart`, e.g. 214
    for 1535). The DOC NR column is SimplBooks' journal/document number (Kande
    nr., as shown in the SB UI) — this is NOT the id that `kanne show` takes; to
    open an underlying entry from the CLI find it with `kanne list --search` by
    its date + description. Saldo is debit-positive (a positive saldo is a
    debit/asset balance, negative a credit/liability balance)."""
    pf, pt = _report_date(period_from), _report_date(period_to)
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        payload = _report_export_data(
            http, account, "mainledger", pf, pt,
            extra={"report[financial_account_id]": str(account_id)})
    if not isinstance(payload, list):
        raise click.ClickException("Unexpected mainledger payload shape — layout changed?")
    led = _parse_account_ledger(payload)

    if as_json:
        click.echo(json.dumps(led, indent=2, ensure_ascii=False))
        return

    click.secho(f"Pearaamat — {led['account'] or account_id}   {pf} → {pt}",
                fg="cyan", bold=True)
    click.echo()
    op = led["opening"] or 0.0
    click.echo(f"{'':>10}  {'DOC NR':>7}  {'':<46}  {'DEBIT':>11}  {'CREDIT':>11}  {'SALDO':>12}")
    click.secho(f"{'opening':>10}  {'':>7}  {'algsaldo':<46}  {'':>11}  {'':>11}  {op:>12,.2f}",
                fg="white")
    for m in led["moves"]:
        click.echo(
            f"{m['date']:>10}  {str(m['doc_nr'] or ''):>7}  {m['description'][:46]:<46}  "
            f"{m['debit']:>11,.2f}  {m['credit']:>11,.2f}  {m['saldo']:>12,.2f}")
    cl = led["closing"]
    click.echo()
    p = led["period"]
    if p:
        click.echo(f"period movements: debit {p['debit']:,.2f}   credit {p['credit']:,.2f}   "
                   f"net {p['net']:+,.2f}")
    if cl is not None:
        click.secho(f"closing saldo as of {pt}: {cl:,.2f}", fg="green", bold=True)


# ─── kmd (VAT return / käibedeklaratsioon) ──────────────────────────────────

@cli.group()
def kmd() -> None:
    """Käibedeklaratsioon (KMD / VAT return) — read the declaration SB computes
    from the books, reconcile it against what was filed, and (when the e-MTA
    integration is active) draft / submit / amend it."""


def _parse_vatstatement(payload: dict) -> dict:
    """vatstatement export_data → the KMD declaration form. Top-level rows carry a
    `code` (the KMD line: '1','2','3','4','5','5.3','12','13'…) and cells=[label,
    value]; rows with `parent_row_id`+`account_id` are the contributing-account
    breakdown under a line. Returns the coded lines and a code→value map."""
    lines: list[dict] = []
    by_code: dict[str, float] = {}
    for row in payload.get("rows", []):
        code = row.get("code")
        if code is None:
            continue
        cells = row.get("cells") or ["", 0]
        label = str(cells[0]).strip()
        val = round(_report_num(cells[1]) if len(cells) > 1 else 0.0, 2)
        lines.append({"code": str(code), "label": label, "value": val})
        by_code[str(code)] = val
    return {"lines": lines, "by_code": by_code}


def _kmd_net(by_code: dict) -> float:
    """Signed net VAT for the period: +payable (line 12) / −refund (line 13)."""
    return round(by_code.get("12", 0.0) - by_code.get("13", 0.0), 2)


@kmd.command("show")
@click.option("--period", "period", required=True, help="Tax period YYYY-MM (e.g. 2025-06).")
@click.option("--json", "as_json", is_flag=True)
def kmd_show(period: str, as_json: bool) -> None:
    """The käibedeklaratsioon (KMD form) SB computes from the books for a period.

    Every declaration line (1–13 and sub-lines) with the value SB would file —
    the books' own version of the return, to reconcile against what was actually
    filed to e-MTA. Line 12 is VAT payable, line 13 VAT refundable.

    This vatstatement figure — NOT the VAT closing (VatClosure) legs — is the
    books' authoritative version of the return, the figure to reconcile a filed
    declaration against. Closing legs can be manually adjusted, can under-drain
    input VAT, and can leave a residual debit on the VAT settlement account
    that has nothing to do with what the return should say; never reconcile by
    reading closure legs."""
    pf, pt = _kmd_period_bounds(period)
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        payload = _report_export_data(http, account, "vatstatement", pf, pt)
    decl = _parse_vatstatement(payload)
    net = _kmd_net(decl["by_code"])

    if as_json:
        click.echo(json.dumps({"period": period, "period_from": pf, "period_to": pt,
                               "net": net, **decl}, indent=2, ensure_ascii=False))
        return

    click.secho(f"Käibedeklaratsioon (KMD)  {period}   ({pf} → {pt})", fg="cyan", bold=True)
    click.echo()
    click.secho(f"{'LINE':<6} {'DESCRIPTION':<58} {'AMOUNT':>13}", bold=True)
    for ln in decl["lines"]:
        click.echo(f"{ln['code']:<6} {ln['label'][:58]:<58} {ln['value']:>13,.2f}")
    click.echo()
    if net >= 0:
        click.secho(f"net VAT payable (line 12−13): {net:,.2f}", fg="yellow", bold=True)
    else:
        click.secho(f"net VAT refundable (line 12−13): {net:,.2f}", fg="green", bold=True)


def _kmd_period_for_month(http, account, year: int, month: int) -> dict:
    """Fetch + parse the books' KMD for one month; return code→value + net."""
    pf, pt = _kmd_period_bounds(f"{year:04d}-{month:02d}")
    payload = _report_export_data(http, account, "vatstatement", pf, pt)
    decl = _parse_vatstatement(payload)
    return {"month": month, "by_code": decl["by_code"], "net": _kmd_net(decl["by_code"])}


@kmd.command("list")
@click.option("--year", type=int, required=True, help="Calendar year, e.g. 2025.")
@click.option("--json", "as_json", is_flag=True)
def kmd_list(year: int, as_json: bool) -> None:
    """Per-month KMD overview for a year — the books' output VAT (line 4), input
    VAT (line 5) and net (line 12−13) for every month, the reconciliation backbone."""
    cookies, account = session_or_die()
    rows = []
    with build_http(cookies, account) as http:
        for mo in range(1, 13):
            r = _kmd_period_for_month(http, account, year, mo)
            bc = r["by_code"]
            rows.append({"month": mo, "out": bc.get("4", 0.0), "input": bc.get("5", 0.0),
                         "payable": bc.get("12", 0.0), "refund": bc.get("13", 0.0),
                         "net": r["net"]})

    if as_json:
        click.echo(json.dumps({"year": year, "months": rows}, indent=2, ensure_ascii=False))
        return

    click.secho(f"KMD overview — {year} (from the books)", fg="cyan", bold=True)
    click.echo()
    click.secho(f"{'MONTH':<8} {'OUT(4)':>11} {'INPUT(5)':>11} {'PAYABLE(12)':>13} "
                f"{'REFUND(13)':>12} {'NET':>11}", bold=True)
    tot = 0.0
    for r in rows:
        tot = round(tot + r["net"], 2)
        click.echo(f"{year}-{r['month']:02d}  {r['out']:>11,.2f} {r['input']:>11,.2f} "
                   f"{r['payable']:>13,.2f} {r['refund']:>12,.2f} {r['net']:>11,.2f}")
    click.echo()
    click.secho(f"Σ net VAT over {year}: {tot:+,.2f}  (+payable / −refund)", bold=True)


def _parse_filed_kmd_csv(path: str) -> dict:
    """An e-MTA KMD export (the per-period declaration CSV) → {year, months:{m:{code:val}}}.
    Rows are keyed by the language-independent line code in column 0 ('R4','R5',
    'R12','R13'); month columns are located from the header's 'M.YYYY' period tags.
    Decimal comma, ';' delimiter, empty cell = 0."""
    import csv as _csv
    raw = Path(path).read_text(encoding="utf-8-sig", errors="replace")
    rows = list(_csv.reader(raw.splitlines(), delimiter=";"))
    month_cols: dict[int, int] = {}   # column index → month number
    year = None
    for r in rows:
        for idx, cell in enumerate(r):
            m = re.search(r"\b(\d{1,2})\.(\d{4})\b", cell)
            if m and idx >= 2:
                month_cols[idx] = int(m.group(1))
                year = int(m.group(2))
        if month_cols:
            break
    if not month_cols:
        raise click.ClickException("Couldn't find month columns (M.YYYY headers) in the CSV.")
    wanted = {"R4", "R5", "R12", "R13", "R1"}
    months: dict[int, dict] = {}
    for r in rows:
        if not r:
            continue
        code = r[0].strip().strip('"')
        if code not in wanted:
            continue
        for idx, mo in month_cols.items():
            val = _report_num(r[idx]) if idx < len(r) else 0.0
            months.setdefault(mo, {})[code] = round(val, 2)
    return {"year": year, "months": months}


@kmd.command("reconcile")
@click.option("--filed", "filed_csv", required=True, type=click.Path(dir_okay=False, exists=True),
              help="The e-MTA KMD export CSV of what was actually filed.")
@click.option("--year", type=int, default=None, help="Override the year (else read from the CSV).")
@click.option("--tolerance", type=float, default=0.05,
              help="Per-month net gap (EUR) treated as rounding noise (default 0.05).")
@click.option("--json", "as_json", is_flag=True)
def kmd_reconcile(filed_csv: str, year: int | None, tolerance: float, as_json: bool) -> None:
    """Reconcile the books' KMD against what was filed to e-MTA.

    Parses a filed KMD export CSV and, for every month, compares the filed net VAT
    (filed line 12 − line 13) to what SB computes from the books today. Months whose
    net differs by more than a cent are flagged — those are the declarations to amend."""
    filed = _parse_filed_kmd_csv(filed_csv)
    yr = year or filed["year"]
    if not yr:
        raise click.ClickException("No year in the CSV — pass --year.")

    cookies, account = session_or_die()
    out = []
    with build_http(cookies, account) as http:
        for mo in range(1, 13):
            fm = filed["months"].get(mo)
            if not fm:
                continue
            books = _kmd_period_for_month(http, account, yr, mo)
            filed_net = round(fm.get("R12", 0.0) - fm.get("R13", 0.0), 2)
            books_net = books["net"]
            delta = round(books_net - filed_net, 2)
            out.append({
                "month": mo, "filed_net": filed_net, "books_net": books_net, "delta": delta,
                "filed_input": fm.get("R5", 0.0), "books_input": books["by_code"].get("5", 0.0),
                "filed_output": fm.get("R4", 0.0), "books_output": books["by_code"].get("4", 0.0),
                "ties": abs(delta) <= tolerance,
            })

    mismatches = [r for r in out if not r["ties"]]
    if as_json:
        click.echo(json.dumps({"year": yr, "rows": out,
                               "mismatch_months": [r["month"] for r in mismatches]},
                              indent=2, ensure_ascii=False))
        return

    click.secho(f"KMD reconciliation — {yr}   (books vs filed)", fg="cyan", bold=True)
    click.echo()
    click.secho(f"{'MONTH':<8} {'FILED NET':>12} {'BOOKS NET':>12} {'Δ(books−filed)':>15}  {'':<6}", bold=True)
    for r in out:
        mark = "ok" if r["ties"] else "DIFF"
        col = "green" if r["ties"] else "yellow"
        line = (f"{yr}-{r['month']:02d}  {r['filed_net']:>12,.2f} {r['books_net']:>12,.2f} "
                f"{r['delta']:>+15,.2f}  ")
        click.echo(line, nl=False)
        click.secho(mark, fg=col, bold=not r["ties"])
    click.echo()
    if not mismatches:
        click.secho("✓ every filed month ties to the books.", fg="green", bold=True)
        return
    click.secho(f"⚠ {len(mismatches)} month(s) differ — amend candidates:", fg="yellow", bold=True)
    for r in mismatches:
        favour = "in our favour" if r["delta"] < 0 else "against us"
        click.echo(f"  {yr}-{r['month']:02d}: Δ {r['delta']:+,.2f} ({favour})   "
                   f"input books {r['books_input']:,.2f} vs filed {r['filed_input']:,.2f}; "
                   f"output books {r['books_output']:,.2f} vs filed {r['filed_output']:,.2f}")


def _emta_integration_active(http, account: str) -> bool:
    """True when direct e-MTA filing is wired. The settings page offers an
    'Aktiveeri' / token-verification form while it is OFF; once linked that
    activation affordance is gone."""
    r = http.get(f"{BASE}/{account}/integrations/settings/emta")
    if r.status_code != 200:
        return False
    body = r.text.lower()
    return "aktiveeri" not in body and "user_verification/send_link" not in body


def _require_emta_active() -> tuple:
    """Gate for the two e-MTA-filing leaves. Returns (cookies, account) when the
    integration is live; exits 4 (policy) with the activation path when it is not."""
    cookies, account = session_or_die()
    with build_http(cookies, account) as http:
        if not _emta_integration_active(http, account):
            _die(4, "emta_inactive",
                 "Direct e-MTA filing is not activated for this account.\n"
                 "  → one-time, out-of-band (KZ): SimplBooks → Seaded → Integratsioonid → "
                 "e-MTA → Aktiveeri, and authorise SimplBooks in e-MTA.\n"
                 "  Once active, the submit/amend flow gets wired against the live "
                 "send action and verified before first use.")
    return cookies, account


@kmd.command("submit")
@click.option("--period", required=True, help="Tax period YYYY-MM to file.")
@click.option("--yes", is_flag=True, help="Skip the confirmation prompt.")
def kmd_submit(period: str, yes: bool) -> None:
    """File the period's KMD to e-MTA directly (requires the e-MTA integration).

    Filing a declaration to the tax authority is an external, effectively
    irreversible act: it always confirms first (unless --yes) and only runs when
    the e-MTA integration is active."""
    _require_emta_active()
    raise click.ClickException(
        "e-MTA integration reports active, but the live send action has not been "
        "wired/verified yet — ping the operator to finish `kmd submit` against the "
        "real flow before filing. (Refusing to POST a declaration blind.)")


@kmd.command("amend")
@click.option("--period", required=True, help="Tax period YYYY-MM to re-file (parandusdeklaratsioon).")
@click.option("--yes", is_flag=True, help="Skip the confirmation prompt.")
def kmd_amend(period: str, yes: bool) -> None:
    """Re-file a corrected KMD for a past period (parandusdeklaratsioon) to e-MTA.

    Same gate and caution as `submit`: external, effectively irreversible, e-MTA
    integration required."""
    _require_emta_active()
    raise click.ClickException(
        "e-MTA integration reports active, but the live amend action has not been "
        "wired/verified yet — ping the operator to finish `kmd amend` against the "
        "real flow before re-filing. (Refusing to POST a declaration blind.)")


def _vatstatement_page_html(http: httpx.Client, account: str, period_from: str) -> str:
    """Render the vatstatement report page for `period_from` (DD.MM.YYYY,
    first-of-month). The GET seeds csrf + the saved-report id; the POST switches
    SB's session period and re-renders the page with the per-line change-flag
    column populated (col-type-change cells gain `text-danger` for any line that
    moved since the period was confirmed). Only report[period_from] is sent —
    omitting period_to is what makes SB treat the visit as a period switch."""
    url = f"{BASE}/{account}/financial_reports/vatstatement"
    r = http.get(url)
    if _session_stale(r):
        auto_login_attempt(interactive=False)
        creds = load_credentials()
        http.cookies = httpx.Cookies(parse_cookie_string(creds["SIMPLBOOKS_COOKIE"]))
        r = http.get(url)
    if r.status_code != 200:
        raise click.ClickException(f"GET vatstatement returned {r.status_code}")
    soup = BeautifulSoup(r.text, "html.parser")
    tok = soup.find("input", {"name": "_csrfToken"})
    rid = soup.find("input", {"name": "report[id]"})
    if not tok or not tok.get("value") or not rid or not rid.get("value"):
        raise click.ClickException("vatstatement page layout changed — no _csrfToken / report[id].")
    body = [
        ("_csrfToken", tok["value"]),
        ("report[id]", rid["value"]),
        ("report[name]", "vatstatement"),
        ("report[is_saved_recently]", ""),
        ("report[did_transaction_save_fail]", ""),
        ("report[send_success_msg]", ""),
        ("report[period_from]", period_from),
    ]
    headers = {"Referer": url, "Origin": BASE,
               "Content-Type": "application/x-www-form-urlencoded"}
    r2 = http.post(url, content=urlencode(body), headers=headers, follow_redirects=True)
    if r2.status_code != 200:
        raise click.ClickException(f"POST vatstatement returned {r2.status_code}")
    return r2.text


def _vat_change_flags(html: str) -> list[dict]:
    """Per-row scrape of SB's change-since-confirm flags on the rendered
    vatstatement page. A row whose `col-type-change` cell also carries
    `text-danger` is a flagged declaration line; we extract the line code from
    the row header's `title` attr (e.g. '5. Kokku sisendkäibemaksusumma…' → '5')
    and the red cell's stripped text. Empty list ⇒ the month reconciles."""
    soup = BeautifulSoup(html, "html.parser")
    flagged: list[dict] = []
    for tr in soup.find_all("tr"):
        td = tr.find("td", class_=lambda c: c and "col-type-change" in c and "text-danger" in c)
        if not td:
            continue
        header = tr.find(["th", "td"])
        line = ""
        if header is not None:
            t = (header.get("title") or "").strip()
            m = re.match(r"(\d+(?:\.\d+)*)", t)
            if m:
                line = m.group(1)
        flagged.append({"line": line, "value": td.get_text(strip=True)})
    return flagged


@kmd.command("check")
@click.option("--year", type=int, required=True, help="Calendar year, e.g. 2025.")
@click.option("--filed", "filed_csv", default=None,
              type=click.Path(dir_okay=False, exists=True),
              help="Optional e-MTA KMD export CSV — adds the books-vs-filed net delta per month.")
@click.option("--json", "as_json", is_flag=True)
def kmd_check(year: int, filed_csv: str | None, as_json: bool) -> None:
    """SimpleBooks' own per-period KMD reconciliation signal, per line.

    On the vatstatement report page SB flags every declaration line that moved
    since the period was confirmed (the `col-type-change` cell gets `text-danger`).
    This walks all 12 months of --year and reports SB's verdict — RECONCILES, or
    the flagged R<line>=<value> list. With --filed, also computes the books-vs-filed
    net delta per month (same parsing as `kmd reconcile`)."""
    cookies, account = session_or_die()
    filed = _parse_filed_kmd_csv(filed_csv) if filed_csv else None

    rows: list[dict] = []
    with build_http(cookies, account) as http:
        for mo in range(1, 13):
            pf = f"01.{mo:02d}.{year:04d}"
            html = _vatstatement_page_html(http, account, pf)
            flags = _vat_change_flags(html)
            row: dict = {"month": mo, "reconciles": not flags, "flags": flags}
            if filed is not None:
                fm = filed["months"].get(mo)
                if fm:
                    books = _kmd_period_for_month(http, account, year, mo)
                    filed_net = round(fm.get("R12", 0.0) - fm.get("R13", 0.0), 2)
                    row["filed_net"] = filed_net
                    row["books_net"] = books["net"]
                    row["delta"] = round(books["net"] - filed_net, 2)
                else:
                    row["filed_net"] = None
                    row["books_net"] = None
                    row["delta"] = None
            rows.append(row)

    if as_json:
        click.echo(json.dumps({"year": year, "months": rows}, indent=2, ensure_ascii=False))
        return

    click.secho(f"KMD check — {year}   (SimpleBooks per-period change flags)",
                fg="cyan", bold=True)
    click.echo()
    head = f"{'MONTH':<8} {'SB STATUS':<48}"
    if filed is not None:
        head += f"  {'Δ(books−filed)':>15}"
    click.secho(head, bold=True)
    for r in rows:
        if r["reconciles"]:
            status, col = "RECONCILES", "green"
        else:
            status = " ".join(f"R{f['line']}={f['value']}" for f in r["flags"])
            col = "yellow"
        click.echo(f"{year}-{r['month']:02d}  ", nl=False)
        click.secho(f"{status[:48]:<48}", fg=col, bold=not r["reconciles"], nl=False)
        if filed is not None:
            d = r.get("delta")
            if d is None:
                click.echo(f"  {'-':>15}")
            else:
                click.echo(f"  {d:>+15,.2f}")
        else:
            click.echo()
    click.echo()
    diffs = [r for r in rows if not r["reconciles"]]
    if not diffs:
        click.secho("✓ every month reconciles per SimpleBooks.", fg="green", bold=True)
    else:
        click.secho(f"⚠ {len(diffs)} month(s) flagged by SimpleBooks — review the lines above.",
                    fg="yellow", bold=True)


def _find_vatclosure_id(period_html: str) -> int | None:
    """The closure row on the vatstatement period page exposes financial_transactions/
    delete/<id> and /edit/<id> links — pull the id from whichever appears first."""
    m = re.search(r"/financial_transactions/(?:delete|edit)/(\d+)", period_html)
    return int(m.group(1)) if m else None


def _harvest_closure_form(period_html: str) -> tuple[list[tuple[str, str]], list[str], str]:
    """SB re-renders an inline VatClosure create-form on the period page
    (id='transaction-form') only when there is no closure for the period. Harvest
    every input/select/textarea, the leg keys (in order seen), and the csrf — the
    fresh, SB-computed legs are exactly what this form carries."""
    soup = BeautifulSoup(period_html, "html.parser")
    form = soup.find("form", {"id": "transaction-form"})
    if not form:
        raise click.ClickException(
            "No #transaction-form on the period page — expected SB's fresh VatClosure "
            "create-form after the delete. Page layout changed?")
    fields: list[tuple[str, str]] = []
    keys_seen: list[str] = []
    seen: set[str] = set()
    for el in form.find_all(["input", "select", "textarea"]):
        name = el.get("name")
        if not name:
            continue
        itype = (el.get("type") or "").lower()
        if itype in ("file", "submit", "button", "reset"):
            continue
        if el.name == "select":
            opt = el.find("option", selected=True)
            value = opt.get("value", "") if opt else ""
        elif el.name == "textarea":
            value = el.get_text()
        else:
            if itype == "checkbox" and not el.has_attr("checked"):
                continue
            value = el.get("value", "")
        fields.append((name, value or ""))
        m = KANNE_LINE_RE.fullmatch(name)
        if m and m.group(1) not in seen:
            keys_seen.append(m.group(1))
            seen.add(m.group(1))
    csrf_input = form.find("input", {"name": "_csrfToken"}) or soup.find("input", {"name": "_csrfToken"})
    if not csrf_input or not csrf_input.get("value"):
        raise click.ClickException("No _csrfToken on inline transaction-form.")
    if not keys_seen:
        raise click.ClickException("Inline transaction-form carries no legs — SB did not prefill.")
    return fields, keys_seen, csrf_input["value"]


def _format_closure_legs(lines: dict, acct_map: dict) -> tuple[list[dict], dict]:
    """Render `_scrape_kanne_edit_form` lines + an account map into a sorted list
    of {idx, account_*, debit, credit, note} plus a balance dict — the same view
    `kanne show` builds, lifted here for closure-side display."""
    def _ord(kv):
        return int(kv[0]) if kv[0].isdigit() else 9999
    legs = []
    for idx, ln in sorted(lines.items(), key=_ord):
        aid = str(ln.get("financial_account_id") or "")
        info = acct_map.get(aid, {})
        legs.append({
            "idx": idx,
            "account_id": aid,
            "account_code": info.get("code", ""),
            "account_name": info.get("name", ""),
            "debit": ln.get("transaction_sum_debit", "0,00"),
            "credit": ln.get("transaction_sum_credit", "0,00"),
            "note": ln.get("account_note", ""),
        })
    debit, credit = _kanne_balance(lines)
    bal = {"debit": round(debit, 2), "credit": round(credit, 2),
           "ok": abs(debit - credit) < 0.005}
    return legs, bal


def _print_closure_legs(legs: list[dict], balance: dict) -> None:
    click.secho(f"  {'#':>3}  {'ACCOUNT':<42}  {'DEBIT':>11}  {'CREDIT':>11}  NOTE", bold=True)
    for leg in legs:
        acct = f"{leg['account_id']:>4} {leg['account_code']} {leg['account_name']}".strip()
        click.echo(
            f"  {leg['idx'][:3]:>3}  {acct[:42]:<42}  "
            f"{leg['debit']:>11}  {leg['credit']:>11}  {leg['note']}"
        )
    tie = "✓" if balance["ok"] else "✗ DOES NOT BALANCE"
    click.echo(f"  {'':>3}  {'balance':<42}  "
               f"{balance['debit']:>11.2f}  {balance['credit']:>11.2f}  {tie}")


def _print_regenerate_preview(period: str, figures: dict, old_id: int,
                              old_legs: list[dict], old_balance: dict) -> None:
    click.secho(f"KMD regenerate — {period}   (regenerate preview)", fg="cyan", bold=True)
    click.echo()
    click.echo(f"  Existing closure : kanne {old_id}")
    click.echo(f"  Books KMD        : output(4) {figures['output']:,.2f}   "
               f"input(5) {figures['input']:,.2f}")
    click.echo(f"                     payable(12) {figures['payable']:,.2f}  "
               f"refund(13) {figures['refund']:,.2f}  net {figures['net']:+,.2f}")
    click.echo()
    click.secho("Current closure legs:", bold=True)
    _print_closure_legs(old_legs, old_balance)


def _print_create_preview(period: str, figures: dict,
                          proposed_legs: list[dict], proposed_balance: dict) -> None:
    click.secho(f"KMD regenerate — {period}   (create preview)", fg="cyan", bold=True)
    click.echo()
    click.echo(f"  Existing closure : (none)")
    click.echo(f"  Books KMD        : output(4) {figures['output']:,.2f}   "
               f"input(5) {figures['input']:,.2f}")
    click.echo(f"                     payable(12) {figures['payable']:,.2f}  "
               f"refund(13) {figures['refund']:,.2f}  net {figures['net']:+,.2f}")
    click.echo()
    click.secho("Proposed closure legs (from SB's inline create-form):", bold=True)
    _print_closure_legs(proposed_legs, proposed_balance)


def _has_inline_closure_form(html: str) -> bool:
    """True when the period page renders SB's inline VatClosure create-form
    (id='transaction-form'). SB renders it when no closure exists for the period
    and SB has any VAT activity to close; absent on zero-VAT periods."""
    return BeautifulSoup(html, "html.parser").find("form", {"id": "transaction-form"}) is not None


def _lines_from_harvested(fields: list[tuple[str, str]]) -> dict[str, dict]:
    """Group harvested form fields by leg key → {attr: value}, mirroring
    `_scrape_kanne_edit_form`'s `lines` shape so the same formatters work."""
    out: dict[str, dict] = {}
    for n, v in fields:
        m = KANNE_LINE_RE.fullmatch(n)
        if m:
            out.setdefault(m.group(1), {})[m.group(2)] = v
    return out


def _submit_inline_closure(http: httpx.Client, account: str, period_dm: str,
                           cookies: dict) -> tuple[int, list[dict], dict]:
    """Harvest the period's inline VatClosure create-form, drop the zero-sum
    rounding leg the browser omits, urlencoded POST to financial_transactions/update,
    then verify by re-fetching the period and reading the new closure's legs.
    Shared by the create branch (no prior closure) and the regenerate branch
    (after the stale closure was deleted)."""
    fresh_page = _vatstatement_page_html(http, account, period_dm)
    harvested, leg_keys, form_csrf = _harvest_closure_form(fresh_page)

    by_key: dict[str, dict[str, str]] = {}
    for n, v in harvested:
        m = KANNE_LINE_RE.fullmatch(n)
        if m:
            by_key.setdefault(m.group(1), {})[m.group(2)] = v
    drop_keys: set[str] = set()
    for k in leg_keys:
        leg = by_key.get(k, {})
        debit = _amount_float(leg.get("transaction_sum_debit") or "0")
        credit = _amount_float(leg.get("transaction_sum_credit") or "0")
        if debit == 0.0 and credit == 0.0:
            drop_keys.add(k)

    body: list[tuple[str, str]] = []
    for n, v in harvested:
        m = KANNE_LINE_RE.fullmatch(n)
        if m and m.group(1) in drop_keys:
            continue
        body.append((n, v))
    _set_field(body, "_csrfToken", form_csrf)

    http.headers["Referer"] = f"{BASE}/{account}/financial_reports/vatstatement"
    http.headers["Origin"] = BASE
    encoded = urlencode(body)
    r = http.post(f"{BASE}/{account}/financial_transactions/update", content=encoded, headers={"Content-Type": "application/x-www-form-urlencoded"})
    if r.status_code not in (200, 302):
        fail = CONFIG_DIR / "last_kmd_regenerate_failure.html"
        fail.write_text(r.text)
        raise click.ClickException(
            f"submit returned HTTP {r.status_code}. Response → {fail}")

    verify_page = _vatstatement_page_html(http, account, period_dm)
    new_id = _find_vatclosure_id(verify_page)
    if new_id is None:
        raise click.ClickException(
            "re-rendered period page carries no VatClosure id — the closure may "
            "not have been created.")
    _f, new_lines, _ri, _csrf2 = _scrape_kanne_edit_form(http, account, new_id)
    with build_http(cookies, account, ajax=True) as ajax:
        acct_map = _resolve_accounts(ajax, account)
    new_legs, new_balance = _format_closure_legs(new_lines, acct_map)
    if not new_balance["ok"]:
        raise click.ClickException(
            f"new closure {new_id} does not balance "
            f"(debit {new_balance['debit']:.2f} vs credit {new_balance['credit']:.2f}).")
    return new_id, new_legs, new_balance


@kmd.command("regenerate")
@click.option("--period", required=True, help="Tax period YYYY-MM to regenerate the closure for.")
@click.option("--apply", "do_apply", is_flag=True,
              help="Perform the delete + recreate (default: dry-run preview only).")
@click.option("--yes", is_flag=True,
              help="Skip the interactive confirmation (required with --apply + --json / non-tty).")
@click.option("--json", "as_json", is_flag=True)
def kmd_regenerate(period: str, do_apply: bool, yes: bool, as_json: bool) -> None:
    """Create a missing VAT closing kanne or regenerate a stale one.

    The closing kanne (Käibemaksu kontode sulgemine, base_object_type=VatClosure)
    is what zeroes the input/output VAT accounts into the settlement account at
    period end. SB only computes fresh legs from its inline VatClosure create-form
    on the vatstatement page — it does not recompute a saved closure in place.
    This command transparently handles both states:

      - no prior closure ⇒ create:     submit the inline create-form SB has
                                       already prefilled with the fresh legs.
      - existing closure ⇒ regenerate: delete the stale one so SB re-renders its
                                       inline create-form, then submit.

    Modes:
      dry-run (default)  preview proposed legs (create) or existing+books figures
                         (regenerate) and exit. No mutation.
      --apply            create or delete+recreate, then re-fetch the period and
                         confirm the new closure balances. On regenerate, a
                         recreate failure AFTER the delete is fatal and loud
                         (period left with no closure — recreate manually).

    --apply on a declared period confirms first (type 'yes'); pass --yes alongside
    --json or in non-interactive runs.

    Reverse-charge input VAT is excluded from the VAT settlement account's
    closing leg by design, so that leg sitting below KMD line 5 (R5) by exactly
    the reverse-charge amount is correct, not stale — do not treat that gap as
    a reason to regenerate."""
    pf, pt = _kmd_period_bounds(period)
    yr, mo = period.split("-")
    period_dm = f"01.{mo}.{yr}"
    cookies, account = session_or_die()

    with build_http(cookies, account) as http:
        page = _vatstatement_page_html(http, account, period_dm)
        old_id = _find_vatclosure_id(page)

        payload = _report_export_data(http, account, "vatstatement", pf, pt)
        decl = _parse_vatstatement(payload)
        net = _kmd_net(decl["by_code"])
        figures = {
            "output": decl["by_code"].get("4", 0.0),
            "input": decl["by_code"].get("5", 0.0),
            "payable": decl["by_code"].get("12", 0.0),
            "refund": decl["by_code"].get("13", 0.0),
            "net": net,
        }

        old_legs: list[dict] = []
        old_balance: dict | None = None
        proposed_legs: list[dict] = []
        proposed_balance: dict | None = None

        if old_id is not None:
            operation = "regenerate"
            _f, lines, _ri, _csrf = _scrape_kanne_edit_form(http, account, old_id)
            with build_http(cookies, account, ajax=True) as ajax:
                acct_map = _resolve_accounts(ajax, account)
            old_legs, old_balance = _format_closure_legs(lines, acct_map)
        else:
            operation = "create"
            if not _has_inline_closure_form(page):
                noop = {
                    "period": period, "operation": "noop", "applied": False,
                    "figures": figures,
                    "old_closure_id": None, "old_legs": [], "old_balance": None,
                    "proposed_legs": [], "proposed_balance": None,
                    "new_closure_id": None, "new_legs": [], "new_balance": None,
                }
                if as_json:
                    click.echo(json.dumps(noop, indent=2, ensure_ascii=False))
                    return
                click.secho(f"KMD regenerate — {period}", fg="cyan", bold=True)
                click.secho("No VAT closure on this period and no inline create-form rendered "
                            "— SB sees no VAT activity to close.", fg="yellow")
                click.echo(f"  → books' KMD for {period}: net {net:+,.2f} EUR.")
                return

            harvested, _keys, _csrf = _harvest_closure_form(page)
            harvested_lines = _lines_from_harvested(harvested)
            with build_http(cookies, account, ajax=True) as ajax:
                acct_map = _resolve_accounts(ajax, account)
            proposed_legs, proposed_balance = _format_closure_legs(harvested_lines, acct_map)

        report: dict = {
            "period": period, "operation": operation, "applied": False,
            "figures": figures,
            "old_closure_id": old_id,
            "old_legs": old_legs,
            "old_balance": old_balance,
            "proposed_legs": proposed_legs,
            "proposed_balance": proposed_balance,
            "new_closure_id": None,
            "new_legs": [],
            "new_balance": None,
        }

        if not do_apply:
            if as_json:
                click.echo(json.dumps(report, indent=2, ensure_ascii=False))
                return
            if operation == "regenerate":
                _print_regenerate_preview(period, figures, old_id, old_legs, old_balance)
                click.echo()
                click.secho("(dry-run) re-run with --apply to delete and recreate.", fg="cyan")
                click.secho("  The exact fresh legs are produced by SimplBooks during --apply.",
                            fg="cyan")
            else:
                _print_create_preview(period, figures, proposed_legs, proposed_balance)
                click.echo()
                click.secho("(dry-run) re-run with --apply to create.", fg="cyan")
            return

        if not yes:
            if as_json or not sys.stdin.isatty():
                raise click.ClickException(
                    "--apply in a non-interactive context (--json / no tty) requires --yes.")
            if operation == "regenerate":
                _print_regenerate_preview(period, figures, old_id, old_legs, old_balance)
                click.echo()
                click.secho(
                    f"⚠ {period} is a closed/declared period. Regenerating will DELETE "
                    f"closure kanne {old_id} and recreate it from current books.",
                    fg="yellow", bold=True)
            else:
                _print_create_preview(period, figures, proposed_legs, proposed_balance)
                click.echo()
                click.secho(
                    f"⚠ {period} is a closed/declared period. Creating the VAT closure "
                    f"from current books.",
                    fg="yellow", bold=True)
            click.secho("  Type 'yes' to proceed: ", fg="yellow", nl=False)
            if input().strip().lower() != "yes":
                raise click.ClickException("Aborted by operator.")

    if operation == "regenerate":
        # (1) delete — _do_delete owns its own client + verify GET.
        _do_delete("financial_transactions", old_id, csrf_path="financial_transactions/add")
        # Anything after the delete that fails leaves the period without a closure —
        # be loud and tell the operator to recreate manually.
        try:
            with build_http(cookies, account) as http:
                new_id, new_legs, new_balance = _submit_inline_closure(
                    http, account, period_dm, cookies)
        except Exception as e:
            raise click.ClickException(
                f"REGENERATE INCOMPLETE — closure {old_id} for {period} was DELETED but "
                f"recreate failed: {str(e)}\n"
                f"  → SB now has no VAT closure for this period. Inspect manually and "
                f"recreate before filing.")
    else:
        # Create branch — no delete; a submit failure leaves the period exactly as before.
        with build_http(cookies, account) as http:
            new_id, new_legs, new_balance = _submit_inline_closure(
                http, account, period_dm, cookies)

    report["applied"] = True
    report["new_closure_id"] = new_id
    report["new_legs"] = new_legs
    report["new_balance"] = new_balance

    if as_json:
        click.echo(json.dumps(report, indent=2, ensure_ascii=False))
        return

    if operation == "regenerate":
        click.secho(f"✓ Regenerated VAT closure for {period}", fg="green", bold=True)
        click.echo(f"  Old kanne : {old_id}    New kanne : {new_id}")
        click.echo(f"  URL       : {BASE}/{account}/financial_transactions/view/{new_id}")
        click.echo()
        click.secho("OLD legs", bold=True)
        _print_closure_legs(old_legs, old_balance)
        click.echo()
        click.secho("NEW legs", bold=True)
        _print_closure_legs(new_legs, new_balance)
    else:
        click.secho(f"✓ Created VAT closure for {period}", fg="green", bold=True)
        click.echo(f"  New kanne : {new_id}")
        click.echo(f"  URL       : {BASE}/{account}/financial_transactions/view/{new_id}")
        click.echo()
        click.secho("Legs", bold=True)
        _print_closure_legs(new_legs, new_balance)


def _kmd_period_bounds(period: str) -> tuple[str, str]:
    """'YYYY-MM' → (first-day, last-day) in YYYY-MM-DD."""
    m = re.fullmatch(r"(\d{4})-(\d{2})", period.strip())
    if not m:
        raise click.ClickException("--period must be YYYY-MM (e.g. 2025-06).")
    y, mo = int(m.group(1)), int(m.group(2))
    if not 1 <= mo <= 12:
        raise click.ClickException("month out of range in --period.")
    nxt = datetime(y + (mo == 12), (mo % 12) + 1, 1)
    last = nxt - timedelta(days=1)
    return f"{y:04d}-{mo:02d}-01", last.strftime("%Y-%m-%d")


