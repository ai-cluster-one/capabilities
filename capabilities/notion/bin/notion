#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""
notion — agent-first CLI for publishing markdown to Notion pages.

This tool is designed to be invoked by agents. Run `notion help` to load
the full usage contract on demand — do not rely on memorised knowledge of
its surface.

Credentials resolve through the standard four-tier cascade (first non-empty
wins): a project .env(.local) > ~/.config/notion/credentials.env > the
process environment. The token is read by env-var NAME (NOTION_TOKEN =
<Notion Personal Access Token>) and never travels on the command line.

  --token-env <KEY>   Act as a different identity by naming the env/cred KEY
                      that holds the PAT (default NOTION_TOKEN). Names the key,
                      never the value — a global option accepted anywhere on
                      the line (e.g. notion publish <page> --token-env NOTION_ALT_TOKEN).

Commands:
  notion help                                 Print this document.
  notion doctor                               Health check: creds + reachability + identity.
  notion whoami                               Identity + workspace.
  notion children <parent>                    List direct child pages.
  notion get <page>                           Fetch page as markdown (incl. title).
  notion publish <page> [<md>|-]              Replace body + title of existing page.
  notion create --parent <p> [--title T] [<md>|-]
                                              Create new page under parent.
  notion upsert --parent <p> [--title T] [<md>|-]
                                              Update by exact title or create.

Page references:
  <page> / <parent> accept a bare UUID (dashed or 32-char) OR a full Notion
  URL. The 32-hex slug is extracted from URLs automatically.

Markdown input:
  Any command that takes <md> accepts a file path, "-" for stdin, or no
  argument (defaults to stdin).

Title handling:
  The local markdown file is the source of truth for both the title and the
  body. If the first non-blank line is a level-1 heading (`# Title`), that
  line is extracted as the page title and stripped from the body before
  sending. This keeps local file and Notion page in sync via a single edit.

  - `get`: prepends `# <page title>` to the returned markdown.
  - `publish`: updates both the page body and (if the H1 changed) the title.
  - `create` / `upsert`: title comes from the H1 when present; `--title`
    is required only when the file has no leading H1. If both are given,
    the H1 wins.

Contract commands (the same on every capability):
  notion stub                                 One-line awareness text.
  notion manifest --json                      Machine-readable declaration.
  notion guide [<topic>]                      Guide topics / one guide body,
                                               fetched live from the docs base.
  notion ids list|get <l>|set <l> <v>|rm <l>  The project identifiers envelope
              [--note <text>]                  (.capabilities/notion/identifiers.json).
  notion refs                                 Menu of the project's reference
                                               files for this capability.

I/O contract:
  - Success: JSON on stdout, exit 0. (`get` emits raw markdown.)
  - Error:   {"error": {"code", "message", "hint", "status"}} on stderr,
             non-zero exit.

Exit codes:
  0  success
  2  auth (unauthorized / restricted_resource / missing credentials)
  3  not found (object_not_found)
  4  disabled by project policy (.capabilities/settings.json — ask the user,
     never enable it yourself)
  5  server / network (5xx, timeout, rate-limit exhausted)
  6  input / validation
  7  conflict (domain-specific: ambiguous title in upsert, concurrent edit)

Quirks worth knowing:
  - `POST /v1/search` is unavailable to PAT tokens (returns 0 results).
    To locate a page by name, list a known parent's `children` and match
    in the caller. There is no global workspace-wide name lookup.
  - `upsert` matches direct children only; a grandchild with the same
    title is not considered. Walk the tree explicitly if you need that.
"""

import argparse
import json
import os
import re
import sys
import time
from pathlib import Path
from typing import NoReturn

import httpx

API_BASE = "https://api.notion.com/v1"
NOTION_VERSION = "2026-03-11"
TIMEOUT = httpx.Timeout(30.0)
MAX_RETRIES = 3

# --- Capability declaration (protocol 1) — one home for every contract fact --

NAME = "notion"
PROTOCOL = 1
SUMMARY = ("Notion CLI over the REST API — publish markdown to pages: list "
           "child pages, fetch a page as markdown, replace a page's body and "
           "title, create under a parent, and upsert by exact title.")
SCOPE = "project"   # credential scope: "project" | "user"
CRED_KEYS = [
    {"key": "NOTION_TOKEN", "secret": True, "required": True,
     "note": "integration token (default identity; alternates via --token-env)"},
]
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CONFIG_DIR = _CONFIG_HOME / "notion"
CREDENTIALS_ENV = CONFIG_DIR / "credentials.env"

UUID_DASHED = re.compile(r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}")
UUID_PLAIN = re.compile(r"[0-9a-f]{32}")
H1_RE = re.compile(r"\A(?:[ \t]*\n)*[ \t]*#[ \t]+([^\n]+?)[ \t]*(?:\n|\Z)")


# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


# --- Credentials -------------------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


# --- Capability contract (protocol 1) — shared verbatim across capabilities --

def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks."""
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _project_settings() -> dict:
    """Capability-owned, non-secret project config: .capabilities/<NAME>/settings.json."""
    envdir = _env_dir()
    if envdir is None:
        return {}
    try:
        return json.loads((envdir / "settings.json").read_text())
    except (OSError, ValueError):
        return {}


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import httpx as _hx
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        resp = _hx.get(url, headers=headers, timeout=10.0, follow_redirects=True)
        if resp.status_code == 200:
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(resp.text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(resp.text); return
        if resp.status_code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if resp.status_code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        raise _hx.HTTPError(f"upstream returned {resp.status_code}")
    except _hx.HTTPError as e:
        if cache.exists():
            sys.stderr.write(json.dumps(
                {"warning": f"upstream unreachable; serving cached copy ({e})"},
                ensure_ascii=False) + "\n")
            _emit(cache.read_text()); return
        _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    out = []
    if envdir and envdir.is_dir():
        for md in sorted(envdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    else:
        return
    sys.exit(0)


def _load_token(key: str = "NOTION_TOKEN") -> str:
    """Resolve a PAT by env-var NAME through the credential cascade — a project
    .env(.local), then ~/.config/notion/credentials.env, then the process env;
    first non-empty wins. `key` defaults to NOTION_TOKEN; the global
    `--token-env <KEY>` flag selects an alternate key to act as another identity.
    The token value never travels on the command line — only its name (so there is
    no value flag tier; the secret stays off argv, deliberately)."""
    tok = (_project_env().get(key)
           or _parse_env_file(CREDENTIALS_ENV).get(key)
           or os.environ.get(key)
           or "").strip()
    if tok:
        return tok
    if key == "NOTION_TOKEN":
        _die(2, "missing_token",
             f"NOTION_TOKEN not found in a project .env, {CREDENTIALS_ENV}, or the environment",
             "add NOTION_TOKEN=<your PAT> to the user config or a project .env")
    _die(2, "missing_token",
         f"{key} not found in a project .env, {CREDENTIALS_ENV}, or the environment",
         f"add {key}=<PAT> to the user config or a project .env to use --token-env {key}")


# --- Reference parsing -------------------------------------------------------

def _to_uuid(ref: str) -> str:
    """Extract a canonical dashed UUID from a Notion URL or raw ID."""
    s = ref.strip().lower()
    m = UUID_DASHED.search(s)
    if m:
        return m.group(0)
    m = UUID_PLAIN.search(s.replace("-", ""))
    if m:
        h = m.group(0)
        return f"{h[0:8]}-{h[8:12]}-{h[12:16]}-{h[16:20]}-{h[20:32]}"
    _die(6, "bad_page_ref",
         f"could not extract a Notion page UUID from {ref!r}",
         "pass a 32-char hex UUID, a dashed UUID, or a full Notion page URL")


# --- Markdown input ----------------------------------------------------------

def _extract_h1_title(md: str) -> tuple[str | None, str]:
    """If the first non-blank line is `# Title`, return (title, body_without_h1).
    Otherwise return (None, md). Strips immediately following blank lines from
    the body so a round-trip with `_compose_with_h1` is idempotent.
    """
    m = H1_RE.match(md)
    if not m:
        return None, md
    title = m.group(1).strip()
    body = md[m.end():].lstrip("\n")
    return title, body


def _compose_with_h1(title: str, body: str) -> str:
    """Inverse of `_extract_h1_title`: prepend `# title` + blank line to body."""
    return f"# {title}\n\n{body}" if body else f"# {title}\n"


def _read_md(arg: str | None) -> str:
    if arg is None or arg == "-":
        data = sys.stdin.read()
        if not data:
            _die(6, "empty_stdin",
                 "no markdown content received on stdin",
                 "pipe content in, or pass a file path")
        return data
    p = Path(arg)
    if not p.exists():
        _die(6, "file_not_found",
             f"markdown file does not exist: {arg}",
             "check the path; pass '-' to read from stdin")
    return p.read_text(encoding="utf-8")


# --- HTTP --------------------------------------------------------------------

def _client(token: str) -> httpx.Client:
    return httpx.Client(
        base_url=API_BASE,
        timeout=TIMEOUT,
        headers={
            "Authorization": f"Bearer {token}",
            "Notion-Version": NOTION_VERSION,
            "Content-Type": "application/json",
        },
    )


def _request(client: httpx.Client, method: str, path: str,
             json_body: dict | None = None) -> dict:
    last_status: int | None = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = client.request(method, path, json=json_body)
        except httpx.TimeoutException:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "timeout",
                 f"request timed out: {method} {path}",
                 "Notion API was unresponsive; check status.notion.com")
        except httpx.RequestError as e:
            _die(5, "network_error", f"network error: {e}", "check connectivity")

        last_status = resp.status_code
        if resp.status_code == 429:
            retry_after = float(resp.headers.get("Retry-After", "1"))
            if attempt < MAX_RETRIES:
                time.sleep(retry_after)
                continue
            _die(5, "rate_limited",
                 f"rate-limited after {MAX_RETRIES} attempts",
                 "back off and retry later", status=429)
        if resp.status_code >= 500:
            if attempt < MAX_RETRIES:
                time.sleep(attempt * 1.5)
                continue
            _die(5, "server_error",
                 f"Notion returned {resp.status_code}",
                 "check status.notion.com", status=resp.status_code)

        try:
            data = resp.json()
        except ValueError:
            _die(5, "invalid_response",
                 f"non-JSON response from {method} {path}",
                 status=resp.status_code)

        if resp.status_code >= 400:
            notion_code = data.get("code", "unknown_error")
            notion_msg = data.get("message", "")
            if notion_code in ("unauthorized", "restricted_resource"):
                exit_code = 2
                hint = "PAT may not have access to this resource"
            elif notion_code == "object_not_found":
                exit_code = 3
                hint = "verify the page UUID and that the PAT can see it"
            elif notion_code == "validation_error":
                exit_code = 6
                hint = "check request body shape against Notion API docs"
            elif notion_code == "conflict_error":
                exit_code = 7
                hint = "the resource was modified concurrently; retry"
            else:
                exit_code = 5
                hint = None
            _die(exit_code, notion_code, notion_msg, hint, status=resp.status_code)

        return data

    _die(5, "exhausted_retries",
         f"exhausted {MAX_RETRIES} attempts on {method} {path}",
         status=last_status)


# --- Helpers -----------------------------------------------------------------

def _page_title(page: dict) -> str:
    props = page.get("properties", {}) or {}
    for v in props.values():
        if v.get("type") == "title":
            arr = v.get("title") or []
            if arr:
                return "".join(t.get("plain_text", "") for t in arr)
    return ""


def _title_prop_key(page: dict) -> str | None:
    """Find the property key whose type is `title` (usually 'title' for normal
    pages; can differ for database rows)."""
    props = page.get("properties", {}) or {}
    for k, v in props.items():
        if v.get("type") == "title":
            return k
    return None


def _title_property_body(prop_key: str, title: str) -> dict:
    return {
        "properties": {
            prop_key: {"title": [{"type": "text", "text": {"content": title}}]}
        }
    }


def _page_summary(page: dict, action: str | None = None) -> dict:
    out = {
        "page_id": page.get("id"),
        "url": page.get("url"),
        "title": _page_title(page),
    }
    if action:
        out["action"] = action
    return out


# --- Commands ----------------------------------------------------------------

def cmd_doctor(c: httpx.Client) -> dict:
    """Cheapest authenticated round-trip — proves creds resolved, endpoint
    reachable, identity confirmed. Rides the same exit codes (2 if the token is
    missing/rejected, 5 if Notion is unreachable)."""
    return {"ok": True, "reachable": True, **cmd_whoami(c)}


def cmd_whoami(c: httpx.Client) -> dict:
    data = _request(c, "GET", "/users/me")
    bot = data.get("bot", {}) or {}
    owner = bot.get("owner", {}) or {}
    out = {
        "id": data.get("id"),
        "name": data.get("name"),
        "type": data.get("type"),
        "owner_type": owner.get("type"),
        "workspace_name": bot.get("workspace_name"),
    }
    if owner.get("type") == "user":
        out["owner_user"] = (owner.get("user") or {}).get("name")
    return out


def cmd_children(c: httpx.Client, parent: str) -> list[dict]:
    parent_id = _to_uuid(parent)
    results: list[dict] = []
    cursor: str | None = None
    while True:
        path = f"/blocks/{parent_id}/children?page_size=100"
        if cursor:
            path += f"&start_cursor={cursor}"
        data = _request(c, "GET", path)
        for r in data.get("results", []):
            if r.get("type") == "child_page":
                results.append({
                    "id": r["id"],
                    "title": (r.get("child_page") or {}).get("title", ""),
                })
        if not data.get("has_more"):
            break
        cursor = data.get("next_cursor")
    return results


def cmd_get(c: httpx.Client, page: str) -> str:
    page_id = _to_uuid(page)
    page_data = _request(c, "GET", f"/pages/{page_id}")
    title = _page_title(page_data)
    data = _request(c, "GET", f"/pages/{page_id}/markdown")
    md = data.get("markdown", "")
    return _compose_with_h1(title, md) if title else md


def cmd_publish(c: httpx.Client, page: str, md: str) -> dict:
    page_id = _to_uuid(page)
    h1_title, body_md = _extract_h1_title(md)

    body_patch = {"type": "replace_content",
                  "replace_content": {"new_str": body_md}}
    data = _request(c, "PATCH", f"/pages/{page_id}/markdown", body_patch)
    if data.get("object") != "page":
        data = _request(c, "GET", f"/pages/{page_id}")

    if h1_title is not None and h1_title != _page_title(data):
        prop_key = _title_prop_key(data)
        if prop_key is None:
            _die(5, "no_title_property",
                 "page has no property of type 'title'",
                 "this should not happen for normal pages; check the page id")
        data = _request(c, "PATCH", f"/pages/{page_id}",
                        _title_property_body(prop_key, h1_title))
    return _page_summary(data, action="updated")


def _resolve_title(h1_title: str | None, title_arg: str | None) -> str:
    """H1 wins; fall back to --title; otherwise abort."""
    if h1_title:
        return h1_title
    if title_arg:
        return title_arg
    _die(6, "missing_title",
         "no title: file has no leading '# H1' and --title not given",
         "add a '# Title' as the first line of the file, or pass --title")


def cmd_create(c: httpx.Client, parent: str,
               title_arg: str | None, md: str) -> dict:
    parent_id = _to_uuid(parent)
    h1_title, body_md = _extract_h1_title(md)
    title = _resolve_title(h1_title, title_arg)
    body = {
        "parent": {"page_id": parent_id},
        "properties": {
            "title": {"title": [{"type": "text", "text": {"content": title}}]}
        },
        "markdown": body_md,
    }
    data = _request(c, "POST", "/pages", body)
    return _page_summary(data, action="created")


def cmd_upsert(c: httpx.Client, parent: str,
               title_arg: str | None, md: str) -> dict:
    parent_id = _to_uuid(parent)
    h1_title, _ = _extract_h1_title(md)
    title = _resolve_title(h1_title, title_arg)
    children = cmd_children(c, parent_id)
    matches = [ch for ch in children if ch["title"] == title]
    if len(matches) > 1:
        _die(7, "ambiguous_title",
             f"{len(matches)} direct children of parent match title {title!r}",
             "use 'publish <id>' against a specific page to disambiguate")
    if len(matches) == 1:
        return cmd_publish(c, matches[0]["id"], md)
    return cmd_create(c, parent_id, title, md)


# --- CLI ---------------------------------------------------------------------

def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    p = argparse.ArgumentParser(
        prog="notion",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help", help="print the full usage contract")
    sub.add_parser("doctor", help="health check: creds + reachability + identity")
    sub.add_parser("whoami", help="confirm token and return identity")

    sp = sub.add_parser("children", help="list child pages of a parent page")
    sp.add_argument("parent", help="parent page UUID or Notion URL")

    sp = sub.add_parser("get", help="fetch page body as markdown")
    sp.add_argument("page", help="page UUID or Notion URL")

    sp = sub.add_parser("publish", help="replace body of an existing page")
    sp.add_argument("page", help="page UUID or Notion URL")
    sp.add_argument("md", nargs="?", default="-",
                    help="markdown file path or '-' for stdin (default: stdin)")

    sp = sub.add_parser("create", help="create a new page under a parent")
    sp.add_argument("--parent", required=True, help="parent page UUID or URL")
    sp.add_argument("--title", default=None,
                    help="title for the new page (optional if file has '# H1')")
    sp.add_argument("md", nargs="?", default="-",
                    help="markdown file path or '-' for stdin (default: stdin)")

    sp = sub.add_parser("upsert", help="find by title under parent, or create")
    sp.add_argument("--parent", required=True, help="parent page UUID or URL")
    sp.add_argument("--title", default=None,
                    help="exact title to match (optional if file has '# H1')")
    sp.add_argument("md", nargs="?", default="-",
                    help="markdown file path or '-' for stdin (default: stdin)")

    # `--token-env <KEY>` is a global override accepted anywhere on the line
    # (extracted before argparse so it works after the subcommand, e.g.
    # `notion publish <page> --token-env NOTION_ALT_TOKEN`). It names the env/cred
    # key holding the PAT to act as — never the token value itself.
    argv = sys.argv[1:]
    token_key = "NOTION_TOKEN"
    cleaned: list[str] = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--token-env" and i + 1 < len(argv):
            token_key = argv[i + 1]; i += 2; continue
        if a.startswith("--token-env="):
            token_key = a.split("=", 1)[1]; i += 1; continue
        cleaned.append(a); i += 1

    args = p.parse_args(cleaned)

    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return

    token = _load_token(token_key)

    with _client(token) as c:
        if args.cmd == "doctor":
            _emit(cmd_doctor(c))
        elif args.cmd == "whoami":
            _emit(cmd_whoami(c))
        elif args.cmd == "children":
            _emit(cmd_children(c, args.parent))
        elif args.cmd == "get":
            _emit(cmd_get(c, args.page))
        elif args.cmd == "publish":
            _emit(cmd_publish(c, args.page, _read_md(args.md)))
        elif args.cmd == "create":
            _emit(cmd_create(c, args.parent, args.title, _read_md(args.md)))
        elif args.cmd == "upsert":
            _emit(cmd_upsert(c, args.parent, args.title, _read_md(args.md)))


if __name__ == "__main__":
    main()
