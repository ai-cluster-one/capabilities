#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx>=0.27",
# ]
# ///
"""
youtrack — agent-first CLI for basic YouTrack issue work.

Run `youtrack help` before use; this is the complete contract.

Configuration resolves as named connections. Without a registry, `default`
uses YOUTRACK_URL and YOUTRACK_TOKEN from the standard cascade (project
.env/.env.local, ~/.config/youtrack/credentials.env, then process env).
YOUTRACK_URL is the YouTrack origin, for example https://acme.youtrack.cloud.
YOUTRACK_TOKEN is a permanent token and never belongs on the command line.

A project may declare capabilities/youtrack/connections.json:
  {
    "default": "work",
    "connections": {
      "work": {
        "secret_env": "YOUTRACK_WORK_TOKEN",
        "base_url": "https://acme.youtrack.cloud",
        "allow_write": true
      }
    }
  }

Commands:
  youtrack help                              Print this contract.
  youtrack connections                       Show local config resolution.
  youtrack doctor [--connection ID]          Check config, identity, reachability.

Contract commands:
  youtrack stub
  youtrack manifest --json
  youtrack guide [topic]
  youtrack ids list|get|set|rm
  youtrack refs

Read:
  youtrack whoami                            Current YouTrack user.
  youtrack projects [--query TEXT]           Projects visible to the token.
  youtrack task ISSUE                        Read one issue (ID or URL).
  youtrack comments ISSUE [--limit N]        Read recent comments.
  youtrack issues QUERY [--limit N]          Search issues server-side; returns
                                             structured issue data (id, idReadable,
                                             summary, description, State).
  youtrack articles [--project ID] [--limit N]
                                             List knowledge-base articles (paged;
                                             --project scopes to one project). This
                                             is a listing, not a full-text search.
  youtrack article ID                        Read one article (ID or URL): summary,
                                             content, project, parent/child refs.
  youtrack article-comments ID [--limit N]   Read recent comments on an article.

Write:
  youtrack create --project ID --summary S   Create an issue. Project is the
        [--description TEXT|-]                database entity id (for example 0-0),
                                             not its short name. Store stable ids
                                             with `youtrack ids set project …`.
  youtrack comment ISSUE [--text TEXT|-]     Add a comment; omitted text reads stdin.
  youtrack update ISSUE --state STATE        Update issue workflow state. STATE is
                                             a state name (e.g. "In Progress").
                                             Respects allow_write connection policy.
  youtrack article-create --summary S        Create an article. Give --project ID
        [--content TEXT|-] [--project ID]    (database entity id) OR --parent ID to
        [--parent ID]                        create a sub-article under an article.
  youtrack article-update ID                 Update an article's summary and/or
        [--summary S] [--content TEXT|-]     content. Respects allow_write policy.
  youtrack article-comment ID [--text TEXT|-]
                                             Add a comment to an article.

Global options accepted anywhere:
  --connection ID                            Select a named connection.
  --token-env KEY                            Select the env key holding the token.

Text arguments accept inline text, a readable file path, or `-` for stdin.
Success is JSON on stdout. Errors are JSON on stderr. Exit codes: 0 success,
2 auth/config, 3 not found, 4 policy refusal, 5 network/server, 6 input.
"""

import argparse
import json
import os
import re
import sys
import time
from pathlib import Path
from typing import NoReturn

import httpx

NAME = "youtrack"
SUMMARY = "YouTrack CLI for issues (read/create/comment/update state) and the knowledge base (read, create, and update articles and article comments)."
SCOPE = "project"
CRED_KEYS = [
    {"key": "YOUTRACK_URL", "secret": False, "required": True,
     "note": "YouTrack origin, e.g. https://acme.youtrack.cloud"},
    {"key": "YOUTRACK_TOKEN", "secret": True, "required": True,
     "note": "permanent token (perm:…); alternates via --token-env"},
]
WRITE_VERBS = {"create", "comment", "update",
               "article-create", "article-update", "article-comment"}
WRITE_DEFAULT = True
DOCS_BASE = ""
TOPICS: list = []
STATE = False
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CONFIG_DIR = _CONFIG_HOME / NAME
CREDENTIALS_ENV = CONFIG_DIR / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding capabilities/, legacy .capabilities/,
    .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / "capabilities" / "settings.json").is_file()
                or (d / ".capabilities").is_dir()
                or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_capabilities_dir(root: Path) -> Path:
    """The active project envelope root.

    `capabilities/` is canonical. A legacy `.capabilities/` remains readable
    until `capabilities init` migrates it. If both exist, the canonical tree
    wins once it carries settings.json; otherwise the legacy configured tree
    remains active so merely creating an empty visible directory loses no gate.
    """
    current = root / "capabilities"
    legacy = root / ".capabilities"
    if (current / "settings.json").is_file() or not legacy.is_dir():
        return current
    return legacy


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _auth_context() -> dict | None:
    """Optional runtime authority envelope passed by an ingress/service.

    Absence means the ordinary project gate is the whole policy. Presence means
    a request-scoped authority layer exists and must fail closed before any
    credential or network work happens.
    """
    raw = os.environ.get("CAPABILITIES_AUTH_CONTEXT")
    if not raw:
        return None
    try:
        if raw.lstrip().startswith("{"):
            data = json.loads(raw)
        else:
            data = json.loads(Path(raw).read_text())
    except (OSError, ValueError) as e:
        _die(4, "auth_context_unreadable",
             "runtime authority context could not be read",
             f"{raw}: {e}")
    if not isinstance(data, dict):
        _die(4, "auth_context_invalid",
             "runtime authority context is not an object")
    return data


def _auth_capability_allowed(rule) -> bool:
    if rule is True or rule == "*":
        return True
    if rule in (False, None):
        return False
    if isinstance(rule, dict):
        if rule.get("deny") is True:
            return False
        if rule.get("enabled") is False or rule.get("allow") is False:
            return False
        return True
    return False


def _auth_gate() -> None:
    ctx = _auth_context()
    if ctx is None:
        return
    allowed = ctx.get("allowed_capabilities")
    if allowed is None:
        return
    if allowed is True or allowed == "*":
        return
    if isinstance(allowed, list):
        if NAME in allowed or "*" in allowed:
            return
    elif isinstance(allowed, dict):
        if _auth_capability_allowed(allowed.get(NAME, allowed.get("*"))):
            return
    else:
        _die(4, "auth_context_invalid",
             "runtime authority context has invalid allowed_capabilities")
    source = ctx.get("source") or "runtime"
    role = ctx.get("sender_role") or ctx.get("role") or "unknown"
    chat = ctx.get("chat_id") or "unknown"
    _die(4, "capability_not_authorized",
         f"{NAME} is not authorized for this {source} request",
         f"role={role}; chat_id={chat}; adjust runtime authority policy instead of bypassing the gate")


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks.

    If an ingress supplied CAPABILITIES_AUTH_CONTEXT, that request-scoped gate
    is stricter and also runs here, before credentials or network calls.
    """
    _auth_gate()
    root = _project_root()
    if root is None:
        return
    gate_file = _project_capabilities_dir(root) / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project's active capabilities/."""
    root = _project_root()
    return (_project_capabilities_dir(root) / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None:
            envelope = _project_capabilities_dir(root)
            if (envelope / "settings.json").is_file():
                return envelope / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract — the declaration surface --------------------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import urllib.error as _ue
    import urllib.request as _ur
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        req = _ur.Request(url, headers=headers)
        with _ur.urlopen(req, timeout=10.0) as resp:
            text = resp.read().decode(resp.headers.get_content_charset() or "utf-8")
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(text); return
    except _ue.HTTPError as e:
        if e.code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if e.code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        err = f"upstream returned {e.code}"
    except _ue.URLError as e:
        err = str(e.reason)
    except OSError as e:
        err = str(e)
    if cache.exists():
        sys.stderr.write(json.dumps(
            {"warning": f"upstream unreachable; serving cached copy ({err})"},
            ensure_ascii=False) + "\n")
        _emit(cache.read_text()); return
    _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _render_ids_markdown(data: dict) -> str:
    """Render the {label: {value, note}} envelope as the labelled markdown
    list the manager's `capabilities ids <NAME>` also produces — one shared
    format across the ids surface and the identifiers section of `help`."""
    lines: list[str] = []
    for label, entry in sorted(data.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        v = entry.get("value")
        vs = f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"
        line = f"- **{label}**: {vs}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    return "\n".join(lines)


def _identifiers_section() -> str:
    """The Identifiers block appended to the bare top-level help — deterministic
    first-touch surfacing of `capabilities/<NAME>/identifiers.json` so an
    agent following the `<NAME> help` startup protocol loads the discovered
    labels/values/notes into context at once. Empty when no project envelope
    or nothing recorded (do not bloat help with an empty section)."""
    envdir = _env_dir()
    if envdir is None:
        return ""
    ids_file = envdir / "identifiers.json"
    if not ids_file.exists():
        return ""
    try:
        data = json.loads(ids_file.read_text())
    except (OSError, ValueError):
        return ""
    if not isinstance(data, dict) or not data:
        return ""
    header = (
        "\n═══ Identifiers ═════════════════════════════════════════════════════════════\n\n"
        f"Structural lookups discovered for `{NAME}` in this project. Fetch a single\n"
        f"raw value with `{NAME} ids get <label>`; the full envelope is also at\n"
        f"`capabilities ids {NAME}`.\n\n"
    )
    return header + _render_ids_markdown(data) + "\n"


def _cmd_help() -> None:
    """Bare top-level help: the CLI's HELP body (module-level `HELP` if
    defined, else the module docstring), then the project's Identifiers
    section. Only fires when no extra args follow — per-verb help stays
    untouched so `<NAME> help <subcommand>` is not intercepted."""
    g = globals()
    text = g.get("HELP") or g.get("__doc__") or ""
    if text.startswith("\n"):
        text = text.lstrip("\n")
    sys.stdout.write(text)
    if text and not text.endswith("\n"):
        sys.stdout.write("\n")
    section = _identifiers_section()
    if section:
        sys.stdout.write(section)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not (envdir.parent / "settings.json").is_file():
            _die(6, "no_envelope", "no capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved.

    `help` is a contract verb only when bare (no extra args) — the top-level
    dump plus the Identifiers section. `<NAME> help <subcommand>` falls
    through to the CLI so per-verb help stays clean."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    elif cmd == "help" and len(argv) == 1:
        _cmd_help()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<

def _load_token(key: str = "YOUTRACK_TOKEN") -> str:
    value = (_project_env().get(key) or _parse_env_file(CREDENTIALS_ENV).get(key)
             or os.environ.get(key) or "").strip()
    if value:
        return value
    _die(2, "missing_token", f"{key} is not configured",
         f"set {key} in project .env, {CREDENTIALS_ENV}, or process env")

# >>> contract: connections (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

def _resolve_env_key(key: str) -> tuple[str | None, str | None, Path | None]:
    """Resolve one env key through cascade tiers 2-4: project .env(.local) →
    user credentials.env → process env. Returns (value, tier, source)."""
    root = _project_root()
    if root is not None:
        for fname in (".env.local", ".env"):
            val = _parse_env_file(root / fname).get(key)
            if val:
                return val, "project", root / fname
    val = _parse_env_file(CREDENTIALS_ENV).get(key)
    if val:
        return val, "user", CREDENTIALS_ENV
    val = os.environ.get(key)
    if val:
        return val, "env", None
    return None, None, None


def _mask(value: str) -> str:
    return ("…" + value[-4:]) if len(value) >= 8 else "****"


def _connections_registry() -> tuple[dict | None, Path | None]:
    """The connections envelope and its path: project envelope first, else the
    user config home. First found wins, never merged; (None, None) when neither
    declares one (the implicit default connection applies)."""
    envdir = _env_dir()
    candidates = ([envdir / "connections.json"] if envdir else []) + \
                 [_CONFIG_HOME / NAME / "connections.json"]
    for reg_file in candidates:
        if not reg_file.is_file():
            continue
        try:
            raw = json.loads(reg_file.read_text())
        except (ValueError, OSError) as e:
            _die(6, "bad_config", f"cannot read {reg_file}: {e}")
        if not isinstance(raw, dict) or not isinstance(raw.get("connections"), dict) \
                or not raw["connections"]:
            _die(6, "bad_config", f"{reg_file} is not a connections envelope",
                 'expected {"default": "<id>", "connections": { ... }}')
        return raw, reg_file
    return None, None


def _select_connection(reg: dict | None, wanted: str | None) -> tuple[str, dict | None]:
    """flag → default pointer → sole entry → die 6. No registry → the implicit
    default. A connection's own `address` field selects it too (used where a
    connection carries a human-recognizable address; absent fields never match)."""
    if reg is None:
        if wanted and wanted != "default":
            _die(6, "unknown_connection",
                 "no connections registry; the sole connection is 'default'",
                 "the implicit default resolves from the credential cascade")
        return "default", None
    conns = reg["connections"]
    if wanted:
        if wanted in conns:
            return wanted, conns[wanted]
        for cid, entry in conns.items():
            if (entry or {}).get("address", "").lower() == wanted.lower():
                return cid, entry
        _die(6, "unknown_connection", f"no connection matches {wanted!r}",
             f"known: {', '.join(conns)}")
    default = reg.get("default")
    if default:
        if default not in conns:
            _die(6, "bad_default", f"default points to unknown connection {default!r}",
                 f"known: {', '.join(conns)}")
        return default, conns[default]
    if len(conns) == 1:
        cid = next(iter(conns))
        return cid, conns[cid]
    _die(6, "ambiguous_connection",
         f"registry defines {len(conns)} connections and no default; "
         f"pass --connection <id>",
         f"known: {', '.join(conns)}")


def _write_gate(conn_id: str, allow_write: bool, verb: str) -> None:
    """Policy from the committed registry; nothing in the cascade lifts it."""
    if verb in WRITE_VERBS and not allow_write:
        _die(4, "read_only",
             f"connection {conn_id!r} does not allow writes",
             "Do not lift the gate yourself — ask the user; granting is "
             "`allow_write: true` on this connection in connections.json.")


def _key_report(key: str, secret: bool, required: bool,
                value: str | None, tier: str | None, source) -> dict:
    return {"key": key, "secret": secret, "required": required,
            "set": bool(value), "tier": tier if value else None,
            "source": str(source) if (value and source) else None,
            "value": (_mask(value) if secret else value) if value else None}


def _missing_required(keys: list) -> list:
    """Required report rows (from _key_report) that did not resolve through the
    cascade — empty ⇒ credentials present. The primitive behind doctor's
    network-free readiness gate, read from the same per-key resolution
    `connections` reports, so the gate and the report can never disagree."""
    return [k["key"] for k in keys if k["required"] and not k["set"]]


def _doctor_gate(report: dict, wanted: str | None) -> None:
    """doctor's network-free readiness gate. Refuse with exit 2 — naming the
    unresolved required keys, before any round-trip — when a connection under
    test cannot resolve its required config through the cascade, so readiness is
    judged by the same resolution `connections` reports, never a parallel check.
    Checks the selected connection, else every connection in the report."""
    conns = report.get("connections") or {}
    targets = [wanted] if (wanted and wanted in conns) else list(conns)
    problems: dict = {}
    for cid in targets:
        miss = _missing_required((conns.get(cid) or {}).get("keys") or [])
        if miss:
            problems[cid] = miss
    if problems:
        detail = "; ".join(f"{c}: {', '.join(ks)}" for c, ks in sorted(problems.items()))
        _die(2, "credentials_missing",
             f"unresolved required config — {detail}",
             f"set each in the project .env/.env.local, the user credentials.env, "
             f"or process env; `{NAME} connections` shows where every value resolves")

# <<< contract: connections <<<

def _resolve_base_url(entry: dict | None, reg_file: Path | None = None):
    if isinstance(entry, dict) and str(entry.get("base_url") or entry.get("url") or "").strip():
        return str(entry.get("base_url") or entry.get("url")).strip().rstrip("/"), "connection", reg_file
    value, tier, source = _resolve_env_key("YOUTRACK_URL")
    return (value.rstrip("/") if value else None), tier, source

def _connections_report() -> dict:
    reg, reg_file = _connections_registry()
    out: dict = {"default": None, "connections": {}}
    if reg is None:
        token, tt, ts = _resolve_env_key("YOUTRACK_TOKEN")
        url, ut, us = _resolve_env_key("YOUTRACK_URL")
        out["default"] = "default"
        out["connections"]["default"] = {
            "allow_write": WRITE_DEFAULT,
            "keys": [_key_report("YOUTRACK_URL", False, True, url, ut, us),
                     _key_report("YOUTRACK_TOKEN", True, True, token, tt, ts)]}
        return out
    conns = reg["connections"]
    out["default"] = reg.get("default") or (next(iter(conns)) if len(conns) == 1 else None)
    for cid, raw in conns.items():
        entry = raw if isinstance(raw, dict) else {}
        key = entry.get("secret_env")
        token, tt, ts = _resolve_env_key(key) if key else (None, None, None)
        url, ut, us = _resolve_base_url(entry, reg_file)
        out["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": [_key_report("base_url", False, True, url, ut, us),
                     _key_report(key or "secret_env", True, True, token, tt, ts)]}
    return out

def _cmd_connections() -> None:
    _emit(_connections_report())

def _read_text(source: str) -> str:
    if source == "-":
        return sys.stdin.read()
    path = Path(source)
    if "\n" not in source and path.is_file():
        try:
            return path.read_text()
        except OSError as exc:
            _die(6, "input", f"cannot read {path}: {exc}")
    return source

def _issue_ref(value: str) -> str:
    value = value.strip()
    match = re.search(r"/issue/([^/?#]+)", value)
    return match.group(1) if match else value

def _client(base_url: str, token: str) -> httpx.Client:
    return httpx.Client(base_url=base_url + "/api", timeout=30.0,
                        headers={"Authorization": f"Bearer {token}",
                                 "Accept": "application/json",
                                 "Content-Type": "application/json"})

def _request(client: httpx.Client, method: str, path: str, **kwargs):
    for attempt in range(3):
        try:
            response = client.request(method, path, **kwargs)
        except (httpx.TimeoutException, httpx.NetworkError) as exc:
            if attempt < 2:
                time.sleep(0.5 * (2 ** attempt)); continue
            _die(5, "network_error", str(exc))
        if response.status_code == 429 and attempt < 2:
            try: delay = min(float(response.headers.get("Retry-After", "1")), 10)
            except ValueError: delay = 1
            time.sleep(delay); continue
        break
    if response.status_code in (401, 403):
        _die(2, "auth", "YouTrack rejected the credentials or permission", status=response.status_code)
    if response.status_code == 404:
        _die(3, "not_found", "YouTrack resource not found", status=404)
    if response.status_code >= 500 or response.status_code == 429:
        _die(5, "server_error", response.text[:500] or "YouTrack server error", status=response.status_code)
    if response.status_code >= 400:
        _die(6, "invalid_request", response.text[:1000] or "YouTrack rejected the request", status=response.status_code)
    if not response.content:
        return {}
    try:
        return response.json()
    except ValueError:
        _die(5, "bad_response", "YouTrack returned non-JSON data")

USER_FIELDS = "id,login,name,fullName,email"
PROJECT_FIELDS = "id,name,shortName"
ISSUE_FIELDS = "id,idReadable,summary,description,created,updated,resolved,project(id,name,shortName),reporter(id,login,fullName)"
ISSUE_SEARCH_FIELDS = "id,idReadable,summary,description,customFields(name,value(name))"
COMMENT_FIELDS = "id,text,created,updated,author(id,login,fullName)"
ARTICLE_FIELDS = ("id,idReadable,summary,content,created,updated,"
                  "project(id,name,shortName),reporter(id,login,fullName),"
                  "parentArticle(id,idReadable,summary),"
                  "childArticles(id,idReadable,summary)")
ARTICLE_LIST_FIELDS = ("id,idReadable,summary,updated,"
                       "project(id,name,shortName),parentArticle(idReadable)")
ARTICLE_COMMENT_FIELDS = "id,text,created,updated,author(id,login,fullName)"

def cmd_whoami(c):
    return _request(c, "GET", "/users/me", params={"fields": USER_FIELDS})

def cmd_projects(c, query):
    params = {"fields": PROJECT_FIELDS, "$top": 100}
    if query: params["query"] = query
    return _request(c, "GET", "/admin/projects", params=params)

def cmd_task(c, issue):
    return _request(c, "GET", f"/issues/{_issue_ref(issue)}", params={"fields": ISSUE_FIELDS})

def cmd_create(c, project, summary, description):
    body = {"project": {"id": project}, "summary": summary}
    if description is not None: body["description"] = description
    return _request(c, "POST", "/issues", params={"fields": ISSUE_FIELDS}, json=body)

def cmd_comments(c, issue, limit):
    return _request(c, "GET", f"/issues/{_issue_ref(issue)}/comments",
                    params={"fields": COMMENT_FIELDS, "$top": limit})

def cmd_comment(c, issue, text):
    return _request(c, "POST", f"/issues/{_issue_ref(issue)}/comments",
                    params={"fields": COMMENT_FIELDS}, json={"text": text})

def cmd_issues(c, query, limit):
    params = {"fields": ISSUE_SEARCH_FIELDS, "query": query,
              "customFields": "State", "$top": limit}
    result = _request(c, "GET", "/issues", params=params)
    def extract_state(issue):
        for field in (issue.get("customFields") or []):
            if field.get("name") == "State":
                value = field.get("value")
                if isinstance(value, dict):
                    return value.get("name")
                return value
        return None
    return [{"id": i["id"], "idReadable": i["idReadable"],
             "summary": i["summary"], "description": i.get("description"),
             "State": extract_state(i)} for i in result]

def cmd_update(c, issue, state):
    return _request(c, "POST", f"/issues/{_issue_ref(issue)}",
                    params={"fields": "customFields(name,value(name))"},
                    json={"customFields": [
                        {"name": "State", "$type": "StateIssueCustomField", "value": {"name": state}}
                    ]})

def _article_ref(value):
    value = value.strip()
    match = re.search(r"/articles/([^/?#]+)", value)
    return match.group(1) if match else value

def cmd_articles(c, project, limit):
    path = f"/admin/projects/{project}/articles" if project else "/articles"
    return _request(c, "GET", path,
                    params={"fields": ARTICLE_LIST_FIELDS, "$top": limit})

def cmd_article(c, article):
    return _request(c, "GET", f"/articles/{_article_ref(article)}",
                    params={"fields": ARTICLE_FIELDS})

def cmd_article_comments(c, article, limit):
    return _request(c, "GET", f"/articles/{_article_ref(article)}/comments",
                    params={"fields": ARTICLE_COMMENT_FIELDS, "$top": limit})

def cmd_article_create(c, summary, content, project, parent):
    body = {"summary": summary}
    if content is not None: body["content"] = content
    if parent: body["parentArticle"] = {"id": _article_ref(parent)}
    if project: body["project"] = {"id": project}
    return _request(c, "POST", "/articles",
                    params={"fields": ARTICLE_FIELDS}, json=body)

def cmd_article_update(c, article, summary, content):
    body = {}
    if summary is not None: body["summary"] = summary
    if content is not None: body["content"] = content
    return _request(c, "POST", f"/articles/{_article_ref(article)}",
                    params={"fields": ARTICLE_FIELDS}, json=body)

def cmd_article_comment(c, article, text):
    return _request(c, "POST", f"/articles/{_article_ref(article)}/comments",
                    params={"fields": ARTICLE_COMMENT_FIELDS}, json={"text": text})

def _check_connection(base_url, token):
    with _client(base_url, token) as c:
        return {"ok": True, "base_url": base_url, "identity": cmd_whoami(c)}

def cmd_doctor(reg, reg_file, wanted, token_key):
    report = _connections_report()
    _doctor_gate(report, wanted)
    targets = [wanted] if wanted else list(report["connections"])
    checked = {}
    for cid in targets:
        selected, entry = _select_connection(reg, cid)
        key = token_key or (entry or {}).get("secret_env") or "YOUTRACK_TOKEN"
        base_url, _, _ = _resolve_base_url(entry, reg_file)
        checked[selected] = _check_connection(base_url, _load_token(key))
    _emit({"ok": True, "connections": checked})

def main() -> None:
    _gate()
    argv = sys.argv[1:]
    _contract(argv)
    parser = argparse.ArgumentParser(prog=NAME, add_help=True)
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("whoami")
    p = sub.add_parser("projects"); p.add_argument("--query")
    p = sub.add_parser("task"); p.add_argument("issue")
    p = sub.add_parser("comments"); p.add_argument("issue"); p.add_argument("--limit", type=int, default=50)
    p = sub.add_parser("issues"); p.add_argument("query"); p.add_argument("--limit", type=int, default=100)
    p = sub.add_parser("create"); p.add_argument("--project", required=True); p.add_argument("--summary", required=True); p.add_argument("--description")
    p = sub.add_parser("comment"); p.add_argument("issue"); p.add_argument("--text")
    p = sub.add_parser("update"); p.add_argument("issue"); p.add_argument("--state", required=True)
    p = sub.add_parser("articles"); p.add_argument("--project"); p.add_argument("--limit", type=int, default=100)
    p = sub.add_parser("article"); p.add_argument("article")
    p = sub.add_parser("article-comments"); p.add_argument("article"); p.add_argument("--limit", type=int, default=50)
    p = sub.add_parser("article-create"); p.add_argument("--summary", required=True); p.add_argument("--content"); p.add_argument("--project"); p.add_argument("--parent")
    p = sub.add_parser("article-update"); p.add_argument("article"); p.add_argument("--summary"); p.add_argument("--content")
    p = sub.add_parser("article-comment"); p.add_argument("article"); p.add_argument("--text")
    sub.add_parser("doctor")

    token_key = wanted = None
    cleaned = []
    i = 0
    while i < len(argv):
        if argv[i] in ("--token-env", "--connection") and i + 1 < len(argv):
            if argv[i] == "--token-env": token_key = argv[i + 1]
            else: wanted = argv[i + 1]
            i += 2; continue
        if argv[i].startswith("--token-env="): token_key = argv[i].split("=", 1)[1]; i += 1; continue
        if argv[i].startswith("--connection="): wanted = argv[i].split("=", 1)[1]; i += 1; continue
        cleaned.append(argv[i]); i += 1
    args = parser.parse_args(cleaned)
    reg, reg_file = _connections_registry()
    if args.cmd == "doctor":
        cmd_doctor(reg, reg_file, wanted, token_key); return
    cid, entry = _select_connection(reg, wanted)
    _write_gate(cid, WRITE_DEFAULT if entry is None else bool(entry.get("allow_write", WRITE_DEFAULT)), args.cmd)
    key = token_key or (entry or {}).get("secret_env") or "YOUTRACK_TOKEN"
    base_url, _, _ = _resolve_base_url(entry, reg_file)
    if not base_url: _die(2, "missing_url", "YOUTRACK_URL/base_url is not configured")
    with _client(base_url, _load_token(key)) as client:
        if args.cmd == "whoami": _emit(cmd_whoami(client))
        elif args.cmd == "projects": _emit(cmd_projects(client, args.query))
        elif args.cmd == "task": _emit(cmd_task(client, args.issue))
        elif args.cmd == "comments":
            if args.limit < 1: _die(6, "input", "--limit must be positive")
            _emit(cmd_comments(client, args.issue, args.limit))
        elif args.cmd == "issues":
            if args.limit < 1: _die(6, "input", "--limit must be positive")
            _emit(cmd_issues(client, args.query, args.limit))
        elif args.cmd == "create":
            description = _read_text(args.description) if args.description is not None else None
            _emit(cmd_create(client, args.project, args.summary, description))
        elif args.cmd == "comment":
            text = _read_text(args.text if args.text is not None else "-")
            if not text.strip(): _die(6, "input", "comment text cannot be empty")
            _emit(cmd_comment(client, args.issue, text))
        elif args.cmd == "update":
            _emit(cmd_update(client, args.issue, args.state))
        elif args.cmd == "articles":
            if args.limit < 1: _die(6, "input", "--limit must be positive")
            _emit(cmd_articles(client, args.project, args.limit))
        elif args.cmd == "article":
            _emit(cmd_article(client, args.article))
        elif args.cmd == "article-comments":
            if args.limit < 1: _die(6, "input", "--limit must be positive")
            _emit(cmd_article_comments(client, args.article, args.limit))
        elif args.cmd == "article-create":
            if not args.project and not args.parent:
                _die(6, "input", "article-create needs --project or --parent")
            content = _read_text(args.content) if args.content is not None else None
            _emit(cmd_article_create(client, args.summary, content, args.project, args.parent))
        elif args.cmd == "article-update":
            if args.summary is None and args.content is None:
                _die(6, "input", "article-update needs --summary or --content")
            content = _read_text(args.content) if args.content is not None else None
            _emit(cmd_article_update(client, args.article, args.summary, content))
        elif args.cmd == "article-comment":
            text = _read_text(args.text if args.text is not None else "-")
            if not text.strip(): _die(6, "input", "comment text cannot be empty")
            _emit(cmd_article_comment(client, args.article, text))

if __name__ == "__main__":
    main()
