# whatsapp — credentials (copy to $XDG_CONFIG_HOME/whatsapp/credentials.env,
# default ~/.config/whatsapp/credentials.env, and fill). This is the user-config
# source in the cascade; a consuming project can override per-project in its own
# .env(.local), and a profile's whatsapp.json names which key holds the secret.
# PUBLIC REPO: never commit real values. Leave blank here; fill only the copy.

# WAHA instance URL — the self-hosted WhatsApp HTTP API endpoint. Single-instance
# use sets it here; in profile mode the URL is `base_url` in whatsapp.json instead.
# A connection value, not a secret, but it pins the instance — keep it out of the CLI.
WAHA_BASE_URL=

# WAHA API key — the instance X-Api-Key. In profile mode the holding env var is
# named by each profile's `secret_env`; this is the conventional single-instance
# name. Never pass on argv.
WAHA_WHATSAPP_API_KEY=

# Dashboard basic auth — only if the WAHA instance fronts its API with HTTP basic
# auth. Leave blank otherwise.
# WAHA_DASHBOARD_USERNAME=
# WAHA_DASHBOARD_PASSWORD=

# Deepgram API key — only `whatsapp transcribe` reads it. Leave blank unless this
# install transcribes exported voice/audio. Never pass on argv.
# DEEPGRAM_API_KEY=
