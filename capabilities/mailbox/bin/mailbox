#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "imap-tools>=1.13",
#     "httpx>=0.27",
#     "fpdf2>=2.7",
# ]
# ///
"""
mailbox — agent-first IMAP/SMTP CLI for mailboxes.

This tool is designed to be invoked by agents. Run `mailbox help` to load
the full usage contract on demand — do not rely on memorised knowledge of
its surface.

This is a THIN, project-agnostic adapter: read, fetch attachments, flag, send.
Any orchestration (invoice-drain, triage, routing) is a CONSUMER's operation
layer that reads this tool's JSON — it does NOT live here. The tool knows
nothing about who owns a mailbox; that lives in the consuming project.

CONNECTIONS
  Configuration resolves as named connections. With no registry the sole
  connection is `default`, resolved from the credential cascade (flat keys
  below). A project with several mailboxes declares them in
  <project>/.capabilities/mailbox/connections.json:
    {
      "default": "<id>",
      "connections": {
        "<id>": {
          "address":    "user@example.com",
          "imap_host":  "mail.example.com", "imap_port": 993,
          "smtp_host":  "mail.example.com", "smtp_port": 587,
          "secret_env": "MAILBOX_<ID>_APP_PASSWORD",
          "allow_write": true
        }
      }
    }
  The registry resolves project envelope first, else the machine-level
  ~/.config/mailbox/connections.json; first found wins, never merged.

  Only the password is secret: the entry names the env var holding it
  ("secret_env"); the value resolves through the cascade — project
  .env/.env.local → ~/.config/mailbox/credentials.env → process env.

  WRITES ARE OFF BY DEFAULT: mailbox writes leave the system (mail reaches
  real people), so send/move/seen (and fetch --mark-seen) exit 4 unless the
  connection carries an explicit "allow_write": true. No flag lifts the
  gate; granting it is a deliberate registry edit, made after asking the
  user. The implicit default connection can never write.

  Selection: --connection <id|address> accepted before or after the
  subcommand (--mailbox is an alias). Unflagged, the registry's "default"
  pointer applies, else the sole entry; several entries without a pointer
  is refused as ambiguous.

  Credential keys for the implicit default connection (no registry):
    MAILBOX_ADDRESS       mailbox address                  (required)
    MAILBOX_IMAP_HOST     IMAP host                        (required)
    MAILBOX_IMAP_PORT     IMAP port                        (default 993)
    MAILBOX_SMTP_HOST     SMTP host                        (required)
    MAILBOX_SMTP_PORT     SMTP port                        (default 587)
    MAILBOX_APP_PASSWORD  app password (secret)            (required)

Commands:
  mailbox help                                Print this document.
  mailbox connections                         Where every connection's values
                                              resolve from (tier, source,
                                              secrets masked). Local only.
  mailbox mailboxes                           Alias of `mailbox connections`.
  mailbox doctor [--connection <id>]          Validate IMAP + SMTP login —
                                              every connection, or one.
  mailbox list [--unread] [--folder F]        List messages (headers only).
        [--since YYYY-MM-DD] [--limit N]      JSON: uid, message_id, date,
                                              from, subject, seen.
  mailbox search [--from EMAIL]               Server-side IMAP SEARCH; same
        [--subject S] [--text T]              output shape as `list`.
        [--since YYYY-MM-DD] [--folder F]
        [--limit N]
  mailbox show <uid> | --message-id <id>      One message: headers, text body,
        [--folder F]                          attachment manifest (no payloads).
                                              --message-id locates it across ALL
                                              folders (folder-agnostic; survives an
                                              INBOX -> Archive move) and reports the
                                              folder it now lives in.
  mailbox fetch <uid> | --message-id <id>     Save attachments to DIR.
        --save-dir DIR [--folder F]           JSON: saved paths + content types.
        [--mark-seen]                         mark-seen is OFF by default.
                                              --message-id as for show.
  mailbox pdf <uid> | --message-id <id>       Render the message as a self-
        --save-dir DIR [--folder F]           contained PDF: headers, the FULL
                                              text body (wraps long lines and
                                              paginates), attachment manifest.
                                              UTF-8 safe (Cyrillic, Estonian, ...).
                                              JSON: saved path + attachment
                                              manifest. --message-id as for show.
  mailbox eml <uid> | --message-id <id>       Save the raw RFC822 source (.eml)
        --save-dir DIR [--folder F]           exactly as it sits on the server
                                              (BODY.PEEK[], all headers and MIME
                                              parts preserved) — the archival
                                              original for authenticity proofs.
                                              JSON: saved path. --message-id as
                                              for show.
  mailbox seen <uid> [--unsee] [--folder F]   Flag / unflag \\Seen.
  mailbox folders                             List IMAP folders (find Archive).
  mailbox move <uid> --to-folder F            Move a message to another folder
        [--folder F]                          (e.g. INBOX -> Archive).
  mailbox send --to A [--to B ...] --subject S
        [--body TEXT | --body-file F | -]     Send a message. Body from
        [--cc A ...] [--attach FILE ...]      --body, a file, or stdin.
        [--in-reply-to MESSAGE-ID]

IMAP concurrency:
  Folder reads (list/search/show/fetch) each open one IMAP connection. Many
  servers cap concurrent sessions, so run them sequentially rather than in
  parallel; a stuck or refused connection fails fast (30s socket timeout,
  non-zero exit) rather than hanging.

Idempotency:
  Use message_id (globally stable) as the dedup key for processing, NOT uid.
  IMAP uids reset if the folder's UIDVALIDITY changes (server migration), and
  a uid is only valid inside the folder it was read from — moving a message
  (e.g. INBOX -> Archive) reassigns it. To re-open a message after a move, use
  `show`/`fetch --message-id <id>`, which finds it in whatever folder it now
  lives in. A uid + --folder is the fast path when both are known and current.

I/O contract:
  - Success: JSON on stdout, exit 0.
  - Error:   {"error": {"code", "message", "hint"}} on stderr, non-zero exit.

Contract commands (the same on every capability):
  mailbox stub                                One-line awareness text.
  mailbox manifest --json                     Machine-readable declaration.
  mailbox guide [<topic>]                     Guide topics / one guide body,
                                              fetched live from the docs base.
  mailbox ids list|get <l>|set <l> <v>|rm <l> The project identifiers envelope
          [--note <text>]                     (.capabilities/mailbox/identifiers.json).
  mailbox refs                                Menu of the project's reference
                                              files for this capability.

Exit codes:
  0  success
  2  auth (missing credentials, login rejected)
  3  not found (no message with that uid)
  4  policy refusal — the project gate (.capabilities/settings.json) on any
     verb, or a write verb on a read-only connection (allow_write: false).
     Ask the user; never lift a gate yourself.
  5  server / network (IMAP/SMTP unreachable, timeout)
  6  input / validation
"""

import argparse
import json
import mimetypes
import os
import smtplib
import ssl
import sys
from datetime import date, datetime
from email.message import EmailMessage
from pathlib import Path
from typing import NoReturn

from imap_tools import AND, MailBox, MailboxLoginError, MailMessageFlags


# --- Capability declaration (protocol 2) — one home for every contract fact --

NAME = "mailbox"
PROTOCOL = 2
SUMMARY = ("Thin IMAP/SMTP CLI for mailboxes — list/show messages, save "
           "attachments, render PDF, save raw .eml, flag `\\Seen`, move "
           "between folders, and send.")
SCOPE = "project"   # credential scope: "project" | "user"
CRED_KEYS = [       # the implicit default connection; a registry entry supplies these per id
    {"key": "MAILBOX_ADDRESS", "secret": False, "required": True, "note": "mailbox address"},
    {"key": "MAILBOX_IMAP_HOST", "secret": False, "required": True, "note": "IMAP host"},
    {"key": "MAILBOX_IMAP_PORT", "secret": False, "required": False, "note": "IMAP port (default 993)"},
    {"key": "MAILBOX_SMTP_HOST", "secret": False, "required": True, "note": "SMTP host"},
    {"key": "MAILBOX_SMTP_PORT", "secret": False, "required": False, "note": "SMTP port (default 587)"},
    {"key": "MAILBOX_APP_PASSWORD", "secret": True, "required": True, "note": "app password"},
]
WRITE_VERBS = {"send", "move", "seen"}   # domain verbs that mutate the mailbox
WRITE_DEFAULT = False   # mailbox writes leave the system (mail to real people) — granted per connection, explicitly
DOCS_BASE = ""      # upstream guides base URL; "" while no guides ship
TOPICS: list = []   # shipped guide topics
STATE = False       # True when the capability writes session/cache state
POST_INSTALL: list = []

_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config"))
CREDENTIALS_ENV = _CONFIG_HOME / "mailbox" / "credentials.env"
_STATE_HOME = Path(os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state"))

PORT_DEFAULTS = {"imap_port": 993, "smtp_port": 587}


# >>> contract: capability core (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

# --- Error reporting ---------------------------------------------------------

def _die(exit_code: int, code: str, message: str,
         hint: str | None = None, status: int | None = None) -> NoReturn:
    err: dict = {"code": code, "message": message}
    if hint:
        err["hint"] = hint
    if status is not None:
        err["status"] = status
    sys.stderr.write(json.dumps({"error": err}, ensure_ascii=False) + "\n")
    sys.exit(exit_code)


def _emit(value) -> None:
    if isinstance(value, str):
        sys.stdout.write(value)
        if value and not value.endswith("\n"):
            sys.stdout.write("\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


# --- Project / file plumbing -------------------------------------------------

def _parse_env_file(path: Path) -> dict:
    """Parse a KEY=VALUE env/dotenv file. Missing/unreadable file -> {}."""
    out: dict = {}
    try:
        text = path.read_text()
    except OSError:
        return out
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("export "):
            k = k[len("export "):].strip()
        out[k] = v.strip().strip('"').strip("'")
    return out


def _project_root() -> Path | None:
    """Nearest project root, walking up from $CLAUDE_PROJECT_DIR (else cwd):
    the first directory holding .capabilities/, .env(.local), or .git.
    $HOME is never a project root (the machine registry lives there)."""
    start = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    here = Path(start).resolve()
    home = Path.home().resolve()
    for d in (here, *here.parents):
        if d == home:
            return None
        if ((d / ".capabilities").is_dir() or (d / ".env").exists()
                or (d / ".env.local").exists() or (d / ".git").is_dir()):
            return d
    return None


def _project_env() -> dict:
    """Project .env(.local) at the project root. .env.local overrides .env."""
    root = _project_root()
    if root is None:
        return {}
    merged = _parse_env_file(root / ".env")
    merged.update(_parse_env_file(root / ".env.local"))  # .local wins
    return merged


def _gate() -> None:
    """absent → run; enabled → run; disabled → exit 4. Unreadable never blocks."""
    root = _project_root()
    if root is None:
        return
    gate_file = root / ".capabilities" / "settings.json"
    try:
        entry = json.loads(gate_file.read_text()).get("capabilities", {}).get(NAME)
    except (OSError, ValueError):
        return
    if isinstance(entry, dict) and entry.get("enabled") is False:
        _die(4, "disabled",
             f"{NAME} is disabled in this project ({gate_file})",
             "Do not enable it yourself — ask the user whether to enable it, then stop.")


def _env_dir() -> Path | None:
    """The capability's envelope dir in the project: .capabilities/<NAME>/."""
    root = _project_root()
    return (root / ".capabilities" / NAME) if root is not None else None


def _state_dir() -> Path:
    """State follows the scope of the credentials that minted it; project state
    lands inside the envelope only where .capabilities/ already exists."""
    if SCOPE == "project":
        root = _project_root()
        if root is not None and (root / ".capabilities").is_dir():
            return root / ".capabilities" / NAME / "state"
    return _STATE_HOME / NAME


# --- Capability contract (protocol 2) — the declaration surface --------------

def _docs_base() -> str:
    key = f"{NAME.upper()}_DOCS_BASE"
    return (_project_env().get(key)
            or _parse_env_file(CREDENTIALS_ENV).get(key)
            or os.environ.get(key)
            or DOCS_BASE)


def _cmd_guide(argv: list[str]) -> None:
    if not argv:
        _emit(sorted(TOPICS)); return
    topic = argv[0]
    if topic not in TOPICS:
        _die(3, "not_found", f"no guide topic {topic!r}",
             f"topics: {', '.join(sorted(TOPICS)) or 'none shipped'}")
    import urllib.error as _ue
    import urllib.request as _ur
    url = _docs_base().rstrip("/") + "/" + topic + ".md"
    cache_dir = _STATE_HOME / NAME / "guides"
    cache, etag_f = cache_dir / f"{topic}.md", cache_dir / f"{topic}.etag"
    headers = {}
    if cache.exists() and etag_f.exists():
        headers["If-None-Match"] = etag_f.read_text().strip()
    try:
        req = _ur.Request(url, headers=headers)
        with _ur.urlopen(req, timeout=10.0) as resp:
            text = resp.read().decode(resp.headers.get_content_charset() or "utf-8")
            cache_dir.mkdir(parents=True, exist_ok=True)
            cache.write_text(text)
            if resp.headers.get("etag"):
                etag_f.write_text(resp.headers["etag"])
            _emit(text); return
    except _ue.HTTPError as e:
        if e.code == 304 and cache.exists():
            _emit(cache.read_text()); return
        if e.code == 404:
            _die(3, "not_found", f"guide {topic!r} missing upstream", url)
        err = f"upstream returned {e.code}"
    except _ue.URLError as e:
        err = str(e.reason)
    except OSError as e:
        err = str(e)
    if cache.exists():
        sys.stderr.write(json.dumps(
            {"warning": f"upstream unreachable; serving cached copy ({err})"},
            ensure_ascii=False) + "\n")
        _emit(cache.read_text()); return
    _die(5, "network_error", f"could not fetch guide {topic!r}; no cache exists", url)


def _render_ids_markdown(data: dict) -> str:
    """Render the {label: {value, note}} envelope as the labelled markdown
    list the manager's `capabilities ids <NAME>` also produces — one shared
    format across the ids surface and the identifiers section of `help`."""
    lines: list[str] = []
    for label, entry in sorted(data.items()):
        entry = entry if isinstance(entry, dict) else {"value": entry}
        v = entry.get("value")
        vs = f"`{v}`" if isinstance(v, str) else "`" + json.dumps(v, ensure_ascii=False) + "`"
        line = f"- **{label}**: {vs}"
        note = entry.get("note")
        if note:
            line += f" — {note}"
        lines.append(line)
    return "\n".join(lines)


def _identifiers_section() -> str:
    """The Identifiers block appended to the bare top-level help — deterministic
    first-touch surfacing of `.capabilities/<NAME>/identifiers.json` so an
    agent following the `<NAME> help` startup protocol loads the discovered
    labels/values/notes into context at once. Empty when no project envelope
    or nothing recorded (do not bloat help with an empty section)."""
    envdir = _env_dir()
    if envdir is None:
        return ""
    ids_file = envdir / "identifiers.json"
    if not ids_file.exists():
        return ""
    try:
        data = json.loads(ids_file.read_text())
    except (OSError, ValueError):
        return ""
    if not isinstance(data, dict) or not data:
        return ""
    header = (
        "\n═══ Identifiers ═════════════════════════════════════════════════════════════\n\n"
        f"Structural lookups discovered for `{NAME}` in this project. Fetch a single\n"
        f"raw value with `{NAME} ids get <label>`; the full envelope is also at\n"
        f"`capabilities ids {NAME}`.\n\n"
    )
    return header + _render_ids_markdown(data) + "\n"


def _cmd_help() -> None:
    """Bare top-level help: the CLI's HELP body (module-level `HELP` if
    defined, else the module docstring), then the project's Identifiers
    section. Only fires when no extra args follow — per-verb help stays
    untouched so `<NAME> help <subcommand>` is not intercepted."""
    g = globals()
    text = g.get("HELP") or g.get("__doc__") or ""
    if text.startswith("\n"):
        text = text.lstrip("\n")
    sys.stdout.write(text)
    if text and not text.endswith("\n"):
        sys.stdout.write("\n")
    section = _identifiers_section()
    if section:
        sys.stdout.write(section)


def _cmd_ids(argv: list[str]) -> None:
    sub = argv[0] if argv else "list"
    envdir = _env_dir()
    ids_file = (envdir / "identifiers.json") if envdir else None
    data: dict = {}
    if ids_file and ids_file.exists():
        try:
            data = json.loads(ids_file.read_text())
        except ValueError:
            _die(6, "bad_envelope", f"{ids_file} is not valid JSON")
    if sub == "list":
        _emit(data); return
    if sub == "get":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        _emit((data[argv[1]] or {}).get("value")); return
    if sub == "set":
        if len(argv) < 3:
            _die(6, "input", f"usage: {NAME} ids set <label> <value> [--note <text>]")
        if envdir is None or not envdir.parent.is_dir():
            _die(6, "no_envelope", "no .capabilities/ envelope in this project",
                 "run `capabilities init` first")
        label, raw = argv[1], argv[2]
        try:
            value = json.loads(raw)
        except ValueError:
            value = raw
        note = ""
        if "--note" in argv:
            ni = argv.index("--note")
            if ni + 1 >= len(argv):
                _die(6, "input", "--note needs a value")
            note = argv[ni + 1]
        data[label] = {"value": value, "note": note or (data.get(label) or {}).get("note", "")}
        envdir.mkdir(parents=True, exist_ok=True)
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"set": label}); return
    if sub == "rm":
        if len(argv) < 2 or argv[1] not in data:
            _die(3, "not_found", "unknown identifier label",
                 f"`{NAME} ids list` shows the labels")
        del data[argv[1]]
        ids_file.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
        _emit({"removed": argv[1]}); return
    _die(6, "input", f"unknown ids subcommand {sub!r}", f"{NAME} ids list|get|set|rm")


def _cmd_refs() -> None:
    envdir = _env_dir()
    refdir = (envdir / "reference") if envdir else None
    out = []
    if refdir and refdir.is_dir():
        for md in sorted(refdir.glob("*.md")):
            name = desc = None
            try:
                lines = md.read_text().splitlines()
            except OSError:
                continue
            if lines and lines[0].strip() == "---":
                for line in lines[1:30]:
                    if line.strip() == "---":
                        break
                    if line.startswith("name:"):
                        name = line.split(":", 1)[1].strip()
                    elif line.startswith("description:"):
                        desc = line.split(":", 1)[1].strip()
            if name:
                out.append({"name": name, "description": desc or "", "path": str(md)})
    _emit(out)


def _contract(argv: list[str]) -> None:
    """Dispatch the contract verbs; domain verbs fall through to the CLI's own
    parser. Runs after _gate(), before any credential is resolved.

    `help` is a contract verb only when bare (no extra args) — the top-level
    dump plus the Identifiers section. `<NAME> help <subcommand>` falls
    through to the CLI so per-verb help stays clean."""
    cmd = argv[0] if argv else ""
    if cmd == "stub":
        _emit(f"{SUMMARY} Run `{NAME} help`.")
    elif cmd == "manifest":
        _emit({"name": NAME, "protocol": PROTOCOL, "summary": SUMMARY,
               "credentials": {"scope": SCOPE, "keys": CRED_KEYS},
               "docs": {"base": DOCS_BASE, "topics": sorted(TOPICS)},
               "state": STATE, "post_install": POST_INSTALL})
    elif cmd == "guide":
        _cmd_guide(argv[1:])
    elif cmd == "ids":
        _cmd_ids(argv[1:])
    elif cmd == "refs":
        _cmd_refs()
    elif cmd == "connections":
        _cmd_connections()
    elif cmd == "help" and len(argv) == 1:
        _cmd_help()
    else:
        return
    sys.exit(0)

# <<< contract: capability core <<<


# >>> contract: connections (generated — edit contract/preamble.py, run `capabilities sync-contract`) >>>

def _resolve_env_key(key: str) -> tuple[str | None, str | None, Path | None]:
    """Resolve one env key through cascade tiers 2-4: project .env(.local) →
    user credentials.env → process env. Returns (value, tier, source)."""
    root = _project_root()
    if root is not None:
        for fname in (".env.local", ".env"):
            val = _parse_env_file(root / fname).get(key)
            if val:
                return val, "project", root / fname
    val = _parse_env_file(CREDENTIALS_ENV).get(key)
    if val:
        return val, "user", CREDENTIALS_ENV
    val = os.environ.get(key)
    if val:
        return val, "env", None
    return None, None, None


def _mask(value: str) -> str:
    return ("…" + value[-4:]) if len(value) >= 8 else "****"


def _connections_registry() -> tuple[dict | None, Path | None]:
    """The connections envelope and its path: project envelope first, else the
    user config home. First found wins, never merged; (None, None) when neither
    declares one (the implicit default connection applies)."""
    envdir = _env_dir()
    candidates = ([envdir / "connections.json"] if envdir else []) + \
                 [_CONFIG_HOME / NAME / "connections.json"]
    for reg_file in candidates:
        if not reg_file.is_file():
            continue
        try:
            raw = json.loads(reg_file.read_text())
        except (ValueError, OSError) as e:
            _die(6, "bad_config", f"cannot read {reg_file}: {e}")
        if not isinstance(raw, dict) or not isinstance(raw.get("connections"), dict) \
                or not raw["connections"]:
            _die(6, "bad_config", f"{reg_file} is not a connections envelope",
                 'expected {"default": "<id>", "connections": { ... }}')
        return raw, reg_file
    return None, None


def _select_connection(reg: dict | None, wanted: str | None) -> tuple[str, dict | None]:
    """flag → default pointer → sole entry → die 6. No registry → the implicit
    default. A connection's own `address` field selects it too (used where a
    connection carries a human-recognizable address; absent fields never match)."""
    if reg is None:
        if wanted and wanted != "default":
            _die(6, "unknown_connection",
                 "no connections registry; the sole connection is 'default'",
                 "the implicit default resolves from the credential cascade")
        return "default", None
    conns = reg["connections"]
    if wanted:
        if wanted in conns:
            return wanted, conns[wanted]
        for cid, entry in conns.items():
            if (entry or {}).get("address", "").lower() == wanted.lower():
                return cid, entry
        _die(6, "unknown_connection", f"no connection matches {wanted!r}",
             f"known: {', '.join(conns)}")
    default = reg.get("default")
    if default:
        if default not in conns:
            _die(6, "bad_default", f"default points to unknown connection {default!r}",
                 f"known: {', '.join(conns)}")
        return default, conns[default]
    if len(conns) == 1:
        cid = next(iter(conns))
        return cid, conns[cid]
    _die(6, "ambiguous_connection",
         f"registry defines {len(conns)} connections and no default; "
         f"pass --connection <id>",
         f"known: {', '.join(conns)}")


def _write_gate(conn_id: str, allow_write: bool, verb: str) -> None:
    """Policy from the committed registry; nothing in the cascade lifts it."""
    if verb in WRITE_VERBS and not allow_write:
        _die(4, "read_only",
             f"connection {conn_id!r} does not allow writes",
             "Do not lift the gate yourself — ask the user; granting is "
             "`allow_write: true` on this connection in connections.json.")


def _key_report(key: str, secret: bool, required: bool,
                value: str | None, tier: str | None, source) -> dict:
    return {"key": key, "secret": secret, "required": required,
            "set": bool(value), "tier": tier if value else None,
            "source": str(source) if (value and source) else None,
            "value": (_mask(value) if secret else value) if value else None}


def _missing_required(keys: list) -> list:
    """Required report rows (from _key_report) that did not resolve through the
    cascade — empty ⇒ credentials present. The primitive behind doctor's
    network-free readiness gate, read from the same per-key resolution
    `connections` reports, so the gate and the report can never disagree."""
    return [k["key"] for k in keys if k["required"] and not k["set"]]


def _doctor_gate(report: dict, wanted: str | None) -> None:
    """doctor's network-free readiness gate. Refuse with exit 2 — naming the
    unresolved required keys, before any round-trip — when a connection under
    test cannot resolve its required config through the cascade, so readiness is
    judged by the same resolution `connections` reports, never a parallel check.
    Checks the selected connection, else every connection in the report."""
    conns = report.get("connections") or {}
    targets = [wanted] if (wanted and wanted in conns) else list(conns)
    problems: dict = {}
    for cid in targets:
        miss = _missing_required((conns.get(cid) or {}).get("keys") or [])
        if miss:
            problems[cid] = miss
    if problems:
        detail = "; ".join(f"{c}: {', '.join(ks)}" for c, ks in sorted(problems.items()))
        _die(2, "credentials_missing",
             f"unresolved required config — {detail}",
             f"set each in the project .env/.env.local, the user credentials.env, "
             f"or process env; `{NAME} connections` shows where every value resolves")

# <<< contract: connections <<<


# --- Connections (capability-specific) --------------------------------------

def _build_cfg(cid: str, entry: dict | None) -> tuple[dict | None, dict | None]:
    """Materialize one connection's config. Returns (cfg, problem) — problem is
    an error dict ({"exit", "code", "message", "hint"?}) instead of a die, so
    doctor can report every connection rather than stopping at the first."""
    if entry is None:   # the implicit default — flat keys through the cascade
        vals = {k["key"]: _resolve_env_key(k["key"])[0] for k in CRED_KEYS}
        missing = [k["key"] for k in CRED_KEYS if k["required"] and not vals[k["key"]]]
        if missing:
            return None, {
                "exit": 2, "code": "missing_credentials",
                "message": f"unset: {', '.join(missing)}",
                "hint": f"set them in the project .env(.local), {CREDENTIALS_ENV}, "
                        f"or the environment — or declare a connections registry "
                        f"(.capabilities/{NAME}/connections.json)"}
        return {
            "id": cid, "allow_write": WRITE_DEFAULT,
            "user": vals["MAILBOX_ADDRESS"],
            "password": vals["MAILBOX_APP_PASSWORD"],
            "imap_host": vals["MAILBOX_IMAP_HOST"],
            "imap_port": int(vals["MAILBOX_IMAP_PORT"] or PORT_DEFAULTS["imap_port"]),
            "smtp_host": vals["MAILBOX_SMTP_HOST"],
            "smtp_port": int(vals["MAILBOX_SMTP_PORT"] or PORT_DEFAULTS["smtp_port"]),
        }, None
    secret_env = entry.get("secret_env")
    if not secret_env:
        return None, {"exit": 6, "code": "no_secret_env",
                      "message": f"connection {cid!r} is missing 'secret_env'"}
    password, _, _ = _resolve_env_key(secret_env)
    if not password:
        return None, {
            "exit": 2, "code": "missing_secret",
            "message": f"env var {secret_env} (for connection {cid!r}) is unset",
            "hint": f"set {secret_env} in the project's .env / .env.local, "
                    f"{CREDENTIALS_ENV}, or the environment"}
    missing = [k for k in ("address", "imap_host", "smtp_host") if not entry.get(k)]
    if missing:
        return None, {"exit": 6, "code": "incomplete_connection",
                      "message": f"connection {cid!r} missing: {', '.join(missing)}"}
    return {
        "id": cid, "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
        "user": entry["address"],
        "password": password,
        "imap_host": entry["imap_host"],
        "imap_port": int(entry.get("imap_port", PORT_DEFAULTS["imap_port"])),
        "smtp_host": entry["smtp_host"],
        "smtp_port": int(entry.get("smtp_port", PORT_DEFAULTS["smtp_port"])),
    }, None


def _load_config(wanted: str | None) -> dict:
    reg, _ = _connections_registry()
    cid, entry = _select_connection(reg, wanted)
    cfg, problem = _build_cfg(cid, entry)
    if problem:
        _die(problem["exit"], problem["code"], problem["message"],
             problem.get("hint"))
    return cfg


def _connections_report() -> dict:
    """The resolution report — every connection, every value, its winning tier
    and source, secrets masked. Local only: no network, no login attempt. The
    one resolver doctor's gate and the `connections` verb both read."""
    reg, reg_path = _connections_registry()
    report: dict = {"default": None, "connections": {}}
    if reg is None:
        keys = []
        for k in CRED_KEYS:
            value, tier, source = _resolve_env_key(k["key"])
            keys.append(_key_report(k["key"], k["secret"], k["required"],
                                    value, tier, source))
        report["default"] = "default"
        report["connections"]["default"] = {"allow_write": WRITE_DEFAULT, "keys": keys}
        return report
    conns = reg["connections"]
    report["default"] = reg.get("default") or \
        (next(iter(conns)) if len(conns) == 1 else None)
    for cid, entry in conns.items():
        entry = entry if isinstance(entry, dict) else {}
        keys = []
        for field in ("address", "imap_host", "imap_port", "smtp_host", "smtp_port"):
            value = entry.get(field)
            keys.append(_key_report(
                field, False, field in ("address", "imap_host", "smtp_host"),
                str(value) if value is not None else None,
                "connection", reg_path))
        secret_env = entry.get("secret_env")
        if secret_env:
            value, tier, source = _resolve_env_key(secret_env)
            keys.append(_key_report(secret_env, True, True, value, tier, source))
        else:
            keys.append(_key_report("secret_env", False, True, None, None, None))
        report["connections"][cid] = {
            "allow_write": bool(entry.get("allow_write", WRITE_DEFAULT)),
            "keys": keys}
    return report


def _cmd_connections() -> None:
    _emit(_connections_report())


# --- Output ------------------------------------------------------------------

def _read_body(src: str | None) -> str:
    if src is None or src == "-":
        return sys.stdin.read()
    p = Path(src)
    return p.read_text() if p.exists() else src


def _safe_filename(name: str | None, uid: str, idx: int, content_type: str) -> str:
    if not name:
        ext = mimetypes.guess_extension(content_type or "") or ".bin"
        return f"attachment_{uid}_{idx}{ext}"
    name = os.path.basename(name).replace("/", "_").replace("\\", "_").lstrip(".")
    return name or f"attachment_{uid}_{idx}"


# --- IMAP --------------------------------------------------------------------

def _imap(cfg: dict) -> MailBox:
    hint = ("connection failed — note many IMAP servers cap concurrent "
            "connections, so run folder reads (list/search/show/fetch) "
            "sequentially rather than in parallel")
    try:
        mb = MailBox(cfg["imap_host"], port=cfg["imap_port"], timeout=30)
        mb.login(cfg["user"], cfg["password"], initial_folder="INBOX")
        return mb
    except MailboxLoginError as e:
        _die(2, "login_rejected", f"IMAP login failed: {e}", hint)
    except (OSError, ssl.SSLError) as e:
        _die(5, "imap_unreachable",
             f"cannot reach IMAP {cfg['imap_host']}:{cfg['imap_port']}: {e}",
             hint)


def _ascii_reduce(value: str) -> str | None:
    """The longest whitespace-token of `value` that is pure ASCII, or None if
    every token carries a non-ASCII byte. Used to keep a coarse server-side
    SEARCH criterion when the real query is non-ASCII (which Gmail refuses
    even with CHARSET UTF-8 — imaplib inlines the bytes instead of sending
    an IMAP literal). The full string then narrows client-side."""
    if all(ord(c) < 128 for c in value):
        return value
    ascii_tokens = [t for t in value.split() if t and all(ord(c) < 128 for c in t)]
    return max(ascii_tokens, key=len) if ascii_tokens else None


def _criteria(unread: bool, since: str | None,
              from_: str | None = None, subject: str | None = None,
              text: str | None = None):
    """Server-side SEARCH criteria + the client-side narrows the caller
    must run after fetch. Every non-ASCII text field is reduced to its
    longest ASCII token for the server (or dropped if none survives) and
    added to `narrows` as `(field, casefold(full_original))` so the caller
    can match the untruncated string in Python. When every text field is
    pure ASCII, `narrows` is empty and behavior is byte-identical to the
    old server-only path."""
    kw = {}
    narrows: list[tuple[str, str]] = []
    if unread:
        kw["seen"] = False
    if since:
        try:
            kw["date_gte"] = datetime.strptime(since, "%Y-%m-%d").date()
        except ValueError:
            _die(6, "bad_date", f"--since must be YYYY-MM-DD, got {since!r}")
    for field, value in (("from_", from_), ("subject", subject), ("text", text)):
        if not value:
            continue
        if all(ord(c) < 128 for c in value):
            kw[field] = value
            continue
        reduced = _ascii_reduce(value)
        if reduced:
            kw[field] = reduced
        narrows.append((field, value.casefold()))
    return (AND(**kw) if kw else "ALL"), narrows


def _narrow_iter(msgs, narrows: list[tuple[str, str]]):
    """Keep only messages whose real header/body substring matches every
    non-ASCII narrow, case-insensitive per Unicode casefold. A `text`
    narrow scans subject + from + body, so the caller must fetch without
    `headers_only` when any narrow targets that field (see _needs_body)."""
    for m in msgs:
        ok = True
        for field, needle in narrows:
            if field == "from_":
                hay = m.from_ or ""
            elif field == "subject":
                hay = m.subject or ""
            else:
                hay = " ".join([m.subject or "", m.from_ or "", m.text or ""])
            if needle not in hay.casefold():
                ok = False
                break
        if ok:
            yield m


def _needs_body(narrows: list[tuple[str, str]]) -> bool:
    return any(field == "text" for field, _ in narrows)


def _one(mb: MailBox, uid: str, mark_seen: bool):
    msgs = list(mb.fetch(AND(uid=str(uid)), mark_seen=mark_seen, bulk=False))
    if not msgs:
        _die(3, "not_found", f"no message with uid {uid} in this folder")
    return msgs[0]


# Folders probed first when locating by Message-ID; the rest are appended.
_PRIORITY_FOLDERS = ("INBOX", "Archive")


def _locate_by_message_id(mb: MailBox, message_id: str):
    """Find the message carrying this Message-ID, in whatever folder holds it.

    message_id is globally stable, so the first hit is THE message regardless of
    which folder it now lives in (e.g. after an INBOX -> Archive move, where the
    uid the message had in INBOX no longer addresses it). Returns (folder, msg);
    dies 3 if no folder holds it. IMAP HEADER search is a substring match, so the
    value matches with or without its angle brackets.
    """
    crit = f'HEADER MESSAGE-ID "{message_id.strip()}"'
    names = [f.name for f in mb.folder.list()]
    ordered = [n for n in _PRIORITY_FOLDERS if n in names] + \
              [n for n in names if n not in _PRIORITY_FOLDERS]
    for name in ordered:
        try:
            mb.folder.set(name)
        except Exception:
            continue  # unselectable container (\Noselect) — can't hold a message
        msgs = list(mb.fetch(crit, mark_seen=False, bulk=False, limit=1))
        if msgs:
            return name, msgs[0]
    _die(3, "not_found",
         f"no message with Message-ID {message_id} in any folder",
         "use the message_id exactly as `list`/`show` report it")


# --- Commands ----------------------------------------------------------------

def _check_connection(cfg: dict) -> dict:
    """One connection's round-trip, reported rather than died — doctor covers
    every connection, so a broken one becomes a finding, not a stop."""
    out: dict = {"user": cfg["user"],
                 "imap": f"{cfg['imap_host']}:{cfg['imap_port']}"}
    try:
        mb = MailBox(cfg["imap_host"], port=cfg["imap_port"])
        mb.login(cfg["user"], cfg["password"], initial_folder="INBOX")
        with mb:
            out["inbox_total"] = len(mb.uids("ALL"))
            out["inbox_unseen"] = len(mb.uids(AND(seen=False)))
    except MailboxLoginError as e:
        return out | {"ok": False, "category": 2, "error": f"IMAP login failed: {e}"}
    except (OSError, ssl.SSLError) as e:
        return out | {"ok": False, "category": 5,
                      "error": f"cannot reach IMAP {cfg['imap_host']}:{cfg['imap_port']}: {e}"}
    try:
        with smtplib.SMTP(cfg["smtp_host"], cfg["smtp_port"], timeout=30) as s:
            s.starttls(context=ssl.create_default_context())
            s.login(cfg["user"], cfg["password"])
        out["smtp_ok"] = True
    except smtplib.SMTPAuthenticationError as e:
        return out | {"ok": False, "category": 2, "error": f"SMTP login failed: {e}"}
    except (OSError, smtplib.SMTPException) as e:
        return out | {"ok": False, "category": 5,
                      "error": f"cannot reach SMTP {cfg['smtp_host']}:{cfg['smtp_port']}: {e}"}
    return out | {"ok": True}


def cmd_doctor(wanted: str | None) -> None:
    """Every connection bare; one with --connection. Exit 0 only when every
    examined connection is healthy, else the first failure's category."""
    _doctor_gate(_connections_report(), wanted)
    reg, _ = _connections_registry()
    if wanted is not None or reg is None:
        targets = [_select_connection(reg, wanted)]
    else:
        targets = list(reg["connections"].items())
    connections: dict = {}
    fail_exit = 0
    for cid, entry in targets:
        cfg, problem = _build_cfg(cid, entry)
        if problem:
            res = {"ok": False, "category": problem["exit"],
                   "error": problem["message"]}
            if problem.get("hint"):
                res["hint"] = problem["hint"]
        else:
            res = _check_connection(cfg)
        if not res.get("ok") and not fail_exit:
            fail_exit = res.get("category") or 5
        res.pop("category", None)
        connections[cid] = res
    _emit({"ok": fail_exit == 0, "connections": connections})
    if fail_exit:
        sys.exit(fail_exit)


def _emit_msg(m) -> dict:
    return {
        "uid": m.uid, "message_id": m.headers.get("message-id", ("",))[0] or None,
        "date": m.date_str, "from": m.from_, "to": list(m.to),
        "subject": m.subject, "seen": "\\Seen" in m.flags,
    }


def _fetch_with_narrow(mb: MailBox, criteria, narrows, *, limit: int) -> list:
    """One fetch + optional client-side narrow. When narrows are active we
    widen the server window (a coarse ASCII token is a superset match) and
    then trim to the caller's `limit` after the full-substring filter, so
    --limit applies to the narrowed result."""
    server_limit = max(limit * 5, 200) if narrows else limit
    msgs = mb.fetch(criteria, mark_seen=False,
                    headers_only=not _needs_body(narrows), bulk=False,
                    reverse=True, limit=server_limit)
    out = []
    for m in _narrow_iter(msgs, narrows):
        out.append(_emit_msg(m))
        if len(out) >= limit:
            break
    return out


def cmd_list(cfg: dict, folder: str, unread: bool, since: str | None, limit: int) -> list:
    with _imap(cfg) as mb:
        if folder != "INBOX":
            mb.folder.set(folder)
        criteria, narrows = _criteria(unread, since)
        return _fetch_with_narrow(mb, criteria, narrows, limit=limit)


def cmd_search(cfg: dict, folder: str, from_: str | None, subject: str | None,
               since: str | None, text: str | None, limit: int) -> list:
    with _imap(cfg) as mb:
        if folder != "INBOX":
            mb.folder.set(folder)
        criteria, narrows = _criteria(False, since, from_, subject, text)
        return _fetch_with_narrow(mb, criteria, narrows, limit=limit)


def cmd_show(cfg: dict, uid: str | None, folder: str, message_id: str | None = None) -> dict:
    with _imap(cfg) as mb:
        if message_id:
            folder, m = _locate_by_message_id(mb, message_id)
        else:
            if folder != "INBOX":
                mb.folder.set(folder)
            m = _one(mb, uid, mark_seen=False)
        return {
            "uid": m.uid, "folder": folder,
            "message_id": m.headers.get("message-id", ("",))[0] or None,
            "date": m.date_str, "from": m.from_, "to": list(m.to), "cc": list(m.cc),
            "subject": m.subject, "seen": "\\Seen" in m.flags,
            "text": m.text or m.html, "has_html": bool(m.html),
            "attachments": [
                {"filename": a.filename, "content_type": a.content_type, "size": a.size}
                for a in m.attachments
            ],
        }


def cmd_fetch(cfg: dict, uid: str | None, folder: str, save_dir: str,
              mark_seen: bool, message_id: str | None = None) -> dict:
    out_dir = Path(save_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    saved = []
    with _imap(cfg) as mb:
        if message_id:
            folder, m = _locate_by_message_id(mb, message_id)
            uid = m.uid
            if mark_seen:
                mb.flag(str(uid), MailMessageFlags.SEEN, True)
        else:
            if folder != "INBOX":
                mb.folder.set(folder)
            m = _one(mb, uid, mark_seen=mark_seen)
        for i, a in enumerate(m.attachments):
            fname = _safe_filename(a.filename, uid, i, a.content_type)
            dest = out_dir / fname
            dest.write_bytes(a.payload)
            saved.append({"path": str(dest), "content_type": a.content_type, "size": a.size})
    return {"uid": uid, "folder": folder,
            "message_id": m.headers.get("message-id", ("",))[0] or None,
            "saved": saved, "marked_seen": mark_seen}


# Ordered probe list — first hit wins; a project-scoped override lands first
# so a machine without a system Unicode TTF can still render.
_PDF_FONT_CANDIDATES = (
    Path.home() / ".config" / "mailbox" / "pdf-font.ttf",
    Path("/System/Library/Fonts/Supplemental/Arial Unicode.ttf"),
    Path("/Library/Fonts/Arial Unicode.ttf"),
    Path("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"),
    Path("/usr/share/fonts/dejavu/DejaVuSans.ttf"),
    Path("/usr/share/fonts/TTF/DejaVuSans.ttf"),
    Path("/usr/share/fonts/liberation/LiberationSans-Regular.ttf"),
)


def _find_pdf_font() -> Path | None:
    for c in _PDF_FONT_CANDIDATES:
        if c.is_file():
            return c
    return None


def _html_to_text(html: str) -> str:
    """Minimal HTML -> text: strip tags, collapse whitespace. Used only when a
    message ships HTML but no text/plain part."""
    from html.parser import HTMLParser
    from html import unescape

    class _X(HTMLParser):
        def __init__(self):
            super().__init__()
            self.buf: list[str] = []
            self.skip = 0
        def handle_starttag(self, tag, attrs):
            if tag in ("script", "style"):
                self.skip += 1
            elif tag in ("br", "p", "div", "li", "tr"):
                self.buf.append("\n")
        def handle_endtag(self, tag):
            if tag in ("script", "style") and self.skip:
                self.skip -= 1
            elif tag in ("p", "div", "li", "tr"):
                self.buf.append("\n")
        def handle_data(self, data):
            if not self.skip:
                self.buf.append(data)

    x = _X()
    try:
        x.feed(html)
    except Exception:
        return unescape(html)
    text = unescape("".join(x.buf))
    # collapse runs of blank lines
    lines = [ln.rstrip() for ln in text.splitlines()]
    out: list[str] = []
    blank = 0
    for ln in lines:
        if ln.strip():
            out.append(ln); blank = 0
        else:
            blank += 1
            if blank <= 1:
                out.append("")
    return "\n".join(out).strip()


def _pdf_slug(subject: str | None, uid: str | int) -> str:
    base = (subject or f"message-{uid}").strip()
    slug = "".join(c if (c.isalnum() or c in "-_ .") else "_" for c in base)
    slug = slug.strip().strip(".")[:80] or f"message-{uid}"
    return f"{slug}.pdf"


def _render_message_pdf(subject: str, from_: str, to: list, cc: list,
                        date_str: str, body: str, attachments: list,
                        font_path: Path, dest: Path) -> None:
    """Render one message to `dest`. Extracted so it can be exercised on a
    synthetic fixture without an IMAP round-trip. Every `multi_cell` returns
    the cursor to the left margin — the fpdf2 default (`new_x=RIGHT`) leaves
    it at the page's right edge, which silently pushes subsequent cells off
    the page and truncates the body."""
    from fpdf import FPDF

    pdf = FPDF(unit="mm", format="A4")
    pdf.set_margin(15)
    pdf.set_auto_page_break(True, margin=15)
    pdf.add_font("Body", "", str(font_path))
    pdf.add_page()
    w = pdf.epw

    def _row(size: float, text: str, h: float = 5) -> None:
        pdf.set_font("Body", "", size)
        pdf.multi_cell(w, h, text, wrapmode="CHAR",
                       new_x="LMARGIN", new_y="NEXT")

    _row(14, subject or "(no subject)", h=8)
    pdf.ln(2)

    for label, value in (("From", from_), ("To", ", ".join(to)),
                         ("Cc", ", ".join(cc)), ("Date", date_str)):
        if value:
            _row(10, f"{label}: {value}")
    pdf.ln(3)

    if body:
        for line in body.splitlines() or [""]:
            _row(11, line if line else " ")
    else:
        _row(11, "(empty body)")

    pdf.ln(4)
    if attachments:
        _row(10, f"Attachments ({len(attachments)}):")
        for a in attachments:
            size_kb = (a["size"] or 0) / 1024
            _row(10,
                 f"  - {a['filename'] or '(unnamed)'} "
                 f"({a['content_type'] or 'application/octet-stream'}, "
                 f"{size_kb:.1f} KB)")
    else:
        _row(10, "Attachments: none")

    pdf.output(str(dest))


def cmd_pdf(cfg: dict, uid: str | None, folder: str, save_dir: str,
            message_id: str | None = None) -> dict:
    try:
        import fpdf  # noqa: F401
    except ImportError as e:
        _die(5, "missing_dependency", f"fpdf2 is required for pdf: {e}",
             "reinstall the mailbox capability so uv resolves the script deps")

    out_dir = Path(save_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    with _imap(cfg) as mb:
        if message_id:
            folder, m = _locate_by_message_id(mb, message_id)
            uid = m.uid
        else:
            if folder != "INBOX":
                mb.folder.set(folder)
            m = _one(mb, uid, mark_seen=False)

        subject = m.subject or ""
        from_ = m.from_ or ""
        to = list(m.to)
        cc = list(m.cc)
        date_str = m.date_str or ""
        msgid_val = m.headers.get("message-id", ("",))[0] or None
        text = m.text or ""
        html = m.html or ""
        attachments = [
            {"filename": a.filename, "content_type": a.content_type, "size": a.size}
            for a in m.attachments
        ]

    body = text or (_html_to_text(html) if html else "")

    font_path = _find_pdf_font()
    if font_path is None:
        _die(5, "no_font",
             "no Unicode-capable TTF font found on this system",
             "place a TTF at ~/.config/mailbox/pdf-font.ttf, "
             "or install a system font (macOS: Arial Unicode; Linux: DejaVu Sans)")

    dest = out_dir / _pdf_slug(subject, uid)
    _render_message_pdf(subject, from_, to, cc, date_str, body, attachments,
                        font_path, dest)

    return {"uid": uid, "folder": folder,
            "message_id": msgid_val,
            "saved": str(dest),
            "attachments": attachments}


def cmd_eml(cfg: dict, uid: str | None, folder: str, save_dir: str,
            message_id: str | None = None) -> dict:
    """Save the raw RFC822 source (.eml) — the on-server bytes fetched with
    BODY.PEEK[] so no flags flip. imap_tools parses fetch data into `.obj` and
    drops the raw payload, so we re-fetch through the underlying imaplib client
    after locating the message."""
    out_dir = Path(save_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    with _imap(cfg) as mb:
        if message_id:
            folder, m = _locate_by_message_id(mb, message_id)
            uid = m.uid
        else:
            if folder != "INBOX":
                mb.folder.set(folder)
            m = _one(mb, uid, mark_seen=False)
        msgid_val = m.headers.get("message-id", ("",))[0] or None
        typ, data = mb.client.uid("fetch", str(uid), "(BODY.PEEK[])")
        if typ != "OK":
            _die(5, "fetch_failed",
                 f"raw fetch for uid {uid} returned {typ}")
        raw: bytes | None = None
        for item in data or []:
            if isinstance(item, tuple) and len(item) >= 2 \
                    and isinstance(item[1], (bytes, bytearray)):
                raw = bytes(item[1])
                break
        if not raw:
            _die(5, "fetch_failed",
                 f"IMAP server returned no raw body for uid {uid}")

    dest = out_dir / f"message-{uid}.eml"
    dest.write_bytes(raw)
    return {"uid": uid, "folder": folder,
            "message_id": msgid_val,
            "saved": str(dest)}


def cmd_seen(cfg: dict, uid: str, folder: str, unsee: bool) -> dict:
    with _imap(cfg) as mb:
        if folder != "INBOX":
            mb.folder.set(folder)
        _one(mb, uid, mark_seen=False)  # validate existence
        mb.flag(str(uid), MailMessageFlags.SEEN, not unsee)
    return {"uid": uid, "seen": not unsee}


def cmd_folders(cfg: dict) -> list:
    with _imap(cfg) as mb:
        return [{"name": f.name, "delimiter": f.delim} for f in mb.folder.list()]


def cmd_move(cfg: dict, uid: str, folder: str, to_folder: str) -> dict:
    with _imap(cfg) as mb:
        if folder != "INBOX":
            mb.folder.set(folder)
        _one(mb, uid, mark_seen=False)  # validate existence in source folder
        mb.move(str(uid), to_folder)
    return {"uid": uid, "from_folder": folder, "moved_to": to_folder}


def cmd_send(cfg: dict, to: list[str], cc: list[str], subject: str,
             body: str, attach: list[str], in_reply_to: str | None) -> dict:
    msg = EmailMessage()
    msg["From"] = cfg["user"]
    msg["To"] = ", ".join(to)
    if cc:
        msg["Cc"] = ", ".join(cc)
    msg["Subject"] = subject
    if in_reply_to:
        msg["In-Reply-To"] = in_reply_to
        msg["References"] = in_reply_to
    msg.set_content(body)
    for f in attach:
        p = Path(f)
        if not p.exists():
            _die(6, "attachment_missing", f"attachment not found: {f}")
        ctype, _ = mimetypes.guess_type(p.name)
        maintype, _, subtype = (ctype or "application/octet-stream").partition("/")
        msg.add_attachment(p.read_bytes(), maintype=maintype, subtype=subtype, filename=p.name)
    try:
        with smtplib.SMTP(cfg["smtp_host"], cfg["smtp_port"], timeout=30) as s:
            s.starttls(context=ssl.create_default_context())
            s.login(cfg["user"], cfg["password"])
            s.send_message(msg)
    except smtplib.SMTPAuthenticationError as e:
        _die(2, "smtp_auth", f"SMTP login failed: {e}")
    except (OSError, smtplib.SMTPException) as e:
        _die(5, "send_failed", f"send failed: {e}")
    return {"sent": True, "to": to, "cc": cc, "subject": subject,
            "attachments": [Path(f).name for f in attach]}


# --- CLI ---------------------------------------------------------------------

def _require_selector(args) -> None:
    """show/fetch take exactly one of a positional <uid> or --message-id."""
    has_uid = getattr(args, "uid", None) is not None
    has_mid = getattr(args, "message_id", None) is not None
    if has_uid and has_mid:
        _die(6, "ambiguous_selector",
             "pass either <uid> or --message-id, not both")
    if not has_uid and not has_mid:
        _die(6, "missing_selector",
             f"the {args.cmd} command needs a <uid> or --message-id <id>")


def main() -> None:
    _gate()                      # every verb passes the project gate first
    _contract(sys.argv[1:])      # contract verbs; domain verbs fall through
    # --connection/--mailbox is accepted before AND after the subcommand:
    # the shared parent carries it for every subparser (SUPPRESS so an absent
    # post-subcommand flag never clobbers a value parsed pre-subcommand), and
    # the top-level parser carries it for the pre-subcommand position.
    conn_parent = argparse.ArgumentParser(add_help=False)
    conn_parent.add_argument("--connection", "--mailbox", dest="connection",
                             default=argparse.SUPPRESS,
                             help="connection id or address (optional with a "
                                  "default pointer or a sole connection); "
                                  "accepted before or after the subcommand")

    p = argparse.ArgumentParser(
        prog="mailbox", description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--connection", "--mailbox", dest="connection", default=None,
                   help="connection id or address (optional with a default "
                        "pointer or a sole connection); accepted before or "
                        "after the subcommand")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("help", parents=[conn_parent],
                   help="print the full usage contract")
    sub.add_parser("doctor", parents=[conn_parent],
                   help="validate IMAP + SMTP login, per connection")
    sub.add_parser("folders", parents=[conn_parent], help="list IMAP folders")

    sp = sub.add_parser("list", parents=[conn_parent],
                        help="list messages (headers only)")
    sp.add_argument("--folder", default="INBOX")
    sp.add_argument("--unread", action="store_true")
    sp.add_argument("--since", default=None, help="YYYY-MM-DD")
    sp.add_argument("--limit", type=int, default=50)

    sp = sub.add_parser("search", parents=[conn_parent],
                        help="server-side IMAP SEARCH (same output as list)")
    sp.add_argument("--from", dest="from_", default=None,
                    help="FROM substring match")
    sp.add_argument("--subject", default=None, help="SUBJECT substring match")
    sp.add_argument("--since", default=None, help="YYYY-MM-DD")
    sp.add_argument("--text", default=None,
                    help="TEXT match (body and headers)")
    sp.add_argument("--folder", default="INBOX")
    sp.add_argument("--limit", type=int, default=50)

    sp = sub.add_parser("show", parents=[conn_parent],
                        help="show one message (by uid or --message-id)")
    sp.add_argument("uid", nargs="?", default=None)
    sp.add_argument("--message-id", dest="message_id", default=None,
                    help="locate across all folders by Message-ID (folder-agnostic)")
    sp.add_argument("--folder", default="INBOX")

    sp = sub.add_parser("fetch", parents=[conn_parent],
                        help="save a message's attachments (by uid or --message-id)")
    sp.add_argument("uid", nargs="?", default=None)
    sp.add_argument("--message-id", dest="message_id", default=None,
                    help="locate across all folders by Message-ID (folder-agnostic)")
    sp.add_argument("--save-dir", required=True)
    sp.add_argument("--folder", default="INBOX")
    sp.add_argument("--mark-seen", action="store_true")

    sp = sub.add_parser("pdf", parents=[conn_parent],
                        help="render a message to a self-contained PDF")
    sp.add_argument("uid", nargs="?", default=None)
    sp.add_argument("--message-id", dest="message_id", default=None,
                    help="locate across all folders by Message-ID (folder-agnostic)")
    sp.add_argument("--save-dir", required=True)
    sp.add_argument("--folder", default="INBOX")

    sp = sub.add_parser("eml", parents=[conn_parent],
                        help="save the raw RFC822 source (.eml)")
    sp.add_argument("uid", nargs="?", default=None)
    sp.add_argument("--message-id", dest="message_id", default=None,
                    help="locate across all folders by Message-ID (folder-agnostic)")
    sp.add_argument("--save-dir", required=True)
    sp.add_argument("--folder", default="INBOX")

    sp = sub.add_parser("seen", parents=[conn_parent],
                        help="flag or unflag \\Seen")
    sp.add_argument("uid")
    sp.add_argument("--unsee", action="store_true")
    sp.add_argument("--folder", default="INBOX")

    sp = sub.add_parser("move", parents=[conn_parent],
                        help="move a message to another folder")
    sp.add_argument("uid")
    sp.add_argument("--to-folder", required=True)
    sp.add_argument("--folder", default="INBOX")

    sp = sub.add_parser("send", parents=[conn_parent], help="send a message")
    sp.add_argument("--to", action="append", required=True)
    sp.add_argument("--cc", action="append", default=[])
    sp.add_argument("--subject", required=True)
    sp.add_argument("--body", default=None)
    sp.add_argument("--body-file", default=None, help="file path or '-' for stdin")
    sp.add_argument("--attach", action="append", default=[])
    sp.add_argument("--in-reply-to", default=None)

    args = p.parse_args()

    if args.cmd == "help":
        sys.stdout.write((__doc__ or "").lstrip("\n"))
        return
    if args.cmd == "doctor":
        cmd_doctor(args.connection)
        return

    cfg = _load_config(args.connection)
    _write_gate(cfg["id"], cfg["allow_write"], args.cmd)
    if args.cmd == "fetch" and args.mark_seen and cfg["allow_write"] is False:
        _die(4, "read_only",
             f"connection {cfg['id']!r} is read-only; --mark-seen mutates the mailbox",
             "drop --mark-seen, or ask the user whether to allow writes")
    if args.cmd == "folders":
        _emit(cmd_folders(cfg))
    elif args.cmd == "move":
        _emit(cmd_move(cfg, args.uid, args.folder, args.to_folder))
    elif args.cmd == "list":
        _emit(cmd_list(cfg, args.folder, args.unread, args.since, args.limit))
    elif args.cmd == "search":
        _emit(cmd_search(cfg, args.folder, args.from_, args.subject,
                         args.since, args.text, args.limit))
    elif args.cmd == "show":
        _require_selector(args)
        _emit(cmd_show(cfg, args.uid, args.folder, args.message_id))
    elif args.cmd == "fetch":
        _require_selector(args)
        _emit(cmd_fetch(cfg, args.uid, args.folder, args.save_dir, args.mark_seen, args.message_id))
    elif args.cmd == "pdf":
        _require_selector(args)
        _emit(cmd_pdf(cfg, args.uid, args.folder, args.save_dir, args.message_id))
    elif args.cmd == "eml":
        _require_selector(args)
        _emit(cmd_eml(cfg, args.uid, args.folder, args.save_dir, args.message_id))
    elif args.cmd == "seen":
        _emit(cmd_seen(cfg, args.uid, args.folder, args.unsee))
    elif args.cmd == "send":
        body = args.body if args.body is not None else _read_body(args.body_file)
        _emit(cmd_send(cfg, args.to, args.cc, args.subject, body, args.attach, args.in_reply_to))


if __name__ == "__main__":
    main()
